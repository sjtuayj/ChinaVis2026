  "events": [
    {
      "event_id": "01002006_e00001",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "包拯"
      ],
      "text": "扶大宋锦华夷赤心肝胆，",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00002",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯上，四青袍、王朝、马汉、张龙、赵虎同上。",
      "text_length": 22
    },
    {
      "event_id": "01002006_e00003",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "包拯"
      ],
      "text": "坐开封无一日心不忧烦。",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00004",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "包拯"
      ],
      "text": "多只为那柳金蝉屈死凄惨，错断了颜查散年幼儿男。我且到望乡台亲自查看，",
      "text_length": 34
    },
    {
      "event_id": "01002006_e00005",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯上台子。",
      "text_length": 6
    },
    {
      "event_id": "01002006_e00006",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄垛板",
      "speakers": [
        "包拯"
      ],
      "text": "又只见：大鬼卒、小鬼判、牛头马面，押定了去世的亡魂项带铁链，悲惨惨，阴风绕，遍体冷，我心胆皆寒。",
      "text_length": 48
    },
    {
      "event_id": "01002006_e00007",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "包拯"
      ],
      "text": "站立在望乡台用目观看：望开封那就是自己的家园。牙床上睡一人蓬头铁面，有王朝和马汉睡卧在两边。可怜他初为官定远小县，可怜他审赵大又被人参。可怜他断日光又把君谏，可怜他为查散，下阴曹，游七殿，一殿一殿哪得安然！观东方一阵明一阵发暗，那就是受罪处名叫阴山。屈死鬼一定在那厢受难，俺包拯要入那虎穴龙潭。叫王朝，",
      "text_length": 151
    },
    {
      "event_id": "01002006_e00008",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王朝"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01002006_e00009",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "包拯"
      ],
      "text": "和马汉，",
      "text_length": 4
    },
    {
      "event_id": "01002006_e00010",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马汉"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01002006_e00011",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "包拯"
      ],
      "text": "阴山去看，",
      "text_length": 5
    },
    {
      "event_id": "01002006_e00012",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯下台子。油流鬼上。",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00013",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "何方冤鬼，少往前进！",
      "text_length": 10
    },
    {
      "event_id": "01002006_e00014",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "唔！",
      "text_length": 2
    },
    {
      "event_id": "01002006_e00015",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "包拯"
      ],
      "text": "山谷中缘何有一鬼孤单？",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00016",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "何方冤鬼，在此摆来摆去？待我油流鬼将你们拿下！",
      "text_length": 23
    },
    {
      "event_id": "01002006_e00017",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "唔，你为何叫做油流鬼？",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00018",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "各殿灯油，多是我添，故而叫做油流鬼。",
      "text_length": 18
    },
    {
      "event_id": "01002006_e00019",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "你在此作甚？",
      "text_length": 6
    },
    {
      "event_id": "01002006_e00020",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "在此看守冤鬼。",
      "text_length": 7
    },
    {
      "event_id": "01002006_e00021",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "唔，你这里也有冤鬼么？",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00022",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "冤鬼多得很，你问他干什么？",
      "text_length": 13
    },
    {
      "event_id": "01002006_e00023",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "哦，老夫就是那龙图阁大学士兼理开封，包拯。",
      "text_length": 21
    },
    {
      "event_id": "01002006_e00024",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "原来是包大人，小鬼不知，多有得罪！",
      "text_length": 17
    },
    {
      "event_id": "01002006_e00025",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "罢了，起来。",
      "text_length": 6
    },
    {
      "event_id": "01002006_e00026",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "多谢大人！不在阳间来到阴山作甚？",
      "text_length": 16
    },
    {
      "event_id": "01002006_e00027",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "老夫只为一桩奇冤，亲下阴曹。你在此看守，多是些什么冤鬼？",
      "text_length": 28
    },
    {
      "event_id": "01002006_e00028",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "内有一女鬼，名叫柳氏金蝉。",
      "text_length": 13
    },
    {
      "event_id": "01002006_e00029",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "那柳金蝉……",
      "text_length": 6
    },
    {
      "event_id": "01002006_e00030",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "01002006_e00031",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "得何病症而死？",
      "text_length": 7
    },
    {
      "event_id": "01002006_e00032",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "因李保图财害命，用绳索勒死的。",
      "text_length": 15
    },
    {
      "event_id": "01002006_e00033",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "这就不对了。老夫在五殿也曾看过生死簿：“颜查散谋死表妹柳金蝉”，怎么说是李保？",
      "text_length": 39
    },
    {
      "event_id": "01002006_e00034",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "你要说颜查散谋害人命，这就屈枉死好人！",
      "text_length": 19
    },
    {
      "event_id": "01002006_e00035",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "怎见得？",
      "text_length": 4
    },
    {
      "event_id": "01002006_e00036",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "那旁有一太湖石，你且坐下，待我慢慢儿的讲来。",
      "text_length": 22
    },
    {
      "event_id": "01002006_e00037",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "慢慢讲来。",
      "text_length": 5
    },
    {
      "event_id": "01002006_e00038",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "只因正月十五日大放花灯，忽然狂风一阵，将灯吹灭。来了一只猛虎，将柳小姐背到喜鹊桥边。来了恶人李保，图财害命，用绳索勒死的。",
      "text_length": 61
    },
    {
      "event_id": "01002006_e00039",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "那柳金蝉为何不到阎君那里控告于他？",
      "text_length": 17
    },
    {
      "event_id": "01002006_e00040",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "想她前去控告，那李保乃是我家判爷的外甥，将柳小姐藏在阴山，将生死簿改移了“颜查散谋死表妹柳金蝉”。",
      "text_length": 49
    },
    {
      "event_id": "01002006_e00041",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "他改移生死簿难道上面无有墨迹么？",
      "text_length": 16
    },
    {
      "event_id": "01002006_e00042",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "他撕了一篇，写上一篇，哪里来的墨迹！",
      "text_length": 18
    },
    {
      "event_id": "01002006_e00043",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "他撕了一篇，放在何处？",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00044",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "他揉了纸揉，订了生死簿。",
      "text_length": 12
    },
    {
      "event_id": "01002006_e00045",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "你待怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01002006_e00046",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "订了生死簿。",
      "text_length": 6
    },
    {
      "event_id": "01002006_e00047",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "好判官！",
      "text_length": 4
    },
    {
      "event_id": "01002006_e00048",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "包拯"
      ],
      "text": "好一个大胆无知判官，改移了生死簿讲我遮瞒。五阎君依仗你是阴曹的障暗，油流鬼有一事还要你仔细详参。",
      "text_length": 48
    },
    {
      "event_id": "01002006_e00049",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "油流鬼，柳金蝉的阴魂今在何处？",
      "text_length": 15
    },
    {
      "event_id": "01002006_e00050",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "现在阴山背后石桥底下。",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00051",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "带路，老夫观看。",
      "text_length": 8
    },
    {
      "event_id": "01002006_e00052",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "待我唤她一声，听她讲些什么。",
      "text_length": 14
    },
    {
      "event_id": "01002006_e00053",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "但凭于你。",
      "text_length": 5
    },
    {
      "event_id": "01002006_e00054",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "柳金蝉，阎君查看阴山，你可要听好了！",
      "text_length": 18
    },
    {
      "event_id": "01002006_e00055",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "柳金蝉"
      ],
      "text": "苦吓！",
      "text_length": 3
    },
    {
      "event_id": "01002006_e00056",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内二黄摇板",
      "speakers": [
        "柳金蝉"
      ],
      "text": "在阳间哪知道阴世路远，柳金蝉这冤仇总有万千。那判爷与李保骨肉亲眷，但不知何日里得见青天？",
      "text_length": 44
    },
    {
      "event_id": "01002006_e00057",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "你听见没有？",
      "text_length": 6
    },
    {
      "event_id": "01002006_e00058",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "嗳！",
      "text_length": 2
    },
    {
      "event_id": "01002006_e00059",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "包拯"
      ],
      "text": "耳听得哭声高如同眼见，方信那油流鬼话不虚传。带上了柳金蝉老夫判断，",
      "text_length": 33
    },
    {
      "event_id": "01002006_e00060",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "我家判爷厉害！",
      "text_length": 7
    },
    {
      "event_id": "01002006_e00061",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "唔，",
      "text_length": 2
    },
    {
      "event_id": "01002006_e00062",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "包拯"
      ],
      "text": "谁不知包青天法律森严？",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00063",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "柳金蝉走动！哈！",
      "text_length": 8
    },
    {
      "event_id": "01002006_e00064",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "内二黄摇板",
      "speakers": [
        "柳金蝉"
      ],
      "text": "忽听得油流鬼一声呼唤，",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00065",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "柳金蝉上。",
      "text_length": 5
    },
    {
      "event_id": "01002006_e00066",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "柳金蝉"
      ],
      "text": "问鬼哥呼唤我请为哪般？",
      "text_length": 11
    },
    {
      "event_id": "01002006_e00067",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "柳金蝉"
      ],
      "text": "鬼哥唤我何事？",
      "text_length": 7
    },
    {
      "event_id": "01002006_e00068",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "油流鬼"
      ],
      "text": "包大人查看阴山。有什么冤枉前去申诉。",
      "text_length": 18
    },
    {
      "event_id": "01002006_e00069",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "柳金蝉"
      ],
      "text": "有劳了！",
      "text_length": 4
    },
    {
      "event_id": "01002006_e00070",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "柳金蝉"
      ],
      "text": "听说是包大人查看阴山，不由得柳金蝉喜在心间。哭啼啼走上前开恩一线！",
      "text_length": 33
    },
    {
      "event_id": "01002006_e00071",
      "play_id": "01002006",
      "scene_id": "01002006_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "包拯"
      ],
      "text": "哭啼啼哀告我有什么奇冤？我问你名和姓家住在哪县？",
      "text_length": 24
    },
    {
