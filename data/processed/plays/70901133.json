  "events": [
    {
      "event_id": "70901133_e00001",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄德功、刘良佐、刘泽清戎装随军校、众兵执旗帜、器械呐喊同上。",
      "text_length": 30
    },
    {
      "event_id": "70901133_e00002",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "俺庐、和、镇守史，靖安侯黄德功。",
      "text_length": 16
    },
    {
      "event_id": "70901133_e00003",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "俺淮、徐、镇守史，东平侯刘泽清。",
      "text_length": 16
    },
    {
      "event_id": "70901133_e00004",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘良佐"
      ],
      "text": "俺凤、泗、镇守史，广昌侯刘良佐。",
      "text_length": 16
    },
    {
      "event_id": "70901133_e00005",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "二位贤弟请传令。闻得高杰在黄金坝上，点齐人马预备迎敌。我们分做三队人马，依次前进。",
      "text_length": 41
    },
    {
      "event_id": "70901133_e00006",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘良佐"
      ],
      "text": "俺带的人马原少。俺前去挑战，二位兄长与我接应便了。",
      "text_length": 25
    },
    {
      "event_id": "70901133_e00007",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "我的田雄不曾来，我做第二队，总叫河洲哥哥压哨便了。",
      "text_length": 25
    },
    {
      "event_id": "70901133_e00008",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "既如此，一同杀上前去。",
      "text_length": 11
    },
    {
      "event_id": "70901133_e00009",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖急急风〗。众人同下。〖急急风〗。高杰引众兵卒同上。",
      "text_length": 26
    },
    {
      "event_id": "70901133_e00010",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "俺乃扬州镇守史兴平侯高杰是也。闻得三镇前来征讨。三军！摆开阵势，准备迎敌。",
      "text_length": 37
    },
    {
      "event_id": "70901133_e00011",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同允。刘良佐上。",
      "text_length": 10
    },
    {
      "event_id": "70901133_e00012",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘良佐"
      ],
      "text": "呔！高杰，快快出来争个谁大谁小。",
      "text_length": 16
    },
    {
      "event_id": "70901133_e00013",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "啊！你花马刘是咱小兄弟，你还敢如此。",
      "text_length": 18
    },
    {
      "event_id": "70901133_e00014",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘良佐"
      ],
      "text": "你满口胡说，撒马过来。",
      "text_length": 11
    },
    {
      "event_id": "70901133_e00015",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘良佐、高杰同战，刘良佐败下。〖急急风〗。黄德功持双鞭上。",
      "text_length": 29
    },
    {
      "event_id": "70901133_e00016",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "高杰，我黄闯子的本领你是晓得的，快快磕头，饶你不死。",
      "text_length": 26
    },
    {
      "event_id": "70901133_e00017",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄得功、高杰同战，高杰示意众兵卒混战。",
      "text_length": 19
    },
    {
      "event_id": "70901133_e00018",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "呔！高杰！向来兵对兵，将对将。如要混战，到底你是无理贼子，今日且输与你一阵。",
      "text_length": 38
    },
    {
      "event_id": "70901133_e00019",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄德功败下，刘泽清持双刀上。",
      "text_length": 14
    },
    {
      "event_id": "70901133_e00020",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "呔！高杰，你休要逞强，来，来，来！我与你横战也可，竖战也可，你可晓得我翻天鹞子不怕人的么。来，来，来！我与你杀！杀！杀！",
      "text_length": 60
    },
    {
      "event_id": "70901133_e00021",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘泽清、高杰同战。侯方域上，摇令旗。刘泽清、高杰同住战。",
      "text_length": 28
    },
    {
      "event_id": "70901133_e00022",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "阁部大元帅有令，四镇作反，皆督师之过。请先到帅府杀了元帅，再到南京抢了宫阙，不必在此混战，骚害平民。",
      "text_length": 50
    },
    {
      "event_id": "70901133_e00023",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "朝廷是我们立的，哎唷，元帅是朝廷派的，要不给元帅留个面子。我们本不曾作反。只是高杰无礼，混乱座次。我们争个明白，好参谒元帅。",
      "text_length": 62
    },
    {
      "event_id": "70901133_e00024",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "俺高杰乃本部先锋，怎敢作反。他们领兵来杀，只得迎敌。",
      "text_length": 26
    },
    {
      "event_id": "70901133_e00025",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "不奉军令，妄行厮杀，都是反贼。明日奏闻朝廷，你们自己去分辩吧。",
      "text_length": 31
    },
    {
      "event_id": "70901133_e00026",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "朝廷是我们立的，元帅是朝廷派的。我们违了军令，便是叛了朝廷，如何使得？情愿束手待罪，只求元帅饶恕。",
      "text_length": 49
    },
    {
      "event_id": "70901133_e00027",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "高将军，你如何说？",
      "text_length": 9
    },
    {
      "event_id": "70901133_e00028",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "我高杰是元帅犬马，犯了军法，只听元帅处分。",
      "text_length": 21
    },
    {
      "event_id": "70901133_e00029",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "既如此说，速传黄、刘二镇回赴辕门，央求元帅。",
      "text_length": 22
    },
    {
      "event_id": "70901133_e00030",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "二镇败走，各回汛地去了。",
      "text_length": 12
    },
    {
      "event_id": "70901133_e00031",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "你淮、扬两镇，唇齿之邦，又无宿嫌，为何听人指使？快快前去，候元帅发落。",
      "text_length": 35
    },
    {
      "event_id": "70901133_e00032",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众兵卒同下，侯方域下高台。高杰、刘泽清同至辕门。",
      "text_length": 24
    },
    {
      "event_id": "70901133_e00033",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "已到辕门了。两位将军在外等候，待俺传进去。",
      "text_length": 21
    },
    {
      "event_id": "70901133_e00034",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域进。",
      "text_length": 5
    },
    {
      "event_id": "70901133_e00035",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "元帅有令，四镇擅相争夺，皆当军法从事。但高将军不知礼体，挑嫌起衅，罪有所归。着与三镇服礼，俟解和之日再行处分。",
      "text_length": 55
    },
    {
      "event_id": "70901133_e00036",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "香柳娘",
      "speakers": [
        "侯方域"
      ],
      "text": "劝将军自思，劝将军自思，祸来难救，负荆早向辕门叩。",
      "text_length": 25
    },
    {
      "event_id": "70901133_e00037",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高杰恼。",
      "text_length": 4
    },
    {
      "event_id": "70901133_e00038",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "俺高杰，乃元帅标下先锋。元帅不加护庇，倒叫与三镇服礼，可不羞死人也。罢，罢，罢！看来元帅也不能用俺了。不免领兵渡江，另做事业去吧。",
      "text_length": 65
    },
    {
      "event_id": "70901133_e00039",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "香柳娘",
      "speakers": [
        "高杰"
      ],
      "text": "这屈辱怎当，这屈辱怎当，渡过大江头，事业从新做。",
      "text_length": 24
    },
    {
      "event_id": "70901133_e00040",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "三军快来，随俺前去。",
      "text_length": 10
    },
    {
      "event_id": "70901133_e00041",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众兵卒同上，呐喊摇旗同下。",
      "text_length": 13
    },
    {
      "event_id": "70901133_e00042",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "啊呀呀！高杰竟要过江了。想江南有他的党羽，不日要领来与俺厮闹。俺也早去约会黄、刘二镇，多带人马，到此迎敌。",
      "text_length": 53
    },
    {
      "event_id": "70901133_e00043",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "香柳娘",
      "speakers": [
        "刘泽清"
      ],
      "text": "笑力穷远走，笑力穷远走，长江洗羞，防他重来作寇。",
      "text_length": 24
    },
    {
      "event_id": "70901133_e00044",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘泽清下。侯方域呆。",
      "text_length": 10
    },
    {
      "event_id": "70901133_e00045",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "不料局势如此，教俺怎生收救。",
      "text_length": 14
    },
    {
      "event_id": "70901133_e00046",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "香柳娘",
      "speakers": [
        "侯方域"
      ],
      "text": "恨山河半倾，恨山河半倾，怎能重构；人心瓦解忘恩旧。",
      "text_length": 25
    },
    {
      "event_id": "70901133_e00047",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域向南望。",
      "text_length": 7
    },
    {
      "event_id": "70901133_e00048",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "那高杰竟是反了。",
      "text_length": 8
    },
    {
      "event_id": "70901133_e00049",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "香柳娘",
      "speakers": [
        "侯方域"
      ],
      "text": "看扬扬渡江，看扬扬渡江，旗帜乱中流，直入南徐口。",
      "text_length": 24
    },
    {
      "event_id": "70901133_e00050",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域向北望。",
      "text_length": 7
    },
    {
      "event_id": "70901133_e00051",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "那刘泽清也急忙北去，要约会三镇人马，全来迎敌。",
      "text_length": 23
    },
    {
      "event_id": "70901133_e00052",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "香柳娘",
      "speakers": [
        "侯方域"
      ],
      "text": "这烟尘偏有，这烟尘偏有，好叫俺元帅搔头，参谋搓手。",
      "text_length": 25
    },
    {
      "event_id": "70901133_e00053",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "且回复了阁部，再作计较。正是：",
      "text_length": 15
    },
    {
      "event_id": "70901133_e00054",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "侯方域"
      ],
      "text": "堂堂开府辖通侯，江北淮南数上游。只恐楼船与铁马，一时都羡好扬州。",
      "text_length": 32
    },
    {
      "event_id": "70901133_e00055",
      "play_id": "70901133",
      "scene_id": "70901133_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}