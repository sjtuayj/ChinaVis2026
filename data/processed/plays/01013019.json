  "events": [
    {
      "event_id": "01013019_e00001",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉上。",
      "text_length": 5
    },
    {
      "event_id": "01013019_e00002",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "林黛玉"
      ],
      "text": "春去无痕，莽天涯，怎不销魂？",
      "text_length": 14
    },
    {
      "event_id": "01013019_e00003",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "林黛玉"
      ],
      "text": "长安三月踏春阳，处处春阳总断肠。红瘦绿肥人寂寞，杜鹃声里吊余芳。",
      "text_length": 32
    },
    {
      "event_id": "01013019_e00004",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "奴家林黛玉。幼失怙恃。多蒙外祖母史太君抚养，寄居荣国贾府之中。诸姑伯姊，却也是另眼相看，只有宝玉哥哥，偏偏要无理取闹，昨晚偶过怡红院，他却是闭门不理。咳，这也是寄人篱下的苦处，怎不叫人伤感也！",
      "text_length": 96
    },
    {
      "event_id": "01013019_e00005",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "林黛玉"
      ],
      "text": "叹春光都付与多愁多病，奈何天辜负了美景良辰。可怜奴无家雁霜天只影，好比那萍和梗一样飘零。花如烟柳如卷落花成阵，",
      "text_length": 55
    },
    {
      "event_id": "01013019_e00006",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉抚琴，叹。",
      "text_length": 8
    },
    {
      "event_id": "01013019_e00007",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "林黛玉"
      ],
      "text": "这焦桐却为何弹不成声？",
      "text_length": 11
    },
    {
      "event_id": "01013019_e00008",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉翻书。",
      "text_length": 6
    },
    {
      "event_id": "01013019_e00009",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "林黛玉"
      ],
      "text": "“良辰美景奈何天，赏心乐事谁家院？”",
      "text_length": 18
    },
    {
      "event_id": "01013019_e00010",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "咳，这乃杜丽娘伤春之词，怎么她也是这样的情怀哪！",
      "text_length": 24
    },
    {
      "event_id": "01013019_e00011",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "林黛玉"
      ],
      "text": "似这般无聊赖春将人困，我只得对鹦鹉却诉衷情。",
      "text_length": 22
    },
    {
      "event_id": "01013019_e00012",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "呵，鹦鹉，这几年来，我与你相依为命。想我黛玉，自幼父母双亡，又无兄弟姊妹，独自一人，零丁孤苦。如今离乡别井，寄居舅母家中。虽然是长者慈爱，怎么比得自己的双亲。只有表哥宝玉，嗳呀，再休提起！想我这畸零之身，哪里还有人体谅我的苦衷，哪里还有人知道我的心事呵。鹦鹉鹦鹉，怎么你也无言。难道说他厌弃我，你也厌弃我不成咳？黛玉呵，黛玉，你真好命苦呵！",
      "text_length": 170
    },
    {
      "event_id": "01013019_e00013",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "林黛玉"
      ],
      "text": "似有情却无情教人深恨，能言鸟竟无语安慰奴心。",
      "text_length": 22
    },
    {
      "event_id": "01013019_e00014",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃上。",
      "text_length": 4
    },
    {
      "event_id": "01013019_e00015",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫娟"
      ],
      "text": "姑娘的痴病又发了，必定又是宝二爷得罪了他。呵，姑娘，今日乃是饯花盛会，各房的奶奶姑娘，都在园里送春，等候姑娘前去，联诗饮酒。",
      "text_length": 62
    },
    {
      "event_id": "01013019_e00016",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉如不闻。",
      "text_length": 7
    },
    {
      "event_id": "01013019_e00017",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "林黛玉"
      ],
      "text": "炉烟如我瘦，辛苦未成灰。",
      "text_length": 12
    },
    {
      "event_id": "01013019_e00018",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫娟"
      ],
      "text": "姑娘，各房的奶奶姑娘们在园子里送春，等姑娘前去。",
      "text_length": 24
    },
    {
      "event_id": "01013019_e00019",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "怎么……送春？",
      "text_length": 7
    },
    {
      "event_id": "01013019_e00020",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫娟"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "01013019_e00021",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "春去了么，到哪里去了，怎么不叫她回来？",
      "text_length": 19
    },
    {
      "event_id": "01013019_e00022",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫娟"
      ],
      "text": "春去无言，叫我那里寻找？",
      "text_length": 12
    },
    {
      "event_id": "01013019_e00023",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "01013019_e00024",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "林黛玉"
      ],
      "text": "春去消息谁知，除非问取黄鹂呵。",
      "text_length": 15
    },
    {
      "event_id": "01013019_e00025",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "紫鹃，安顿花锄，我要葬花去了。",
      "text_length": 15
    },
    {
      "event_id": "01013019_e00026",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫娟"
      ],
      "text": "外面春风似剪，姑娘不去也罢。",
      "text_length": 14
    },
    {
      "event_id": "01013019_e00027",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "咳，你看花谢花飞一片片沾泥随水。想世间薄命的人儿，还不是同落花一样么？",
      "text_length": 35
    },
    {
      "event_id": "01013019_e00028",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "林黛玉"
      ],
      "text": "扫愁帚贮香囊花锄一柄，我且到沁芳桥葬玉埋春。",
      "text_length": 22
    },
    {
      "event_id": "01013019_e00029",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉下。",
      "text_length": 5
    },
    {
      "event_id": "01013019_e00030",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫娟"
      ],
      "text": "我们姑娘，跟宝玉自幼十分相爱。哪里晓得越相爱，越烦恼。年纪一天大似一天。据我想来，彼此既然真心相爱，就要彼此原谅，每日里牵愁惹恨，又何苦呢？正是：",
      "text_length": 73
    },
    {
      "event_id": "01013019_e00031",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "紫娟"
      ],
      "text": "两情只要能长久，岂在朝朝暮暮愁。",
      "text_length": 16
    },
    {
      "event_id": "01013019_e00032",
      "play_id": "01013019",
      "scene_id": "01013019_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫娟下。",
      "text_length": 4
    },
    {
      "event_id": "01013019_e00033",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉上。",
      "text_length": 5
    },
    {
      "event_id": "01013019_e00034",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "贾宝玉"
      ],
      "text": "昨夜晚怨东风无端蹂躏，满园春吹变了一片愁云。林妹妹他本是惜花如命，却为何这时候不到园林？",
      "text_length": 44
    },
    {
      "event_id": "01013019_e00035",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "小生宝玉。今日一来是赴饯花盛会，二来这几日林妹妹有些恼我，必然是小生得罪了他，等见着他，赔个礼儿要紧。",
      "text_length": 51
    },
    {
      "event_id": "01013019_e00036",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "贾宝玉"
      ],
      "text": "我这里扫残红独穿花径，早来到埋香处流水孤坟。",
      "text_length": 22
    },
    {
      "event_id": "01013019_e00037",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "到此已是林妹妹葬花之所，你看梨花飘雪，柳絮飞棉，倘若林妹妹看见，必定是十分的伤感，待我收拾起来，也好安慰于她。",
      "text_length": 55
    },
    {
      "event_id": "01013019_e00038",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉扫花，望。",
      "text_length": 8
    },
    {
      "event_id": "01013019_e00039",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "远望一女子，隐约行过花丛，好像是林妹妹来了，待我闪躲一旁，听她讲些什么？正是：",
      "text_length": 39
    },
    {
      "event_id": "01013019_e00040",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贾宝玉"
      ],
      "text": "隔林听燕语，掬水奠花魂。",
      "text_length": 12
    },
    {
      "event_id": "01013019_e00041",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉下。",
      "text_length": 5
    },
    {
      "event_id": "01013019_e00042",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "expression",
      "mode_label": "内哭",
      "speakers": [
        "林黛玉"
      ],
      "text": "呵吓……",
      "text_length": 4
    },
    {
      "event_id": "01013019_e00043",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉上。",
      "text_length": 5
    },
    {
      "event_id": "01013019_e00044",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "林黛玉"
      ],
      "text": "碧云天芳草地蜂愁蝶怨，乱莺声啼不住似水流年。绕疏篱穿曲径遮遮掩掩，又只见一抔土谁荐寒泉。",
      "text_length": 44
    },
    {
      "event_id": "01013019_e00045",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "来此已是葬花之所。",
      "text_length": 9
    },
    {
      "event_id": "01013019_e00046",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉看。",
      "text_length": 5
    },
    {
      "event_id": "01013019_e00047",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "哪个有心人替我扫了一堆花瓣在此？莫非是那宝……嗳，他哪里有这样细腻的心情哪！",
      "text_length": 38
    },
    {
      "event_id": "01013019_e00048",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "林黛玉"
      ],
      "text": "林黛玉把花锄无限凄怆，繁华尽花事了难怨东皇。可怜你经过了一年冷淡，可怜你消受得几日风光。可怜你软红尘芳魂四散，可怜你温柔性付与汪洋。说什么护花枝金铃十万，说什么渡花魂宝筏一航。侬葬花人道我落了情障，要知道侬与花一样下场。我这里赋招魂泪和花葬，夜漫漫春寂寂地老天荒。",
      "text_length": 132
    },
    {
      "event_id": "01013019_e00049",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "侬今葬花人笑痴，他年葬侬知是谁。一朝春尽红颜老，花落人亡两不知。呵呀！",
      "text_length": 35
    },
    {
      "event_id": "01013019_e00050",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉在假山后偷窥，失声哭，衣兜中花撒落满地。林黛玉惊祝。",
      "text_length": 29
    },
    {
      "event_id": "01013019_e00051",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "我道是谁，原来是即狼心短……",
      "text_length": 14
    },
    {
      "event_id": "01013019_e00052",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉、贾宝玉同绕场，林黛玉欲行，贾宝玉止。",
      "text_length": 22
    },
    {
      "event_id": "01013019_e00053",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "妹妹，不要走。且等我说完这一句话。大家撩开手就是了。",
      "text_length": 26
    },
    {
      "event_id": "01013019_e00054",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "宝二爷有何吩咐？",
      "text_length": 8
    },
    {
      "event_id": "01013019_e00055",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "既有今日，何必当初？",
      "text_length": 10
    },
    {
      "event_id": "01013019_e00056",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "当初怎么，今日又怎么样？",
      "text_length": 12
    },
    {
      "event_id": "01013019_e00057",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "想当初妹妹与我，是怎样的要好，彼此一处长大，每日一同吃饭，一同玩耍。有我爱吃的，看见妹妹也爱吃，就留着等妹妹同吃。丫头仆妇们，有想不到的，我替他们想到，怕叫妹妹生气。为的就是既然要好，总要比别人都好，才显得真好。可怜我并无同心的亲兄弟亲姐妹，只有妹妹一人，能够体谅我的心事。谁指望妹妹人大心大，偏不和我要好，反去和那外四路的什么凤姐姐、宝姐姐要好，拿我三日不理四日不睬。我也不知道怎么得罪了妹妹，妹妹就是打我骂我，千万休不理我，叫我有冤无处诉，就是死了也是个屈死鬼。任凭高僧高道超度，还要妹妹说明了原故，才能够托生呢……妹妹也忍心不答应我一声么……",
      "text_length": 274
    },
    {
      "event_id": "01013019_e00058",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "你休来骗我。你还是回去关上你的门罢！",
      "text_length": 18
    },
    {
      "event_id": "01013019_e00059",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "妹妹，此话从何而起？",
      "text_length": 10
    },
    {
      "event_id": "01013019_e00060",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "昨晚我到怡红院去，你为何闭门不理？",
      "text_length": 17
    },
    {
      "event_id": "01013019_e00061",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "哪有此事？",
      "text_length": 5
    },
    {
      "event_id": "01013019_e00062",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "还说没有此事，我站在门外，脚也站酸了。",
      "text_length": 19
    },
    {
      "event_id": "01013019_e00063",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "真正没有此事。妹妹若不相信，待我对天盟誓。皇天在上：我宝玉若有半句虚言，叫我落在水里，变个大大的王八，等到林妹妹百年之后，替妹妹驮石碑。妹妹这可相信了罢！",
      "text_length": 77
    },
    {
      "event_id": "01013019_e00064",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉、贾宝玉互视，同笑。",
      "text_length": 13
    },
    {
      "event_id": "01013019_e00065",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "还不快快的起来。",
      "text_length": 8
    },
    {
      "event_id": "01013019_e00066",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "妹妹，这你可相信了。",
      "text_length": 10
    },
    {
      "event_id": "01013019_e00067",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "大约是你家大丫头偷赖不来开门，也是有的。",
      "text_length": 20
    },
    {
      "event_id": "01013019_e00068",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "待我回去教训她们。",
      "text_length": 9
    },
    {
      "event_id": "01013019_e00069",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "也应当教训教训。得罪了我，不要紧，倘若得罪了什么宝姑娘、贝姑娘，那还了得？",
      "text_length": 37
    },
    {
      "event_id": "01013019_e00070",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "她又提起宝姐姐了！",
      "text_length": 9
    },
    {
      "event_id": "01013019_e00071",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "你今日来此则甚？",
      "text_length": 8
    },
    {
      "event_id": "01013019_e00072",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "妹妹呀！",
      "text_length": 4
    },
    {
      "event_id": "01013019_e00073",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "贾宝玉"
      ],
      "text": "都只为收拾那残脂剩粉，怕东风吹散了艳魄芳魂。我怜它好一似昙花泡影，因此上摄香土聊当饯春。",
      "text_length": 44
    },
    {
      "event_id": "01013019_e00074",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "如此说来，这香冢之旁，那堆花瓣，是你扫来的？",
      "text_length": 22
    },
    {
      "event_id": "01013019_e00075",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "你怎么知道？",
      "text_length": 6
    },
    {
      "event_id": "01013019_e00076",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "嗳呀。还是他有这细腻的心情呵！",
      "text_length": 15
    },
    {
      "event_id": "01013019_e00077",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "林黛玉"
      ],
      "text": "听他言不由我芳心辗转，一样春愁两地牵。你我问春春不管，伤春肠断有谁怜。",
      "text_length": 35
    },
    {
      "event_id": "01013019_e00078",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉、贾宝玉同叹。紫鹃上。",
      "text_length": 14
    },
    {
      "event_id": "01013019_e00079",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫娟"
      ],
      "text": "他们又是怎么样了？待我诳她回去。呵，姑娘，老太太等你吃饭了。",
      "text_length": 30
    },
    {
      "event_id": "01013019_e00080",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "晓得了。",
      "text_length": 4
    },
    {
      "event_id": "01013019_e00081",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉做身段，林黛玉、紫娟同下。",
      "text_length": 16
    },
    {
      "event_id": "01013019_e00082",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "01013019_e00083",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贾宝玉"
      ],
      "text": "流水斜阳春去尽，独留青冢向黄昏。",
      "text_length": 16
    },
    {
      "event_id": "01013019_e00084",
      "play_id": "01013019",
      "scene_id": "01013019_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 52,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
