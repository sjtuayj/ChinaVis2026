  "events": [
    {
      "event_id": "04022002_e00001",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘上。",
      "text_length": 5
    },
    {
      "event_id": "04022002_e00002",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "赵五娘"
      ],
      "text": "家业凋零，思夫君，日夜忧心！",
      "text_length": 14
    },
    {
      "event_id": "04022002_e00003",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵五娘"
      ],
      "text": "年荒亲死夫无讯，多感大公一亲邻。南山筑坟裙兜土，决意上京把夫寻。",
      "text_length": 32
    },
    {
      "event_id": "04022002_e00004",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "唉！自从我丈夫蔡伯喈进京赶考，数载未回；陈留郡荒旱三载，公婆双双饿死。我有心寻找伯喈，一叙别后之苦。斗室无光，不免在月光之下，描画公婆面容，带在身旁，寻我丈夫便了。",
      "text_length": 82
    },
    {
      "event_id": "04022002_e00005",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小过门。赵五娘搬凳出门。",
      "text_length": 12
    },
    {
      "event_id": "04022002_e00006",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "喂呀，公公婆婆啊！",
      "text_length": 9
    },
    {
      "event_id": "04022002_e00007",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "赵五娘"
      ],
      "text": "手提着羊毫笔思前想后，想起了二公婆珠泪双流！老爹娘盼姣儿功名成就，谁知他到京都去不回头。我在家承欢笑奉养姑舅，遭荒旱他二老撒手西游！画起了老公爹面黄肌瘦，画起了老婆婆背驼腰钩；画起了老公爹竹杖在手，画起了老婆婆满面忧愁。拭泪痕停霜毫遗容画就——",
      "text_length": 122
    },
    {
      "event_id": "04022002_e00008",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘捧画入门。",
      "text_length": 8
    },
    {
      "event_id": "04022002_e00009",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵五娘"
      ],
      "text": "无非是表孝思慈影长留！",
      "text_length": 11
    },
    {
      "event_id": "04022002_e00010",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "公婆遗像画好，无有祭礼，这便怎处？唉，只好用凉水一祭便了！",
      "text_length": 29
    },
    {
      "event_id": "04022002_e00011",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘挂容，以凉水一杯祭拜。",
      "text_length": 14
    },
    {
      "event_id": "04022002_e00012",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "赵五娘"
      ],
      "text": "喂呀，公婆啊！",
      "text_length": 7
    },
    {
      "event_id": "04022002_e00013",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵五娘"
      ],
      "text": "但愿得二公婆多多保佑，与伯喈早相会免得飘流。",
      "text_length": 22
    },
    {
      "event_id": "04022002_e00014",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘伏几而卧。鸡鸣。张广才内叹息，提琵琶、雨伞上。",
      "text_length": 26
    },
    {
      "event_id": "04022002_e00015",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "张广才"
      ],
      "text": "听衰柳鸣寒蝉树枯草瘦，西风起黄叶落扑面生愁。赵五娘孤单单京城奔走，此一去好一似断缆的孤舟。",
      "text_length": 45
    },
    {
      "event_id": "04022002_e00016",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "老汉，张广才。只因蔡伯喈进京赶考，一去数载，杳无音信；可怜他的二老爹娘，双双饥饿而死。如今赵五娘子要进京寻找伯喈，只是她一贫如洗，老汉又无力帮助，是老汉只带来雨伞一把，琵琶一面，还有一些散碎银两，赠送于她。唉！来此已是，五娘开门来。",
      "text_length": 116
    },
    {
      "event_id": "04022002_e00017",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "外面何人叫门？",
      "text_length": 7
    },
    {
      "event_id": "04022002_e00018",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "老汉来了。",
      "text_length": 5
    },
    {
      "event_id": "04022002_e00019",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "哦，原来大公驾到。",
      "text_length": 9
    },
    {
      "event_id": "04022002_e00020",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘开门。",
      "text_length": 6
    },
    {
      "event_id": "04022002_e00021",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "大公请进。",
      "text_length": 5
    },
    {
      "event_id": "04022002_e00022",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "04022002_e00023",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "大公请坐。",
      "text_length": 5
    },
    {
      "event_id": "04022002_e00024",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "有座。五娘你当真要进京寻找伯喈么？",
      "text_length": 17
    },
    {
      "event_id": "04022002_e00025",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "是啊，媳妇去心已定了。",
      "text_length": 11
    },
    {
      "event_id": "04022002_e00026",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "一路之上，可有盘费？",
      "text_length": 10
    },
    {
      "event_id": "04022002_e00027",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "似这样饥荒年景，衣食不保，哪有盘费，只得乞讨而去了……",
      "text_length": 27
    },
    {
      "event_id": "04022002_e00028",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "唉，苦煞你了！老汉带来琵琶一面，雨伞一把，还有一些散碎银两，你且收下。",
      "text_length": 35
    },
    {
      "event_id": "04022002_e00029",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "这个……前恩未报，又蒙恩赐，媳妇不敢领受。",
      "text_length": 21
    },
    {
      "event_id": "04022002_e00030",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "受人之托，理当帮助，你只管收下吧。",
      "text_length": 17
    },
    {
      "event_id": "04022002_e00031",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "多谢大公。",
      "text_length": 5
    },
    {
      "event_id": "04022002_e00032",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张广才看画。",
      "text_length": 6
    },
    {
      "event_id": "04022002_e00033",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "啊五娘，这就是你的不是了。",
      "text_length": 13
    },
    {
      "event_id": "04022002_e00034",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "怎么是媳妇的不是？",
      "text_length": 9
    },
    {
      "event_id": "04022002_e00035",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "你方才言道，饥荒年景，衣食不保，哪里来的银钱，与你公婆画影呢？",
      "text_length": 31
    },
    {
      "event_id": "04022002_e00036",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "这个……啊大公，这画像不是画工画的。",
      "text_length": 18
    },
    {
      "event_id": "04022002_e00037",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "哦，不是画工画的，是哪个画的呢？",
      "text_length": 16
    },
    {
      "event_id": "04022002_e00038",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "是媳妇在月光之下，用水墨描画而成的。",
      "text_length": 18
    },
    {
      "event_id": "04022002_e00039",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "哦，是五娘自己描画而成的？",
      "text_length": 13
    },
    {
      "event_id": "04022002_e00040",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "04022002_e00041",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "若是旁人画的，老汉不看也罢；既是五娘自己画的，老汉倒要仔细看看。",
      "text_length": 32
    },
    {
      "event_id": "04022002_e00042",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张广才看画。",
      "text_length": 6
    },
    {
      "event_id": "04022002_e00043",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "张广才"
      ],
      "text": "老哥！老嫂！老哥，老嫂啊……",
      "text_length": 14
    },
    {
      "event_id": "04022002_e00044",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "张广才"
      ],
      "text": "见容像不由我心酸痛！",
      "text_length": 10
    },
    {
      "event_id": "04022002_e00045",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "张广才"
      ],
      "text": "老哥，老嫂，兄嫂啊……",
      "text_length": 11
    },
    {
      "event_id": "04022002_e00046",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "张广才"
      ],
      "text": "滚滚珠泪洒前胸！画老哥手扶竹杖难以行动，画老嫂两鬓白乱发蓬松。空养你儿蔡伯喈终何用，生不能养二老死不能送终！",
      "text_length": 54
    },
    {
      "event_id": "04022002_e00047",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "收好了。",
      "text_length": 4
    },
    {
      "event_id": "04022002_e00048",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "04022002_e00049",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘收画。",
      "text_length": 6
    },
    {
      "event_id": "04022002_e00050",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "大公，媳妇要到坟前一走。",
      "text_length": 12
    },
    {
      "event_id": "04022002_e00051",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "老汉奉陪。将门带好了。",
      "text_length": 11
    },
    {
      "event_id": "04022002_e00052",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "04022002_e00053",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘背起包袱、雨伞、琵琶，与张广才同出门，倒锁门。",
      "text_length": 26
    },
    {
      "event_id": "04022002_e00054",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "张广才"
      ],
      "text": "思念双亲绘真容，生前死后一般同。五娘贤孝人感动，",
      "text_length": 24
    },
    {
      "event_id": "04022002_e00055",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘、张广才同走圆场。",
      "text_length": 12
    },
    {
      "event_id": "04022002_e00056",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "张广才"
      ],
      "text": "只见坟上柏和松。",
      "text_length": 8
    },
    {
      "event_id": "04022002_e00057",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "公婆啊！",
      "text_length": 4
    },
    {
      "event_id": "04022002_e00058",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵五娘"
      ],
      "text": "屈膝躬身哀言禀，尊声公婆在天灵：都只为守家门难逃饥馑……",
      "text_length": 28
    },
    {
      "event_id": "04022002_e00059",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "赵五娘"
      ],
      "text": "公婆啊！",
      "text_length": 4
    },
    {
      "event_id": "04022002_e00060",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵五娘"
      ],
      "text": "到京城寻儿夫归祭双亲！",
      "text_length": 11
    },
    {
      "event_id": "04022002_e00061",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵五娘看坟。",
      "text_length": 6
    },
    {
      "event_id": "04022002_e00062",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "啊大公，媳妇不去了。",
      "text_length": 10
    },
    {
      "event_id": "04022002_e00063",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "为何不去？",
      "text_length": 5
    },
    {
      "event_id": "04022002_e00064",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "公婆坟墓，无人看守。",
      "text_length": 10
    },
    {
      "event_id": "04022002_e00065",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "这个么，五娘只管前去，老汉在一日，与你看守一日。你来看哪，老汉倘有不测，那时就难以效劳了。",
      "text_length": 45
    },
    {
      "event_id": "04022002_e00066",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "多谢大公，媳妇拜别了。",
      "text_length": 11
    },
    {
      "event_id": "04022002_e00067",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张广才"
      ],
      "text": "且慢！老汉还有几句言语，你且听了。",
      "text_length": 17
    },
    {
      "event_id": "04022002_e00068",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "张广才"
      ],
      "text": "叫一声五娘且慢行，老汉言语你且听：身上背定公婆影，你身体单弱步难行。未曾天晚早投宿，起程必须等天明；涉水登山心要稳，行船过渡莫争行；沟渠之水不洁净，渴向人家求茶羹；逢人只说三分话，未可全抛一片心。五娘此番京城进，寻着伯喈把理评；倘若伯喈不相认，怀抱琵琶诉苦情。你莫说公婆丧了命，你莫说头上剪乌云，你莫说亲戚朋友来帮衬，你莫说兜土筑新坟；你就说公婆现在堂上等，叫他早早转家门。五娘此去多谨慎，但愿早到早回程。",
      "text_length": 203
    },
    {
      "event_id": "04022002_e00069",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵五娘"
      ],
      "text": "大公啊！",
      "text_length": 4
    },
    {
      "event_id": "04022002_e00070",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "赵五娘"
      ],
      "text": "大公不必细叮咛，嘱咐的言语谨记心。身上背定公婆影，不顾艰难奔京城。逢人只说三分话，怎可全抛一片心。媳妇此番京城进，寻着伯喈把理评；倘若伯喈不相认，怀抱琵琶诉苦情。我不说公婆丧了命，我不说剪乌云，葬双亲，众亲友来帮衬，亲自兜土筑新坟。我只说公婆堂前等，教他即刻转家门。拜别大公上路径——",
      "text_length": 142
    },
    {
      "event_id": "04022002_e00071",
      "play_id": "04022002",
      "scene_id": "04022002_s01",
      "scene_no": 1,
