    {
      "event_id": "02001003_e00012",
      "play_id": "02001003",
      "scene_id": "02001003_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众仙"
      ],
      "text": "今当福德星君千秋华诞，我等奉福禄寿三位星君相召随往筵前。",
      "text_length": 28
    },
    {
      "event_id": "02001003_e00013",
      "play_id": "02001003",
      "scene_id": "02001003_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。",
      "text_length": 5
    },
    {
      "event_id": "02001003_e00014",
      "play_id": "02001003",
      "scene_id": "02001003_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众仙"
      ],
      "text": "你看祥云光耀，星君来也。",
      "text_length": 12
    },
    {
      "event_id": "02001003_e00015",
      "play_id": "02001003",
      "scene_id": "02001003_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。众仙引福星、禄星、寿星同上。",
      "text_length": 19
    },
    {
      "event_id": "02001003_e00016",
      "play_id": "02001003",
      "scene_id": "02001003_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同新水令",
      "speakers": [
        "福星",
        "禄星",
        "寿星"
      ],
      "text": "步云程，双手捧蟠桃，俺寿星鬓眉未老。福田开荡荡，禄利水迢迢。眉比同曹，祝华筵同来到。",
      "text_length": 42
    },
    {
      "event_id": "02001003_e00017",
      "play_id": "02001003",
      "scene_id": "02001003_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众仙"
      ],
      "text": "三位星君在上，我等稽首。",
      "text_length": 12
    },
    {
      "event_id": "02001003_e00018",
      "play_id": "02001003",
      "scene_id": "02001003_s01",
