  "events": [
    {
      "event_id": "03055004_e00001",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、大太监引宋太宗同上。",
      "text_length": 14
    },
    {
      "event_id": "03055004_e00002",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "宋太宗"
      ],
      "text": "龙楼凤阁九重霄，有道君王坐龙朝。",
      "text_length": 16
    },
    {
      "event_id": "03055004_e00003",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "宋太宗"
      ],
      "text": "午夜漏声催箭晓，九重春色醉仙桃。旌旗日暖龙蛇动，宫殿风微燕雀高。",
      "text_length": 32
    },
    {
      "event_id": "03055004_e00004",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "孤、大宋天子国号雍熙在位。只因胡儿打来战表，寡人命潘洪挂帅，杨家父子以为先行，前去征剿，不知胜负如何。今日早朝。内侍，展放龙门！",
      "text_length": 64
    },
    {
      "event_id": "03055004_e00005",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "遵旨。展放龙门哪！",
      "text_length": 9
    },
    {
      "event_id": "03055004_e00006",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵德芳上。",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00007",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵德芳"
      ],
      "text": "感叹忠良事，奏与叔王知。",
      "text_length": 12
    },
    {
      "event_id": "03055004_e00008",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "儿臣见驾，叔王万岁！",
      "text_length": 10
    },
    {
      "event_id": "03055004_e00009",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "平身，赐坐。",
      "text_length": 6
    },
    {
      "event_id": "03055004_e00010",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "谢坐！",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00011",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "皇儿上殿，有何本奏？",
      "text_length": 10
    },
    {
      "event_id": "03055004_e00012",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "启奏叔王：今有呼延老将军与杨家做保，气呕身亡了！",
      "text_length": 24
    },
    {
      "event_id": "03055004_e00013",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "唉，老将军哪！",
      "text_length": 7
    },
    {
      "event_id": "03055004_e00014",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "宋太宗哭。",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00015",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "杨老将军围困两狼山，里无粮草，外无救兵，命七子回营搬兵求救。潘太师不发人马倒也罢了；反提起打子之仇，将七将军绑在芭蕉树上，乱箭射死。",
      "text_length": 66
    },
    {
      "event_id": "03055004_e00016",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "咳，我朝又丢了一员虎将！",
      "text_length": 12
    },
    {
      "event_id": "03055004_e00017",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "杨老将军在两狼山下，望兵兵不到，望子子不归，在李陵碑下尽忠而亡！",
      "text_length": 32
    },
    {
      "event_id": "03055004_e00018",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "皇儿怎么知道？",
      "text_length": 7
    },
    {
      "event_id": "03055004_e00019",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "杨郡马回朝来了。",
      "text_length": 8
    },
    {
      "event_id": "03055004_e00020",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "为何不上殿见孤？",
      "text_length": 8
    },
    {
      "event_id": "03055004_e00021",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "他有父孝在身，不敢上殿。",
      "text_length": 12
    },
    {
      "event_id": "03055004_e00022",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "恕他无罪。内侍，宣杨郡马上殿！",
      "text_length": 15
    },
    {
      "event_id": "03055004_e00023",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "杨郡马上殿哪！",
      "text_length": 7
    },
    {
      "event_id": "03055004_e00024",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "杨延昭"
      ],
      "text": "领旨！",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00025",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭上。",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00026",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "高拨子",
      "speakers": [
        "杨延昭"
      ],
      "text": "为上殿先打朝王鼓，午门外来了我叩阁臣。朝前走不见了我的年迈父，朝后看又不见七弟小英雄。往日里上金殿弟兄们成双摆对，到如今只落得延昭一个人。凄惨惨悲切切把金殿来上，有罪的杨延昭见圣君。",
      "text_length": 91
    },
    {
      "event_id": "03055004_e00027",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "罪臣、杨延昭见驾，吾皇万岁！",
      "text_length": 14
    },
    {
      "event_id": "03055004_e00028",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "杨郡马为何不抬起头来？",
      "text_length": 11
    },
    {
      "event_id": "03055004_e00029",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "有罪不敢抬头。",
      "text_length": 7
    },
    {
      "event_id": "03055004_e00030",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "恕卿无罪。",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00031",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "谢万岁！",
      "text_length": 4
    },
    {
      "event_id": "03055004_e00032",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "头顶何物？",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00033",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "御状。",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00034",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "呈上来。",
      "text_length": 4
    },
    {
      "event_id": "03055004_e00035",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭呈状，宋太宗看，念。",
      "text_length": 13
    },
    {
      "event_id": "03055004_e00036",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "“具叩阁人罪臣杨延昭，今告太师潘洪按兵不发，谋篡山河等……”",
      "text_length": 30
    },
    {
      "event_id": "03055004_e00037",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "唔！大胆杨郡马！别人可以告得，潘太师乃当今国丈，你都敢告？吃小王一锏！",
      "text_length": 35
    },
    {
      "event_id": "03055004_e00038",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "皇儿，只要他告得有理。有道是：王子犯法，与庶民同罪。可以告得。",
      "text_length": 31
    },
    {
      "event_id": "03055004_e00039",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "可以告得？杨郡马，万岁准告，你有什么冤枉？一一诉来！",
      "text_length": 26
    },
    {
      "event_id": "03055004_e00040",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "容奏！",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00041",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "杨延昭"
      ],
      "text": "杨延昭跪金阶啼哭掉泪，尊一声万岁爷和八贤君。我这里写就了御状一纸，听为臣一本一本奏当今：那胡儿打来了连环战表，他要夺吾主爷锦绣乾坤。潘仁美在金殿挂了帅印，臣父子在马前做了先行。在三关领兵来点卯，误了日期问典刑。多亏了呼延将军把情讲，赦却了父子戴罪立功。一计不成把二计定，可怜他年迈之人气死边庭。黄道日不发人和马，黑煞日期要兴兵。五百名校刀手把守关门上，他要臣父子们将胡儿斩尽绝根。要得胜许我们回营交令，斩不尽杀不绝不许回营。臣父子只得决一死战，围困在两狼山好不惨情。被番兵四下里围成铁桶，内无粮草外无救兵。命七弟回大营搬兵取救，潘太师提起了打子事情。将臣弟绑法标屈死可悯，射一百单三箭一命归阴。臣的父两狼山望兵不到，他望子来子亦无音。命臣我探听七弟信，可怜他年迈人李陵碑下丧残生。臣当初八个人把幽州闯，到如今只剩下为臣一人。没奈何逃出了边关外，写下了御状叩明君。臣不告圣天子三宫六院，臣不告王子与龙孙；臣不告朝中公侯驸马，臣不告文武众公卿；臣不告五府并六院，臣不告各府州县共子民；臣不告解粮官限误时刻，十道本告的是太师潘洪。",
      "text_length": 462
    },
    {
      "event_id": "03055004_e00042",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "告他何来？",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00043",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "万岁！",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00044",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "杨延昭"
      ],
      "text": "一告他私通辽邦打战表，二告他谋篡山河是真情；三告他文官挂了武帅印，四告他要臣父子做先行；五告他逼得那呼延老将丧了命，六告他上方宝剑乱斩人；七告他公报私仇射死我七弟，八告他害我父李陵碑下命归阴；九告他在边关开怀畅饮，十告他卖官爵私受金银。臣告他若有一事错，情愿枭首在午门。杨延昭心中苦楚说不尽！",
      "text_length": 146
    },
    {
      "event_id": "03055004_e00045",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵德芳"
      ],
      "text": "贤王听来也伤心。",
      "text_length": 8
    },
    {
      "event_id": "03055004_e00046",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "宋太宗"
      ],
      "text": "这是君也哭来，",
      "text_length": 7
    },
    {
      "event_id": "03055004_e00047",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "万岁！",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00048",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "杨延昭"
      ],
      "text": "我臣也哭，",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00049",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵德芳"
      ],
      "text": "小王落泪，",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00050",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "大太监"
      ],
      "text": "两旁内侍臣大放悲声。",
      "text_length": 10
    },
    {
      "event_id": "03055004_e00051",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "万岁呀！",
      "text_length": 4
    },
    {
      "event_id": "03055004_e00052",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "杨延昭"
      ],
      "text": "万岁准了臣的本，君是君来臣是臣。万岁不准臣的本，回到火塘为庶民。",
      "text_length": 32
    },
    {
      "event_id": "03055004_e00053",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭下。",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00054",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "皇儿传旨：可有粗心胆大之臣，去到雁门关提拿潘洪进京问罪？",
      "text_length": 28
    },
    {
      "event_id": "03055004_e00055",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "遵旨。",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00056",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵德芳向内。",
      "text_length": 6
    },
    {
      "event_id": "03055004_e00057",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "万岁有旨：可有粗心大胆之臣，去到雁门关提拿潘洪进京问罪？",
      "text_length": 28
    },
    {
      "event_id": "03055004_e00058",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "呼延必显"
      ],
      "text": "呼必显愿往！",
      "text_length": 6
    },
    {
      "event_id": "03055004_e00059",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "启奏叔王：呼必显愿往。",
      "text_length": 11
    },
    {
      "event_id": "03055004_e00060",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "随旨上殿！",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00061",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "随旨上殿。",
      "text_length": 5
    },
    {
      "event_id": "03055004_e00062",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "呼延必显"
      ],
      "text": "领旨！",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00063",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "呼延必显上。",
      "text_length": 6
    },
    {
      "event_id": "03055004_e00064",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延必显"
      ],
      "text": "扫殿侯呼必显见驾，吾皇万岁！",
      "text_length": 14
    },
    {
      "event_id": "03055004_e00065",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宋太宗"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "03055004_e00066",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延必显"
      ],
      "text": "万万岁！贤爷千岁！",
      "text_length": 9
    },
    {
      "event_id": "03055004_e00067",
      "play_id": "03055004",
      "scene_id": "03055004_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德芳"
      ],
      "text": "平身。",
      "text_length": 3
