      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杜丽娘上。",
      "text_length": 5
    },
    {
      "event_id": "70902109_e00002",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "绕池游",
      "speakers": [
        "杜丽娘"
      ],
      "text": "梦回莺啭，乱煞年光遍，人立小庭深院。",
      "text_length": 18
    },
    {
      "event_id": "70902109_e00003",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "春香上。",
      "text_length": 4
    },
    {
      "event_id": "70902109_e00004",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "绕池游",
      "speakers": [
        "春香"
      ],
      "text": "炷尽沉烟，抛残绣线，恁今春关情似去年？",
      "text_length": 19
    },
    {
      "event_id": "70902109_e00005",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杜丽娘"
      ],
      "text": "晓来望断梅关，宿妆残。",
      "text_length": 11
    },
    {
      "event_id": "70902109_e00006",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "春香"
      ],
      "text": "小姐，",
      "text_length": 3
    },
    {
      "event_id": "70902109_e00007",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "春香"
      ],
      "text": "你侧着宜春髻子恰凭栏。",
      "text_length": 11
    },
    {
      "event_id": "70902109_e00008",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杜丽娘"
      ],
      "text": "剪不断，理还乱，闷无端。",
      "text_length": 12
    },
    {
      "event_id": "70902109_e00009",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "春香"
      ],
      "text": "已吩咐催花莺燕惜春看。",
      "text_length": 11
    },
    {
      "event_id": "70902109_e00010",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杜丽娘"
      ],
      "text": "春香，可曾吩咐花郎，扫除花径么？",
      "text_length": 16
    },
    {
      "event_id": "70902109_e00011",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "春香"
      ],
      "text": "已吩咐过了。",
      "text_length": 6
    },
    {
      "event_id": "70902109_e00012",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杜丽娘"
      ],
      "text": "取镜台衣服过来。",
      "text_length": 8
    },
    {
      "event_id": "70902109_e00013",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "春香"
      ],
      "text": "晓得。",
      "text_length": 3
    },
    {
      "event_id": "70902109_e00014",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "春香"
      ],
      "text": "云髻罢梳还对镜，罗衣欲换更添香。",
      "text_length": 16
    },
    {
      "event_id": "70902109_e00015",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "春香"
      ],
      "text": "小姐，镜台衣服在此。",
      "text_length": 10
    },
    {
      "event_id": "70902109_e00016",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杜丽娘"
      ],
      "text": "放下。",
      "text_length": 3
    },
    {
      "event_id": "70902109_e00017",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "春香"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "70902109_e00018",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杜丽娘"
      ],
      "text": "好天气也！",
      "text_length": 5
    },
    {
      "event_id": "70902109_e00019",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "步步娇",
      "speakers": [
        "杜丽娘"
      ],
      "text": "袅晴丝吹来闲庭院，摇漾春如线。停半晌整花钿，没揣菱花偷人半面，迤逗的彩云偏。我步香闺怎便把全身现？",
      "text_length": 49
    },
    {
      "event_id": "70902109_e00020",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "春香"
      ],
      "text": "小姐。",
      "text_length": 3
    },
    {
      "event_id": "70902109_e00021",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "醉扶归",
      "speakers": [
        "春香"
      ],
      "text": "你道翠生生出落的裙衫儿茜，艳晶晶花簪八宝填。",
      "text_length": 22
    },
    {
      "event_id": "70902109_e00022",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杜丽娘"
      ],
      "text": "春香。",
      "text_length": 3
    },
    {
      "event_id": "70902109_e00023",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "醉扶归",
      "speakers": [
        "杜丽娘"
      ],
      "text": "可知我一生儿爱好是天然？",
      "text_length": 12
    },
    {
      "event_id": "70902109_e00024",
      "play_id": "70902109",
      "scene_id": "70902109_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同醉扶归",
      "speakers": [
        "杜丽娘",
        "春香"
      ],
      "text": "恰三春好处无人见。不堤防沉鱼落雁鸟惊喧，则怕的羞花闭月花愁颤。",
      "text_length": 31
    },
