  "events": [
    {
      "event_id": "01006017_e00001",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王朝、马汉引包拯同上。",
      "text_length": 11
    },
    {
      "event_id": "01006017_e00002",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "包拯"
      ],
      "text": "一片丹心，保宋主，锦绣龙廷。",
      "text_length": 14
    },
    {
      "event_id": "01006017_e00003",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "包拯"
      ],
      "text": "黑暗暗乌纱盖顶，明亮亮玉带围身。上金殿君王见喜，下朝房文武皆尊。",
      "text_length": 32
    },
    {
      "event_id": "01006017_e00004",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "老夫，包拯。宋室驾前为臣。今奉圣命陈州放粮，且喜放粮已毕，不免回朝交旨复命。王朝、马汉，",
      "text_length": 44
    },
    {
      "event_id": "01006017_e00005",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王朝、马汉同允。",
      "text_length": 8
    },
    {
      "event_id": "01006017_e00006",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "人役可齐？",
      "text_length": 5
    },
    {
      "event_id": "01006017_e00007",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "王朝",
        "马汉"
      ],
      "text": "俱已齐备。",
      "text_length": 5
    },
    {
      "event_id": "01006017_e00008",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "吩咐外厢开道。",
      "text_length": 7
    },
    {
      "event_id": "01006017_e00009",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "王朝",
        "马汉"
      ],
      "text": "外厢开道。",
      "text_length": 5
    },
    {
      "event_id": "01006017_e00010",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍同上。",
      "text_length": 6
    },
    {
      "event_id": "01006017_e00011",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "包拯"
      ],
      "text": "奉王命散君粮出了朝道，",
      "text_length": 11
    },
    {
      "event_id": "01006017_e00012",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "包拯"
      ],
      "text": "一路上断了些恶棍土豪。随带着王朝、马汉、张龙、赵，又收下小豪杰御猫展昭。白玉堂闹开府盗过了三宝，又收下五义士暗保宋朝。叫王朝和马汉急忙开道，",
      "text_length": 70
    },
    {
      "event_id": "01006017_e00013",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、王朝、马汉同下。",
      "text_length": 12
    },
    {
      "event_id": "01006017_e00014",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "为国家哪顾得昼夜勤劳。",
      "text_length": 11
    },
    {
      "event_id": "01006017_e00015",
      "play_id": "01006017",
      "scene_id": "01006017_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯下。",
      "text_length": 4
    },
    {
      "event_id": "01006017_e00016",
      "play_id": "01006017",
      "scene_id": "01006017_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小妖引黑鼠同上。",
      "text_length": 9
    },
    {
      "event_id": "01006017_e00017",
      "play_id": "01006017",
      "scene_id": "01006017_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "黑鼠"
      ],
      "text": "修炼千年道法高，变化人形乐逍遥。",
      "text_length": 16
    },
    {
      "event_id": "01006017_e00018",
      "play_id": "01006017",
      "scene_id": "01006017_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黑鼠"
      ],
      "text": "我乃黑鼠大仙是也。今有包拯陈州放粮而回，打此经过，不免变作假包模样，搅乱一回。众小妖，命你等变作王朝、马汉，三班衙役模样，速速变来。",
      "text_length": 66
    },
    {
      "event_id": "01006017_e00019",
      "play_id": "01006017",
      "scene_id": "01006017_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
