      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李敬犹"
      ],
      "text": "为父送你归阴曹。",
      "text_length": 8
    },
