      "event_id": "02006046_e00047",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
