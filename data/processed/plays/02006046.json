      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李敬犹"
      ],
      "text": "一朝奉君相交好，异姓骨肉胜同胞。舍子代替天有报，愁眉展放免悲劳。悲切切将儿抱，",
      "text_length": 39
    },
    {
      "event_id": "02006046_e00085",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "李敬犹"
      ],
      "text": "哎呀，儿吓！",
      "text_length": 6
    },
