      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李敬犹"
      ],
      "text": "舍亲生，",
      "text_length": 4
    },
    {
      "event_id": "02006046_e00089",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "薛猛",
        "张夫人",
        "李敬犹"
      ],
      "text": "神明相照，",
      "text_length": 5
    },
    {
