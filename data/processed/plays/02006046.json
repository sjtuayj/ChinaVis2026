      "event_id": "02006046_e00051",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "爵主出来了。",
