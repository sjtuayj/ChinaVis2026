      "event_id": "02006046_e00048",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "张夫人"
      ],
      "text": "三叔惹祸惧法逃。",
      "text_length": 8
    },
