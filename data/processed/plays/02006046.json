      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛猛"
      ],
      "text": "吓，大人在哪里？",
      "text_length": 8
    },
