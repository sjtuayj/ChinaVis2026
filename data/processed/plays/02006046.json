      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
