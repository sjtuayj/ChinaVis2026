      "seq_global": 94,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛猛、张夫人同回头，同叹。",
      "text_length": 13
    },
