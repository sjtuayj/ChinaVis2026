      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李敬犹"
      ],
      "text": "在哪里？哎呀，爵主！夫人！",
      "text_length": 13
    },
