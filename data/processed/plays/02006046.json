      "event_id": "02006046_e00049",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
