      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛猛、张夫人同跪。",
      "text_length": 9
    },
    {
      "event_id": "02006046_e00055",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李敬犹"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "02006046_e00056",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李敬犹"
      ],
      "text": "不见你带露随朝早，",
      "text_length": 9
    },
    {
      "event_id": "02006046_e00057",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "李敬犹"
      ],
      "text": "爵主！夫人吓！",
      "text_length": 7
    },
    {
      "event_id": "02006046_e00058",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李敬犹"
      ],
      "text": "不见你与主立功劳。忠良非是知心少，",
      "text_length": 17
    },
    {
      "event_id": "02006046_e00059",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "李敬犹"
      ],
      "text": "哎呀，爵主吓！",
      "text_length": 7
    },
    {
      "event_id": "02006046_e00060",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李敬犹"
      ],
      "text": "怎奈犯罪法不饶。",
      "text_length": 8
    },
    {
      "event_id": "02006046_e00061",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛猛"
      ],
      "text": "大人吓！",
      "text_length": 4
    },
    {
      "event_id": "02006046_e00062",
      "play_id": "02006046",
      "scene_id": "02006046_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "薛猛"
      ],
      "text": "罪犯天条当承受，",
