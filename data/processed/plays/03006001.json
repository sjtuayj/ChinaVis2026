  "events": [
    {
      "event_id": "03006001_e00001",
      "play_id": "03006001",
      "scene_id": "03006001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、卞庄同上。",
      "text_length": 9
    },
    {
      "event_id": "03006001_e00002",
      "play_id": "03006001",
      "scene_id": "03006001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卞庄"
      ],
      "text": "某、卞庄。奉了平王之命，捉拿伍子胥。众将官，起兵前往！",
      "text_length": 27
    },
    {
      "event_id": "03006001_e00003",
      "play_id": "03006001",
      "scene_id": "03006001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03006001_e00004",
      "play_id": "03006001",
      "scene_id": "03006001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    },
    {
      "event_id": "03006001_e00005",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 5,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上，起霸。",
      "text_length": 7
    },
    {
      "event_id": "03006001_e00006",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "伍员"
      ],
      "text": "拜将封侯印，盖世保乾坤。扶保平王主，四路扫烟尘。",
      "text_length": 24
    },
    {
      "event_id": "03006001_e00007",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "俺，姓伍名员字子胥，乃楚国监利人也。可恨平王无道，父纳子妻为妾。那时怒恼某家，保定皇家四口，我就杀——杀出重围。似淤泥挡住轮车，沙滩围困蛟龙。",
      "text_length": 71
    },
    {
      "event_id": "03006001_e00008",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "伍员"
      ],
      "text": "天哪，天！",
      "text_length": 5
    },
    {
      "event_id": "03006001_e00009",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "俺伍员好似一轮明月又被浮云遮。",
      "text_length": 15
    },
    {
      "event_id": "03006001_e00010",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "伍员"
      ],
      "text": "且住！",
      "text_length": 3
    },
    {
      "event_id": "03006001_e00011",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "耳边厢又听得人马呐喊，想是卞庄追兵甚紧，不免请出国太龙驾登程。臣有请国太！",
      "text_length": 37
    },
    {
      "event_id": "03006001_e00012",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "国太上。",
      "text_length": 4
    },
    {
      "event_id": "03006001_e00013",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "国太"
      ],
      "text": "泪似湘江水，点点不断流。",
      "text_length": 12
    },
    {
      "event_id": "03006001_e00014",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "臣伍员见驾，国太、幼主千岁！",
      "text_length": 14
    },
    {
      "event_id": "03006001_e00015",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "03006001_e00016",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "千千岁！",
      "text_length": 4
    },
    {
      "event_id": "03006001_e00017",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "卿家将哀家请了出来，为了何事？",
      "text_length": 15
    },
    {
      "event_id": "03006001_e00018",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "卞庄追兵甚紧，请国太龙驾登程！",
      "text_length": 15
    },
    {
      "event_id": "03006001_e00019",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "如此将军带马！",
      "text_length": 7
    },
    {
      "event_id": "03006001_e00020",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "臣领旨！",
      "text_length": 4
    },
    {
      "event_id": "03006001_e00021",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "马昭仪上龙驹珠泪滚滚，骂一声狗奸贼卖国的奸臣。楚平王坐江山朝纲不正，把一个亲生子赶出了午门。",
      "text_length": 46
    },
    {
      "event_id": "03006001_e00022",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "耳边厢又听得人马喊，想是卞庄发来兵。眼望着松林一寺院，请国太下马躲贼兵。",
      "text_length": 36
    },
    {
      "event_id": "03006001_e00023",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "兵困禅宇……",
      "text_length": 6
    },
    {
      "event_id": "03006001_e00024",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "马后悲！君臣们被困在重围。葵花树上拴战马，虎头银枪插土堆。将身儿来站在廊檐内，且听国太发纶徽。",
      "text_length": 47
    },
    {
      "event_id": "03006001_e00025",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "楚兵纷纷扎了队，君臣逃命好不伤悲。将军快把雄兵退，救我母子出重围。",
      "text_length": 33
    },
    {
      "event_id": "03006001_e00026",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "子胥向前本奏启，尊声国太听端的：那卞庄好似得胜的猫儿强似虎，为臣似虎落平川被犬欺。幼主爷龙困沙滩难翻转，龙国太背时凤凰不如鸡。臣要保只保小千岁，难保国太杀出重围。",
      "text_length": 81
    },
    {
      "event_id": "03006001_e00027",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "将军你呢！",
      "text_length": 5
    },
    {
      "event_id": "03006001_e00028",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "斗宝曾在临潼会，万马营中逞雄威。保皇家四口丧两口，不怨将军怨着谁。",
      "text_length": 33
    },
    {
      "event_id": "03006001_e00029",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "子胥闻说忙屈膝，",
      "text_length": 8
    },
    {
      "event_id": "03006001_e00030",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "03006001_e00031",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "谢国太。",
      "text_length": 4
    },
    {
      "event_id": "03006001_e00032",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "尊声国太驾听知：龙国太今年三十二，为臣的四十少二春。知道的自说臣保主，不知者反说臣的……",
      "text_length": 44
    },
    {
      "event_id": "03006001_e00033",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "哽！",
      "text_length": 2
    },
    {
      "event_id": "03006001_e00034",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "一个“妻”字未出唇，国太面上怒气生。子胥若有欺天意，苍天岂容我伍员。",
      "text_length": 34
    },
    {
      "event_id": "03006001_e00035",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "被他一言来提醒，提醒南柯梦里人。将军暂退廊檐下，容我母子暗思忖。",
      "text_length": 32
    },
    {
      "event_id": "03006001_e00036",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    },
    {
      "event_id": "03006001_e00037",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "独坐在大佛殿自思自恨，怀抱着年幼儿大放悲声。恨只恨儿祖父纲常丧尽，父纳了子的妻败坏人伦。连累了儿的父东逃西奔，连累了伍将军丧胆游魂。到如今母子们无方寄命，奔天涯走地角凄凄惨惨无处安身。回头便把将军请，",
      "text_length": 100
    },
    {
      "event_id": "03006001_e00038",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "03006001_e00039",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "后面来了保驾臣。迈步且把禅堂进，国太快快设计行！",
      "text_length": 24
    },
    {
      "event_id": "03006001_e00040",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "人言子胥是好将，今日果然不虚名。太子付与将军抱，",
      "text_length": 24
    },
    {
      "event_id": "03006001_e00041",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "扬尘舞蹈接王身。解开甲胄藏幼主，辞别国太便登程。手拿金枪踏金蹬，",
      "text_length": 32
    },
    {
      "event_id": "03006001_e00042",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "将军请转。",
      "text_length": 5
    },
    {
      "event_id": "03006001_e00043",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "国太有话快说明！",
      "text_length": 8
    },
    {
      "event_id": "03006001_e00044",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "不当将军保太子，直当将军你自己生。",
      "text_length": 17
    },
    {
      "event_id": "03006001_e00045",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "国太不必细叮咛，君是君来臣是臣。国太快把良谋定，放我君臣早逃生。",
      "text_length": 32
    },
    {
      "event_id": "03006001_e00046",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "国太"
      ],
      "text": "苍天降下无情剑，斩断母子两离分。将身跳在葵花井！",
      "text_length": 24
    },
    {
      "event_id": "03006001_e00047",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "将军，那旁有人来了！",
      "text_length": 10
    },
    {
      "event_id": "03006001_e00048",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "国太跳井，下。",
      "text_length": 7
    },
    {
      "event_id": "03006001_e00049",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "伍员"
      ],
      "text": "一见国太丧了命，子胥倒做不忠臣。推倒土墙忙掩井，",
      "text_length": 24
    },
    {
      "event_id": "03006001_e00050",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "卞庄上，卞庄、伍员同开打，伍员败下。四龙套同上。",
      "text_length": 24
    },
    {
      "event_id": "03006001_e00051",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "那贼大败！",
      "text_length": 5
    },
    {
      "event_id": "03006001_e00052",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卞庄"
      ],
      "text": "紧紧追赶！",
      "text_length": 5
    },
    {
      "event_id": "03006001_e00053",
      "play_id": "03006001",
      "scene_id": "03006001_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "03006001_e00054",
      "play_id": "03006001",
      "scene_id": "03006001_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员换白髯口上。",
      "text_length": 8
    },
    {
      "event_id": "03006001_e00055",
      "play_id": "03006001",
      "scene_id": "03006001_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "杀败了，杀败了！",
      "text_length": 8
    },
    {
      "event_id": "03006001_e00056",
      "play_id": "03006001",
      "scene_id": "03006001_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "伍员"
      ],
      "text": "子胥离家有数年，不报冤仇誓不还。解开甲胄观幼主，",
      "text_length": 24
    },
    {
      "event_id": "03006001_e00057",
      "play_id": "03006001",
      "scene_id": "03006001_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "伍员"
      ],
      "text": "哈哈哈……",
      "text_length": 5
    },
    {
      "event_id": "03006001_e00058",
      "play_id": "03006001",
      "scene_id": "03006001_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "伍员"
      ],
      "text": "一夜髯白过昭关。",
      "text_length": 8
    },
    {
      "event_id": "03006001_e00059",
      "play_id": "03006001",
      "scene_id": "03006001_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "唗！卞庄休赶，伍老爷去也！",
      "text_length": 13
    },
    {
      "event_id": "03006001_e00060",
      "play_id": "03006001",
      "scene_id": "03006001_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}