  "events": [
    {
      "event_id": "08005006_e00001",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "白素贞"
      ],
      "text": "离峨眉驾祥云飘越崇山，",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00002",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云旗同上。白素贞上，舞蹈。",
      "text_length": 14
    },
    {
      "event_id": "08005006_e00003",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "白素贞"
      ],
      "text": "飞过了幽谷峻岭来到凡尘。自幼儿在深山养性修炼。习就了隐身术法力无边。全凭着变化奇随机应变，施法力呼风唤雨降福民间。只为我凡心动把红尘思念，因此上离仙山要自配良缘。但愿得此一番了却心愿，宁羡人间我不羡仙。",
      "text_length": 101
    },
    {
      "event_id": "08005006_e00004",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "白素贞"
      ],
      "text": "俺本白蛇女婵娟，深山悟道数千年。神通广大苦修炼。奇巧变化隐世间。呕心炼就双锋剑，降妖除怪不费难。任他纵有千般化，难逃仙姑法力全。",
      "text_length": 64
    },
    {
      "event_id": "08005006_e00005",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "我乃，白蛇仙姑素贞是也。自幼在峨眉修炼，习就奇巧变化，炼成双锋宝剑。是我思念凡尘美景，为此下得山来观赏人间的湖色河山，以解烦闷。倘遇称心君子结为共衾同枕之人，以享人间快乐，岂不美哉。不觉前面已是青峰山了。看那古树盘藤。银杏环山，绿竹摇摆，云霞万色，幽谷俊秀，草木峥嵘，蝶入群芳，百鸟声喧，好一派景象也。",
      "text_length": 151
    },
    {
      "event_id": "08005006_e00006",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "白素贞"
      ],
      "text": "碧树千里锁青苑，霞光穿射云环山。遥望幽谷处，紫气阵阵寒。",
      "text_length": 28
    },
    {
      "event_id": "08005006_e00007",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "看幽谷深处紫气冲天，寒气阵阵掠过，定有精灵修炼。待我闯峰越岭者。",
      "text_length": 32
    },
    {
      "event_id": "08005006_e00008",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "白素贞"
      ],
      "text": "速驾云峰闯青山，飞越向前。",
      "text_length": 13
    },
    {
      "event_id": "08005006_e00009",
      "play_id": "08005006",
      "scene_id": "08005006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云旗、白素贞同下。",
      "text_length": 10
    },
    {
      "event_id": "08005006_e00010",
      "play_id": "08005006",
      "scene_id": "08005006_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小高台。四风旗、青蛇同上。",
      "text_length": 13
    },
    {
      "event_id": "08005006_e00011",
      "play_id": "08005006",
      "scene_id": "08005006_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "青蛇"
      ],
      "text": "变化奇巧，法力无边，苦修炼，幻术精湛，尘心常常念。",
      "text_length": 25
    },
    {
      "event_id": "08005006_e00012",
      "play_id": "08005006",
      "scene_id": "08005006_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "青蛇"
      ],
      "text": "俺本青峰一蛇仙，变化奇巧法力全。皆因尘缘难绝断，朝夕思念女婵娟。",
      "text_length": 32
    },
    {
      "event_id": "08005006_e00013",
      "play_id": "08005006",
      "scene_id": "08005006_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "我乃，青峰山光华洞青蛇大仙是也。在深山修炼千年，精通幻变，法力无边。怎奈尘缘未断，常常思念凡尘之乐，因此正果未成。啊，看远方云峰起落，朝我仙山而来，定有精灵闯越青峰。众小仙，驾起云头迎上前去。",
      "text_length": 96
    },
    {
      "event_id": "08005006_e00014",
      "play_id": "08005006",
      "scene_id": "08005006_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四风旗"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "08005006_e00015",
      "play_id": "08005006",
      "scene_id": "08005006_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四风旗、青蛇同下。",
      "text_length": 9
    },
    {
      "event_id": "08005006_e00016",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 16,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云旗、白素贞同上，舞蹈。",
      "text_length": 13
    },
    {
      "event_id": "08005006_e00017",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 17,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "折桂令",
      "speakers": [
        "白素贞"
      ],
      "text": "观山景绿深处银杏千年，望泉水倾斜直下，似银河飞落九天。这边厢葱翠花鲜，那边厢白鹤崖畔。山巅缠绕瑞烟，翠柏拂云天。是何物挡住云端，寻衅者痴想生还。",
      "text_length": 72
    },
    {
      "event_id": "08005006_e00018",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 18,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四风旗、青蛇同上。",
      "text_length": 9
    },
    {
      "event_id": "08005006_e00019",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 19,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "呔，何方妖魔擅闯仙山？",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00020",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 20,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "你且听了：俺乃峨眉山得道仙姑白素贞，你是何方魔怪快快通上名来。",
      "text_length": 31
    },
    {
      "event_id": "08005006_e00021",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "我乃青峰山青蛇大仙是也。",
      "text_length": 12
    },
    {
      "event_id": "08005006_e00022",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "原来是青蛇仙翁。我来问你，挡住云头，挡我去路，是何意也？",
      "text_length": 28
    },
    {
      "event_id": "08005006_e00023",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "白蛇仙子，我对你实言了吧：我看你品貌端正，意欲和你在青峰宝洞，结为终生伴侣，一同修真养性，求得正果，岂不是美哉？",
      "text_length": 56
    },
    {
      "event_id": "08005006_e00024",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "休得胡言，你既欲修真养性，以求正果，就该清心寡欲，潜心悟道，怎能生此邪念。听我相劝，速速断了此念，回山修炼去吧。",
      "text_length": 56
    },
    {
      "event_id": "08005006_e00025",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "住口，你今依从便罢，稍若迟延，你来看，可知俺青峰宝剑的厉害。",
      "text_length": 30
    },
    {
      "event_id": "08005006_e00026",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "青蛇精，你大胆。",
      "text_length": 8
    },
    {
      "event_id": "08005006_e00027",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "白素贞"
      ],
      "text": "听一言来怒满膛，山中魔怪敢猖狂。我发慈悲将你放，快去修炼改善良。再若痴迷心妄想，双刃青锋剑下亡。",
      "text_length": 48
    },
    {
      "event_id": "08005006_e00028",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "喳，喳，喳，哇呀呀，看剑。",
      "text_length": 13
    },
    {
      "event_id": "08005006_e00029",
      "play_id": "08005006",
      "scene_id": "08005006_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云旗、四风旗自两边分下。白素贞、青蛇对剑，青蛇败下，白素贞追下。",
      "text_length": 33
    },
    {
      "event_id": "08005006_e00030",
      "play_id": "08005006",
      "scene_id": "08005006_s04",
      "scene_no": 4,
      "seq_global": 30,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云旗、四风旗同上，群舞，舞毕分下。青蛇败上，白素贞追上，对打。青蛇败下。白素贞耍下场，追下。",
      "text_length": 47
    },
    {
      "event_id": "08005006_e00031",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 31,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "青蛇败上，白素贞追上，舞蹈。白素贞打青蛇抢背。四云旗、四风旗自两边分上。",
      "text_length": 36
    },
    {
      "event_id": "08005006_e00032",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 32,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "看剑。",
      "text_length": 3
    },
    {
      "event_id": "08005006_e00033",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 33,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "且慢，白蛇仙子果然道法非凡，望乞慈悲，饶恕于我，情愿跟随仙子，侍奉左右，一同修炼，求得正果。我若口不应心，定遭五雷之劫。",
      "text_length": 60
    },
    {
      "event_id": "08005006_e00034",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 34,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "这……你既发誓，快快请起。",
      "text_length": 13
    },
    {
      "event_id": "08005006_e00035",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 35,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "多谢仙子慈悲。",
      "text_length": 7
    },
    {
      "event_id": "08005006_e00036",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 36,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "青蛇仙翁，你可知阴阳有别，你我怎能一路同行?",
      "text_length": 22
    },
    {
      "event_id": "08005006_e00037",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 37,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "这个，俺情愿化一女身，侍奉仙子终生。",
      "text_length": 18
    },
    {
      "event_id": "08005006_e00038",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 38,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "既然如此，就请仙翁变来。",
      "text_length": 12
    },
    {
      "event_id": "08005006_e00039",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 39,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "献丑了。",
      "text_length": 4
    },
    {
      "event_id": "08005006_e00040",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 40,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "青蛇"
      ],
      "text": "口念真言翻身变，",
      "text_length": 8
    },
    {
      "event_id": "08005006_e00041",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 41,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四风旗遮青蛇同下，遮青蛇化身同上。",
      "text_length": 17
    },
    {
      "event_id": "08005006_e00042",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 42,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "青蛇"
      ],
      "text": "变一个青春女婵娟。",
      "text_length": 9
    },
    {
      "event_id": "08005006_e00043",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 43,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "白蛇仙子，你看我变得如何？",
      "text_length": 13
    },
    {
      "event_id": "08005006_e00044",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 44,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "果然法术高强。我有意与你结为姐妹，生死与共，不知你意如何？",
      "text_length": 29
    },
    {
      "event_id": "08005006_e00045",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 45,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "正合我意，请问仙子道高几何？",
      "text_length": 14
    },
    {
      "event_id": "08005006_e00046",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 46,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "七千九百余年。",
      "text_length": 7
    },
    {
      "event_id": "08005006_e00047",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 47,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "哎呀，仙子高我五百余载。",
      "text_length": 12
    },
    {
      "event_id": "08005006_e00048",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 48,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "如此说来我占长了，你我对天一拜。",
      "text_length": 16
    },
    {
      "event_id": "08005006_e00049",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 49,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "白素贞"
      ],
      "text": "数千年居山林修真养性，",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00050",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 50,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "青蛇"
      ],
      "text": "姐姐你道高我五百余春。",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00051",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 51,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "白素贞"
      ],
      "text": "我与你肝胆相照患难与共，",
      "text_length": 12
    },
    {
      "event_id": "08005006_e00052",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 52,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "青蛇"
      ],
      "text": "若三心和二意五雷轰身。",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00053",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 53,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "姐姐请上，受小妹一拜。",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00054",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 54,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "为姐也有一拜。",
      "text_length": 7
    },
    {
      "event_id": "08005006_e00055",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 55,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "白素贞、青蛇同拜。",
      "text_length": 9
    },
    {
      "event_id": "08005006_e00056",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 56,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "青蛇"
      ],
      "text": "从今后姐妹们相依相伴，",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00057",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 57,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "白素贞"
      ],
      "text": "同甘苦共患难永不离分。",
      "text_length": 11
    },
    {
      "event_id": "08005006_e00058",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 58,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "请姐姐到古洞观赏。",
      "text_length": 9
    },
    {
      "event_id": "08005006_e00059",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 59,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "正要拜观。",
      "text_length": 5
    },
    {
      "event_id": "08005006_e00060",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 60,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青蛇"
      ],
      "text": "众小仙，回洞去者。",
      "text_length": 9
    },
    {
      "event_id": "08005006_e00061",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 61,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同沽美酒",
      "speakers": [
        "白素贞",
        "青蛇"
      ],
      "text": "喜相逢，恰相逢，巧今朝得知音。同心合意志向同，在山林拜昆仲。同修炼拜求长生，炼仙丹变化无穷。发慈悲指引迷津，渡群灵扶助苍身。俺呵！每日里苦炼求经，学慈航大显神通。哎呀！宏誓愿锦绣前程。",
      "text_length": 92
    },
    {
      "event_id": "08005006_e00062",
      "play_id": "08005006",
      "scene_id": "08005006_s05",
      "scene_no": 5,
      "seq_global": 62,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "急急风，众人同亮相。",
      "text_length": 10
    }
  ],
  "roles_inferred": true
}