      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹参"
      ],
      "text": "得令。呔，众将官！",
      "text_length": 9
    },
    {
      "event_id": "02002005_e00012",
      "play_id": "02002005",
      "scene_id": "02002005_s01",
