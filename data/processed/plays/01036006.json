  "events": [
    {
      "event_id": "01036006_e00001",
      "play_id": "01036006",
      "scene_id": "01036006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00002",
      "play_id": "01036006",
      "scene_id": "01036006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "王宝钏"
      ],
      "text": "富贵贫贱天注定，岂知由天不由人，",
      "text_length": 16
    },
    {
      "event_id": "01036006_e00003",
      "play_id": "01036006",
      "scene_id": "01036006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏坐。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00004",
      "play_id": "01036006",
      "scene_id": "01036006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王宝钏"
      ],
      "text": "身坐窑内心烦焦，父亲空枉保当朝。厌贫爱富古来少，夫妻赶至在寒窑，",
      "text_length": 32
    },
    {
      "event_id": "01036006_e00005",
      "play_id": "01036006",
      "scene_id": "01036006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "奴家，王氏宝钏。可恨爹爹，嫌贫爱富，与我击掌，因此赶出相府，来在窑中居住。思想起来，好不凄惨人也。",
      "text_length": 49
    },
    {
      "event_id": "01036006_e00006",
      "play_id": "01036006",
      "scene_id": "01036006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "王宝钏"
      ],
      "text": "王宝钏坐窑内泪痕双标，我的父空作了一品当朝。嫌贫穷爱富贵世间真少，反把那父女情一旦相抛。耳边厢又听得锣鼓喊噪，想必是奴的父来到寒窑。我只得在门前将人盼瞧，西北风吹得我透骨寒烧。我这里回窑内将门闭了，等候了薛平郎转回寒窑。",
      "text_length": 110
    },
    {
      "event_id": "01036006_e00007",
      "play_id": "01036006",
      "scene_id": "01036006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏下。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00008",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵上。〖四击头〗。薛平贵起霸。",
      "text_length": 17
    },
    {
      "event_id": "01036006_e00009",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "薛平贵"
      ],
      "text": "头戴金盔一点红，身穿铠甲响玲珑。红纱洞降烈火马，唐王驾前立大功。",
      "text_length": 32
    },
    {
      "event_id": "01036006_e00010",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "俺，姓薛名琼，字平贵，大国长安人氏。只因红纱洞内，出了妖魔伤人，唐王出下榜文，有人降得此怪，高官任做，骏马任骑。是俺前去揭了榜文，前去降妖。哪知道是一匹红鬃烈马，被俺将它擒住，前去见驾，唐王见喜，封我后营都督府。可恨王允，上殿参奏一本，将都督府改为马前先行。谁知西凉下国，打来连环战表，要与我主争斗江山。那时圣上，命苏龙、魏虎挂帅，命俺以为马前先行。此番征战西凉，不知三年五载，我不免赶回寒窑，与三姐一别。王允吓王允，俺此番征战西凉，若有寸箭之功，回来定不与你干休！",
      "text_length": 233
    },
    {
      "event_id": "01036006_e00011",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "薛平贵"
      ],
      "text": "王允奏本心太惨，",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00012",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "与我结仇为那般。降了烈马佩鞍轡，唐王封俺都督官。西凉下国贼造反，王允上殿把本参。苏龙、魏虎挂了帅，平贵倒作了先行官。我这里催马往前赶，来在窑门把马拴。忙将寒窑门扣响，叫声三姐快开门。",
      "text_length": 91
    },
    {
      "event_id": "01036006_e00013",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐开门来。",
      "text_length": 6
    },
    {
      "event_id": "01036006_e00014",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "王宝钏"
      ],
      "text": "来了！",
      "text_length": 3
    },
    {
      "event_id": "01036006_e00015",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00016",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "忽听窑外有人捶，想必平郎转回归。用手开门来观看，为何这身荣耀回？",
      "text_length": 32
    },
    {
      "event_id": "01036006_e00017",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "吓，平郎回来了，",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00018",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "回来了。",
      "text_length": 4
    },
    {
      "event_id": "01036006_e00019",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "平郎，哪里来的这身荣耀？",
      "text_length": 12
    },
    {
      "event_id": "01036006_e00020",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐哪里知道，只因红纱洞中，出了妖魔伤人。唐王出了榜文在外，有人降了妖魔，高官任做，骏马任骑。是为夫的揭了榜文，前去降妖，谁知乃是一匹红鬃烈马，是我将它降住，唐王见喜，封我后军都督府。",
      "text_length": 92
    },
    {
      "event_id": "01036006_e00021",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "恭喜平郎。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00022",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "且慢，这喜中有变！",
      "text_length": 9
    },
    {
      "event_id": "01036006_e00023",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "怎样有变？",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00024",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "可恨你父，上殿参奏一本，将我后营都督府，改为马前先行。谁知西凉下国造反，圣上命苏龙、魏虎挂帅，命我做他先行，此番前去，不知三年五载，因此回得寒窑，与三姐一别。",
      "text_length": 79
    },
    {
      "event_id": "01036006_e00025",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "你待怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00026",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "与你一别。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00027",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01036006_e00028",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏气椅。",
      "text_length": 6
    },
    {
      "event_id": "01036006_e00029",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐醒来！",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00030",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "王宝钏"
      ],
      "text": "听他言唬得我心惊胆怕，",
      "text_length": 11
    },
    {
      "event_id": "01036006_e00031",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "王宝钏"
      ],
      "text": "平郎！我夫！吓夫吓吓！",
      "text_length": 11
    },
    {
      "event_id": "01036006_e00032",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "恨爹爹害平郎启奏皇家。父好比秦赵高指鹿为马，父好比汉萧何私造律法；父好比奸曹操进宫迫驾，父好比毛延寿怀抱琵琶。身为了宰相家全不怕被人来骂，害平郎赶女儿所为哪般？",
      "text_length": 80
    },
    {
      "event_id": "01036006_e00033",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐吓！",
      "text_length": 4
    },
    {
      "event_id": "01036006_e00034",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "说什么秦赵高指鹿为马，说什么汉萧何私造律法；说什么奸曹操进宫迫驾，说什么毛延寿怀抱琵琶。你的父与平贵把仇结下，苦害我薛平贵所为哪般？",
      "text_length": 66
    },
    {
      "event_id": "01036006_e00035",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "对着相府高声骂，害得我夫平郎难以归家。",
      "text_length": 19
    },
    {
      "event_id": "01036006_e00036",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01036006_e00037",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "耳边听得号炮炸，想必是魏虎贼把兵发。辞别三姐把马跨，",
      "text_length": 26
    },
    {
      "event_id": "01036006_e00038",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "扯住衣衿不松开。你要走来将奴带，平郎夫吓！",
      "text_length": 21
    },
    {
      "event_id": "01036006_e00039",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "苦苦拉我为何来？",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00040",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "此去定有三五载，你把为妻怎安排？",
      "text_length": 16
    },
    {
      "event_id": "01036006_e00041",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐吓！",
      "text_length": 4
    },
    {
      "event_id": "01036006_e00042",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐不必泪双流，平贵言来听从头：十担干柴米八斗，你在寒窑度春秋。守得我来你就守，守不得我来把我丢。",
      "text_length": 49
    },
    {
      "event_id": "01036006_e00043",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "夫吓！",
      "text_length": 3
    },
    {
      "event_id": "01036006_e00044",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "王宝钏"
      ],
      "text": "平郎说话莫来由，妻子言来听从头：马备双鞍路难走，女嫁二夫骂名流。三年五载将你守，富贵荣华一旦丢。守得不过你也要守，饿死寒窑不回头，",
      "text_length": 65
    },
    {
      "event_id": "01036006_e00045",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "薛平贵"
      ],
      "text": "好个三姐世少有，落下美名万古流，",
      "text_length": 16
    },
    {
      "event_id": "01036006_e00046",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "中军上。",
      "text_length": 4
    },
    {
      "event_id": "01036006_e00047",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "平贵听令：元帅身坐教场，连点二卯，再有一卯不到，按军令示刑。",
      "text_length": 30
    },
    {
      "event_id": "01036006_e00048",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "中军"
      ],
      "text": "将军不下马，",
      "text_length": 6
    },
    {
      "event_id": "01036006_e00049",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "薛平贵"
      ],
      "text": "各自奔前程。",
      "text_length": 6
    },
    {
      "event_id": "01036006_e00050",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "中军下。",
      "text_length": 4
    },
    {
      "event_id": "01036006_e00051",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "适才何人到来？",
      "text_length": 7
    },
    {
      "event_id": "01036006_e00052",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "中军到此，言道元帅身坐教场，连点二卯，再有一卯不到，要按军令示刑。",
      "text_length": 33
    },
    {
      "event_id": "01036006_e00053",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "几时起程？",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00054",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "即刻起程。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00055",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "为妻送你一程。",
      "text_length": 7
    },
    {
      "event_id": "01036006_e00056",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "有劳三姐。",
      "text_length": 5
    },
    {
      "event_id": "01036006_e00057",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "夫吓！",
      "text_length": 3
    },
    {
      "event_id": "01036006_e00058",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "手挽平郎出窑门，",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00059",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "平贵带过马缰绳。",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00060",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "你往西凉身保稳，",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00061",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "你在寒窑守孤灯。",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00062",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "但愿旗开早得胜，",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00063",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "自有书信到窑门。",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00064",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "送夫送到西河岸，",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00065",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "呕呀！",
      "text_length": 3
    },
    {
      "event_id": "01036006_e00066",
      "play_id": "01036006",
      "scene_id": "01036006_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "叫人难舍又难分。",
      "text_length": 8
    },
    {
      "event_id": "01036006_e00067",
      "play_id": "01036006",
