  "events": [
    {
      "event_id": "01003014_e00001",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小锣。周翠屏上。",
      "text_length": 8
    },
    {
      "event_id": "01003014_e00002",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "周翠屏"
      ],
      "text": "清晨起来倚梳妆，蝴蝶儿乱扑纱窗。",
      "text_length": 16
    },
    {
      "event_id": "01003014_e00003",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "周翠屏"
      ],
      "text": "红颜薄命女娇娘，不幸父母丧无常。命苦身落烟花巷，何日跳出是非墙？",
      "text_length": 32
    },
    {
      "event_id": "01003014_e00004",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "奴家，周翠屏。爹爹在世，官居五马太守。不幸父母双亡，多蒙姑母，恩养成人。是她改变心肠，将奴卖在烟巷花柳之中。多蒙世家公子抬爱，赠名陈三两。是我结拜一个兄弟，名叫陈魁，年长一十六岁，倒是个志气君子。昨日妈儿娘寿诞之日，命他前去拜寿。这般时候，不见到来。正是：",
      "text_length": 128
    },
    {
      "event_id": "01003014_e00005",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "周翠屏"
      ],
      "text": "满怀心腹事，尽在不言中。",
      "text_length": 12
    },
    {
      "event_id": "01003014_e00006",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "陈魁"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00007",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈魁上。",
      "text_length": 4
    },
    {
      "event_id": "01003014_e00008",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "陈魁"
      ],
      "text": "可恼老淫妇，叫人气断肠。",
      "text_length": 12
    },
    {
      "event_id": "01003014_e00009",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐开门来。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00010",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "外面什么人叫门？",
      "text_length": 8
    },
    {
      "event_id": "01003014_e00011",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "为弟到了。",
      "text_length": 5
    },
    {
      "event_id": "01003014_e00012",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "兄弟到了，待姐姐与你开门。",
      "text_length": 13
    },
    {
      "event_id": "01003014_e00013",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周翠屏开门。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00014",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "兄弟请进。",
      "text_length": 5
    },
    {
      "event_id": "01003014_e00015",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐请。",
      "text_length": 4
    },
    {
      "event_id": "01003014_e00016",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "请坐。",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00017",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "有座。可恼吓，可恼吓！",
      "text_length": 11
    },
    {
      "event_id": "01003014_e00018",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "兄弟这般嗔怒，与哪个淘气？",
      "text_length": 13
    },
    {
      "event_id": "01003014_e00019",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "与你妈儿娘淘气。",
      "text_length": 8
    },
    {
      "event_id": "01003014_e00020",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "与她淘的何气？",
      "text_length": 7
    },
    {
      "event_id": "01003014_e00021",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "昨日妈儿娘寿诞之日，为弟前去拜寿。满满斟上一杯酒，跪在她的面前，叫她允承我一件大事。",
      "text_length": 42
    },
    {
      "event_id": "01003014_e00022",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "什么大事？",
      "text_length": 5
    },
    {
      "event_id": "01003014_e00023",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "不叫姐姐迎宾接客。",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00024",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "她可曾允承？",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00025",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "她竟然不允。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00026",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "她不允就罢。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00027",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "她罢我不罢。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00028",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "你不罢，心想怎样？",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00029",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "我心想告她。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00030",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "你告她下何句语？",
      "text_length": 8
    },
    {
      "event_id": "01003014_e00031",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "我告她买良为娼，私买人口。大老爷闻听此言，将她一顿板子打死，方消为弟心头之恨。",
      "text_length": 39
    },
    {
      "event_id": "01003014_e00032",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "兄弟这两句话，还是你心中就有，还是旁人教道于你？",
      "text_length": 24
    },
    {
      "event_id": "01003014_e00033",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐说哪里话来，为弟长成一十六岁，这两句话，不会讲它，怎样为人？",
      "text_length": 32
    },
    {
      "event_id": "01003014_e00034",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "姐姐告便。",
      "text_length": 5
    },
    {
      "event_id": "01003014_e00035",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "请便。",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00036",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周翠屏背供。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00037",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "观看陈魁，虽则年幼，说两句话，倒是个志气男子。我不免借他几百两银子，叫他大小做个买卖，日后若有发达，好将奴家救出娼门。就是这个主意。",
      "text_length": 66
    },
    {
      "event_id": "01003014_e00038",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周翠屏坐。",
      "text_length": 5
    },
    {
      "event_id": "01003014_e00039",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "兄弟你与她呈讼到官，岂不被旁人耻笑？",
      "text_length": 18
    },
    {
      "event_id": "01003014_e00040",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "依姐姐之见？",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00041",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "大小做个买卖才好。",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00042",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "请问姐姐：为弟要做什么买卖才好？",
      "text_length": 16
    },
    {
      "event_id": "01003014_e00043",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "兄弟愿意做脸朝里的买卖，还是脸朝外的买卖？",
      "text_length": 21
    },
    {
      "event_id": "01003014_e00044",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "脸朝里的怎讲，脸朝外的买卖怎说？",
      "text_length": 16
    },
    {
      "event_id": "01003014_e00045",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "脸朝里的买卖：身背货箱，东家门进，西家门出。",
      "text_length": 22
    },
    {
      "event_id": "01003014_e00046",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "脸朝外的买卖呢？",
      "text_length": 8
    },
    {
      "event_id": "01003014_e00047",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "脸朝外的买卖：在这郓城县下，开一座绒线铺面，这就是脸朝外的买卖。",
      "text_length": 32
    },
    {
      "event_id": "01003014_e00048",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "脸朝外的买卖好做，也得三头五百两银子，为弟哪有许多银子？",
      "text_length": 28
    },
    {
      "event_id": "01003014_e00049",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "你就该在大户人家去借。",
      "text_length": 11
    },
    {
      "event_id": "01003014_e00050",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐你又来了。为弟来在这郓城县，靠亲无亲，靠故无故，哪里去寻，哪里去借？",
      "text_length": 36
    },
    {
      "event_id": "01003014_e00051",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "也罢。你若肯满满斟上一杯酒，跪在我的面前，叫我三声“亲亲姐姐”，我就借与你五百两银子。",
      "text_length": 43
    },
    {
      "event_id": "01003014_e00052",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐真心？",
      "text_length": 5
    },
    {
      "event_id": "01003014_e00053",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "真心。",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00054",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "实意？",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00055",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "实意。",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00056",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "好吓！",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00057",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮紧板",
      "speakers": [
        "陈魁"
      ],
      "text": "满满斟上一杯酒，双膝跪在地留平。",
      "text_length": 16
    },
    {
      "event_id": "01003014_e00058",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "亲亲姐姐，请来用酒，请来用酒。",
      "text_length": 15
    },
    {
      "event_id": "01003014_e00059",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "兄弟，你这算何意？",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00060",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "弟贺的是五百两银子。",
      "text_length": 10
    },
    {
      "event_id": "01003014_e00061",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "咳，怎么你就贺的那五百两银子么？我说兄弟吓，兄弟，想姐姐那五百两银子，非从容易而来的吓！",
      "text_length": 44
    },
    {
      "event_id": "01003014_e00062",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "周翠屏"
      ],
      "text": "一句话儿错出唇，见兄弟跪在地埃尘。用手儿搀起结拜弟，",
      "text_length": 26
    },
    {
      "event_id": "01003014_e00063",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "周翠屏"
      ],
      "text": "姐姐言来听原因：五百银子是小事，哪知姐姐费尽心。前门接了有钱客，后门送出无钱人。命苦身落烟花巷，难得积攒这五百银。但愿得买卖多茂盛，姐姐才的放下心。",
      "text_length": 74
    },
    {
      "event_id": "01003014_e00064",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐不要两泪淋，为弟也非无义人。但愿买卖多茂盛，我情愿将姐姐救出娼门。",
      "text_length": 35
    },
    {
      "event_id": "01003014_e00065",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "01003014_e00066",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "周翠屏"
      ],
      "text": "救不救，全在你，此话在心莫出唇。",
      "text_length": 16
    },
    {
      "event_id": "01003014_e00067",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "陈魁"
      ],
      "text": "自古路遥知马壮，日久才见人的心。",
      "text_length": 16
    },
    {
      "event_id": "01003014_e00068",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "周翠屏"
      ],
      "text": "好一个路遥知马壮，日久才见人的心。来来来随姐姐开箱柜，",
      "text_length": 27
    },
    {
      "event_id": "01003014_e00069",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周翠屏开箱。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00070",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "周翠屏"
      ],
      "text": "亲手儿递你五百银。",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00071",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "陈魁"
      ],
      "text": "一见银两放桌案，再叫姐姐你听原因。",
      "text_length": 17
    },
    {
      "event_id": "01003014_e00072",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐，想为弟带了许多银两，若被你妈儿娘看见，她说为弟盗你的家财不成？",
      "text_length": 34
    },
    {
      "event_id": "01003014_e00073",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "也罢，待姐姐去到楼上，缝上一条搭膊，将银两带出院去，瞒过妈儿娘，岂不是好？",
      "text_length": 37
    },
    {
      "event_id": "01003014_e00074",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "但凭姐姐。",
      "text_length": 5
    },
    {
      "event_id": "01003014_e00075",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "随姐姐上楼。",
      "text_length": 6
    },
    {
      "event_id": "01003014_e00076",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周翠屏、陈魁同上楼。小梆子。周翠屏捻线。",
      "text_length": 20
    },
    {
      "event_id": "01003014_e00077",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈魁"
      ],
      "text": "上楼来我这里打开针织，观兄弟容貌儿可算第一。缝搭膊表一表姐姐的情意，他哪知陈三两一片心机。观兄弟春心动放下作计，",
      "text_length": 56
    },
    {
      "event_id": "01003014_e00078",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "行弦。",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00079",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "aria",
      "mode_label": "花梆子原板",
      "speakers": [
        "周翠屏"
      ],
      "text": "叫兄弟你醒来细听仔细。",
      "text_length": 11
    },
    {
      "event_id": "01003014_e00080",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "且住，兄弟苏醒，兄弟醒来。睡死你了！",
      "text_length": 18
    },
    {
      "event_id": "01003014_e00081",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐搭膊可曾缝完？",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00082",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周翠屏"
      ],
      "text": "还有几针，未曾缝完。你我伙缝了罢。",
      "text_length": 17
    },
    {
      "event_id": "01003014_e00083",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "行上弦。周翠屏咬线。",
      "text_length": 10
    },
    {
      "event_id": "01003014_e00084",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "周翠屏"
      ],
      "text": "我将搭膊缝完毕，再叫兄弟听仔细：来来来你把肩儿背，",
      "text_length": 25
    },
    {
      "event_id": "01003014_e00085",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "aria",
      "mode_label": "断板腔",
      "speakers": [
        "周翠屏"
      ],
      "text": "大谅来妈儿不晓得。",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00086",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "陈魁"
      ],
      "text": "姐姐打开皇历看一看，看看黄道好吉日。",
      "text_length": 18
    },
    {
      "event_id": "01003014_e00087",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "周翠屏"
      ],
      "text": "初四、十五、廿七，俱都是开市好吉日。",
      "text_length": 18
    },
    {
      "event_id": "01003014_e00088",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "陈魁"
      ],
      "text": "辞别姐姐下楼去，",
      "text_length": 8
    },
    {
      "event_id": "01003014_e00089",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "下锣。",
      "text_length": 3
    },
    {
      "event_id": "01003014_e00090",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "陈魁"
      ],
      "text": "回家去禀告爹娘知。",
      "text_length": 9
    },
    {
      "event_id": "01003014_e00091",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈魁下。",
      "text_length": 4
    },
    {
      "event_id": "01003014_e00092",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "周翠屏"
      ],
      "text": "一见兄弟下楼门，背转身来自想情。但愿买卖多茂盛，他将我陈三两救出火坑。",
      "text_length": 35
    },
    {
      "event_id": "01003014_e00093",
      "play_id": "01003014",
      "scene_id": "01003014_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周翠屏下。",
      "text_length": 5
    }
  ],
