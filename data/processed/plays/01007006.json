  "events": [
    {
      "event_id": "01007006_e00001",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗春提灯上。〖水底鱼〗。",
      "text_length": 12
    },
    {
      "event_id": "01007006_e00002",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "俺，罗春，继父罗成。只因河北反了刘黑塔，李天寿挂帅夺取铭关，二奸王谋了帅印，命我继父以为前战先行，将那四门紧闭，不放继父进城；如若放进，全家诛杀，看那日已西沉，不免手提红灯，且上城楼，探听继父下落便了。",
      "text_length": 101
    },
    {
      "event_id": "01007006_e00003",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "罗春"
      ],
      "text": "昔日英雄霸王强，楚汉相争动刀枪。霸王自刎乌江丧，韩信命丧女陈仓。自古多少英雄将，好似南柯梦一场。将身来至敌楼上，",
      "text_length": 56
    },
    {
      "event_id": "01007006_e00004",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗春上城。",
      "text_length": 5
    },
    {
      "event_id": "01007006_e00005",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "罗春"
      ],
      "text": "不知继父在哪厢？",
      "text_length": 8
    },
    {
      "event_id": "01007006_e00006",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内锁呐二黄导板",
      "speakers": [
        "罗成"
      ],
      "text": "黑夜里闷坏了罗士信，",
      "text_length": 10
    },
    {
      "event_id": "01007006_e00007",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成上。",
      "text_length": 4
    },
    {
      "event_id": "01007006_e00008",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "回龙腔慢板",
      "speakers": [
        "罗成"
      ],
      "text": "胡风儿吹得我透甲如冰。",
      "text_length": 11
    },
    {
      "event_id": "01007006_e00009",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "耳边厢又听得金声震，",
      "text_length": 10
    },
    {
      "event_id": "01007006_e00010",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "想必是——",
      "text_length": 5
    },
    {
      "event_id": "01007006_e00011",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "想必是那苏烈鸣锣收军。那反贼他倒有爱将之意，三千岁全无有痛臣之心。那江边渔翁收了钓，砍柴樵子下山林。庵观寺院钟鼓响，那放牛牧童转芳村，",
      "text_length": 67
    },
    {
      "event_id": "01007006_e00012",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "罗成"
      ],
      "text": "加鞭催动白龙马，只见城楼掌红灯。掌灯之人是哪个？",
      "text_length": 24
    },
    {
      "event_id": "01007006_e00013",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "罗春"
      ],
      "text": "儿是继子小罗春。",
      "text_length": 8
    },
    {
      "event_id": "01007006_e00014",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "罗成"
      ],
      "text": "听说来了罗春子，不孝奴才骂几声：明知奸王将父害，还不开关救严亲！",
      "text_length": 32
    },
    {
      "event_id": "01007006_e00015",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "罗春"
      ],
      "text": "爹爹有所不知情，只因奸王使计行：如若放进继父身，全家诛杀罪非轻。",
      "text_length": 32
    },
    {
      "event_id": "01007006_e00016",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "哦吓！",
      "text_length": 3
    },
    {
      "event_id": "01007006_e00017",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "罗成"
      ],
      "text": "这是我错把姣儿怨，埋怨罗春也枉然。",
      "text_length": 17
    },
    {
      "event_id": "01007006_e00018",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01007006_e00019",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "爹爹。",
      "text_length": 3
    },
    {
      "event_id": "01007006_e00020",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "城楼上还有何人？",
      "text_length": 8
    },
    {
      "event_id": "01007006_e00021",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "只有孩儿一人。",
      "text_length": 7
    },
    {
      "event_id": "01007006_e00022",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "好。儿将红灯坠下城来，待为父修下血书，儿去搬兵救父。",
      "text_length": 26
    },
    {
      "event_id": "01007006_e00023",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "孩儿遵命。",
      "text_length": 5
    },
    {
      "event_id": "01007006_e00024",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗春放灯。",
      "text_length": 5
    },
    {
      "event_id": "01007006_e00025",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "罗成"
      ],
      "text": "下了雕鞍城边站，",
      "text_length": 8
    },
    {
      "event_id": "01007006_e00026",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "虎头枪插立在马前。临阵上哪里有笔和砚？拔宝剑割战袍修书一封。钢牙一咬中指破，",
      "text_length": 38
    },
    {
      "event_id": "01007006_e00027",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "呼呼呼！",
      "text_length": 4
    },
    {
      "event_id": "01007006_e00028",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "罗成"
      ],
      "text": "十指连心痛煞人！上写着为臣顿首拜，启奏秦王有道明君：都只为秦琼封王位，程咬金解粮未回程；尉迟敬德身染病，我朝缺少挂帅人。三王元吉挂帅印，俺罗成做了马前先行。头一阵枪挑李天寿，有功不赏反加刑。责打为臣四十棍，身带棒伤还要出兵。从早晨杀到了午时候，午时杀到夜黄昏。连杀四门不得进，城楼遇见小罗春。望求千岁速救应，千岁爷吓！快到长安搬救兵。",
      "text_length": 167
    },
    {
      "event_id": "01007006_e00029",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "罗春"
      ],
      "text": "罗春接书泪涟涟，哀告爹爹听儿言：倒不如铭关造了反，点动人马反朝廷。",
      "text_length": 33
    },
    {
      "event_id": "01007006_e00030",
      "play_id": "01007006",
      "scene_id": "01007006_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "罗成"
      ],
      "text": "罗家本是忠臣将，岂能做那反叛人！儿今若提造反字，金枪之下命不存！",
