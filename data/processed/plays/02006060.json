  "events": [
    {
      "event_id": "02006060_e00001",
      "play_id": "02006060",
      "scene_id": "02006060_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "卜荷上。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00002",
      "play_id": "02006060",
      "scene_id": "02006060_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "卜荷"
      ],
      "text": "身居将帅逞英豪，方显男儿志量高。",
      "text_length": 16
    },
    {
      "event_id": "02006060_e00003",
      "play_id": "02006060",
      "scene_id": "02006060_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "卜荷"
      ],
      "text": "头戴狐尾巾，上插雉尾翎。虽居凉州地，还有中原心。",
      "text_length": 24
    },
    {
      "event_id": "02006060_e00004",
      "play_id": "02006060",
      "scene_id": "02006060_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卜荷"
      ],
      "text": "俺乃代战国都督大元帅卜荷是也。今日打听中原消息，唐家内无贤臣，外少兵将。又兼连年荒旱，盗贼并起。有志夺取中原，不免趁此时候，兴兵前去，待我奏明主上便了。",
      "text_length": 76
    },
    {
      "event_id": "02006060_e00005",
      "play_id": "02006060",
      "scene_id": "02006060_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "卜荷"
      ],
      "text": "唐王驾坐在长安，他国正来我为偏。年年中原把贡献，屈居人下不耐烦。因此聚下兵百万，又选良将有千员。盔甲刀枪俱精选，粮草足用几十年。他国连年遭荒旱，烟尘四起绕中原。边廷没有一良将，朝内文武臣不贤。我国兴起人和马，选兵调将抢北关。长驱直抢中原地，扶保我主坐长安。今日上朝把主见，夺取中原奏一番。",
      "text_length": 144
    },
    {
      "event_id": "02006060_e00006",
      "play_id": "02006060",
      "scene_id": "02006060_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "卜荷下。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00007",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "代战王、内侍同上。",
      "text_length": 9
    },
    {
      "event_id": "02006060_e00008",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "代战王"
      ],
      "text": "香绕拱门，一心坐九重。",
      "text_length": 11
    },
    {
      "event_id": "02006060_e00009",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "代战王"
      ],
      "text": "民强国富有，凤阁与龙楼。要知山川状，端的古凉州。",
      "text_length": 24
    },
    {
      "event_id": "02006060_e00010",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战王"
      ],
      "text": "朕乃代战王。虽是偏邦，却喜民安国泰，五谷丰登；文能安国，武能安邦。今乃大朝之日。内臣！",
      "text_length": 43
    },
    {
      "event_id": "02006060_e00011",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02006060_e00012",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战王"
      ],
      "text": "闪放龙门！",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00013",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍"
      ],
      "text": "领旨。闪放龙门！",
      "text_length": 8
    },
    {
      "event_id": "02006060_e00014",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "卜荷上。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00015",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "卜荷"
      ],
      "text": "一步入金阙，奏与圣明君。",
      "text_length": 12
    },
    {
      "event_id": "02006060_e00016",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卜荷"
      ],
      "text": "臣大元帅卜荷有本奏上。",
      "text_length": 11
    },
    {
      "event_id": "02006060_e00017",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战王"
      ],
      "text": "有何本奏？",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00018",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卜荷"
      ],
      "text": "臣打听中原消息，连年荒旱，主弱臣庸，内无贤臣，外无良将。趁此兴兵前去，一破可取中原，望我主圣参。",
      "text_length": 48
    },
    {
      "event_id": "02006060_e00019",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战王"
      ],
      "text": "卿家所奏，足见元帅为国之心。但唐家王气未衰，待孤修下一道表章献上。看他君臣如何理论，那时兴兵未迟。卿家且自退班，待朕修表。",
      "text_length": 61
    },
    {
      "event_id": "02006060_e00020",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卜荷"
      ],
      "text": "谢千岁。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00021",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "卜荷下。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00022",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "代战王"
      ],
      "text": "代战王在金殿前思后忖，龙书案提羊毫写下表文。上写着代战王百拜顿首，拜上了中原主大唐明君。连年的进表文命臣上贡，感皇上加恩赐绸缎书文。谢不尽我皇王天高地厚，恼得是边廷上大小三军。每日里出边疆伤害百姓，抢牛羊毁房舍踏坏苗根。到今日特命臣进来战表，两下里发兵将定下输赢。哪一国胜下了愿尊为上，分君臣裂疆土永息太平。写完了一通表打下玺印，叫一声大元帅来见寡人。",
      "text_length": 176
    },
    {
      "event_id": "02006060_e00023",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "卜荷上。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00024",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卜荷"
      ],
      "text": "臣候旨！",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00025",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战王"
      ],
      "text": "这道表章，打到中原，叫唐朝即兴人马前来对阵。卿家准备人马，命差官把表章打进唐朝，下殿。",
      "text_length": 43
    },
    {
      "event_id": "02006060_e00026",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "卜荷"
      ],
      "text": "请驾回宫。",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00027",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "代战王下。",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00028",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "卜荷"
      ],
      "text": "挂印元帅就命俺，兴兵要夺锦江山。整顿操练人和马，等候回表破长安。",
      "text_length": 32
    },
    {
      "event_id": "02006060_e00029",
      "play_id": "02006060",
      "scene_id": "02006060_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "卜荷下。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00030",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "使臣上。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00031",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "使臣"
      ],
      "text": "奉旨打战表，急急到天朝。",
      "text_length": 12
    },
    {
      "event_id": "02006060_e00032",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "使臣"
      ],
      "text": "俺西凉国使臣是也，奉旨进表中原，马上加鞭。",
      "text_length": 21
    },
    {
      "event_id": "02006060_e00033",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "使臣下。李子忠上。",
      "text_length": 9
    },
    {
      "event_id": "02006060_e00034",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李子忠"
      ],
      "text": "执掌黄门侍奉君，金阶玉路色色新。为人若是全忠孝，臣奉君来子奉亲。",
      "text_length": 32
    },
    {
      "event_id": "02006060_e00035",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "下官黄门官李子忠是也。今乃进表之日，只得在此伺候。",
      "text_length": 25
    },
    {
      "event_id": "02006060_e00036",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "使臣上。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00037",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "使臣"
      ],
      "text": "山高路又远，特来进表文。",
      "text_length": 12
    },
    {
      "event_id": "02006060_e00038",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "使臣"
      ],
      "text": "来此已是午门，哪位老爷在此？",
      "text_length": 14
    },
    {
      "event_id": "02006060_e00039",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "哪国来的？",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00040",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "使臣"
      ],
      "text": "代战国进来战表。",
      "text_length": 8
    },
    {
      "event_id": "02006060_e00041",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "待我传奏，午门候旨。",
      "text_length": 10
    },
    {
      "event_id": "02006060_e00042",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "使臣"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "02006060_e00043",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "使臣下。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00044",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "香烟霭霭，圣驾临朝。",
      "text_length": 10
    },
    {
      "event_id": "02006060_e00045",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众太监同上。",
      "text_length": 6
    },
    {
      "event_id": "02006060_e00046",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众太监"
      ],
      "text": "咦咦。",
      "text_length": 3
    },
    {
      "event_id": "02006060_e00047",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐王上。",
      "text_length": 4
    },
    {
      "event_id": "02006060_e00048",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "唐王"
      ],
      "text": "河清海晏，一统江山。",
      "text_length": 10
    },
    {
      "event_id": "02006060_e00049",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "唐王"
      ],
      "text": "金鸡架上九龙头，太阳一出照九州。三天门外朝北斗，金钟一响拜冕旒。",
      "text_length": 32
    },
    {
      "event_id": "02006060_e00050",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐王"
      ],
      "text": "寡人，大唐天子在位，今当早朝。内侍！",
      "text_length": 18
    },
    {
      "event_id": "02006060_e00051",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监甲"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02006060_e00052",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐王"
      ],
      "text": "闪放龙门。",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00053",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监甲"
      ],
      "text": "领旨。闪放龙门。",
      "text_length": 8
    },
    {
      "event_id": "02006060_e00054",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "臣黄门官李子忠启奏：今有代战国进来表章，请主龙目观看。",
      "text_length": 27
    },
    {
      "event_id": "02006060_e00055",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐王"
      ],
      "text": "传上金殿。",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00056",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02006060_e00057",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "唐王"
      ],
      "text": "金殿上打开了代战表，字字行行看分明。上写着小臣三顿首，启奏大朝唐主君：只因两国分上下，年年进贡反称臣。今日打来一战表，两国争斗定输赢。倘若你国得了胜，年年进贡愿称臣。若是我国得了胜，要把中原一扫平。看罢表章心害怕，不由孤王吃一惊。开言便把李卿叫，",
      "text_length": 123
    },
    {
      "event_id": "02006060_e00058",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "臣。",
      "text_length": 2
    },
    {
      "event_id": "02006060_e00059",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "唐王"
      ],
      "text": "寡人言来听分明：代战王他今起反意，要夺寡人长安城。你今领下王旨意，打发使臣转回程。回去报与他国主，孤家不日便出征。再到兵部传王旨，整顿人马到边廷。四门挂起招军榜，只要精壮便为军。平贼有功回朝转，全家个个自有封。爱卿快传王旨意，为王进宫候音信。",
      "text_length": 121
    },
    {
      "event_id": "02006060_e00060",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李子忠"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02006060_e00061",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监甲"
      ],
      "text": "请驾回宫。",
      "text_length": 5
    },
    {
      "event_id": "02006060_e00062",
      "play_id": "02006060",
      "scene_id": "02006060_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}