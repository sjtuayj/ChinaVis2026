  "events": [
    {
      "event_id": "03096003_e00001",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四月华旗、四马童、关平、周仓、关羽同上。",
      "text_length": 20
    },
    {
      "event_id": "03096003_e00002",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "关羽"
      ],
      "text": "正气冲霄汉，文光射斗牛。",
      "text_length": 12
    },
    {
      "event_id": "03096003_e00003",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "关羽"
      ],
      "text": "头戴金冠凤翅飘，凤眼蚕眉逞英豪。忠义扶定汉室主，上阵全凭偃月刀。",
      "text_length": 32
    },
    {
      "event_id": "03096003_e00004",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "某、汉室关。与军师赌头争印，捉拿奸曹。周将！",
      "text_length": 22
    },
    {
      "event_id": "03096003_e00005",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周仓"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "03096003_e00006",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "带马！",
      "text_length": 3
    },
    {
      "event_id": "03096003_e00007",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周仓"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03096003_e00008",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "纛旗手暗上。",
      "text_length": 6
    },
    {
      "event_id": "03096003_e00009",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "关羽"
      ],
      "text": "背地里笑诸葛用兵不到，",
      "text_length": 11
    },
    {
      "event_id": "03096003_e00010",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "关羽上马。",
      "text_length": 5
    },
    {
      "event_id": "03096003_e00011",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "关羽"
      ],
      "text": "在大营他那里藐视吾曹。自幼儿读春秋韬略颇晓，因不平斩熊虎怒诛势豪。为避祸离乡井故土别了，走樊阳才结拜生死故交。初起手破黄巾——",
      "text_length": 63
    },
    {
      "event_id": "03096003_e00012",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "关羽"
      ],
      "text": "立功不小，酒未寒斩华雄初试宝刀。过五关斩六将力保皇嫂，古城边斩蔡阳匹马单刀。将人马埋伏在——",
      "text_length": 46
    },
    {
      "event_id": "03096003_e00013",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "关羽"
      ],
      "text": "华容小道，今日里一定要捉拿奸曹。",
      "text_length": 16
    },
    {
      "event_id": "03096003_e00014",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四马童",
        "关平",
        "周仓"
      ],
      "text": "来此华容小道。",
      "text_length": 7
    },
    {
      "event_id": "03096003_e00015",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "大路安下烟墩，小路设下埋伏。曹操到此，禀爷知道。",
      "text_length": 24
    },
    {
      "event_id": "03096003_e00016",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四马童",
        "关平",
        "周仓"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03096003_e00017",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "场设高台，四月华旗、四马童、关平、周仓同站一字。关羽暗下。",
      "text_length": 29
    },
    {
      "event_id": "03096003_e00018",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "曹操"
      ],
      "text": "曹孟德在马上长吁短叹，",
      "text_length": 11
    },
    {
      "event_id": "03096003_e00019",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、张辽、许褚、曹洪、曹操同上。",
      "text_length": 18
    },
    {
      "event_id": "03096003_e00020",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "唉！",
      "text_length": 2
    },
    {
      "event_id": "03096003_e00021",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "曹操"
      ],
      "text": "手捶胸眼流泪口怨苍天。在中原领人马八十三万，实指望扫东吴踏平江南。又谁知小周郎谋略广远，https://scripts.xikao.com/play/030960032022-10-07还有那诸葛亮诡计多端。黄公覆他把那苦肉计献，蒋子翼引庞统来献连环。我只说数九天东风少见，又谁知诸葛亮力能回天。烧得我众兵将头焦肉烂，只剩下十八骑好不惨然。正行间勒战马——",
      "text_length": 178
    },
    {
      "event_id": "03096003_e00022",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "曹操"
      ],
      "text": "用目观看，",
      "text_length": 5
    },
    {
      "event_id": "03096003_e00023",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "曹操"
      ],
      "text": "啊哈哈哈……",
      "text_length": 6
    },
    {
      "event_id": "03096003_e00024",
      "play_id": "03096003",
      "scene_id": "03096003_s01",
      "scene_no": 1,
      "seq_global": 24,
