  "events": [
    {
      "event_id": "01010004_e00001",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐夫人上。",
      "text_length": 5
    },
    {
      "event_id": "01010004_e00002",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐夫人"
      ],
      "text": "夫受皇家禄，妻沾雨露恩。",
      "text_length": 12
    },
    {
      "event_id": "01010004_e00003",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "徐策"
      ],
      "text": "开道。",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00004",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、家院引徐策上。",
      "text_length": 11
    },
    {
      "event_id": "01010004_e00005",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "可恼吓，可恼！",
      "text_length": 7
    },
    {
      "event_id": "01010004_e00006",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐夫人"
      ],
      "text": "吓，相爷，今日回得府来。为何这等烦恼？",
      "text_length": 19
    },
    {
      "event_id": "01010004_e00007",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "夫人哪里知道，老夫今日早朝，见张泰奸贼，将薛猛夫妇调进京来，害他夫妻一死，倒也罢了。可叹三岁薛蛟，也受一刀之苦。你道恼也不恼？",
      "text_length": 63
    },
    {
      "event_id": "01010004_e00008",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐夫人"
      ],
      "text": "相爷就该想一良策，搭救忠良才是。",
      "text_length": 16
    },
    {
      "event_id": "01010004_e00009",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "我看金斗面带七煞，难以扶养。意欲带到法场，调换忠良后代，岂不是好？",
      "text_length": 33
    },
    {
      "event_id": "01010004_e00010",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐夫人"
      ],
      "text": "相爷说哪里话来。想你我所生一子，岂肯调换他人一死？那是万万不能的！",
      "text_length": 33
    },
    {
      "event_id": "01010004_e00011",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "夫人吓！",
      "text_length": 4
    },
    {
      "event_id": "01010004_e00012",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄快三眼",
      "speakers": [
        "徐策"
      ],
      "text": "恨薛刚蛮奴才如同禽兽，吃醉酒全不顾脸带含羞。闯下了塌天祸自己逃走，连累了二爹娘不如马牛。真可叹两辽王午门斩首，樊夫人拔宝剑自己刎头。眼见得斩忠良乏嗣无后，到如今斩草除根，寸草不留，天地寒心，你叫我看水流舟？",
      "text_length": 103
    },
    {
      "event_id": "01010004_e00013",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐夫人"
      ],
      "text": "老相爷说此话情理不周，听为妻把此话细说从头：张、薛家在朝中屡屡争斗，老相爷你何必与他出头。怕的是画虎不成反类其狗，那时节船到江心逆水行舟。",
      "text_length": 69
    },
    {
      "event_id": "01010004_e00014",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐策"
      ],
      "text": "贤夫人平日里待人恩厚，到今日为薛家全然不周。无奈何我只得二堂叩首，",
      "text_length": 33
    },
    {
      "event_id": "01010004_e00015",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐夫人"
      ],
      "text": "老相爷跪尘埃情理不周。",
      "text_length": 11
    },
    {
      "event_id": "01010004_e00016",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐夫人"
      ],
      "text": "相爷请起，妾身舍子就是。",
      "text_length": 12
    },
    {
      "event_id": "01010004_e00017",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "夫人舍了罢！家院，",
      "text_length": 9
    },
    {
      "event_id": "01010004_e00018",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "01010004_e00019",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "听我吩咐：将你少爷，装在食盒里面，去到法场，看老夫的眼色行事。",
      "text_length": 31
    },
    {
      "event_id": "01010004_e00020",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00021",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00022",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐策"
      ],
      "text": "可叹薛家世代贤，",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00023",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐夫人"
      ],
      "text": "只因薛刚受牵连。",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00024",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐策"
      ],
      "text": "苍天若助三分眼，",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00025",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐夫人"
      ],
      "text": "仇报仇来冤报冤！",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00026",
      "play_id": "01010004",
      "scene_id": "01010004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐策、徐夫人同下。",
      "text_length": 9
    },
    {
      "event_id": "01010004_e00027",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、二刽子手、张泰上。〖牌子〗。",
      "text_length": 18
    },
    {
      "event_id": "01010004_e00028",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张泰"
      ],
      "text": "树大遮天盖地，根深那怕狂风。任他皇亲国戚，一本斩草除根。",
      "text_length": 28
    },
    {
      "event_id": "01010004_e00029",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张泰"
      ],
      "text": "老夫张泰，今奉圣命，监斩薛猛夫妇。刀斧手，将他夫妻绑上来！",
      "text_length": 29
    },
    {
      "event_id": "01010004_e00030",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二刽子手同允，绑薛猛、马氏同上。",
      "text_length": 16
    },
    {
      "event_id": "01010004_e00031",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马氏"
      ],
      "text": "唉吓，老爷，叫你反来你不反，叫你走来你不走！你我夫妻一死，不值要紧，可怜三岁孩儿，也受一刀之苦。吓、吓、吓！",
      "text_length": 54
    },
    {
      "event_id": "01010004_e00032",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "马氏"
      ],
      "text": "叫你反来你不反，叫你走来你不行。你我一死不打紧，三岁孩童也受刑。",
      "text_length": 32
    },
    {
      "event_id": "01010004_e00033",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "薛猛"
      ],
      "text": "夫人休把我来怪，忠良哪怕刀下开？薛家与你何仇害，苦苦害我为何来？恨不得一足将儿踹，阴曹地府等儿来。",
      "text_length": 49
    },
    {
      "event_id": "01010004_e00034",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张泰"
      ],
      "text": "绑上法标！",
      "text_length": 5
    },
    {
      "event_id": "01010004_e00035",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院上。",
      "text_length": 4
    },
    {
      "event_id": "01010004_e00036",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "家院"
      ],
      "text": "奉了相爷命，法场走一行。",
      "text_length": 12
    },
    {
      "event_id": "01010004_e00037",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "门上哪位在？",
      "text_length": 6
    },
    {
      "event_id": "01010004_e00038",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刽子手甲"
      ],
      "text": "何事？",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00039",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "徐相爷前来活祭。",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00040",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刽子手甲"
      ],
      "text": "候着。启相爷：今有徐相爷前来活祭。",
      "text_length": 17
    },
    {
      "event_id": "01010004_e00041",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张泰"
      ],
      "text": "这老儿又来多事！",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00042",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刽子手甲"
      ],
      "text": "夫人也来了。",
      "text_length": 6
    },
    {
      "event_id": "01010004_e00043",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张泰"
      ],
      "text": "容他一祭。时辰一到，速报我知！",
      "text_length": 15
    },
    {
      "event_id": "01010004_e00044",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张泰下。",
      "text_length": 4
    },
    {
      "event_id": "01010004_e00045",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刽子手甲"
      ],
      "text": "容他一祭。",
      "text_length": 5
    },
    {
      "event_id": "01010004_e00046",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二刽子手同下。",
      "text_length": 7
    },
    {
      "event_id": "01010004_e00047",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "有请相爷、夫人。",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00048",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐策、徐夫人抬盒同上。",
      "text_length": 11
    },
    {
      "event_id": "01010004_e00049",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐策"
      ],
      "text": "我夫妻双双到法场，",
      "text_length": 9
    },
    {
      "event_id": "01010004_e00050",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐夫人"
      ],
      "text": "不知忠良在哪旁？",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00051",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "薛猛儿吓！",
      "text_length": 5
    },
    {
      "event_id": "01010004_e00052",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐策"
      ],
      "text": "儿夫妻好比一张弓，",
      "text_length": 9
    },
    {
      "event_id": "01010004_e00053",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐夫人"
      ],
      "text": "万马营中逞威风。",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00054",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐策"
      ],
      "text": "儿正好开弓弦来断，",
      "text_length": 9
    },
    {
      "event_id": "01010004_e00055",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐夫人"
      ],
      "text": "一到法场一场空！",
      "text_length": 8
    },
    {
      "event_id": "01010004_e00056",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "薛猛！",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00057",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐夫人"
      ],
      "text": "马氏！",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00058",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "吓，夫人，法场之上，人烟甚众，回府去罢。",
      "text_length": 20
    },
    {
      "event_id": "01010004_e00059",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐夫人"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00060",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "徐夫人"
      ],
      "text": "薛猛，马氏，我的金……",
      "text_length": 11
    },
    {
      "event_id": "01010004_e00061",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐策"
      ],
      "text": "噤声！",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00062",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐夫人"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01010004_e00063",
      "play_id": "01010004",
      "scene_id": "01010004_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐夫人下。",
      "text_length": 5
    },
    {
      "event_id": "01010004_e00064",
      "play_id": "01010004",
