      "mode_label": "同一缕麻",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "笑耻。",
      "text_length": 3
    },
    {
      "event_id": "70904115_e00027",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同乔牌儿",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "一个个手执着白木尺，",
      "text_length": 10
    },
    {
      "event_id": "70904115_e00028",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "胡老头"
      ],
      "text": "那是牙笏。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00029",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同乔牌儿",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "身穿着紫褡臂，",
      "text_length": 7
    },
    {
      "event_id": "70904115_e00030",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "胡老头"
      ],
      "text": "那是蟒袍。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00031",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同乔牌儿",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "白石头，黄铜片紧紧在腰中系，",
      "text_length": 14
    },
    {
      "event_id": "70904115_e00032",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "胡老头"
      ],
      "text": "那是玉带。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00033",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同乔牌儿",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "一双脚只踹在黑窝里。",
      "text_length": 10
    },
    {
      "event_id": "70904115_e00034",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "胡老头"
      ],
      "text": "那是朝靴。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00035",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同新水令",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "官人们腰屈共头低，吃得个醉醺醺脑门着地。咿咿呜呜吹竹管，扑咚咚打着牛皮，我见几个回回，他笑一回，",
      "text_length": 48
    },
    {
      "event_id": "70904115_e00036",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同夹白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "咦，哈哈。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00037",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同新水令",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "嗳，他闹一回。",
      "text_length": 7
    },
    {
      "event_id": "70904115_e00038",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "啊哈哈哈，啊，他笑一回。",
      "text_length": 12
    },
    {
      "event_id": "70904115_e00039",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胖姑"
      ],
      "text": "笑一回。",
      "text_length": 4
    },
    {
      "event_id": "70904115_e00040",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "闹一回。",
      "text_length": 4
    },
    {
      "event_id": "70904115_e00041",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王留"
      ],
      "text": "闹一回。",
      "text_length": 4
    },
    {
      "event_id": "70904115_e00042",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "还有什么热闹，学与爷爷听啊。",
      "text_length": 14
    },
    {
      "event_id": "70904115_e00043",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "爷爷，还有哪。",
      "text_length": 7
    },
    {
      "event_id": "70904115_e00044",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同雁儿落",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "见几个粉搽的白面皮横拴着油鬏髻，他笑一声便打一棒锤，跳一跳高似田地。",
      "text_length": 34
    },
    {
      "event_id": "70904115_e00045",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同夹白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "爷爷！",
      "text_length": 3
    },
    {
      "event_id": "70904115_e00046",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同川拨棹",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "好叫我便笑，",
      "text_length": 6
    },
    {
      "event_id": "70904115_e00047",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同夹白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "咦，哈哈哈。",
      "text_length": 6
    },
    {
      "event_id": "70904115_e00048",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同川拨棹",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "哎呀微微。一个汉似木雕成两条腿，我见几个武职，他舞着一面旌旗，忽喇喇口儿里不知说些甚的，装着一个鬼。人多我也看不得仔细。",
      "text_length": 60
    },
    {
      "event_id": "70904115_e00049",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同七兄弟",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "我走到这壁那壁，无奈何自身躯，滚将一个碌碡，在我的跟底，脚踏着才看得真是，百般样儿千般戏。",
      "text_length": 45
    },
    {
      "event_id": "70904115_e00050",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "哈哈，百般样儿千般戏，还有什么热闹，学来爷爷听听啊。",
      "text_length": 26
    },
    {
      "event_id": "70904115_e00051",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "爷爷，只见一个人儿，手提着墨线儿，他叫这个这个……这个这个……",
      "text_length": 31
    },
    {
      "event_id": "70904115_e00052",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "你们倒是说呀。",
      "text_length": 7
    },
    {
      "event_id": "70904115_e00053",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "爷爷，我们忘啦。",
      "text_length": 8
    },
    {
      "event_id": "70904115_e00054",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "一个人儿，手提着墨线儿，噢，想这个么，你们说的不是耍傀儡的罢？",
      "text_length": 31
    },
    {
      "event_id": "70904115_e00055",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "对啦，是耍傀儡的。",
      "text_length": 9
    },
    {
      "event_id": "70904115_e00056",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "好，学与爷爷听啊。",
      "text_length": 9
    },
    {
      "event_id": "70904115_e00057",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王留"
      ],
      "text": "胖姑学呀。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00058",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胖姑"
      ],
      "text": "王留来呀。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00059",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "来来来呀。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00060",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同梅花酒",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "哎它，它唤做甚傀儡，它唤做甚魁垒。墨线儿穿的红白粉儿装的什么样的东西嗖嗖的呼啸起咚咚的鼓声催，见几个舞着大旗，",
      "text_length": 55
    },
    {
      "event_id": "70904115_e00061",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同夹白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "爷爷！",
      "text_length": 3
    },
    {
      "event_id": "70904115_e00062",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同梅花酒",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "他坐着吃堂食，俺立着看筵席。两条腿半僵直，肚皮中似春雷，要吃也不得吃。",
      "text_length": 35
    },
    {
      "event_id": "70904115_e00063",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同收江南",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "呀。好教我坐而立而耐着饥，去时乘兴转时迟，说了半日，肚皮耐着饥，霎时间日西，霎时间日西，可正是席前花影座闲移。",
      "text_length": 55
    },
    {
      "event_id": "70904115_e00064",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "喂呀，把我累坏了。",
      "text_length": 9
    },
    {
      "event_id": "70904115_e00065",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "爷爷，我们饿了。",
      "text_length": 8
    },
    {
      "event_id": "70904115_e00066",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "胡老头"
      ],
      "text": "你们饿了，后面去吃饸饹去罢。",
      "text_length": 14
    },
    {
      "event_id": "70904115_e00067",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "胖姑",
        "王留"
      ],
      "text": "多谢爷爷。",
      "text_length": 5
    },
    {
      "event_id": "70904115_e00068",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "煞尾",
      "speakers": [
        "胖姑"
      ],
      "text": "雨余云罢芝麻地，",
      "text_length": 8
    },
    {
      "event_id": "70904115_e00069",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "王留"
      ],
      "text": "爷爷！",
      "text_length": 3
    },
    {
      "event_id": "70904115_e00070",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "煞尾",
      "speakers": [
        "王留"
      ],
      "text": "我到那沤麻坑里洗个澡去。",
      "text_length": 12
    },
    {
      "event_id": "70904115_e00071",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "胡老头"
      ],
      "text": "不许去！",
      "text_length": 4
    },
    {
      "event_id": "70904115_e00072",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "煞尾",
      "speakers": [
        "胖姑"
      ],
      "text": "唐三藏今日取经去，",
      "text_length": 9
    },
    {
      "event_id": "70904115_e00073",
      "play_id": "70904115",
      "scene_id": "70904115_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "胖姑"
      ],
      "text": "爷爷！",
      "text_length": 3
