      "event_id": "01013003_e00009",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01013003_e00010",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "车仗可曾齐备？",
      "text_length": 7
    },
    {
      "event_id": "01013003_e00011",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "齐备多时。",
      "text_length": 5
    },
    {
      "event_id": "01013003_e00012",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "有请二位皇嫂。",
      "text_length": 7
    },
    {
      "event_id": "01013003_e00013",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "甘夫人、糜夫人同上。",
      "text_length": 10
    },
    {
      "event_id": "01013003_e00014",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "甘夫人",
        "糜夫人"
      ],
      "text": "思想皇叔泪嚎啕，终日如同坐监牢。",
      "text_length": 16
    },
    {
      "event_id": "01013003_e00015",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甘夫人",
        "糜夫人"
      ],
      "text": "二叔唤我何事？",
      "text_length": 7
    },
    {
      "event_id": "01013003_e00016",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "小弟两次去见曹操，无奈他高挂免见牌，不容我相见，是弟封金挂印，修书一封，送往曹营，意欲不辞而别。特请二位皇嫂登车。",
      "text_length": 57
    },
    {
      "event_id": "01013003_e00017",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甘夫人",
        "糜夫人"
      ],
      "text": "倘若途中有人拦阻，如何是好？",
      "text_length": 14
    },
    {
      "event_id": "01013003_e00018",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "二位皇嫂，但放宽心，只是小弟这青龙刀，管叫他难逃公道。",
      "text_length": 27
    },
    {
      "event_id": "01013003_e00019",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甘夫人",
        "糜夫人"
      ],
      "text": "全凭二叔。",
      "text_length": 5
    },
    {
      "event_id": "01013003_e00020",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "众小校，趱行者。",
      "text_length": 8
    },
    {
      "event_id": "01013003_e00021",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    },
    {
      "event_id": "01013003_e00022",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二门官同上。",
      "text_length": 6
    },
    {
      "event_id": "01013003_e00023",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "二门官"
      ],
      "text": "奉了丞相令，把守许昌门。",
      "text_length": 12
    },
    {
      "event_id": "01013003_e00024",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖风入松〗。关羽、二皇嫂、四马童同上。",
      "text_length": 19
    },
    {
      "event_id": "01013003_e00025",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "开关！",
      "text_length": 3
    },
    {
      "event_id": "01013003_e00026",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门官"
      ],
      "text": "何人叫关？",
      "text_length": 5
    },
    {
      "event_id": "01013003_e00027",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "关将军保定二位皇嫂过关。",
      "text_length": 12
    },
    {
      "event_id": "01013003_e00028",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门官"
      ],
      "text": "可有丞相将令？",
      "text_length": 7
    },
    {
      "event_id": "01013003_e00029",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "无有。",
      "text_length": 3
    },
    {
      "event_id": "01013003_e00030",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门官"
      ],
      "text": "可有丞相公文？",
      "text_length": 7
    },
    {
      "event_id": "01013003_e00031",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "也无有。",
      "text_length": 4
    },
    {
      "event_id": "01013003_e00032",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门官"
      ],
      "text": "一无丞相将令，二无公文，要想出关，是万万不能。",
      "text_length": 23
    },
    {
      "event_id": "01013003_e00033",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "关羽怒。",
      "text_length": 4
    },
    {
      "event_id": "01013003_e00034",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "尔等敢挡某家的去路么？",
      "text_length": 11
    },
    {
      "event_id": "01013003_e00035",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门官"
      ],
      "text": "小人不敢。",
      "text_length": 5
    },
    {
      "event_id": "01013003_e00036",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "谅尔也不敢。小校，催车！",
      "text_length": 12
    },
    {
      "event_id": "01013003_e00037",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    },
    {
      "event_id": "01013003_e00038",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "门官甲"
      ],
      "text": "伙计，你看他吹胡子瞪眼，实在可怕，我们快快报于丞相知道，便了。",
      "text_length": 31
    },
    {
      "event_id": "01013003_e00039",
      "play_id": "01013003",
      "scene_id": "01013003_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二门官同下。",
      "text_length": 6
    },
    {
      "event_id": "01013003_e00040",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四将、郭嘉、程昱同上。大吹场。曹操上。",
      "text_length": 23
    },
    {
      "event_id": "01013003_e00041",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "曹操"
      ],
      "text": "爕理阴阳，统雄兵，坐镇许昌。",
      "text_length": 14
    },
    {
      "event_id": "01013003_e00042",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小军上。",
      "text_length": 4
    },
    {
      "event_id": "01013003_e00043",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小军"
      ],
      "text": "今有关将军书信一封，丞相请看。",
      "text_length": 15
    },
    {
      "event_id": "01013003_e00044",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "呈上来。",
      "text_length": 4
    },
    {
      "event_id": "01013003_e00045",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。曹操看信。",
      "text_length": 10
    },
    {
      "event_id": "01013003_e00046",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "哦哈哈呀，关公封金挂印，竟是去心一定，真乃是义人也。",
      "text_length": 26
    },
    {
      "event_id": "01013003_e00047",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二门官同上。",
      "text_length": 6
    },
    {
      "event_id": "01013003_e00048",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门官"
      ],
      "text": "启丞相：今有关公，保定二位皇嫂，怒气不息，闯出城去。小人等拦挡不住，特来禀报丞相。",
      "text_length": 41
    },
    {
      "event_id": "01013003_e00049",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "与你等无干，再探。",
      "text_length": 9
    },
    {
      "event_id": "01013003_e00050",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二门官同下。",
      "text_length": 6
    },
    {
      "event_id": "01013003_e00051",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "咳，不料此人，竟自去了。",
      "text_length": 12
    },
    {
      "event_id": "01013003_e00052",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程昱"
      ],
      "text": "看关公志高气扬，情性狂妄，不辞丞相，竟敢修书前来，真乃胆大妄为。丞相何不将他赶回杀之？",
      "text_length": 43
    },
    {
      "event_id": "01013003_e00053",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "此人英雄出众，仗义轻财，不忘故主，吾甚敬之爱之。张辽听令，命你速速赶去，见了关公，叫他少待一时，老夫还要亲自送他一程，以表旧日之情，快去快去。",
      "text_length": 71
    },
    {
      "event_id": "01013003_e00054",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张辽"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "01013003_e00055",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张辽下。",
      "text_length": 4
    },
    {
      "event_id": "01013003_e00056",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "众位将军，随同老夫前去。来，与爷带马。",
      "text_length": 19
    },
    {
      "event_id": "01013003_e00057",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "曹操"
      ],
      "text": "适才间众军校报连番，许昌城走了关美髯。人来与爷带走战，见了关公说根源。",
      "text_length": 35
    },
    {
      "event_id": "01013003_e00058",
      "play_id": "01013003",
      "scene_id": "01013003_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "01013003_e00059",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 59,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "关羽"
      ],
      "text": "写柬辞曹出许昌，",
      "text_length": 8
    },
    {
      "event_id": "01013003_e00060",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 60,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四马童、甘夫人、糜夫人、关羽同上。",
      "text_length": 17
    },
    {
      "event_id": "01013003_e00061",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 61,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "关羽"
      ],
      "text": "挂印信封黄金来去清白，冠冕堂皇。曹孟德他待我恩深谊广，暗用那牢笼计打动我关云长。他爱我是一个英雄能将，我看他到如今枉费心肠。此一番到河北去寻兄长，青龙刀、赤兔马保定皇娘。叫人来你与爷催车仗，",
      "text_length": 95
    },
    {
      "event_id": "01013003_e00062",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "关羽"
      ],
      "text": "见一人骑战马急走慌忙。",
      "text_length": 11
    },
    {
      "event_id": "01013003_e00063",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张辽上。",
      "text_length": 4
    },
    {
      "event_id": "01013003_e00064",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 64,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张辽"
      ],
      "text": "关将军请了。",
      "text_length": 6
    },
    {
      "event_id": "01013003_e00065",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 65,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "原来是文远贤弟，你此番前来，莫非丞相，叫关某回转么？",
      "text_length": 26
    },
    {
      "event_id": "01013003_e00066",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 66,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张辽"
      ],
      "text": "非也。丞相言道：请将军少待片时，丞相要亲自送将军一程。",
      "text_length": 27
    },
    {
      "event_id": "01013003_e00067",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 67,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "纵然丞相，就是带来铁甲雄兵，关某也要决一死战。",
      "text_length": 23
    },
    {
      "event_id": "01013003_e00068",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 68,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "关羽"
      ],
      "text": "张辽把话对我讲，到叫关某无主张。叫人来忙把长桥上，",
      "text_length": 25
    },
    {
      "event_id": "01013003_e00069",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "甘夫人、糜夫人同下，关羽、马童同上桥。",
      "text_length": 19
    },
    {
      "event_id": "01013003_e00070",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "关羽"
      ],
      "text": "等候曹军作商量。",
      "text_length": 8
    },
    {
      "event_id": "01013003_e00071",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 71,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "曹操"
      ],
      "text": "人马纷纷出城壕，",
      "text_length": 8
    },
    {
      "event_id": "01013003_e00072",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 72,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、三将、郭嘉、程昱引曹操同上。",
      "text_length": 18
    },
    {
      "event_id": "01013003_e00073",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 73,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "曹操"
      ],
      "text": "不料关公竟脱逃。我念他英雄盖世武艺好，义气凌云盖九霄。在许昌我与他相交好，赠他的上马金、下马银，美女战马和锦袍。都只为刘备投了贼袁绍，他不忘桃园故旧交。不远千里把兄找，可算得世间一英豪。人来与爷前引道，见一人立马在长桥。",
      "text_length": 110
    },
    {
      "event_id": "01013003_e00074",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 74,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "关将军你为何去心太急？",
      "text_length": 11
    },
    {
      "event_id": "01013003_e00075",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 75,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "丞相容禀：某本解良一武夫，自幼投侍刘皇叔，桃园结义，誓同生死，皇天厚土，共鉴此衷。前在下邳，曾请三事，均蒙丞相恩准。昨日闻得故主刘玄德，现在河北袁绍军中，是某一闻此言，寸心如割，追念前盟，恨不得插翅飞去。有道是：大丈夫义不负心，忠不顾死，新恩虽厚，旧义难忘，倘有未尽之恩，容俟异日图报。昨日挂金封印，缴还丞相，还望丞相无忘昔日之言，为幸也。",
      "text_length": 170
    },
    {
      "event_id": "01013003_e00076",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 76,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "关羽"
      ],
      "text": "勒马提刀把话讲，尊一声丞相听端详：自从下邳来归降，蒙丞相带我见君王。官封我汉寿亭侯皇恩浩荡，蒙丞相赐我锦袍、战马、美女、琼浆。白马坡前无能将，某也曾诛文丑，斩却颜良。非是我关某太狂妄，桃园恩情时时挂在心肠。望丞相开恩将某放，知恩报德不敢忘。",
      "text_length": 120
    },
    {
      "event_id": "01013003_e00077",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 77,
      "seq_in_scene": 19,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "曹操"
      ],
      "text": "听罢言来心欢畅，忠义英雄世无双。",
      "text_length": 16
    },
    {
      "event_id": "01013003_e00078",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 78,
      "seq_in_scene": 20,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "老夫欲与将军朝夕相随，共扶汉室，不料将军去心已定，老夫也不敢强留，现备黄金千两，与将军作路途之费。来！",
      "text_length": 51
    },
    {
      "event_id": "01013003_e00079",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 79,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01013003_e00080",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 80,
      "seq_in_scene": 22,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "将黄金献上。",
      "text_length": 6
    },
    {
      "event_id": "01013003_e00081",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 81,
      "seq_in_scene": 23,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "久承丞相厚恩，感激不尽。某尚有川资，就将黄金分赏丞相之将士可也。",
      "text_length": 32
    },
    {
      "event_id": "01013003_e00082",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 82,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "将军真妙人也，既不收此黄金，现有锦袍一袭，聊以作别，望将军收纳乎。",
      "text_length": 33
    },
    {
      "event_id": "01013003_e00083",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 83,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "曹操"
      ],
      "text": "人言将军义气高，仗义轻财大英豪。千两黄金他不要，只得献上锦战袍。",
      "text_length": 32
    },
    {
      "event_id": "01013003_e00084",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 84,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "关羽"
      ],
      "text": "丞相待我恩谊好，临别又赠我锦战袍。扳鞍下马把话表，",
      "text_length": 25
    },
    {
      "event_id": "01013003_e00085",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 85,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮紧板",
      "speakers": [
        "关羽"
      ],
      "text": "曹营中将士杀气高。李典、乐进把驾保，又有那许褚和张辽。曹孟德行事多奸巧，恐怕中了计笼牢。手执着青龙刀把袍挑，",
      "text_length": 54
    },
    {
      "event_id": "01013003_e00086",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 86,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "关羽挑袍，下桥。",
      "text_length": 8
    },
    {
      "event_id": "01013003_e00087",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 87,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "关羽"
      ],
      "text": "催马加鞭下长桥。",
      "text_length": 8
    },
    {
      "event_id": "01013003_e00088",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 88,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "曹丞相，赠我战袍，足见多情。今日一别，后会有期。异日相逢，定当厚报，关某去也！",
      "text_length": 39
    },
    {
      "event_id": "01013003_e00089",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 89,
      "seq_in_scene": 31,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "关羽下。",
      "text_length": 4
    },
    {
      "event_id": "01013003_e00090",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 90,
      "seq_in_scene": 32,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "曹操"
      ],
      "text": "一见关公他去了，好叫老夫心内焦。",
      "text_length": 16
    },
    {
      "event_id": "01013003_e00091",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 91,
      "seq_in_scene": 33,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "关公已去，老夫少却一员战将，真真可惜！来，带马回营。",
      "text_length": 26
    },
    {
      "event_id": "01013003_e00092",
      "play_id": "01013003",
      "scene_id": "01013003_s04",
      "scene_no": 4,
      "seq_global": 92,
      "seq_in_scene": 34,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}