  "events": [
    {
      "event_id": "01013003_e00001",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小军、马童、关羽同上。",
      "text_length": 11
    },
    {
      "event_id": "01013003_e00002",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "关羽"
      ],
      "text": "身在曹营心在汉，思念桃园泪涟涟。",
      "text_length": 16
    },
    {
      "event_id": "01013003_e00003",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "某，汉寿亭侯。昨闻大哥现在河北袁绍军中，是我封金挂印，去往曹营走辞。可恨奸曹，将免见牌高挂辕门，不容某相见。某特修书一封，不免遣人送至曹营，就此保定二位皇嫂，闯出许昌便了。来！",
      "text_length": 88
    },
    {
      "event_id": "01013003_e00004",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小军"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01013003_e00005",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "这有书信一封，送至曹丞相营中，不得有误。",
      "text_length": 20
    },
    {
      "event_id": "01013003_e00006",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小军"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "01013003_e00007",
      "play_id": "01013003",
      "scene_id": "01013003_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小军下。",
      "text_length": 4
    },
    {
