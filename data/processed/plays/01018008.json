      "event_id": "01018008_e00069",
      "play_id": "01018008",
      "scene_id": "01018008_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "姜美容哭。",
      "text_length": 5
    },
    {
      "event_id": "01018008_e00070",
      "play_id": "01018008",
      "scene_id": "01018008_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "郭得福"
      ],
      "text": "夫妇相见，天降大喜，恸哭为何？",
      "text_length": 15
    },
    {
      "event_id": "01018008_e00071",
      "play_id": "01018008",
      "scene_id": "01018008_s04",
      "scene_no": 4,
      "seq_global": 71,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姜美容"
      ],
      "text": "夫妻见面，天降大喜。但不知二弟、五弟，流落何所？",
      "text_length": 24
    },
    {
      "event_id": "01018008_e00072",
      "play_id": "01018008",
      "scene_id": "01018008_s04",
