      "play_id": "01018008",
      "scene_id": "01018008_s04",
      "scene_no": 4,
      "seq_global": 73,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "郭得福"
      ],
      "text": "梧桐叶落还未干，",
      "text_length": 8
    },
    {
      "event_id": "01018008_e00074",
      "play_id": "01018008",
      "scene_id": "01018008_s04",
      "scene_no": 4,
      "seq_global": 74,
      "seq_in_scene": 52,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "姜美容"
      ],
      "text": "张意把咱下眼看。",
      "text_length": 8
    },
