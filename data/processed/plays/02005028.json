      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张紫艳进见。",
      "text_length": 6
    },
    {
      "event_id": "02005028_e00019",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 19,
