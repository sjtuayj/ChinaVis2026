      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "快备鞍马伺候。",
      "text_length": 7
    },
    {
      "event_id": "02005028_e00022",
      "play_id": "02005028",
