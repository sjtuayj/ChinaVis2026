      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "尊官何来？",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00020",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "我奉大王钧旨，着将军速备鞍马器械，是夜往潼关公干。",
      "text_length": 25
    },
    {
      "event_id": "02005028_e00021",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 21,
