      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "02005028_e00026",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "秦琼"
      ],
      "text": "只见萤萤月光照，清霜透征袍。凭着俺追风单骑，千里宵征，一羽如青鸟。",
      "text_length": 33
    },
    {
      "event_id": "02005028_e00027",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "秦琼！",
      "text_length": 3
    },
    {
      "event_id": "02005028_e00028",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "啊，你为何叫我的名字？",
      "text_length": 11
    },
    {
      "event_id": "02005028_e00029",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "你往哪里去？",
      "text_length": 6
    },
    {
      "event_id": "02005028_e00030",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "到大王营中去。",
      "text_length": 7
    },
    {
      "event_id": "02005028_e00031",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "你要往大王营中去么？",
      "text_length": 10
    },
    {
      "event_id": "02005028_e00032",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "02005028_e00033",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "哎！",
      "text_length": 2
    },
    {
      "event_id": "02005028_e00034",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "张紫艳"
      ],
      "text": "这是鬼门关叫伊魂魄飘，若不早回头，只怕你命难保。",
      "text_length": 24
    },
    {
      "event_id": "02005028_e00035",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "尊官何出此言？",
      "text_length": 7
    },
    {
      "event_id": "02005028_e00036",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "你可晓得大反山东之事么？",
      "text_length": 12
    },
    {
      "event_id": "02005028_e00037",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "噤声！哪个反了山东？",
      "text_length": 10
    },
    {
      "event_id": "02005028_e00038",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "就是贺芳，前日撺掇大王，把程达、尤金监禁齐州狱中，谁知他连结了李密、王伯当，焚烧仓库，拒杀官兵，都往瓦岗寨去了。齐州伸文告急，贺芳又在大王面前，说你暗通线索。必须先斩秦琼，然后发兵剿灭贼党。为此大王大怒，顷刻要把你斩首了！",
      "text_length": 111
    },
    {
      "event_id": "02005028_e00039",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "哎呀，望尊官救我一救。",
      "text_length": 11
    },
    {
      "event_id": "02005028_e00040",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "我哪里是什么尊官！",
      "text_length": 9
    },
    {
      "event_id": "02005028_e00041",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "你是何人？",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00042",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张紫艳脱衣帽。",
      "text_length": 7
    },
    {
      "event_id": "02005028_e00043",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "奴家就是歌姬张紫艳！",
      "text_length": 10
    },
    {
      "event_id": "02005028_e00044",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "原来就是小娘子！",
      "text_length": 8
    },
    {
      "event_id": "02005028_e00045",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "喏奴家呵！",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00046",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "张紫艳"
      ],
      "text": "怎忍见英雄汉餐宝刀，因此乔妆悄然告尔曹。",
      "text_length": 20
    },
    {
      "event_id": "02005028_e00047",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "张紫艳"
      ],
      "text": "你把这支令箭呵！",
      "text_length": 8
    },
    {
      "event_id": "02005028_e00048",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "张紫艳"
      ],
      "text": "急忙奔出潼关，急去偷生好！",
      "text_length": 13
    },
    {
      "event_id": "02005028_e00049",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "秦琼"
      ],
      "text": "感深恩天样高，倘重生，粉身报。",
      "text_length": 15
    },
    {
      "event_id": "02005028_e00050",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "俺秦琼就此去也！",
      "text_length": 8
    },
    {
      "event_id": "02005028_e00051",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "秦琼"
      ],
      "text": "鳌鱼脱金钩，逃生敢惮劳，几次行止还止。",
      "text_length": 19
    },
    {
      "event_id": "02005028_e00052",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "啊小娘子！",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00053",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "你去了怎么又转来？",
      "text_length": 9
    },
    {
      "event_id": "02005028_e00054",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "小娘子我去便去了。",
      "text_length": 9
    },
    {
      "event_id": "02005028_e00055",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "秦琼"
      ],
      "text": "岂可贻累姣娥，反惹人嘲笑。",
      "text_length": 13
    },
    {
      "event_id": "02005028_e00056",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "俺秦琼为朋友而死，理所当然，岂可累及小娘子？于心何忍也！罢，不如仍旧回营，凭大王处置便了！",
      "text_length": 45
    },
    {
      "event_id": "02005028_e00057",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "将军此身架海擎天，关系非小。奴家一身与草木同腐，何必虑及啊！必须当面决断，你才放心！",
      "text_length": 42
    },
    {
      "event_id": "02005028_e00058",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "索南枝",
      "speakers": [
        "张紫艳"
      ],
      "text": "把微躯委短蒿，女英雄万年表！",
      "text_length": 14
    },
    {
      "event_id": "02005028_e00059",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张紫艳"
      ],
      "text": "将军你看那边官兵来了！",
      "text_length": 11
    },
    {
      "event_id": "02005028_e00060",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "在哪里？",
      "text_length": 4
    },
    {
      "event_id": "02005028_e00061",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张紫艳自刎，下。",
      "text_length": 8
    },
    {
      "event_id": "02005028_e00062",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "呀，你看小娘子自刎了！哎呀小娘子吓！",
      "text_length": 18
    },
    {
      "event_id": "02005028_e00063",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "扑灯蛾",
      "speakers": [
        "秦琼"
      ],
      "text": "看英风天与齐，看英风天与齐，尽节人争道，含笑赴青蒿，愧我须眉苟活也！",
      "text_length": 34
    },
    {
      "event_id": "02005028_e00064",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "秦琼"
      ],
      "text": "小娘子吓！",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00065",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "扑灯蛾",
      "speakers": [
        "秦琼"
      ],
      "text": "鞠躬拜倒，待他年墓碣重标，今日里权堆荒草。",
      "text_length": 21
    },
    {
      "event_id": "02005028_e00066",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼拭目。",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00067",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "扑灯蛾",
      "speakers": [
        "秦琼"
      ],
      "text": "痛孤魂，香醪一滴有谁浇。",
      "text_length": 12
    },
    {
      "event_id": "02005028_e00068",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "且住，小娘子已死，哭也无益。不免骑了黄骠马，连夜奔出潼关便了。",
      "text_length": 31
    },
    {
      "event_id": "02005028_e00069",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "秦琼"
      ],
      "text": "我双手撇开生死路——",
      "text_length": 10
    },
    {
      "event_id": "02005028_e00070",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "也罢！",
      "text_length": 3
    },
    {
      "event_id": "02005028_e00071",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "秦琼"
      ],
      "text": "一身跳出是非门。",
      "text_length": 8
    },
    {
      "event_id": "02005028_e00072",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "哎呀小娘子吓！",
      "text_length": 7
    },
    {
      "event_id": "02005028_e00073",
      "play_id": "02005028",
      "scene_id": "02005028_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼悲下。",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00074",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四兵卒引杨林同上。",
      "text_length": 9
    },
    {
      "event_id": "02005028_e00075",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "杨林"
      ],
      "text": "日月依龙德，风云挟豹韬。",
      "text_length": 12
    },
    {
      "event_id": "02005028_e00076",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨林上高座。贺芳急上。",
      "text_length": 11
    },
    {
      "event_id": "02005028_e00077",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贺芳"
      ],
      "text": "忙将破胆惊天事，报与金枝玉叶人。",
      "text_length": 16
    },
    {
      "event_id": "02005028_e00078",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺芳"
      ],
      "text": "大王在上，贺芳打躬交令！",
      "text_length": 12
    },
    {
      "event_id": "02005028_e00079",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "秦琼拿到了么？",
      "text_length": 7
    },
    {
      "event_id": "02005028_e00080",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺芳"
      ],
      "text": "贺芳奉大王钧旨去拿秦琼。说他昨夜黄昏，有一尊官手持令箭，说奉大王将令，差往潼关公干，连夜走了！",
      "text_length": 47
    },
    {
      "event_id": "02005028_e00081",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "那军官一定是奸细，查出一同处斩！",
      "text_length": 16
    },
    {
      "event_id": "02005028_e00082",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺芳允。上官仪急上。",
      "text_length": 10
    },
    {
      "event_id": "02005028_e00083",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "上官仪"
      ],
      "text": "别号人中杰，威分阃外司。",
      "text_length": 12
    },
    {
      "event_id": "02005028_e00084",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "上官仪"
      ],
      "text": "上官仪打躬交令！",
      "text_length": 8
    },
    {
      "event_id": "02005028_e00085",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "上官仪回来了？",
      "text_length": 7
    },
    {
      "event_id": "02005028_e00086",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "上官仪"
      ],
      "text": "是，回来了。",
      "text_length": 6
    },
    {
      "event_id": "02005028_e00087",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "命你郊外巡缉，怎么样了？",
      "text_length": 12
    },
    {
      "event_id": "02005028_e00088",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "上官仪"
      ],
      "text": "奉命郊外巡哨，见一被杀妇人，身穿男子衣帽。仔细检验，原来是歌姬张紫艳。特来报知。",
      "text_length": 40
    },
    {
      "event_id": "02005028_e00089",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "啊！一定是这贱人窃听消息，盗孤令箭，报知秦琼。可恼吓可恼！上官仪听令！",
      "text_length": 35
    },
    {
      "event_id": "02005028_e00090",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "上官仪允。",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00091",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "取我令箭一支，赶上秦琼。说孤毫不见怪，唤他转来，还要重用。",
      "text_length": 29
    },
    {
      "event_id": "02005028_e00092",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "上官仪允。",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00093",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 93,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "上官仪"
      ],
      "text": "得令！",
      "text_length": 3
    },
    {
      "event_id": "02005028_e00094",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 94,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "上官仪"
      ],
      "text": "一心忙似箭，加鞭走如飞。",
      "text_length": 12
    },
    {
      "event_id": "02005028_e00095",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 95,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "上官仪下。",
      "text_length": 5
    },
    {
      "event_id": "02005028_e00096",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 96,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺芳"
      ],
      "text": "贺芳启上大王：上官仪此去，秦琼决不转来。",
      "text_length": 20
    },
    {
      "event_id": "02005028_e00097",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 97,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "就看你带五百铁骑擒回便了。",
      "text_length": 13
    },
    {
      "event_id": "02005028_e00098",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 98,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺芳"
      ],
      "text": "得令！",
      "text_length": 3
    },
    {
      "event_id": "02005028_e00099",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 99,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺芳下。杨林下高座。",
      "text_length": 10
    },
    {
      "event_id": "02005028_e00100",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 100,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨林"
      ],
      "text": "贺芳不是秦琼对手，待孤亲自走遭。秦琼秦琼！",
      "text_length": 21
    },
    {
      "event_id": "02005028_e00101",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 101,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杨林"
      ],
      "text": "这回好似泰山来压卵，须知螳臂怎当车！",
      "text_length": 18
    },
    {
      "event_id": "02005028_e00102",
      "play_id": "02005028",
      "scene_id": "02005028_s02",
      "scene_no": 2,
      "seq_global": 102,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨林、四兵卒同下。",
      "text_length": 9
    }
  ],
  "roles_inferred": true
}