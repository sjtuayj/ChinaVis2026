  "events": [
    {
      "event_id": "05004004_e00001",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐母上。丫鬟随上。",
      "text_length": 9
    },
    {
      "event_id": "05004004_e00002",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "徐母"
      ],
      "text": "身居华堂，终日里，泪珠成行。",
      "text_length": 14
    },
    {
      "event_id": "05004004_e00003",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐母"
      ],
      "text": "汉室江山裂土分，幸喜我儿遇明君。曹操暗中设巧计，难动老身冰雪心。",
      "text_length": 32
    },
    {
      "event_id": "05004004_e00004",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "老身徐母。我儿徐庶，四海云游。闻听他在刘皇叔帐下为臣。曹操心生奸计，将老身赚到许昌，命我修书召子。老身一时性急，用砚石打击奸贼。曹操怒恨，将老身推出辕门，就要问斩。后被程昱讲情，将我赦回安置此处。虽然衣食无缺，终日如坐囹圄。这且不言。今早起来，心惊肉跳，不知为了何事？天到这般时候，吉凶未见。丫鬟，看茶伺候。",
      "text_length": 154
    },
    {
      "event_id": "05004004_e00005",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "05004004_e00006",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "徐母"
      ],
      "text": "想当年徐庶儿出外游荡，习骑射与击剑自逞豪强。抱不平打死了他人命丧，因此上黑夜里逃奔外乡。也是我养姣儿教训不当，才闯下杀身祸天大灾殃。我的儿离膝下十年以上，幸喜得保皇叔际遇贤良。恨只恨曹孟德痴心妄想，他命我修书信召子还乡。那时节恼得我气冲上撞，用砚石击打他要贼命亡。狗奸贼传一令将我上绑，顷刻间要将我斩首云阳。内有个小程昱把情来讲，那曹贼他将我解下法桩。将老身安置在静室奉养，居此间好一似缧绁高墙。小程昱来问安谦谦让让，早问安，晚送膳，锦衣美食，丫鬟侍女，苍头仆妇，伺候得我心内着慌，小程昱也难免诡计暗藏。任你等设下了天罗地网，打不动老身我铁石心肠。",
      "text_length": 274
    },
    {
      "event_id": "05004004_e00007",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "丫鬟，程老爷到此，禀我知道。",
      "text_length": 14
    },
    {
      "event_id": "05004004_e00008",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "05004004_e00009",
      "play_id": "05004004",
      "scene_id": "05004004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐母下。丫鬟随下。",
      "text_length": 9
    },
    {
      "event_id": "05004004_e00010",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、旗牌、徐庶同上。",
      "text_length": 12
    },
    {
      "event_id": "05004004_e00011",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐庶"
      ],
      "text": "闻听得老萱堂囚禁许昌，在新野辞别了创业豪强。好一个刘使君宽宏大量，在长亭饯行时桃园弟兄举杯捧觞。赵子龙坠镫扯丝缰，俱都是珠泪成行，好叫我痛断肝肠。得书信致使我神魂飘荡，走马回荐诸葛表我的心肠。非是我无终始半途异想，都只为母子情五伦纲常。过几处招商店日夜盼望，恨不能插双翅飞到了许昌。适才间进都门愁眉展放，皆因为子不孝累及高堂。",
      "text_length": 163
    },
    {
      "event_id": "05004004_e00012",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "旗牌"
      ],
      "text": "来此已是。",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00013",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "快去通禀。",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00014",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子暗上。",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00015",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "旗牌"
      ],
      "text": "里面哪位在？",
      "text_length": 6
    },
    {
      "event_id": "05004004_e00016",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "何事？",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00017",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "旗牌"
      ],
      "text": "徐老爷回来了。",
      "text_length": 7
    },
    {
      "event_id": "05004004_e00018",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "大相公在上，小人叩头。",
      "text_length": 11
    },
    {
      "event_id": "05004004_e00019",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "罢了。快去禀报太夫人知道。",
      "text_length": 13
    },
    {
      "event_id": "05004004_e00020",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "是。有请太夫人。",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00021",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "徐母"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00022",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐母上。",
      "text_length": 4
    },
    {
      "event_id": "05004004_e00023",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐母"
      ],
      "text": "吉凶二子难猜想，眼跳心惊为哪桩？",
      "text_length": 16
    },
    {
      "event_id": "05004004_e00024",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "何事？",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00025",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "恭喜太夫人，恭喜太夫人。",
      "text_length": 12
    },
    {
      "event_id": "05004004_e00026",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "喜从何来？",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00027",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "大相公回来了。",
      "text_length": 7
    },
    {
      "event_id": "05004004_e00028",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "莫非徐庶到此？",
      "text_length": 7
    },
    {
      "event_id": "05004004_e00029",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00030",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "他不在新野，到此则甚？",
      "text_length": 11
    },
    {
      "event_id": "05004004_e00031",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "小人不知。",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00032",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "他在何处？",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00033",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "现在门外。",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00034",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "唤他进来。",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00035",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "大相公，太夫人唤你进去。",
      "text_length": 12
    },
    {
      "event_id": "05004004_e00036",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "知道了。",
      "text_length": 4
    },
    {
      "event_id": "05004004_e00037",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "旗牌、四青袍同下。",
      "text_length": 9
    },
    {
      "event_id": "05004004_e00038",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "母亲在哪里？母亲在上，孩儿徐庶参拜。",
      "text_length": 18
    },
    {
      "event_id": "05004004_e00039",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "畜生哪！",
      "text_length": 4
    },
    {
      "event_id": "05004004_e00040",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "徐母"
      ],
      "text": "蠢材你把良心坏！",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00041",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "徐庶！",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00042",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "母亲！",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00043",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "我儿！",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00044",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "老娘！",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00045",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "我把你这不孝的奴才吆！",
      "text_length": 11
    },
    {
      "event_id": "05004004_e00046",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐母"
      ],
      "text": "大骂徐庶小奴才。不在新野为将帅，私到许昌为何来？",
      "text_length": 24
    },
    {
      "event_id": "05004004_e00047",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "徐庶"
      ],
      "text": "娘啊！",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00048",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐庶"
      ],
      "text": "想当年儿把人打坏，黑夜逃走颍川来。儿离膝下十余载，常把儿的老娘挂在儿的心怀。因避难儿把名姓改，协助皇叔把兵排。母亲差人把书带，孩儿一见痛心怀。宁可娘在儿不在，岂忍白发赴泉台？",
      "text_length": 87
    },
    {
      "event_id": "05004004_e00049",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "哽！",
      "text_length": 2
    },
    {
      "event_id": "05004004_e00050",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐母"
      ],
      "text": "听罢言来牙咬坏，定是曹操巧安排。儿自幼访友四海外，一封书信诓儿来。你平日聪明今何在？",
      "text_length": 42
    },
    {
      "event_id": "05004004_e00051",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "徐母"
      ],
      "text": "我的儿啦！",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00052",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐母"
      ],
      "text": "为娘的笔迹儿就解不开！",
      "text_length": 11
    },
    {
      "event_id": "05004004_e00053",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐庶"
      ],
      "text": "孩儿见信不自揣，辞别皇叔探娘来。忽促之间儿难解，",
      "text_length": 24
    },
    {
      "event_id": "05004004_e00054",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "徐庶"
      ],
      "text": "儿的娘啊！",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00055",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐庶"
      ],
      "text": "母亲恕儿无学才。",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00056",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐母"
      ],
      "text": "此信何人与你带？",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00057",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐庶"
      ],
      "text": "带信人儿一齐来。",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00058",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "徐母"
      ],
      "text": "问家院来人可在外？",
      "text_length": 9
    },
    {
      "event_id": "05004004_e00059",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "家院"
      ],
      "text": "大相公进门他走开。",
      "text_length": 9
    },
    {
      "event_id": "05004004_e00060",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "大相公进门之时，他就走去了。",
      "text_length": 14
    },
    {
      "event_id": "05004004_e00061",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "哦，原来如此。徐庶徐庶，我把你这无智无才不孝之子！",
      "text_length": 25
    },
    {
      "event_id": "05004004_e00062",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐母坐。",
      "text_length": 4
    },
    {
      "event_id": "05004004_e00063",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "想当年你因激于义愤，将人打死。黑夜之间，涂面逃走。那时为娘带汝弟徐康，苦守家门，并无一言责备与你。我儿虽然闯下杀身大祸，乃是义气肝胆。自儿涂面出外之后，为娘昼夜放心不下，刻刻在外，托人打听儿的着落。闻得我儿江湖访友，四海寻师。指望你达练人情，洞明世事。志量自然开展，学业必然精通。谁料你遇事粗心，当局鲁莽。忘却三思之戒，不顾时局之箴。儿既读圣贤之书，必达周公之礼。忠孝二字，不能同尽；家国两地，岂能兼全？况曹操乃欺君罔上之徒，怎及刘皇叔仁义之士；又是中山靖王之后裔，为汉室嫡派宗亲。儿既倾心辅佐，可谓得其主也。今凭一纸书，竟不查虚实，不辨笔迹，怎么，你竟别皇叔弃明投暗，自取臭名，玷辱宗祖。使为娘担不义之名，儿贻笑五湖三江。我纵死九泉，有何颜面去见徐氏门中之祖先也。",
      "text_length": 333
    },
    {
      "event_id": "05004004_e00064",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "徐母"
      ],
      "text": "恨畜生你把那纲常来败，好一似狼牙箭刺我胸怀。在家中因不平将人打坏，黑夜间涂面目远避祸灾。在新野佐皇叔终身有赖，也不枉为娘我教训奴才。岂不知尽其忠孝名例外？接着了假书信星夜前来！到如今降逆贼臭名万代，辜负了白发人铁石心怀。",
      "text_length": 110
    },
    {
      "event_id": "05004004_e00065",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 56,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "徐庶"
      ],
      "text": "老娘亲休得要身体气坏，恕孩儿不细揣莽撞前来。这也是儿不该荣膺三代，误中了狗奸贼巧计安排。任凭他再作出千奇百怪，想孩儿扶助他转世投胎。",
      "text_length": 66
    },
    {
      "event_id": "05004004_e00066",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 57,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐母"
      ],
      "text": "你虽然不能把奸贼依赖，走新野弃皇叔大大不该。",
      "text_length": 22
    },
    {
      "event_id": "05004004_e00067",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 58,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐庶"
      ],
      "text": "孩儿不愿为官宰，愿在膝下奉萱台。无奈何我只得连连叩拜，儿的娘啊……",
      "text_length": 33
    },
    {
      "event_id": "05004004_e00068",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 59,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐母"
      ],
      "text": "气得老娘眼发呆。老身若有三寸在，徐庶焉能走得开？倒不如一死归阴界，我儿也好死心怀。轻移莲步屏风拐，点点珠泪洒下来。腰间解下无情带，",
      "text_length": 65
    },
    {
      "event_id": "05004004_e00069",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 60,
      "page_no": 4,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "徐母"
      ],
      "text": "我的儿啦！",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00070",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 61,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "罢！",
      "text_length": 2
    },
    {
      "event_id": "05004004_e00071",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 62,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐母"
      ],
      "text": "要想相逢梦中来！",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00072",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 63,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐母上吊，死。",
      "text_length": 7
    },
    {
      "event_id": "05004004_e00073",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 64,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐庶"
      ],
      "text": "母亲请出屏风外，孩儿跪得腿难挨。",
      "text_length": 16
    },
    {
      "event_id": "05004004_e00074",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 65,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟上。",
      "text_length": 4
    },
    {
      "event_id": "05004004_e00075",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 66,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "大相公，大事不好！",
      "text_length": 9
    },
    {
      "event_id": "05004004_e00076",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 67,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00077",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 68,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "太夫人自缢身死！",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00078",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 69,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "闪开了！",
      "text_length": 4
    },
    {
      "event_id": "05004004_e00079",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 70,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐庶看。",
      "text_length": 4
    },
    {
      "event_id": "05004004_e00080",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 71,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "徐庶"
      ],
      "text": "母亲！老娘！唉，娘啊！",
      "text_length": 11
    },
    {
      "event_id": "05004004_e00081",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 72,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐庶晕倒。",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00082",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 73,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "大相公醒来！",
      "text_length": 6
    },
    {
      "event_id": "05004004_e00083",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 74,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "徐庶"
      ],
      "text": "见老娘自缢死魂飞天外！",
      "text_length": 11
    },
    {
      "event_id": "05004004_e00084",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 75,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "徐庶"
      ],
      "text": "母亲！老娘！唉娘啊……",
      "text_length": 11
    },
    {
      "event_id": "05004004_e00085",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 76,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐庶"
      ],
      "text": "不由我一阵阵刀割胸怀。儿离膝下十余载，少奉甘旨老萱台。哪里是曹操假书带？分明是老母勾魂来。不孝的孩儿将娘害，万剐千刀也应该。忠孝二字今何在？儿的娘啊！此事叫儿怎安排？",
      "text_length": 83
    },
    {
      "event_id": "05004004_e00086",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 77,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "丫鬟",
        "家院"
      ],
      "text": "老爷不必悲伤，安排大事要紧。",
      "text_length": 14
    },
    {
      "event_id": "05004004_e00087",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "丫鬟，将太夫人搭在灵床之上，待我准备棺椁。",
      "text_length": 21
    },
    {
      "event_id": "05004004_e00088",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟搭徐母同下。",
      "text_length": 8
    },
    {
      "event_id": "05004004_e00089",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 80,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "05004004_e00090",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 81,
      "page_no": 5,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐庶"
      ],
      "text": "指望归家奉母终，谁知一旦失音容？从今难见慈母面，母子相逢梦寐中。",
      "text_length": 32
    },
    {
      "event_id": "05004004_e00091",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 82,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "哎，娘啊！",
      "text_length": 5
    },
    {
      "event_id": "05004004_e00092",
      "play_id": "05004004",
      "scene_id": "05004004_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 83,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐庶哭，下。家院下。",
      "text_length": 10
    }
  ],
  "roles_inferred": true
}