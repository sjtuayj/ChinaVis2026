  "events": [
    {
      "event_id": "01006006_e00001",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "徐延昭"
      ],
      "text": "掌灯！",
      "text_length": 3
    },
    {
      "event_id": "01006006_e00002",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "徐延昭"
      ],
      "text": "听谯楼打罢了初更时候，",
      "text_length": 11
    },
    {
      "event_id": "01006006_e00003",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二大铠同上，徐延昭上。",
      "text_length": 11
    },
    {
      "event_id": "01006006_e00004",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐延昭"
      ],
      "text": "开山府又来了定国王侯。先王爷晏了驾太子年幼，龙国太无主张推让龙楼。满朝中文武臣旁观袖手，眼见得这江山付与水流。叫家将掌红灯龙楼阁走，见皇陵不见君两泪交流。徐延昭三叩首把本启奏，尊一声臣的主细听从头：先王爷晏了驾太子年幼，恨李良起反心谋篡龙楼。有徐、杨在金殿把本启奏，龙国太她言道：大明朝有事无事，不用徐、杨二大奸党，赶出龙楼。先王爷在阴曹多多保佑，保佑那杨家将急早回头。",
      "text_length": 185
    },
    {
      "event_id": "01006006_e00005",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "徐延昭"
      ],
      "text": "耳边厢又听得人声马吼，想必是李良将来夺龙楼。叫家将掩红灯藏至在屏风以后，今夜晚丧贼手万古名流。",
      "text_length": 47
    },
    {
      "event_id": "01006006_e00006",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二大铠同下。四将、赵飞同上，杨波上。",
      "text_length": 18
    },
    {
      "event_id": "01006006_e00007",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "杨波"
      ],
      "text": "众家儿郎忙随定，见了千岁礼相迎。",
      "text_length": 16
    },
    {
      "event_id": "01006006_e00008",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "参见千岁！",
      "text_length": 5
    },
    {
      "event_id": "01006006_e00009",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐延昭"
      ],
      "text": "哽！胆大杨波，带领众家孩儿，敢是夺取皇陵？",
      "text_length": 21
    },
    {
      "event_id": "01006006_e00010",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "学生怎敢！带领众家孩儿，前来扶保皇陵。",
      "text_length": 19
    },
    {
      "event_id": "01006006_e00011",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐延昭"
      ],
      "text": "众家孩儿今在何处？",
      "text_length": 9
    },
    {
      "event_id": "01006006_e00012",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "现在外面。",
      "text_length": 5
    },
    {
      "event_id": "01006006_e00013",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐延昭"
      ],
      "text": "叫他们悄悄而进。",
      "text_length": 8
    },
    {
      "event_id": "01006006_e00014",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "众家随我前来，见过千岁。",
      "text_length": 12
    },
    {
      "event_id": "01006006_e00015",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四将"
      ],
      "text": "是。参见千岁！",
      "text_length": 7
    },
    {
      "event_id": "01006006_e00016",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐延昭"
      ],
      "text": "站立两厢。",
      "text_length": 5
    },
    {
      "event_id": "01006006_e00017",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐延昭"
      ],
      "text": "一文一武站朝廊，",
      "text_length": 8
    },
    {
      "event_id": "01006006_e00018",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨波"
      ],
      "text": "叙一叙大明朝锦绣家邦。",
      "text_length": 11
    },
    {
      "event_id": "01006006_e00019",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐延昭"
      ],
      "text": "杨大人好一比汉高皇上，",
      "text_length": 11
    },
    {
      "event_id": "01006006_e00020",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨波"
      ],
      "text": "千岁爷好一比西楚霸王。",
      "text_length": 11
    },
    {
      "event_id": "01006006_e00021",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐延昭"
      ],
      "text": "进宫去摔死了年幼太子，我保大人做一朝帝王。",
      "text_length": 21
    },
    {
      "event_id": "01006006_e00022",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨波"
      ],
      "text": "欺君话儿休要讲，谋朝篡位奸贼李良，天理昭彰！",
      "text_length": 22
    },
    {
      "event_id": "01006006_e00023",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐延昭"
      ],
      "text": "我和你不过是闲谈言讲，杨大人你哪有篡位的心肠？我要观观儿郎。杨大郎生来好貌相，好一似当年汉刘王。身旁缺少诸葛亮，阴阳八卦腹内藏，你亚赛刘王！",
      "text_length": 70
    },
    {
      "event_id": "01006006_e00024",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐延昭"
      ],
      "text": "好将！",
      "text_length": 3
    },
    {
      "event_id": "01006006_e00025",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐延昭"
      ],
      "text": "赤面长髯小马芳，亚赛三国关二王。过五关曾斩六员将，擂鼓三通斩蔡阳，你亚赛二王！",
      "text_length": 39
    },
    {
      "event_id": "01006006_e00026",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐延昭"
      ],
      "text": "好将！",
      "text_length": 3
    },
    {
      "event_id": "01006006_e00027",
      "play_id": "01006006",
      "scene_id": "01006006_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "徐延昭"
      ],
      "text": "豹头环眼杨三郎，亚赛当年翼德张。虎牢关前打一仗，枪挑吕布紫金冠，你亚赛翼德张！",
      "text_length": 39
    },
    {
