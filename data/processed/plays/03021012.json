  "events": [
    {
      "event_id": "03021012_e00001",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖大开门〗。四红龙套、马达、江海、代战公主同上。〖点绛唇〗。代战公主左右两望，上高台。",
      "text_length": 43
    },
    {
      "event_id": "03021012_e00002",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "代战公主"
      ],
      "text": "威风凛凛坐将台，杀气腾腾云雾开。兵强马壮将士勇，南朝不敢动兵灾。",
      "text_length": 32
    },
    {
      "event_id": "03021012_e00003",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战公主"
      ],
      "text": "咱家，代战公主是也。只因大王私回长安，咱家带领人马，赶到界牌三关，用金铃鸽儿换回金鈚令箭。是我对他言道，如果有难，将金铃鸽儿放回，咱家也好发兵去救哇！这几日不见鸽子回来，想是大王平安无事。看今日天气晴和，不免到银空山舞猎一回。马达、江海！",
      "text_length": 119
    },
    {
      "event_id": "03021012_e00004",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马达",
        "江海"
      ],
      "text": "有！",
      "text_length": 2
    },
    {
      "event_id": "03021012_e00005",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战公主"
      ],
      "text": "兵发银空山哪！",
      "text_length": 7
    },
    {
      "event_id": "03021012_e00006",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "代战公主下高台，脱蟒。",
      "text_length": 11
    },
    {
      "event_id": "03021012_e00007",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马达",
        "江海"
      ],
      "text": "啊！兵发银空山。带马！",
      "text_length": 11
    },
    {
      "event_id": "03021012_e00008",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "代战公主上马。代战公主、四红龙套、马达、江海同走圆场。",
      "text_length": 27
    },
    {
      "event_id": "03021012_e00009",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马达",
        "江海"
      ],
      "text": "来到银空山。",
      "text_length": 6
    },
    {
      "event_id": "03021012_e00010",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "代战公主"
      ],
      "text": "听我一令！",
      "text_length": 5
    },
    {
      "event_id": "03021012_e00011",
      "play_id": "03021012",
      "scene_id": "03021012_s01",
      "scene_no": 1,
      "seq_global": 11,
