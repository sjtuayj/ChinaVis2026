  "events": [
    {
      "event_id": "03060005_e00001",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、曹彬同上。",
      "text_length": 9
    },
    {
      "event_id": "03060005_e00002",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵匡胤"
      ],
      "text": "逃出天罗地网，",
      "text_length": 7
    },
    {
      "event_id": "03060005_e00003",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "曹彬"
      ],
      "text": "好似雀鸟腾空。",
      "text_length": 7
    },
    {
      "event_id": "03060005_e00004",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "恩人请坐！",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00005",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "贤弟请！多蒙贤弟搭救，我这里当面谢过。",
      "text_length": 19
    },
    {
      "event_id": "03060005_e00006",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "岂敢！小弟当报前恩。",
      "text_length": 10
    },
    {
      "event_id": "03060005_e00007",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "好说。",
      "text_length": 3
    },
    {
      "event_id": "03060005_e00008",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "备得有酒，与恩人压惊。",
      "text_length": 11
    },
    {
      "event_id": "03060005_e00009",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "如此，叨扰了。",
      "text_length": 7
    },
    {
      "event_id": "03060005_e00010",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "恩人请！",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00011",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "03060005_e00012",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹彬"
      ],
      "text": "得恩不报非君子，忘恩负义是小人。",
      "text_length": 16
    },
    {
      "event_id": "03060005_e00013",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、曹彬同饮酒，曹彬醉，睡。〖起初更鼓〗。",
      "text_length": 23
    },
    {
      "event_id": "03060005_e00014",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "二相公醒来，再吃一杯……啊，他竟然睡熟了。唉！想我赵匡胤今宿曹府，好不焦躁人也！",
      "text_length": 40
    },
    {
      "event_id": "03060005_e00015",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "有豪杰坐书房精神不爽，二相公心无事困睡一旁。无奈何推纱窗仰观天象，果然是中秋月分外明光。我本是宦门后娇生惯养，打关东闯关西自称豪强。思爹娘想妹弟终朝盼望，山又高路又远阻隔两厢。洒金桥遇苗顺曾把命讲，他算我到后来南面称王。到如今坐江山全然不想，登九五比南柯大梦一场。周文王得江山全凭吕望，拉八百单八步地久天长。汉刘秀全凭着二十八将，文邓禹、武姚期、岑彭、子章。小唐王全凭着瓦岗诸将，我玄郎并无有架海金梁。",
      "text_length": 201
    },
    {
      "event_id": "03060005_e00016",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起二更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "03060005_e00017",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "恨金鸡不报晓天还未亮，谯楼上睡熟了打更儿郎。恨不能用长枪高挑万丈，用金钩将红日钩出扶桑。",
      "text_length": 44
    },
    {
      "event_id": "03060005_e00018",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张氏上。",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00019",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "张氏"
      ],
      "text": "轻移莲步到书房，且听恩人说其详。",
      "text_length": 16
    },
    {
      "event_id": "03060005_e00020",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "奴家，张氏。赵恩人在书房饮酒，不免去到窗下，听他说些什么。正是：",
      "text_length": 32
    },
    {
      "event_id": "03060005_e00021",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张氏"
      ],
      "text": "若知心腹事，且听口中言。",
      "text_length": 12
    },
    {
      "event_id": "03060005_e00022",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "且住！想我在西门外被崔龙拿住，多亏二相公举家将我救下，好一个张氏嫂嫂，在大街以上，叫俺一声“丈夫”，这样贤人，真是难得呀难得！呀呸！讲什么贤人，道什么难得？他是曹仁之妻，叫俺玄郎一声“丈夫”。若是我那贺氏妻子，叫别人一声“丈夫”，玄郎不知便罢；我若知道，就是这一刀。",
      "text_length": 133
    },
    {
      "event_id": "03060005_e00023",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "03060005_e00024",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "错了！错了！",
      "text_length": 6
    },
    {
      "event_id": "03060005_e00025",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "一句话儿出了唇，倒作忘恩负义人。不饮酒来假装醉，",
      "text_length": 24
    },
    {
      "event_id": "03060005_e00026",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "醉了！醉了！",
      "text_length": 6
    },
    {
      "event_id": "03060005_e00027",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "窗外休听醉汉云。",
      "text_length": 8
    },
    {
      "event_id": "03060005_e00028",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "张氏"
      ],
      "text": "听一言来吃一惊，羞得奴家面通红。腰间解下丝罗带，不如一死丧残生。",
      "text_length": 32
    },
    {
      "event_id": "03060005_e00029",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张氏下。〖起三更鼓〗。华佗上。",
      "text_length": 15
    },
    {
      "event_id": "03060005_e00030",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "华佗"
      ],
      "text": "闷坐松林下，修道数百年。三国我为首，自称华佗仙。",
      "text_length": 24
    },
    {
      "event_id": "03060005_e00031",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "我乃三国华佗是也。只因赤须龙有难，特地前来搭救，讨一封号。来此已是。",
      "text_length": 34
    },
    {
      "event_id": "03060005_e00032",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "华佗进门，与赵匡胤割治肉瘤。",
      "text_length": 14
    },
    {
      "event_id": "03060005_e00033",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "华佗"
      ],
      "text": "不用忧来不用愁，宝剑割去肉龙瘤。阳世之间无用处，抛在长江顺水流。",
      "text_length": 32
    },
    {
      "event_id": "03060005_e00034",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "何方妖道？摆来摆去！",
      "text_length": 10
    },
    {
      "event_id": "03060005_e00035",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "三国华佗。",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00036",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "到此作甚？",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00037",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "前来讨封。",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00038",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "修炼多少年了？",
      "text_length": 7
    },
    {
      "event_id": "03060005_e00039",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "一千余年。",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00040",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "算得一洞老神仙！",
      "text_length": 8
    },
    {
      "event_id": "03060005_e00041",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "谢主隆恩！",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00042",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "华佗"
      ],
      "text": "不是真龙开金口，焉得蓬莱一洞仙！",
      "text_length": 16
    },
    {
      "event_id": "03060005_e00043",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "华佗下。〖起四更鼓〗。张氏上。",
      "text_length": 15
    },
    {
      "event_id": "03060005_e00044",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张氏"
      ],
      "text": "人死如灯灭，犹如汤泼雪。若要还阳转，海底捞明月。",
      "text_length": 24
    },
    {
      "event_id": "03060005_e00045",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "奴乃张氏鬼魂是也。身死之后，方知赵恩人后有九五之尊，不免前去讨一封号。来至书房，待奴进去。",
      "text_length": 45
    },
    {
      "event_id": "03060005_e00046",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "何处鬼魂，在此打搅？",
      "text_length": 10
    },
    {
      "event_id": "03060005_e00047",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "奴乃张氏鬼魂是也。",
      "text_length": 9
    },
    {
      "event_id": "03060005_e00048",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "到此何事？",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00049",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "前来讨封。",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00050",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "前日打华山经过，少一圣母，就封你为插花圣母，复位去吧！金童、玉女，送她归位！",
      "text_length": 38
    },
    {
      "event_id": "03060005_e00051",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "金童",
        "玉女"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03060005_e00052",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金童、玉女捧衣同上，张氏换衣。",
      "text_length": 15
    },
    {
      "event_id": "03060005_e00053",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "谢主隆恩！",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00054",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张氏、金童、玉女同下。〖起五更鼓〗。",
      "text_length": 18
    },
    {
      "event_id": "03060005_e00055",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "曹小姐"
      ],
      "text": "走哇！",
      "text_length": 3
    },
    {
      "event_id": "03060005_e00056",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹小姐上。",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00057",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "曹小姐"
      ],
      "text": "忙将嫂嫂事，报与哥哥知。",
      "text_length": 12
    },
    {
      "event_id": "03060005_e00058",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹小姐"
      ],
      "text": "二哥开门！",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00059",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "贤妹何事？",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00060",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹小姐"
      ],
      "text": "嫂嫂悬梁自缢了！",
      "text_length": 8
    },
    {
      "event_id": "03060005_e00061",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "你且退下！",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00062",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹小姐"
      ],
      "text": "嫂嫂啊！",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00063",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹小姐哭下。",
      "text_length": 6
    },
    {
      "event_id": "03060005_e00064",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "恩人醒来！",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00065",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "插花圣母归了位，三国华佗讨了封。猛然睁开愁眉眼，",
      "text_length": 24
    },
    {
      "event_id": "03060005_e00066",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹彬哭。",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00067",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "贤弟落泪为何情？",
      "text_length": 8
    },
    {
      "event_id": "03060005_e00068",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "嫂嫂自缢了！",
      "text_length": 6
    },
    {
      "event_id": "03060005_e00069",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "嫂嫂啊！贤弟不必如此，嫂嫂必然成仙去了。今日八月十几了？",
      "text_length": 28
    },
    {
      "event_id": "03060005_e00070",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "八月十四。",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00071",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "明日？",
      "text_length": 3
    },
    {
      "event_id": "03060005_e00072",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "八月十五。",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00073",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "八月十五，就是俺光棍家出头之日了。",
      "text_length": 17
    },
    {
      "event_id": "03060005_e00074",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "像你们光棍家，还讲什么根本不成？",
      "text_length": 16
    },
    {
      "event_id": "03060005_e00075",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "贤弟呀！",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00076",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "休道俺光棍家根本不讲，坐一旁听玄郎细说端详：家住在西罗县双龙街上，本姓赵名匡胤表字玄郎。头辈祖名赵高家财甚广，二辈祖名怀庆四海名扬。三辈祖名赵霸残唐为将，子不言父的名四品黄堂。生下了俺玄郎面带奇相，酒醉后杀御乐惹下祸殃。二双亲修书信四路探望，遇柴荣和郑恩关西路旁。我三人尧王庙同把香降，要学那三国中刘备、关、张。董家桥打五虎兄弟各往，柴大哥到怀庆受爵封王。柴仁兄身荣贵不把友忘，差旗牌带书信迎接玄郎。弟兄们同饮酒花亭以上，自分手又相会畅叙情肠。顷刻间鱼池内抖起波浪，吓坏了王府人俱各惊慌。大哥说鱼戏水常来常往，俺玄郎见妖怪甚是猖狂。左挽弓右搭箭对妖撒放，又听得谯楼上鼓打三梆。次日里兄带我金殿来上，郭王爷要报那梦中箭伤。一霎时传旨意将我上绑，柴大哥奏一本刺杀刘王。最不该在金殿海口夸讲，不用兵不带将独下燕邦。走西门遇见了崔龙老将，多亏你举家人搭救玄郎。昨夜晚摆酒宴桌案以上，俺玄郎得二梦记在心旁。",
      "text_length": 398
    },
    {
      "event_id": "03060005_e00077",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "头一梦？",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00078",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "头一梦见华佗三国道长，用宝剑割肉瘤丢入长江。二贤弟若不信观看左膀，",
      "text_length": 33
    },
    {
      "event_id": "03060005_e00079",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹彬看。",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00080",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹彬"
      ],
      "text": "果然是去肉瘤并无损伤。",
      "text_length": 11
    },
    {
      "event_id": "03060005_e00081",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "第二梦？",
      "text_length": 4
    },
    {
      "event_id": "03060005_e00082",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "第二梦见张氏嫂嫂形象，项带绳见玄郎两泪汪汪。我封她为圣母华山以上，有金童和玉女送上山岗。",
      "text_length": 44
    },
    {
      "event_id": "03060005_e00083",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "多谢恩人！",
      "text_length": 5
    },
    {
      "event_id": "03060005_e00084",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "劝贤弟在此处少要来往，搬至在怀庆府可作家乡。柴大哥他是我结义兄长，大小事必然要看在玄郎。监牢内二双亲劳你看望，就说我得了功免挂愁肠。叫贤弟将手铐与我带上，此一去上金殿刺杀刘王。施一礼出门来四下观望，",
      "text_length": 99
    },
    {
      "event_id": "03060005_e00085",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤出门望，曹彬下。",
      "text_length": 11
    },
    {
      "event_id": "03060005_e00086",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "见崔龙人共马各逞豪强。真和假是不是见尔主上，我曹仁不犯法又待何妨！",
      "text_length": 33
    },
    {
      "event_id": "03060005_e00087",
      "play_id": "03060005",
      "scene_id": "03060005_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}