      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大刀手"
      ],
      "text": "呵匕呵。",
      "text_length": 4
    },
    {
      "event_id": "02008019_e00014",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "高行周"
      ],
      "text": "威镇高关，执掌兵权。",
      "text_length": 10
    },
    {
      "event_id": "02008019_e00015",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "高行周"
      ],
      "text": "曾记当年摆战场，五龙二虎逼彦章。兴兵打仗谁敢挡，保定刘王锦家邦。",
      "text_length": 32
    },
    {
      "event_id": "02008019_e00016",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "老夫，高行周，在刘主驾前为臣，官拜东鲁王之职。昨晚夜观天象，赤须火龙前来行刺，老夫本当杀他，恐被天谴五雷击顶。军校！",
      "text_length": 58
    },
    {
      "event_id": "02008019_e00017",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大刀手"
      ],
      "text": "哦。",
      "text_length": 2
    },
    {
      "event_id": "02008019_e00018",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "有请众位将军进帐。",
      "text_length": 9
    },
    {
      "event_id": "02008019_e00019",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "田吉",
        "田庆",
        "刘暗",
        "刘明"
      ],
      "text": "得令！王爷在上，末将等参见。",
      "text_length": 14
    },
    {
      "event_id": "02008019_e00020",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "众位将军，尔等可曾齐备否？",
      "text_length": 13
    },
    {
      "event_id": "02008019_e00021",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "田吉",
        "田庆",
        "刘暗",
        "刘明"
      ],
      "text": "俱已齐备。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00022",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "站立两旁听点。",
      "text_length": 7
    },
    {
      "event_id": "02008019_e00023",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "田吉",
        "田庆",
        "刘暗",
        "刘明"
      ],
      "text": "哦。",
      "text_length": 2
    },
    {
      "event_id": "02008019_e00024",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "田吉。",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00025",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "田吉"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02008019_e00026",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "田庆。",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00027",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "田庆"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02008019_e00028",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "刘暗。",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00029",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘暗"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02008019_e00030",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "刘明。",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00031",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘明"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02008019_e00032",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "众位将军。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00033",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "田吉",
        "田庆",
        "刘暗",
        "刘明"
      ],
      "text": "王爷。",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00034",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "老夫传尔等进帐，非为别事。只因老夫年迈，难以执掌虎头金印。列位将军，有能者，前来执掌。",
      "text_length": 43
    },
    {
      "event_id": "02008019_e00035",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "田吉",
        "田庆",
        "刘暗",
        "刘明"
      ],
      "text": "还有二位少爷。",
      "text_length": 7
    },
    {
      "event_id": "02008019_e00036",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "传。",
      "text_length": 2
    },
    {
      "event_id": "02008019_e00037",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "田吉",
        "田庆",
        "刘暗",
        "刘明"
      ],
      "text": "有请二位少爷。",
      "text_length": 7
    },
    {
      "event_id": "02008019_e00038",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高怀德、高怀亮同上。",
      "text_length": 10
    },
    {
      "event_id": "02008019_e00039",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "爹爹在上，孩儿拜揖。",
      "text_length": 10
    },
    {
      "event_id": "02008019_e00040",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "儿是怀德？",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00041",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高怀德"
      ],
      "text": "儿是怀德。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00042",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "儿是怀亮？",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00043",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高怀亮"
      ],
      "text": "儿是怀亮。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00044",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "哎，哈哈哈！",
      "text_length": 6
    },
    {
      "event_id": "02008019_e00045",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高行周"
      ],
      "text": "擂鼓三通坐大堂，怀德、怀亮站两厢。辕门外来了一个赵……",
      "text_length": 27
    },
    {
      "event_id": "02008019_e00046",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "赵什么？",
      "text_length": 4
    },
    {
      "event_id": "02008019_e00047",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高行周"
      ],
      "text": "我一个“赵”字未出口，两个冤家着了忙。本待不说真情话，絮絮叨叨问端详。罢，罢，罢，且把“赵”字按下了罢，叫声我儿听端详。",
      "text_length": 60
    },
    {
      "event_id": "02008019_e00048",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "儿吓，为父唤你二人进帐，非为别事，只因为父年迈，难以执掌虎头金印，你二人谁能者，前来执掌。",
      "text_length": 45
    },
    {
      "event_id": "02008019_e00049",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高怀德"
      ],
      "text": "孩儿年幼。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00050",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高怀亮"
      ],
      "text": "孩儿年小。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00051",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "唔，动不动年小年幼，可知为父，年方九岁，与尔祖父报仇？",
      "text_length": 27
    },
    {
      "event_id": "02008019_e00052",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "孩儿不知。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00053",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "为父不讲，谅尔也不知，尔且听着！",
      "text_length": 16
    },
    {
      "event_id": "02008019_e00054",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "高行周"
      ],
      "text": "唐僖宗他本是有道皇上，",
      "text_length": 11
    },
    {
      "event_id": "02008019_e00055",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高行周"
      ],
      "text": "庚子年在长安设下教场。那曹州有一人名登金榜，都只为相貌丑赶出科场。祥梅寺贼造反先杀和尚，将唐王赶至在西岐美良。程敬思他本是忠臣良将，沙陀国搬来了老将晋王。",
      "text_length": 77
    },
    {
      "event_id": "02008019_e00056",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "高行周"
      ],
      "text": "卧虎山前收一将，官封一字勇南王。打虎将军太原丧，逼反水贼王彦章。大太保搬取吾父王。你祖太平桥上丧，无影枪下一命亡。",
      "text_length": 57
    },
    {
      "event_id": "02008019_e00057",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "你祖父丧于无影枪下。那时为父，前发不过齐眉，后发不过雁尾，一马来至水贼营盘内，高叫水贼彦章，快快出来受死。只见营盘内，闪出一将，头带乌油盔，身穿乌油铠，跨下乌骓马，亚赛楚霸王。",
      "text_length": 88
    },
    {
      "event_id": "02008019_e00058",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "他是何人？",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00059",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "那就是水贼彦章。一马当先问道，尔是谁家之子，哪家之后，到此何事？此时为父言道，我乃高思继之子，名唤行周，前来与父报仇。那贼闻听，在马上哈哈大笑。",
      "text_length": 72
    },
    {
      "event_id": "02008019_e00060",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "他笑什么？",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00061",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "他笑为父，大不过他一拳，高不过他一膝，劝为父回营，再过三年五载，再来与父报仇。此时为父言道，有志不在年高，无志空长百岁。那贼大怒，手执浑铁镐，分心就刺，为父借势空处藏身，滚鞍躲过。那贼在两军阵前，送了为父一个绰号。",
      "text_length": 107
    },
    {
      "event_id": "02008019_e00062",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "甚么绰号？",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00063",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "名曰滚鞍鹞子。为父用回马枪，分心就刺，那贼用钩马枪躲过，大战数十馀合，不分胜败。为父心生一计，勒马就败，那贼不解其情，催马追赶，为父回头一看，那贼马头，连住为父马尾，为父马尾，连住那贼马头。",
      "text_length": 95
    },
    {
      "event_id": "02008019_e00064",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "爹爹可慌？",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00065",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "为父也不慌。",
      "text_length": 6
    },
    {
      "event_id": "02008019_e00066",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "可忙？",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00067",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "也不忙。紧勒丝繮，将银战杆插在雕鞍，取出祖先铜锤，大叫一声，彦章小儿，招打！",
      "text_length": 38
    },
    {
      "event_id": "02008019_e00068",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高行周"
      ],
      "text": "时衰遇着高鹞子，运去又遇史建唐。铜锤打的兵器丧，打得水贼吐红光。五龙二虎逼他丧，你父才封东鲁王。",
      "text_length": 48
    },
    {
      "event_id": "02008019_e00069",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "怀德挂帅。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00070",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高怀德拜印。",
      "text_length": 6
    },
    {
      "event_id": "02008019_e00071",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 4,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "高怀亮"
      ],
      "text": "哎呀，爹爹吓！",
      "text_length": 7
    },
    {
      "event_id": "02008019_e00072",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高行周"
      ],
      "text": "兵权落在怀德手，怀亮一旁哭嚎啕。",
      "text_length": 16
    },
    {
      "event_id": "02008019_e00073",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "怀亮我儿，为父有尚方宝剑一口，如有不遵令者，先斩后奏，拜剑。",
      "text_length": 30
    },
    {
      "event_id": "02008019_e00074",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高怀亮拜。",
      "text_length": 5
    },
    {
      "event_id": "02008019_e00075",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "听爷吩咐：将人马扎在鹞子岭，有一红脸大汉进关。他若来时，枪头朝里，他若出关，枪头朝外，不要惊唬与他。",
      "text_length": 50
    },
    {
      "event_id": "02008019_e00076",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "田吉",
        "田庆",
        "刘暗",
        "刘明"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00077",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "怀德、怀亮我儿，为父有几句言词，尔等牢牢紧记：",
      "text_length": 23
    },
    {
      "event_id": "02008019_e00078",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "高行周"
      ],
      "text": "昔日楚汉两争强，鸿门设宴害高皇。霸王不听范增语，后来自刎在乌江。",
      "text_length": 32
    },
    {
      "event_id": "02008019_e00079",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "尔等可解得开么？",
      "text_length": 8
    },
    {
      "event_id": "02008019_e00080",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "孩儿解不开。",
      "text_length": 6
    },
    {
      "event_id": "02008019_e00081",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "日后自有应验，下关去罢。",
      "text_length": 12
    },
    {
      "event_id": "02008019_e00082",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高怀德",
        "高怀亮"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "02008019_e00083",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高怀德"
      ],
      "text": "白虎堂上领将令，",
      "text_length": 8
    },
    {
      "event_id": "02008019_e00084",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高怀亮"
      ],
      "text": "弟兄双双扎大营。",
      "text_length": 8
    },
    {
      "event_id": "02008019_e00085",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高怀德、高怀亮同下。",
      "text_length": 10
    },
    {
      "event_id": "02008019_e00086",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高行周"
      ],
      "text": "他弟兄双双下高平，袖内机关怎知情？闷恹恹白虎堂上坐，等候河东姓赵人。",
      "text_length": 34
    },
    {
      "event_id": "02008019_e00087",
