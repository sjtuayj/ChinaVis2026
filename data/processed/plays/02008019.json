      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。四大刀手引高行周同上。",
      "text_length": 16
    },
    {
      "event_id": "02008019_e00013",
      "play_id": "02008019",
      "scene_id": "02008019_s01",
      "scene_no": 1,
      "seq_global": 13,
