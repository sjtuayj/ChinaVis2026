  "events": [
    {
      "event_id": "70902114_e00001",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人随中军同上。",
      "text_length": 8
    },
    {
      "event_id": "70902114_e00002",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "马来。",
      "text_length": 3
    },
    {
      "event_id": "70902114_e00003",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同金钱花",
      "speakers": [
        "众人"
      ],
      "text": "渭城今雨清尘，清尘。轮台古月黄云，黄云。催花羯鼓去从军。枕头上，别情人；刀头上，做功臣。",
      "text_length": 44
    },
    {
      "event_id": "70902114_e00004",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "俺乃玉门关外刘节镇老爷麾下领兵骁将是也。只为土番征战河西，军中少一记室，命新科状元李老爷为参谋，着俺领兵迎接。众将！",
      "text_length": 58
    },
    {
      "event_id": "70902114_e00005",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "70902114_e00006",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "速往灞桥伺候！",
      "text_length": 7
    },
    {
      "event_id": "70902114_e00007",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "70902114_e00008",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同金钱花",
      "speakers": [
        "众人"
      ],
      "text": "枕头上，别情人；刀头上，做功臣。",
      "text_length": 16
    },
    {
      "event_id": "70902114_e00009",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "中军、众人同下。浣纱引霍小玉同上。",
      "text_length": 17
    },
    {
      "event_id": "70902114_e00010",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱"
      ],
      "text": "车来。",
      "text_length": 3
    },
    {
      "event_id": "70902114_e00011",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "金珑璁",
      "speakers": [
        "霍小玉"
      ],
      "text": "春纤余几许？绣征衫亲付与男儿。河桥外，香车驻，看紫骝开道路。",
      "text_length": 30
    },
    {
      "event_id": "70902114_e00012",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "奴家只为李郎，仓促西征，因此禀过母亲，往灞桥送别。",
      "text_length": 25
    },
    {
      "event_id": "70902114_e00013",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱"
      ],
      "text": "启郡主：前面已是灞陵桥了。",
      "text_length": 13
    },
    {
      "event_id": "70902114_e00014",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "咳！哪里是灞陵桥，分明是一座消魂桥也！",
      "text_length": 19
    },
    {
      "event_id": "70902114_e00015",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱"
      ],
      "text": "老爷尚未到来，请郡主歇息片时。",
      "text_length": 15
    },
    {
      "event_id": "70902114_e00016",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "有理。",
      "text_length": 3
    },
    {
      "event_id": "70902114_e00017",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "浣纱、霍小玉同下。众人喝道引李益同上，书童随上。",
      "text_length": 24
    },
    {
      "event_id": "70902114_e00018",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李益"
      ],
      "text": "旌旗日暖散春寒，洒湿沙场泪不干。花里断肠人一刻，明朝相忆路漫漫。",
      "text_length": 32
    },
    {
      "event_id": "70902114_e00019",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "下官李益，名魁春榜，官拜翰林，奉旨往西镇参军，只为军情紧急，火速起行也。",
      "text_length": 36
    },
    {
      "event_id": "70902114_e00020",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同喝道。",
      "text_length": 6
    },
    {
      "event_id": "70902114_e00021",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "李益"
      ],
      "text": "逞军容出塞荣华，这其间有喝不倒的灞陵桥跨。接着阳关路，后拥前呼。",
      "text_length": 32
    },
    {
      "event_id": "70902114_e00022",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "浣纱上。",
      "text_length": 4
    },
    {
      "event_id": "70902114_e00023",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱"
      ],
      "text": "老爷请住马，郡主在此送别。",
      "text_length": 13
    },
    {
      "event_id": "70902114_e00024",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "书童"
      ],
      "text": "老爷，郡主拉笃送别哉。",
      "text_length": 11
    },
    {
      "event_id": "70902114_e00025",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "70902114_e00026",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "点绛唇百忙里陡的个雕鞍住。（白）吩咐暂住头踏。",
      "text_length": 23
    },
    {
      "event_id": "70902114_e00027",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "书童"
      ],
      "text": "吓！嘚，暂住头踏。",
      "text_length": 9
    },
    {
      "event_id": "70902114_e00028",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同允，同下。霍小玉上。霍小玉（白）吓李郎。",
      "text_length": 23
    },
    {
      "event_id": "70902114_e00029",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "夫人。（念）出门何意向边州，",
      "text_length": 14
    },
    {
      "event_id": "70902114_e00030",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "霍小玉"
      ],
      "text": "匹马今朝不少留。",
      "text_length": 8
    },
    {
      "event_id": "70902114_e00031",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李益"
      ],
      "text": "极目关山何日尽，",
      "text_length": 8
    },
    {
      "event_id": "70902114_e00032",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "霍小玉"
      ],
      "text": "断肠丝竹为君愁。",
      "text_length": 8
    },
    {
      "event_id": "70902114_e00033",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "70902114_e00034",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "吓李郎，今日虽是荣行，难教妾不悲怨。此是灞陵桥，妾待折柳尊前，一写阳关之思。",
      "text_length": 38
    },
    {
      "event_id": "70902114_e00035",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "多谢夫人。",
      "text_length": 5
    },
    {
      "event_id": "70902114_e00036",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "浣纱看酒。",
      "text_length": 5
    },
    {
      "event_id": "70902114_e00037",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱"
      ],
      "text": "有酒。",
      "text_length": 3
    },
    {
      "event_id": "70902114_e00038",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "𠮾……（寄生草）怕奏阳关曲。生寒渭水都。是江干桃叶凌波渡，汀洲草碧粘云渍。这河桥柳色迎风诉，（白）这柳呵！",
      "text_length": 53
    },
    {
      "event_id": "70902114_e00039",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "寄生草纤腰倩作绾人丝，可笑它自家飞絮浑难住。",
      "text_length": 22
    },
    {
      "event_id": "70902114_e00040",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "想昨夜呵！（寄生草）倒凤心无阻，交鸳画不如，衾窝宛转春无数，花心历乱魂难驻，阳台半霎云何处。起来鸾袖欲分飞，问芳卿为谁断送春归去？",
      "text_length": 65
    },
    {
      "event_id": "70902114_e00041",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "李郎，妾有泪珠千点，沾君袖也。",
      "text_length": 15
    },
    {
      "event_id": "70902114_e00042",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "咳！可怜！",
      "text_length": 5
    },
    {
      "event_id": "70902114_e00043",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "这泪呵！（寄生草）慢点悬清目，残痕界玉姿。冰壶迸裂蔷薇露，阑干碎滴梨花雨，珠盘溅湿红绡雾。怕层波溜溢粉香渠，这袖呵，轻臙染就湘文筯。",
      "text_length": 66
    },
    {
      "event_id": "70902114_e00044",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "下官此去，不久就归，请止悲泣罢。",
      "text_length": 16
    },
    {
      "event_id": "70902114_e00045",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "霍小玉"
      ],
      "text": "李郎可有甚言语，嘱咐妾身？",
      "text_length": 13
    },
    {
      "event_id": "70902114_e00046",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "夫人吓！",
      "text_length": 4
    },
    {
      "event_id": "70902114_e00047",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "寄生草和闷将闲度，留春伴影居。你通心纽扣蕤蕤束，连心腰彩柔柔护，惊心的衬褥微微絮。分明残梦有些儿，睡醒时好生收拾疼人处。",
      "text_length": 60
    },
    {
      "event_id": "70902114_e00048",
      "play_id": "70902114",
      "scene_id": "70902114_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李益、霍小玉同下。",
      "text_length": 9
    }
  ],
  "roles_inferred": true
}