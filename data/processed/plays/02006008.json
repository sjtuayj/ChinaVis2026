  "events": [
    {
      "event_id": "02006008_e00001",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "场上设白布孝堂，外用桌子，上摆“忠勇公罗成之位”。王氏上。",
      "text_length": 29
    },
    {
      "event_id": "02006008_e00002",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "王氏"
      ],
      "text": "儿夫一命丧沙场，撇奴昼夜好悲伤。",
      "text_length": 16
    },
    {
      "event_id": "02006008_e00003",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王氏"
      ],
      "text": "独坐深闺且自伤，痛夫屈死在沙场。奸王何故行残虐，折我鸾凰梦杳茫。",
      "text_length": 32
    },
    {
      "event_id": "02006008_e00004",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "妾乃罗门王氏。丈夫罗成，为国征讨河北，被二王残害，致遭深陷淤泥河，乱箭射死。撇得奴独守孤帷，好生悲惨。今已午牌时候，不免到灵前哭拜一番。",
      "text_length": 68
    },
    {
      "event_id": "02006008_e00005",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "王氏"
      ],
      "text": "想儿夫文武英雄将，南征北讨世无双。皇天何故不保佑？深陷淤泥万箭亡。愿你早早登仙界，望你阴灵保护我妻房。保佑伊子官高大，荣封追赠恤忠良。可怜不见亲夫面，含悲痛切苦心伤。",
      "text_length": 83
    },
    {
      "event_id": "02006008_e00006",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗春穿孝服上。",
      "text_length": 7
    },
    {
      "event_id": "02006008_e00007",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "罗春"
      ],
      "text": "父骨沙场丧，忠魂化鹤归。",
      "text_length": 12
    },
    {
      "event_id": "02006008_e00008",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "母亲拜揖。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00009",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "罢了。",
      "text_length": 3
    },
    {
      "event_id": "02006008_e00010",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "告母亲知道：方才徐茂功老伯差人来说，秦王赦出天牢，领兵征服河北高丽，杀了苏定方，今已班师。秦王传旨，将苏定方首级，同众公卿赉赠灵前奠祭。即刻就到了。",
      "text_length": 74
    },
    {
      "event_id": "02006008_e00011",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "既如此，快摆香案迎接。",
      "text_length": 11
    },
    {
      "event_id": "02006008_e00012",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "晓得。",
      "text_length": 3
    },
    {
      "event_id": "02006008_e00013",
      "play_id": "02006008",
      "scene_id": "02006008_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王氏、罗春同下。",
      "text_length": 8
    },
    {
      "event_id": "02006008_e00014",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐勣上。",
      "text_length": 4
    },
    {
      "event_id": "02006008_e00015",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "徐勣"
      ],
      "text": "深惜皇朝折栋梁，",
      "text_length": 8
    },
    {
      "event_id": "02006008_e00016",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "尉迟恭上。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00017",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "尉迟恭"
      ],
      "text": "堪怜忠义丧沙场。",
      "text_length": 8
    },
    {
      "event_id": "02006008_e00018",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼上。",
      "text_length": 4
    },
    {
      "event_id": "02006008_e00019",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "秦琼"
      ],
      "text": "中表一生成永别，",
      "text_length": 8
    },
    {
      "event_id": "02006008_e00020",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "程咬金上。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00021",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "程咬金"
      ],
      "text": "奸王误国害忠良。",
      "text_length": 8
    },
    {
      "event_id": "02006008_e00022",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐勣"
      ],
      "text": "我徐绩。",
      "text_length": 4
    },
    {
      "event_id": "02006008_e00023",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尉迟恭"
      ],
      "text": "某尉迟恭。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00024",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "俺秦琼。",
      "text_length": 4
    },
    {
      "event_id": "02006008_e00025",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "咱程咬金。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00026",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "徐勣",
        "尉迟恭",
        "秦琼",
        "程咬金"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "02006008_e00027",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐勣"
      ],
      "text": "可喜秦王平定高丽，回朝奏凯，圣上命我等一同到罗贤弟灵前祭奠，并将苏定方首级献于灵前。",
      "text_length": 42
    },
    {
      "event_id": "02006008_e00028",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "尉迟恭",
        "秦琼",
        "程咬金"
      ],
      "text": "一言未了，想必殿下来也。",
      "text_length": 12
    },
    {
      "event_id": "02006008_e00029",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二内侍⑴一捧祭祀一背人头桶同上，李世民上。",
      "text_length": 21
    },
    {
      "event_id": "02006008_e00030",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "李世民"
      ],
      "text": "烽烟扫尽，痛擎夭摧折，屈坏着万里长城。",
      "text_length": 19
    },
    {
      "event_id": "02006008_e00031",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "徐勣",
        "尉迟恭",
        "秦琼",
        "程咬金"
      ],
      "text": "臣等接驾。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00032",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "02006008_e00033",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "徐勣",
        "尉迟恭",
        "秦琼",
        "程咬金"
      ],
      "text": "愿殿下千岁千千岁。",
      "text_length": 9
    },
    {
      "event_id": "02006008_e00034",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李世民"
      ],
      "text": "扰攘烟尘起战争，专征独扫宇寰清。化家为国皇图永，一统山河乐太平。",
      "text_length": 32
    },
    {
      "event_id": "02006008_e00035",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "孤家秦王世民。为二位王兄王弟谗诤，将孤拘禁天牢。不想河北高丽反叛，父兄命三王元吉领兵征剿，保奏罗王兄为先锋，不发兵卒，只命单身出战，致他马陷淤泥河，乱箭射死。不意被苏定方长驱直进，三王元吉逃回太原，父王命孤出狱，立功赎罪。赖诸将协力，众士同心，平服了河北。今带苏定方首级，同众公卿到罗王兄灵前祭奠。众公卿！",
      "text_length": 153
    },
    {
      "event_id": "02006008_e00036",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "徐勣",
        "尉迟恭",
        "秦琼",
        "程咬金"
      ],
      "text": "臣等有。",
      "text_length": 4
    },
    {
      "event_id": "02006008_e00037",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "就此一同前往。",
      "text_length": 7
    },
    {
      "event_id": "02006008_e00038",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "徐勣",
        "尉迟恭",
        "秦琼",
        "程咬金"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02006008_e00039",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李世民"
      ],
      "text": "跃马扬鞭驾轻车，河北一带惨凄凄。功臣负屈黄泉地，孤王奉旨拜灵祇。",
      "text_length": 32
    },
    {
      "event_id": "02006008_e00040",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "士卒上，报。",
      "text_length": 6
    },
    {
      "event_id": "02006008_e00041",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "士卒"
      ],
      "text": "千岁驾到。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00042",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗春上，跪。",
      "text_length": 6
    },
    {
      "event_id": "02006008_e00043",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "臣罗春接驾，愿殿下千岁千千岁。",
      "text_length": 15
    },
    {
      "event_id": "02006008_e00044",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "02006008_e00045",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "千千岁。",
      "text_length": 4
    },
    {
      "event_id": "02006008_e00046",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "罗王兄灵柩在哪里？",
      "text_length": 9
    },
    {
      "event_id": "02006008_e00047",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗春"
      ],
      "text": "请在中堂。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00048",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "卿家引孤进去。",
      "text_length": 7
    },
    {
      "event_id": "02006008_e00049",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗春应，进。",
      "text_length": 6
    },
    {
      "event_id": "02006008_e00050",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "摆下祭礼。",
      "text_length": 5
    },
    {
      "event_id": "02006008_e00051",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二内侍"
      ],
      "text": "吓。（二内侍同摆祭礼并人头桶。李世民拜。徐勣、尉迟恭、秦琼、程咬金同扶住，同作揖让。徐勣、尉迟恭、秦琼、程咬金同拜，同起。）",
      "text_length": 62
    },
    {
      "event_id": "02006008_e00052",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "啊呀，罗王兄吓！",
      "text_length": 8
    },
    {
      "event_id": "02006008_e00053",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李世民"
      ],
      "text": "想王兄相从已有年，情同骨肉赛桃园。卿家开国功勋大，旗开得胜非等闲。只因误被奸王害，害你屈死在河边。悲伤折我擎天柱，思卿何日还阳间？",
      "text_length": 65
    },
    {
      "event_id": "02006008_e00054",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐勣"
      ],
      "text": "拜灵前祭奠真悲惨，止不住腮边泪涟涟。可怜你是英雄汉，被奸王害你一命丧黄泉。",
      "text_length": 37
    },
    {
      "event_id": "02006008_e00055",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "哭一声贤弟干城将，你代我探主到牢房。冤遇奸王把你害，害你忠良年少亡。",
      "text_length": 34
    },
    {
      "event_id": "02006008_e00056",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "尉迟恭",
        "程咬金"
      ],
      "text": "忙上前祷告心悲切，哭一声贤弟好惨伤。自从识荆来结义，并胆同心扶大唐。恨杀奸王来害你，可怜万箭丧郊荒。",
      "text_length": 50
    },
    {
      "event_id": "02006008_e00057",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "罗春"
      ],
      "text": "稽首叩谢贤恩主，回身谢了伯父众贤良。可怜父亲身先丧，不能同辅大唐王。",
      "text_length": 34
    },
    {
      "event_id": "02006008_e00058",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖内作响〗。",
      "text_length": 6
    },
    {
      "event_id": "02006008_e00059",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "李世民",
        "徐勣",
        "尉迟恭",
        "秦琼",
        "程咬金",
        "罗春"
      ],
      "text": "吓，什么响？",
      "text_length": 6
    },
    {
      "event_id": "02006008_e00060",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成浑身插箭流血手执白绫暗上，立孝堂后高桌上。",
      "text_length": 23
    },
    {
      "event_id": "02006008_e00061",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "罗成"
      ],
      "text": "半空中跑坏了白龙马，为闻吾主祭灵堂。不胜惶悚来款首，感谢王恩天浩荡。又谢众位恩兄长，阴阳间隔泪滂惶。本待犬马图保效，可怜我深陷淤泥魂渺茫。只因气数应该绝，箭下难逃一命亡。但愿吾王登龙位，太平千载庆大唐。",
      "text_length": 101
    },
    {
      "event_id": "02006008_e00062",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "臣启殿下：阴阳间隔，不便下云相见。敢蒙千岁亲临祭奠，为此驾云前来面谢。臣今已列星班，不敢久停，愿千岁善保龙体，以遂众望。各位兄长同心辅政，以助太平。我儿你须孝养母亲，尽孝王事，就此去也。",
      "text_length": 93
    },
    {
      "event_id": "02006008_e00063",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成下。李世民、徐勣、尉迟恭、秦琼、程咬金、罗春同哭。",
      "text_length": 27
    },
    {
      "event_id": "02006008_e00064",
      "play_id": "02006008",
      "scene_id": "02006008_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 51,
