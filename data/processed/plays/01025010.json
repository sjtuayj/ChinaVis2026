  "events": [
    {
      "event_id": "01025010_e00001",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘彦真上。",
      "text_length": 5
    },
    {
      "event_id": "01025010_e00002",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘彦真"
      ],
      "text": "在东宫领了千岁命，迎接母后转回程。暗暗出了皇宫院，不由小王自伤情。想起淫妇西妃女，好叫小王恨在心。依仗父王将你宠，把我欺压不当人。越思越想心头恨，大骂西妃狗贱人！我兄妹与你何仇恨，暗害我们为何情？今日里母后出宫未回转，待小王去接昭阳正院尊。行行正走来得快，",
      "text_length": 128
    },
    {
      "event_id": "01025010_e00003",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘彦真"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01025010_e00004",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘彦真"
      ],
      "text": "那旁又来了对头人。",
      "text_length": 9
    },
    {
      "event_id": "01025010_e00005",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "宫女、太监引唐妃同上。",
      "text_length": 11
    },
    {
      "event_id": "01025010_e00006",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "唐妃"
      ],
      "text": "宫娥摆驾出宫门，来了陪王伴驾人。众星捧月朝前进，",
      "text_length": 24
    },
    {
      "event_id": "01025010_e00007",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐妃"
      ],
      "text": "呵！",
      "text_length": 2
    },
    {
      "event_id": "01025010_e00008",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "唐妃"
      ],
      "text": "銮驾不走是何因？",
      "text_length": 8
    },
    {
      "event_id": "01025010_e00009",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "太子接驾。",
      "text_length": 5
    },
    {
      "event_id": "01025010_e00010",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘彦真"
      ],
      "text": "小王一时把气忍，战战兢兢跪埃尘。儿臣彦真来接驾，",
      "text_length": 24
    },
    {
      "event_id": "01025010_e00011",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "唐妃"
      ],
      "text": "哀家一见怒气嗔！手指狗子高声骂，骂声彦真太不仁。你哪里来是接凤驾，分明是前来安歹心。狗子意高心胆大，瞧不起西宫下院人。不见冤家还自可，一见狗子冒火云。你对父王将言谏，陷害与我为你身。今日见了冤家面，咱们俩结下冤仇似海深。叫人来绑他把宫进，治死畜生免祸根。",
      "text_length": 127
    },
    {
      "event_id": "01025010_e00012",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘彦真"
      ],
      "text": "彦真跌跪泪纷纷，望姨母高开天地恩。虽然儿臣有过犯，也该念我母昭阳伴驾人。",
      "text_length": 36
    },
    {
      "event_id": "01025010_e00013",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐妃"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "01025010_e00014",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "唐妃"
      ],
      "text": "不提你母心不恼，提起你母恼在心。狗贱人曾坐昭阳院，作践西宫不当人。金銮殿上把言谏，她将俺贬在寒宫冷院门。到如今时来运转伴龙驾，三宫六院谁不尊？宫娥忙把宫院进，定叫畜生命归阴！",
      "text_length": 87
    },
    {
      "event_id": "01025010_e00015",
      "play_id": "01025010",
      "scene_id": "01025010_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太监绑刘彦真，众人同下。",
      "text_length": 12
    },
    {
      "event_id": "01025010_e00016",
      "play_id": "01025010",
      "scene_id": "01025010_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "土地上。",
      "text_length": 4
    },
    {
      "event_id": "01025010_e00017",
      "play_id": "01025010",
      "scene_id": "01025010_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "土地"
      ],
      "text": "紫微大帝有大难，慌得吾神不得闲。",
      "text_length": 16
    },
    {
      "event_id": "01025010_e00018",
      "play_id": "01025010",
      "scene_id": "01025010_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "土地下。",
      "text_length": 4
    },
    {
      "event_id": "01025010_e00019",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 19,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "宫女扶刘彦真同上，太监引唐妃同上。",
      "text_length": 17
    },
    {
      "event_id": "01025010_e00020",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 20,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "唐妃"
      ],
      "text": "哀家带怒进宫廷，要报冤仇把气平。宫娥女把药酒忙看过，灌在狗子肚腹中。",
      "text_length": 34
    },
    {
      "event_id": "01025010_e00021",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐妃灌刘彦真。",
      "text_length": 7
    },
    {
      "event_id": "01025010_e00022",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘彦真"
      ],
      "text": "心疼气紧难扎挣，",
      "text_length": 8
    },
    {
      "event_id": "01025010_e00023",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘彦真"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01025010_e00024",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘彦真"
      ],
      "text": "一跤跌在地埃尘。",
      "text_length": 8
    },
    {
      "event_id": "01025010_e00025",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘彦真倒。",
      "text_length": 5
    },
    {
      "event_id": "01025010_e00026",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐妃"
      ],
      "text": "一见畜生赴幽冥，叫人抬起莫消停。将他抛在皂河内，方与哀家免祸星。",
      "text_length": 32
    },
    {
      "event_id": "01025010_e00027",
      "play_id": "01025010",
      "scene_id": "01025010_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太监抬刘彦真同下，众人同下。",
      "text_length": 14
    },
    {
      "event_id": "01025010_e00028",
      "play_id": "01025010",
      "scene_id": "01025010_s04",
      "scene_no": 4,
      "seq_global": 28,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二门神同上。",
      "text_length": 6
    },
    {
      "event_id": "01025010_e00029",
      "play_id": "01025010",
      "scene_id": "01025010_s04",
      "scene_no": 4,
      "seq_global": 29,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "二门神"
      ],
      "text": "神茶玉垒上天庭，凌霄宝殿奏分明。",
      "text_length": 16
    },
    {
      "event_id": "01025010_e00030",
      "play_id": "01025010",
      "scene_id": "01025010_s04",
      "scene_no": 4,
      "seq_global": 30,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二门神同下。",
      "text_length": 6
    },
    {
      "event_id": "01025010_e00031",
      "play_id": "01025010",
      "scene_id": "01025010_s05",
      "scene_no": 5,
      "seq_global": 31,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵妃上。",
      "text_length": 4
    },
    {
      "event_id": "01025010_e00032",
      "play_id": "01025010",
      "scene_id": "01025010_s05",
      "scene_no": 5,
      "seq_global": 32,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "赵妃"
      ],
      "text": "哀家事毕转回宫，不觉眼跳又心惊。适才内侍前来报，西妃害我小娇生。暗暗出了昭阳院，去到皂河查看明。我的皇儿有灾难，命在旦夕少救星。时逢腊月残冬景，天寒地冻水成冰。鹅毛片片迷路径，处处楼台似银城。但愿我儿身有救，满斗焚香谢神灵。",
      "text_length": 112
    },
    {
      "event_id": "01025010_e00033",
      "play_id": "01025010",
      "scene_id": "01025010_s05",
      "scene_no": 5,
      "seq_global": 33,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵妃下。",
      "text_length": 4
    },
    {
      "event_id": "01025010_e00034",
      "play_id": "01025010",
      "scene_id": "01025010_s06",
      "scene_no": 6,
      "seq_global": 34,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四水卒引龙王同上。",
      "text_length": 9
    },
    {
      "event_id": "01025010_e00035",
      "play_id": "01025010",
      "scene_id": "01025010_s06",
      "scene_no": 6,
      "seq_global": 35,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "龙王"
      ],
      "text": "万里乾坤路遥遥，江河湖海透九霄。凌霄宝殿居水府，清波摆动浪滔滔。",
      "text_length": 32
    },
    {
      "event_id": "01025010_e00036",
      "play_id": "01025010",
      "scene_id": "01025010_s06",
      "scene_no": 6,
      "seq_global": 36,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "龙王"
      ],
      "text": "俺，四海龙王是也。只因紫微星君，身临水府有难，须得吾神前去搭救。水卒们，",
      "text_length": 36
    },
    {
      "event_id": "01025010_e00037",
      "play_id": "01025010",
      "scene_id": "01025010_s06",
      "scene_no": 6,
      "seq_global": 37,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四水卒"
      ],
      "text": "圣寿！",
      "text_length": 3
    },
    {
      "event_id": "01025010_e00038",
      "play_id": "01025010",
      "scene_id": "01025010_s06",
      "scene_no": 6,
      "seq_global": 38,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "龙王"
      ],
      "text": "开道皂河去也！",
      "text_length": 7
    },
    {
      "event_id": "01025010_e00039",
      "play_id": "01025010",
      "scene_id": "01025010_s06",
      "scene_no": 6,
      "seq_global": 39,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "龙王"
      ],
      "text": "施展法术显神通，江河湖海冻成冰。水卒开道皂河内，等候皇妃到来临。",
      "text_length": 32
    },
    {
      "event_id": "01025010_e00040",
      "play_id": "01025010",
      "scene_id": "01025010_s06",
      "scene_no": 6,
      "seq_global": 40,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四水卒、龙王同下。",
      "text_length": 9
    },
    {
      "event_id": "01025010_e00041",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 41,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵妃上。",
      "text_length": 4
    },
    {
      "event_id": "01025010_e00042",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 42,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "赵妃"
      ],
      "text": "赵素娘迈步往前行，鹅毛大雪冷难禁。狂风吹得行人冷，一心要去救亲生。行行来至东门外，抬头闪目看分明：果然不比皇宫景，它比别门大改形。楼上放定子母炮，楼下密摆箭雕翎。城左风摆旌旗动，城右兵似一窝蜂。哀家看罢东门景，吸气吞声转身形。恐怕有人来识破，泄漏机关了不成。忙忙转过城关境，暗暗哀家告苍穹。鹅毛大雪迷路径，行动雪地有迹踪。倘若奸妃来赏景，被她识破不相应。若知我儿身有救，必然又把毒计生。须得把雪来除净，方与我儿免祸星。罢罢罢，我拿裙边将雪扫，一步一扫往前行。行行来至皂河径，皂河之内水成冰。哀家施礼忙下跪，祝告龙王在上听：若是我儿身有救，水化冰开显身形。",
      "text_length": 277
    },
    {
      "event_id": "01025010_e00043",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 43,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "龙王、四水卒、刘彦真暗同上。",
      "text_length": 14
    },
    {
      "event_id": "01025010_e00044",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 44,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "赵妃"
      ],
      "text": "赵素娘正在伤心处，一声响亮令人惊。果然水开冰化冻，见一幼子出水平。将我儿携在皂河岸，平坦之地放身形。叫声我儿即刻醒，若有差池母命倾。哀家叫喊多一会，又听我儿哼一声。",
      "text_length": 82
    },
    {
      "event_id": "01025010_e00045",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 45,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "水卒、龙王暗同下。",
      "text_length": 9
    },
    {
      "event_id": "01025010_e00046",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 46,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘彦真"
      ],
      "text": "适才渺渺赴阴城，奸妃害我好苦情。何人救我还阳境，",
      "text_length": 24
    },
    {
      "event_id": "01025010_e00047",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 47,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘彦真"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01025010_e00048",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 48,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘彦真"
      ],
      "text": "又见母后到来临。",
      "text_length": 8
    },
    {
      "event_id": "01025010_e00049",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 49,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵妃"
      ],
      "text": "一见我儿转还生，哀家又喜又伤情。喜的是母子重相会，伤的是湿衣着体冷难禁。忙忙脱下衣一件，与我儿暂且挡雪并遮风。奸妃怎样将你害，细对为娘诉分明。",
      "text_length": 71
    },
    {
      "event_id": "01025010_e00050",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 50,
      "seq_in_scene": 10,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘彦真"
      ],
      "text": "彦真跌跪珠泪倾，多谢母后好恩情。若问奸妃将儿害，儿臣说来母后听：昨日接母进宫廷，遇见西妃狠毒虫。儿臣上前去接驾，不料贼人动无名。手指孩儿高声骂，说我前去把刺行。不容儿说将儿绑，再三哀告不容情。叫人用酒把儿灌，霎时一命丧残生。心疼气紧难扎挣，为儿进了冤死城。多亏母后来搭救，彦真死后又复生。",
      "text_length": 144
    },
    {
      "event_id": "01025010_e00051",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 51,
      "seq_in_scene": 11,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "赵妃"
      ],
      "text": "听罢言来怒气生，不由立刻动无名。奸妃倚仗君王宠，胆敢欺压我子亲生。有朝一日拿住你，太后怎能擅留情。千刀万剐难消恨，剥皮抽筋挖眼睛。割了贼心不算帐，剐骨熬油点天灯。可叹还有金定女，不知奸妃怎待承？叹我儿宫中为太子，你妹金定女俊英。为娘所养你们俩，兄妹二人一母生。到如今被她来作践，公主、太子受苦情。母子不可贪恋住，快些寻路去逃生。倘若被她来知晓，识破机关命定倾。可怜东宫皇太子，只落得路上受贫穷。",
      "text_length": 197
    },
    {
      "event_id": "01025010_e00052",
      "play_id": "01025010",
      "scene_id": "01025010_s07",
      "scene_no": 7,
      "seq_global": 52,
      "seq_in_scene": 12,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘彦真"
      ],
      "text": "彦真不由放悲声，好似狼牙箭穿胸。为儿欲要逃生去，实实难舍母子情。欲待母子常聚会，奸妃知道不容情。彦真必然遭擒获，一定害我命残生。罢罢罢，辞别母后寻路径，哭哭啼啼步难行。若要母子重相见，除非是花儿重开月又明。",
      "text_length": 103
    },
    {
