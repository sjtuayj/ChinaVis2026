  "events": [
    {
      "event_id": "03004001_e00001",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫娥引孙尚香同上。",
      "text_length": 10
    },
    {
      "event_id": "03004001_e00002",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "孙尚香"
      ],
      "text": "恹恹瘦损，怎能消，终日愁闷。",
      "text_length": 14
    },
    {
      "event_id": "03004001_e00003",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙尚香"
      ],
      "text": "别君常挂念，难忘夫妻情。虽无千丈线，万里系人心。",
      "text_length": 24
    },
    {
      "event_id": "03004001_e00004",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "哀家孙氏尚香。只因兄王为讨荆州，定下胭粉之计，将我招赘刘备，不想以假成真。未及三载，他君臣又生一计，命人将我诓回东吴。思想起来，好不愁闷人也。",
      "text_length": 71
    },
    {
      "event_id": "03004001_e00005",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "孙尚香"
      ],
      "text": "孙尚香坐皇宫自思自想，想起了刘皇叔好不惨伤。遭不幸我父王龙归海藏，仲谋兄承父业执掌朝纲。坐江南据九郡贪心妄想，他君臣定巧计要夺荆襄。",
      "text_length": 66
    },
    {
      "event_id": "03004001_e00006",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫娥同上。",
      "text_length": 6
    },
    {
      "event_id": "03004001_e00007",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫娥"
      ],
      "text": "启公主：大事不好了！",
      "text_length": 10
    },
    {
      "event_id": "03004001_e00008",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "03004001_e00009",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫娥"
      ],
      "text": "今有刘贤主，晏驾白帝城了！",
      "text_length": 13
    },
    {
      "event_id": "03004001_e00010",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "怎么讲？",
      "text_length": 4
    },
    {
      "event_id": "03004001_e00011",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫娥"
      ],
      "text": "晏驾白帝城了！",
      "text_length": 7
    },
    {
      "event_id": "03004001_e00012",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "皇叔！夫君！哎呀夫啊！",
      "text_length": 11
    },
    {
      "event_id": "03004001_e00013",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香气椅。",
      "text_length": 6
    },
    {
      "event_id": "03004001_e00014",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "孙尚香"
      ],
      "text": "听一言只觉得神魂飘荡，",
      "text_length": 11
    },
    {
      "event_id": "03004001_e00015",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "不由得尚香女泪洒胸膛。实指望夫妻们同欢同畅，",
      "text_length": 22
    },
    {
      "event_id": "03004001_e00016",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "孙尚香"
      ],
      "text": "皇叔哇……",
      "text_length": 5
    },
    {
      "event_id": "03004001_e00017",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "要相逢除非是梦里黄粱。",
      "text_length": 11
    },
    {
      "event_id": "03004001_e00018",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "且住。想皇叔与我有夫妻之义，他今晏驾白帝城，不免身穿孝服，去到江边一祭便了。宫娥们！",
      "text_length": 42
    },
    {
      "event_id": "03004001_e00019",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫娥"
      ],
      "text": "有！",
      "text_length": 2
    },
    {
      "event_id": "03004001_e00020",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "看孝服伺候！",
      "text_length": 6
    },
    {
      "event_id": "03004001_e00021",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香换孝服。",
      "text_length": 7
    },
    {
      "event_id": "03004001_e00022",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "孙尚香"
      ],
      "text": "喂呀！https://scripts.xikao.com/play/030040012022-03-10",
      "text_length": 52
    },
    {
      "event_id": "03004001_e00023",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "孙尚香"
      ],
      "text": "宫娥女速摆驾长寿宫往，别母后到江边祭奠一场。",
      "text_length": 22
    },
    {
      "event_id": "03004001_e00024",
      "play_id": "03004001",
      "scene_id": "03004001_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香、四宫娥同下。",
      "text_length": 10
    },
    {
      "event_id": "03004001_e00025",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "吴国太"
      ],
      "text": "一日偷闲一日安，",
      "text_length": 8
    },
    {
      "event_id": "03004001_e00026",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二内侍引吴国太同上。",
      "text_length": 10
    },
    {
      "event_id": "03004001_e00027",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "吴国太"
      ],
      "text": "十日无事靠青天。孙权他把大事管，每日征战不得闲。可恨曹丕把位篡，图谋汉室锦江山。我的婿刘备重兴汉，三国纷纷有数年。将身且坐皇宫院，等候我儿来问安。",
      "text_length": 73
    },
    {
      "event_id": "03004001_e00028",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香上。",
      "text_length": 5
    },
    {
      "event_id": "03004001_e00029",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "叹汉皇为社稷今把驾晏，含悲泪进宫去参母问安。",
      "text_length": 22
    },
    {
      "event_id": "03004001_e00030",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "儿臣见驾，愿母后千岁！",
      "text_length": 11
    },
    {
      "event_id": "03004001_e00031",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "03004001_e00032",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "千千岁！",
      "text_length": 4
    },
    {
      "event_id": "03004001_e00033",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "赐坐。",
      "text_length": 3
    },
    {
      "event_id": "03004001_e00034",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "谢坐。喂呀呀……",
      "text_length": 8
    },
    {
      "event_id": "03004001_e00035",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "儿啊，今日进宫，身穿素服，脸带泪痕，为了何事？",
      "text_length": 23
    },
    {
      "event_id": "03004001_e00036",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "启奏母后：今早宫人报道，刘皇叔晏驾白帝城了。",
      "text_length": 22
    },
    {
      "event_id": "03004001_e00037",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "哦，刘皇叔晏驾了？",
      "text_length": 9
    },
    {
      "event_id": "03004001_e00038",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "03004001_e00039",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "唉，可叹哪，可叹！儿啊，你进宫何事？",
      "text_length": 18
    },
    {
      "event_id": "03004001_e00040",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "因此儿臣身穿孝服，奏知母后，要到江边一祭。",
      "text_length": 21
    },
    {
      "event_id": "03004001_e00041",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "儿啊，你虽然与他有夫妻之情，只是你兄王与他有敌国之恨，儿还祭奠他作甚？",
      "text_length": 35
    },
    {
      "event_id": "03004001_e00042",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "唉，母后啊！",
      "text_length": 6
    },
    {
      "event_id": "03004001_e00043",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后说话理太偏，儿臣有本奏根源：都只为荆州讨不转，将儿定计把姻联。荆州未及三年满，又命周善诓儿还。",
      "text_length": 49
    },
    {
      "event_id": "03004001_e00044",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "吴国太"
      ],
      "text": "尚香儿说话理不端，细听为娘说根源：不幸儿父他把驾晏，早年一命丧黄泉。丢下基业无人管，江南九郡付与孙权。今日杀来明日战，只为荆州他不还。定计本是周郎献，才把我儿配凤鸾。劫儿回国是周善，母女分别又团圆。我儿一心去祭奠，一滴何曾到九泉。https://scripts.xikao.com/play/030040012022-03-10",
      "text_length": 164
    },
    {
      "event_id": "03004001_e00045",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后啊！",
      "text_length": 4
    },
    {
      "event_id": "03004001_e00046",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮垛板",
      "speakers": [
        "孙尚香"
      ],
      "text": "说什么祭奠空祭奠，一滴何曾到九泉。儿在东吴他在汉，千里姻缘一线牵。母后不叫儿祭奠，不该与儿配婚男。",
      "text_length": 49
    },
    {
      "event_id": "03004001_e00047",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮垛板",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿本是闺阁女，反道为娘来阻拦。任儿说得莲花现，为娘不准也枉然。",
      "text_length": 32
    },
    {
      "event_id": "03004001_e00048",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮垛板",
      "speakers": [
        "孙尚香"
      ],
      "text": "儿要祭奠偏祭奠，",
      "text_length": 8
    },
    {
      "event_id": "03004001_e00049",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮垛板",
      "speakers": [
        "吴国太"
      ],
      "text": "为娘阻拦要阻拦。",
      "text_length": 8
    },
    {
      "event_id": "03004001_e00050",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03004001_e00051",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮垛板",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后不叫儿祭奠，",
      "text_length": 8
    },
    {
      "event_id": "03004001_e00052",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "罢！",
      "text_length": 2
    },
    {
      "event_id": "03004001_e00053",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮垛板",
      "speakers": [
        "孙尚香"
      ],
      "text": "不如碰死娘面前。",
      "text_length": 8
    },
    {
      "event_id": "03004001_e00054",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮垛板",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿不必行短见，为娘送你到江边。",
      "text_length": 16
    },
    {
      "event_id": "03004001_e00055",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿不必如此，为娘同儿去江边一祭如何？",
      "text_length": 19
    },
    {
      "event_id": "03004001_e00056",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后年迈，不劳前去。现有宫娥陪伴，儿去去就回。",
      "text_length": 23
    },
    {
      "event_id": "03004001_e00057",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "内侍！",
      "text_length": 3
    },
    {
      "event_id": "03004001_e00058",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍甲"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "03004001_e00059",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "看半副銮驾，随你郡主去到江边一祭；千万不可叫你主公知道。",
      "text_length": 28
    },
    {
      "event_id": "03004001_e00060",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍甲"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "03004001_e00061",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后请上，儿臣就此拜别了！",
      "text_length": 13
    },
    {
      "event_id": "03004001_e00062",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "哎呀儿啊，不过一时，何言“拜别”二字？",
      "text_length": 19
    },
    {
      "event_id": "03004001_e00063",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后啊……",
      "text_length": 5
    },
    {
      "event_id": "03004001_e00064",
      "play_id": "03004001",
      "scene_id": "03004001_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
