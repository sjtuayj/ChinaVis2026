      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄忠"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "01017009_e00006",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
