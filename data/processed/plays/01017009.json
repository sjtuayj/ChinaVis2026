      "event_id": "01017009_e00016",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "命你带领三千人马，隐藏在金雁桥下，等候张任到来，不可放他逃走！",
      "text_length": 31
    },
    {
      "event_id": "01017009_e00017",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵云"
      ],
      "text": "得令！",
      "text_length": 3
    },
    {
      "event_id": "01017009_e00018",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵云下。",
      "text_length": 4
    },
    {
      "event_id": "01017009_e00019",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "三将军听令。",
      "text_length": 6
    },
    {
      "event_id": "01017009_e00020",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张飞"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "01017009_e00021",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "命你扮作樵夫模样。在芦苇之中隐藏。擒捉张任，不得有误！",
      "text_length": 27
    },
    {
      "event_id": "01017009_e00022",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张飞"
      ],
      "text": "得令！",
      "text_length": 3
    },
    {
      "event_id": "01017009_e00023",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张飞下。",
      "text_length": 4
    },
    {
      "event_id": "01017009_e00024",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "众将官，准备四轮车辇，待山人出营会敌去者。",
      "text_length": 21
    },
    {
      "event_id": "01017009_e00025",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "诸葛亮"
      ],
      "text": "袖内阴阳安排定，提兵调将捉张任。三军与爷往前进，两军阵前会敌人。",
      "text_length": 32
    },
    {
      "event_id": "01017009_e00026",
      "play_id": "01017009",
      "scene_id": "01017009_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "01017009_e00027",
      "play_id": "01017009",
      "scene_id": "01017009_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四上手引黄忠同上，转场，同下。",
      "text_length": 15
    },
    {
      "event_id": "01017009_e00028",
      "play_id": "01017009",
      "scene_id": "01017009_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套引魏延同上，转场，同下。",
      "text_length": 15
    },
    {
      "event_id": "01017009_e00029",
      "play_id": "01017009",
      "scene_id": "01017009_s04",
      "scene_no": 4,
      "seq_global": 29,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙旗、四英雄、二将引张任同上。",
      "text_length": 16
    },
    {
      "event_id": "01017009_e00030",
      "play_id": "01017009",
      "scene_id": "01017009_s04",
      "scene_no": 4,
      "seq_global": 30,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "张任"
      ],
      "text": "奉主之命守雒城，谨防刘备发来兵。",
      "text_length": 16
    },
    {
      "event_id": "01017009_e00031",
      "play_id": "01017009",
      "scene_id": "01017009_s04",
      "scene_no": 4,
      "seq_global": 31,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "俺，张任。可恨刘备，带领人马夺取西川。是俺奉了主公之令，带兵把守雒城。众将官，起兵前往！",
      "text_length": 44
    },
    {
      "event_id": "01017009_e00032",
      "play_id": "01017009",
      "scene_id": "01017009_s04",
      "scene_no": 4,
      "seq_global": 32,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吹牌子，同下。",
      "text_length": 7
    },
    {
      "event_id": "01017009_e00033",
      "play_id": "01017009",
      "scene_id": "01017009_s05",
      "scene_no": 5,
      "seq_global": 33,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手引张飞同上。",
      "text_length": 9
    },
    {
      "event_id": "01017009_e00034",
      "play_id": "01017009",
      "scene_id": "01017009_s05",
      "scene_no": 5,
      "seq_global": 34,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张飞"
      ],
      "text": "俺，张飞。在帐中奉了军师将令，扮做樵夫模样，藏在芦苇之中，等候张任到来，定要擒他下马。三军的，就此前往！",
      "text_length": 52
    },
    {
      "event_id": "01017009_e00035",
      "play_id": "01017009",
      "scene_id": "01017009_s05",
      "scene_no": 5,
      "seq_global": 35,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "01017009_e00036",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 36,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八卦旗引诸葛亮同上，四龙套、四英雄引张任自下场门同上。",
      "text_length": 27
    },
    {
      "event_id": "01017009_e00037",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 37,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "来者敢么是张任？",
      "text_length": 8
    },
    {
      "event_id": "01017009_e00038",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 38,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "然也。你是何人？敢挡某家去路！",
      "text_length": 15
    },
    {
      "event_id": "01017009_e00039",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 39,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "山人诸葛亮在此。",
      "text_length": 8
    },
    {
      "event_id": "01017009_e00040",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 40,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "想那刘玄德，与吾主乃是同宗兄弟，为何带领人马前来攻取西川？是何道理！",
      "text_length": 34
    },
    {
      "event_id": "01017009_e00041",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 41,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "你主闇弱，不听忠言。吾主刘玄德统领仁义之师，重整汉室社稷。那曹操以百万之众，闻吾之名，望风丧胆，弃甲而逃。似你无名之辈，还不下马投降，等候何时？少时马前被擒，悔之晚矣！",
      "text_length": 84
    },
    {
      "event_id": "01017009_e00042",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 42,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "俺乃堂堂大将，岂能降你？看枪！",
      "text_length": 15
    },
    {
      "event_id": "01017009_e00043",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 43,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "大胆！",
      "text_length": 3
    },
    {
      "event_id": "01017009_e00044",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 44,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张任退。",
      "text_length": 4
    },
    {
      "event_id": "01017009_e00045",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 45,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "杀！",
      "text_length": 2
    },
    {
      "event_id": "01017009_e00046",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 46,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "诸葛亮下，众人随下。张任观察形势。",
      "text_length": 17
    },
    {
      "event_id": "01017009_e00047",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 47,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "杀！",
      "text_length": 2
    },
    {
      "event_id": "01017009_e00048",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 48,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四上手引黄忠同上，起打，黄忠败下。",
      "text_length": 17
    },
    {
      "event_id": "01017009_e00049",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 49,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套引魏延同上，起打，魏延败下。",
      "text_length": 17
    },
    {
      "event_id": "01017009_e00050",
      "play_id": "01017009",
      "scene_id": "01017009_s06",
      "scene_no": 6,
      "seq_global": 50,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张任耍枪花，追下。",
      "text_length": 9
    },
    {
      "event_id": "01017009_e00051",
      "play_id": "01017009",
      "scene_id": "01017009_s07",
      "scene_no": 7,
      "seq_global": 51,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套引赵云同上，转场，同下。",
      "text_length": 15
    },
    {
      "event_id": "01017009_e00052",
      "play_id": "01017009",
      "scene_id": "01017009_s07",
      "scene_no": 7,
      "seq_global": 52,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄忠、魏延同上，过桥，张任追上。",
      "text_length": 16
    },
    {
      "event_id": "01017009_e00053",
      "play_id": "01017009",
      "scene_id": "01017009_s07",
      "scene_no": 7,
      "seq_global": 53,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "且住！那贼败下阵去，待我赶上。吓！来此已是金雁桥。此桥高大，待我卸甲过桥。",
      "text_length": 37
    },
    {
      "event_id": "01017009_e00054",
      "play_id": "01017009",
      "scene_id": "01017009_s07",
      "scene_no": 7,
      "seq_global": 54,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张任脱甲、换靴，上桥。赵云上，枪刺张任，张任翻跟头躲过，与赵云对快枪。张任下，赵云追下。（张任上，黄忠、魏延、赵云同追上，群场开打。黄忠、魏延、赵云同下。张飞上，起打。黄忠、魏延、赵云同上，张飞生擒张任，挟下，众人同下。）",
      "text_length": 111
    },
    {
      "event_id": "01017009_e00055",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 55,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八卦旗引诸葛亮同上，坐帐。黄忠、魏延、赵云、张飞同上。",
      "text_length": 27
    },
    {
      "event_id": "01017009_e00056",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 56,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张飞"
      ],
      "text": "张任拿到！",
      "text_length": 5
    },
    {
      "event_id": "01017009_e00057",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 57,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "绑上来！",
      "text_length": 4
    },
    {
      "event_id": "01017009_e00058",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 58,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张飞"
      ],
      "text": "将张任绑上来！",
      "text_length": 7
    },
    {
      "event_id": "01017009_e00059",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 59,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手押张任同上。",
      "text_length": 9
    },
    {
      "event_id": "01017009_e00060",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 60,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "张任"
      ],
      "text": "大将失机入罗网，盖世英雄无下场！",
      "text_length": 16
    },
    {
      "event_id": "01017009_e00061",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 61,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "胆大张任，见了山人为何不跪？",
      "text_length": 14
    },
    {
      "event_id": "01017009_e00062",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 62,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "俺乃西蜀上将，岂肯跪你！",
      "text_length": 12
    },
    {
      "event_id": "01017009_e00063",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 63,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "你既被擒，若肯归降我主，定是封侯之位。",
      "text_length": 19
    },
    {
      "event_id": "01017009_e00064",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 64,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张任"
      ],
      "text": "某今被擒，你要杀就杀，要斩就斩，何必多言！若要叫俺归降，除非是日从西起！",
      "text_length": 36
    },
    {
      "event_id": "01017009_e00065",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 65,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "张任"
      ],
      "text": "怒气不息把话讲，诸葛孔明听端详：我本西蜀有名将，岂肯在此把你降！",
      "text_length": 32
    },
    {
      "event_id": "01017009_e00066",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 66,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "诸葛亮"
      ],
      "text": "山人只把好言讲，大胆小儿敢逞狂。人来推出将他斩，",
      "text_length": 24
    },
    {
      "event_id": "01017009_e00067",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 67,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张飞磨刀，斫，张任倒。",
      "text_length": 11
    },
    {
      "event_id": "01017009_e00068",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 68,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "诸葛亮"
      ],
      "text": "果然是忠义一儿郎。",
      "text_length": 9
    },
    {
      "event_id": "01017009_e00069",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 69,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "张任忠心为主，执意不降。来，将他尸首不可损坏，用棺木盛殓，埋葬高坡，以表忠义。",
      "text_length": 39
    },
    {
      "event_id": "01017009_e00070",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 70,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众下手抬张任同下。",
      "text_length": 9
    },
    {
      "event_id": "01017009_e00071",
      "play_id": "01017009",
      "scene_id": "01017009_s09",
      "scene_no": 9,
      "seq_global": 71,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "后帐排宴，与众位将军贺功！",
