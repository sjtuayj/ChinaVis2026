      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仕林"
      ],
      "text": "嗳，母亲，将当年受苦之事，说与孩儿知道。",
      "text_length": 20
    },
    {
      "event_id": "01002020_e00041",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
