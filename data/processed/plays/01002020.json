      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仕林"
      ],
      "text": "谢母亲。",
      "text_length": 4
    },
    {
      "event_id": "01002020_e00034",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "那旁有块顽石，我儿坐下。儿吓！哪里来的一身荣耀？",
      "text_length": 24
    },
    {
      "event_id": "01002020_e00035",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
