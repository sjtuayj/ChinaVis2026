  "events": [
    {
      "event_id": "01002020_e00001",
      "play_id": "01002020",
      "scene_id": "01002020_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍同上，许仕林上。",
      "text_length": 11
    },
    {
      "event_id": "01002020_e00002",
      "play_id": "01002020",
      "scene_id": "01002020_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "许仕林"
      ],
      "text": "一色杏花红十里，状元归去马如飞。",
      "text_length": 16
    },
    {
      "event_id": "01002020_e00003",
      "play_id": "01002020",
      "scene_id": "01002020_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许仕林坐。",
      "text_length": 5
    },
    {
      "event_id": "01002020_e00004",
      "play_id": "01002020",
      "scene_id": "01002020_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "许仕林"
      ],
      "text": "中状元名扬天下，琼林宴帽插宫花。喜则喜三宫摘宴，稳坐在三元上下。",
      "text_length": 32
    },
    {
      "event_id": "01002020_e00005",
      "play_id": "01002020",
      "scene_id": "01002020_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仕林"
      ],
      "text": "下官许仕林，蒙圣恩得中头名状矣。想我母亲雷峰塔受苦，是我上殿启奏一本，今日奉旨回家祭祖。左右，吩咐外厢开道。",
      "text_length": 54
    },
    {
      "event_id": "01002020_e00006",
      "play_id": "01002020",
      "scene_id": "01002020_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、许仕林同下。",
      "text_length": 10
    },
    {
      "event_id": "01002020_e00007",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "塔神上。",
      "text_length": 4
    },
    {
      "event_id": "01002020_e00008",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "塔神"
      ],
      "text": "力大无穷顶砚台，玉帝符旨把某差。",
      "text_length": 16
    },
    {
      "event_id": "01002020_e00009",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "塔神"
      ],
      "text": "我乃塔神是也，奉了玉帝符旨，在此看守雷峰塔。不免在此伺候。",
      "text_length": 29
    },
    {
      "event_id": "01002020_e00010",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍同上，同挖门，许仕林上，拈香。",
      "text_length": 18
    },
    {
      "event_id": "01002020_e00011",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "许仕林"
      ],
      "text": "母亲！老娘！娘亲！",
      "text_length": 9
    },
    {
      "event_id": "01002020_e00012",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "许仕林"
      ],
      "text": "见此塔不由人双泪落定，",
      "text_length": 11
    },
    {
      "event_id": "01002020_e00013",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "许仕林"
      ],
      "text": "怎不叫儿痛在心。",
      "text_length": 8
    },
    {
      "event_id": "01002020_e00014",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "许仕林"
      ],
      "text": "哭一声老娘亲不能相见，儿的娘吓……",
      "text_length": 17
    },
    {
      "event_id": "01002020_e00015",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许仕林躺下，四青袍同下。",
      "text_length": 12
    },
    {
      "event_id": "01002020_e00016",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "塔神"
      ],
      "text": "白氏仙姑，你儿前来祭奠于你，快些走动。",
      "text_length": 19
    },
    {
      "event_id": "01002020_e00017",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "白素贞"
      ],
      "text": "在塔中思娇儿珠泪滚滚，",
      "text_length": 11
    },
    {
      "event_id": "01002020_e00018",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "白素贞上。",
      "text_length": 5
    },
    {
      "event_id": "01002020_e00019",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "苦哇……",
      "text_length": 4
    },
    {
      "event_id": "01002020_e00020",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "白素贞"
      ],
      "text": "又听得揭谛神呼唤一声。我这里向前去开言便问，问尊神呼唤我所为何情？",
      "text_length": 33
    },
    {
      "event_id": "01002020_e00021",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "塔神"
      ],
      "text": "你儿许仕林，前来祭奠于你。",
      "text_length": 13
    },
    {
      "event_id": "01002020_e00022",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "可容我母子相见？",
      "text_length": 8
    },
    {
      "event_id": "01002020_e00023",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "塔神"
      ],
      "text": "容你母子相见。",
      "text_length": 7
    },
    {
      "event_id": "01002020_e00024",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "有劳了！",
      "text_length": 4
    },
    {
      "event_id": "01002020_e00025",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "塔神下。",
      "text_length": 4
    },
    {
      "event_id": "01002020_e00026",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "白素贞"
      ],
      "text": "听说是小孩儿前来祭奠，不由我一阵阵泪洒胸前。我这里向前来用目观看，又只见小娇儿倒在塔前。",
      "text_length": 44
    },
    {
      "event_id": "01002020_e00027",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "我儿醒来……",
      "text_length": 6
    },
    {
      "event_id": "01002020_e00028",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "许仕林"
      ],
      "text": "耳边厢又听得有人唤声，",
      "text_length": 11
    },
    {
      "event_id": "01002020_e00029",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "许仕林"
      ],
      "text": "急忙上前开言问：今日下官来到此，你是何人叫仕林？",
      "text_length": 24
    },
    {
      "event_id": "01002020_e00030",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "白素贞"
      ],
      "text": "我的儿你不必将娘来问，我就是在塔中受苦的娘亲。",
      "text_length": 23
    },
    {
      "event_id": "01002020_e00031",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "许仕林"
      ],
      "text": "听说母亲到来临，怎不叫儿痛在心！走上前来忙跪定，一一从头说儿听。",
      "text_length": 32
    },
    {
      "event_id": "01002020_e00032",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
