    },
    {
      "event_id": "01002020_e00036",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仕林"
      ],
      "text": "孩儿得中头名状元，故而这身荣耀。",
      "text_length": 16
    },
    {
      "event_id": "01002020_e00037",
      "play_id": "01002020",
