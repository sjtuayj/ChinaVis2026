      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "这也是为娘命该如此。",
      "text_length": 10
    },
    {
      "event_id": "01002020_e00040",
      "play_id": "01002020",
      "scene_id": "01002020_s02",
