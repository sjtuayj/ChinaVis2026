  "events": [
    {
      "event_id": "70902119_e00001",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "潘必正上。",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00002",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "潘必正"
      ],
      "text": "月明云淡露华浓，欹枕愁听四壁蛩。伤秋宋玉赋西风，落叶惊残梦。",
      "text_length": 30
    },
    {
      "event_id": "70902119_e00003",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "小生对此溶溶夜月，悄悄闲庭，背井离乡，孤衾独枕，好生烦闷。呀，不免到白云楼下闲步一回，多少是好。",
      "text_length": 48
    },
    {
      "event_id": "70902119_e00004",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "潘必正"
      ],
      "text": "闲步芳尘数落红。",
      "text_length": 8
    },
    {
      "event_id": "70902119_e00005",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈妙常上。",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00006",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "陈妙常"
      ],
      "text": "粉墙花影自重重，帘卷残荷水殿风。抱琴弹向月明中，香袅金猊动。",
      "text_length": 30
    },
    {
      "event_id": "70902119_e00007",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "我妙常，连日冗冗俗事，未曾整理冰弦。今夜月明如水，夜色新凉，不免弹潇湘水云一曲，稍寄幽情。",
      "text_length": 45
    },
    {
      "event_id": "70902119_e00008",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "陈妙常"
      ],
      "text": "人在蓬莱第几宫。",
      "text_length": 8
    },
    {
      "event_id": "70902119_e00009",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "潘必正"
      ],
      "text": "步虚声度许飞琼，乍听还疑别院风。",
      "text_length": 16
    },
    {
      "event_id": "70902119_e00010",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "妙！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00011",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "潘必正"
      ],
      "text": "听凄凄楚楚那声中，谁家夜月琴三弄。细数离情曲未终。",
      "text_length": 25
    },
    {
      "event_id": "70902119_e00012",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "陈妙常"
      ],
      "text": "朱弦声杳恨溶溶，",
      "text_length": 8
    },
    {
      "event_id": "70902119_e00013",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "原来陈姑在此操琴，门儿半掩，不免挨身而进。",
      "text_length": 21
    },
    {
      "event_id": "70902119_e00014",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "陈妙常"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00015",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "陈妙常"
      ],
      "text": "长叹空随几阵风。",
      "text_length": 8
    },
    {
      "event_id": "70902119_e00016",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "弹得好吓！",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00017",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "陈妙常"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00018",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "陈妙常"
      ],
      "text": "仙郎何处入帘栊，早是人惊恐。",
      "text_length": 14
    },
    {
      "event_id": "70902119_e00019",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "小儿独坐无聊，步月闲行到此，惊动了。",
      "text_length": 18
    },
    {
      "event_id": "70902119_e00020",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "相公此来呵！",
      "text_length": 6
    },
    {
      "event_id": "70902119_e00021",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "懒画眉",
      "speakers": [
        "陈妙常"
      ],
      "text": "莫不为听云水声寒一曲中？",
      "text_length": 12
    },
    {
      "event_id": "70902119_e00022",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "小生忽听花下，琴声嘹亮，清响绝伦，不觉闲步到此。",
      "text_length": 24
    },
    {
      "event_id": "70902119_e00023",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "小道亦见月明如水，夜色清凉，故而操弄丝桐，少遣岑寂。远辱尊听，实切惶恐。",
      "text_length": 36
    },
    {
      "event_id": "70902119_e00024",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "好说。",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00025",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "久闻足下，指法精妙，操弄绝佳。欲乘此兴，请教一曲如何？",
      "text_length": 27
    },
    {
      "event_id": "70902119_e00026",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "小生略知一二，只是班门弄斧，怎好出丑。",
      "text_length": 19
    },
    {
      "event_id": "70902119_e00027",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "休得太谦，定要请教。",
      "text_length": 10
    },
    {
      "event_id": "70902119_e00028",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "如此请。",
      "text_length": 4
    },
    {
      "event_id": "70902119_e00029",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "请坐。",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00030",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "有坐。好琴吓！",
      "text_length": 7
    },
    {
      "event_id": "70902119_e00031",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "琴曲",
      "speakers": [
        "潘必正"
      ],
      "text": "雉朝雊兮清霜，惨孤飞兮无双。念寡阴兮少阳，怨鳏居兮彷徨，彷徨。",
      "text_length": 31
    },
    {
      "event_id": "70902119_e00032",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "好！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00033",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "出丑！",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00034",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "此乃雉朝飞也。君方盛年，何故弹此无妻之曲？",
      "text_length": 21
    },
    {
      "event_id": "70902119_e00035",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "小生实未有妻！",
      "text_length": 7
    },
    {
      "event_id": "70902119_e00036",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "这也不关我事！",
      "text_length": 7
    },
    {
      "event_id": "70902119_e00037",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "欲求仙姑……",
      "text_length": 6
    },
    {
      "event_id": "70902119_e00038",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00039",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "呀，面教一曲如何？",
      "text_length": 9
    },
    {
      "event_id": "70902119_e00040",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "既听佳音，以清俗耳，何必初学，又乱芳声。",
      "text_length": 20
    },
    {
      "event_id": "70902119_e00041",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "休得太谦，请教了。",
      "text_length": 9
    },
    {
      "event_id": "70902119_e00042",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "但恐污耳。",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00043",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "好说。",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00044",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00045",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00046",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "请坐。",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00047",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "有坐。",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00048",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "献丑了。",
      "text_length": 4
    },
    {
      "event_id": "70902119_e00049",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "琴曲",
      "speakers": [
        "陈妙常"
      ],
      "text": "烟淡淡兮轻云，香霭霭兮桂阴。",
      "text_length": 14
    },
    {
      "event_id": "70902119_e00050",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "请教。叹长宵兮孤冷，",
      "text_length": 10
    },
    {
      "event_id": "70902119_e00051",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "弹得好吓！",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00052",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "陈妙常"
      ],
      "text": "请坐！",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00053",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "琴曲",
      "speakers": [
        "陈妙常"
      ],
      "text": "抱玉兔兮自温，自温。",
      "text_length": 10
    },
    {
      "event_id": "70902119_e00054",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "好！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00055",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "出丑！",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00056",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "此乃广寒游也，正是出家人所弹之曲。只是长宵孤冷，难消遣些！",
      "text_length": 29
    },
    {
      "event_id": "70902119_e00057",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "潘相公，好言重吓！我们出家人，有甚难消遣处？",
      "text_length": 22
    },
    {
      "event_id": "70902119_e00058",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "这也难道！",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00059",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "嗳！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00060",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "陈妙常"
      ],
      "text": "长清短清，那管人离恨？云心水心，有甚闲愁闷？一度春来，一番花褪，怎生上我眉痕？云掩柴门，钟儿磬儿在枕上听。梅子座中焚，梅花帐绝尘，果然是冰清玉润。长长短短，有谁评论？怕谁评论？",
      "text_length": 88
    },
    {
      "event_id": "70902119_e00061",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "仙姑，吓！",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00062",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "更声漏声，独坐谁相问？琴声怨声，两下无凭准。翡翠衾寒，芙蓉月印，三星照人如有心。",
      "text_length": 40
    },
    {
      "event_id": "70902119_e00063",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "仙姑吓！",
      "text_length": 4
    },
    {
      "event_id": "70902119_e00064",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "只怕露冷霜凝，衾儿枕儿谁共温？",
      "text_length": 15
    },
    {
      "event_id": "70902119_e00065",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "潘相公，你出言太狂，屡屡讥诮。呀，莫非有意轻薄奴家？好吓！我去告诉你姑娘，看你如何分解？",
      "text_length": 44
    },
    {
      "event_id": "70902119_e00066",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "仙姑，小生信口相嘲，出言颠倒，伏乞海涵！",
      "text_length": 20
    },
    {
      "event_id": "70902119_e00067",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "巫峡恨云深，桃源羞自寻。",
      "text_length": 12
    },
    {
      "event_id": "70902119_e00068",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "仙姑！",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00069",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "你是个慈悲方寸，望恕却少年心性，少年心性。",
      "text_length": 21
    },
    {
      "event_id": "70902119_e00070",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "告辞！",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00071",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "言语冒犯。",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00072",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "好说。咳！",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00073",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "潘必正"
      ],
      "text": "她把心肠铁样坚，",
      "text_length": 8
    },
    {
      "event_id": "70902119_e00074",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "陈妙常"
      ],
      "text": "岂无春意恋尘凡。",
      "text_length": 8
    },
    {
      "event_id": "70902119_e00075",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "潘必正"
      ],
      "text": "今朝两下轻离别，一夜相思枕上看。",
      "text_length": 16
    },
    {
      "event_id": "70902119_e00076",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "潘相公，花荫深处，仔细行走。",
      "text_length": 14
    },
    {
      "event_id": "70902119_e00077",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "如此借灯一行。",
      "text_length": 7
    },
    {
      "event_id": "70902119_e00078",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "啐！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00079",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "呀！看陈姑十分有意于我，及至挑动她，她又着恼。待我躲过一边，听她说些什么。",
      "text_length": 37
    },
    {
      "event_id": "70902119_e00080",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "潘必正下。",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00081",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "呀！听寂然无声，想是他进书馆去了。咳！潘郎吓潘郎！",
      "text_length": 25
    },
    {
      "event_id": "70902119_e00082",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "陈妙常"
      ],
      "text": "你是个天生俊生，曾占风流性。看他无情有情，只见他笑脸儿来相问。我也心里聪明，",
      "text_length": 38
    },
    {
      "event_id": "70902119_e00083",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "陈妙常"
      ],
      "text": "适才呵！",
      "text_length": 4
    },
    {
      "event_id": "70902119_e00084",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "陈妙常"
      ],
      "text": "把脸儿假狠，口儿里装做硬。我待要应承，这羞惭怎应他那一声？我见了他假惺惺，",
      "text_length": 37
    },
    {
      "event_id": "70902119_e00085",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "陈妙常"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00086",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "陈妙常"
      ],
      "text": "别了他常挂心。看这些花阴月影，凄凄冷冷，照他孤另，照奴孤另！",
      "text_length": 30
    },
    {
      "event_id": "70902119_e00087",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "夜深人静，不免抱琴进去罢。正是：",
      "text_length": 16
    },
    {
      "event_id": "70902119_e00088",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "陈妙常"
      ],
      "text": "此情空满怀，未许人知道。明月照孤帏，泪落知多少！",
      "text_length": 24
    },
    {
      "event_id": "70902119_e00089",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "潘必正嗽。",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00090",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "吓？",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00091",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "吓？",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00092",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈妙常"
      ],
      "text": "啐！",
      "text_length": 2
    },
    {
      "event_id": "70902119_e00093",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈妙常下。",
      "text_length": 5
    },
    {
      "event_id": "70902119_e00094",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 94,
      "seq_in_scene": 94,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "吓哈……小生在此，听了半晌，虽不甚明白——",
      "text_length": 21
    },
    {
      "event_id": "70902119_e00095",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 95,
      "seq_in_scene": 95,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "听她一生两声，句句含愁闷。看她人情道情，多是尘凡性。",
      "text_length": 26
    },
    {
      "event_id": "70902119_e00096",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 96,
      "seq_in_scene": 96,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "妙常！",
      "text_length": 3
    },
    {
      "event_id": "70902119_e00097",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 97,
      "seq_in_scene": 97,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "你一曲琴声，凄清风韵，怎教人不断送青春？那更玉软香温，情儿意儿那些儿不动人？她独自理瑶琴，",
      "text_length": 45
    },
    {
      "event_id": "70902119_e00098",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 98,
      "seq_in_scene": 98,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "身上寒冷了！",
      "text_length": 6
    },
    {
      "event_id": "70902119_e00099",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 99,
      "seq_in_scene": 99,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "我独立苍苔冷。分明是西厢行径，",
      "text_length": 15
    },
    {
      "event_id": "70902119_e00100",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 100,
      "seq_in_scene": 100,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "潘必正"
      ],
      "text": "老天吓！",
      "text_length": 4
    },
    {
      "event_id": "70902119_e00101",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 101,
      "seq_in_scene": 101,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "朝元歌",
      "speakers": [
        "潘必正"
      ],
      "text": "早早成就少年秦晋，少年秦晋！",
      "text_length": 14
    },
    {
      "event_id": "70902119_e00102",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 102,
      "seq_in_scene": 102,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘必正"
      ],
      "text": "呀唷！身上寒冷了！寒、寒、寒冷了！",
      "text_length": 17
    },
    {
      "event_id": "70902119_e00103",
      "play_id": "70902119",
      "scene_id": "70902119_s01",
      "scene_no": 1,
      "seq_global": 103,
      "seq_in_scene": 103,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "潘必正下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}