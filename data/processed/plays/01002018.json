    },
    {
      "event_id": "01002018_e00070",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "是！",
      "text_length": 2
    },
    {
      "event_id": "01002018_e00071",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 71,
