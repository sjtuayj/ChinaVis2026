      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘清提"
      ],
      "text": "快快念来。",
      "text_length": 5
    },
    {
      "event_id": "01002018_e00058",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "是！",
      "text_length": 2
    },
    {
      "event_id": "01002018_e00059",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "目莲"
      ],
      "text": "对准西方身拜定，快将枷锁离娘身。",
      "text_length": 16
    },
    {
      "event_id": "01002018_e00060",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘清提"
      ],
      "text": "为娘双目不明，如何是好？",
      "text_length": 12
    },
    {
      "event_id": "01002018_e00061",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "有佛法。",
      "text_length": 4
    },
    {
      "event_id": "01002018_e00062",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘清提"
      ],
      "text": "快快用来。",
      "text_length": 5
    },
    {
      "event_id": "01002018_e00063",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "遵命！",
      "text_length": 3
    },
