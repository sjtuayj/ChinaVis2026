      "mode_label": "三叫头",
      "speakers": [
        "刘清提"
      ],
      "text": "罗卜！我儿！儿吓！",
      "text_length": 9
    },
    {
      "event_id": "01002018_e00054",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "刘清提"
      ],
      "text": "娘只说阴曹府无报应，天网恢恢有神灵。",
      "text_length": 18
    },
    {
      "event_id": "01002018_e00055",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘清提"
      ],
      "text": "儿吓，为娘披枷带锁，如何是好？",
      "text_length": 15
    },
    {
      "event_id": "01002018_e00056",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "有佛法。",
