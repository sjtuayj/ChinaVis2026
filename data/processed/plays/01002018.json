      "event_id": "01002018_e00064",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "目莲"
      ],
      "text": "对准西方身拜定，取来了甘露水付与娘亲。",
      "text_length": 19
    },
    {
      "event_id": "01002018_e00065",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘清提"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01002018_e00066",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "刘清提"
      ],
      "text": "娘只说母子不能见，谁知相逢地狱门。",
      "text_length": 17
    },
    {
      "event_id": "01002018_e00067",
      "play_id": "01002018",
