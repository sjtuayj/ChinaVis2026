      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "目莲"
      ],
      "text": "唵嘛呢叭咪吽……",
      "text_length": 8
    },
    {
      "event_id": "01002018_e00051",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "哑唷哑唷……不要如此！众鬼卒，将刘氏清提，押出都城。",
      "text_length": 26
    },
    {
      "event_id": "01002018_e00052",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
