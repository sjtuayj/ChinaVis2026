      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘清提"
      ],
      "text": "儿吓，为娘肚中饥饿，如何是好？",
      "text_length": 15
    },
    {
      "event_id": "01002018_e00068",
      "play_id": "01002018",
      "scene_id": "01002018_s01",
