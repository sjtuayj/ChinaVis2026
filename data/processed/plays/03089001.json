      "mode_label": "白",
      "speakers": [
        "女马童"
      ],
      "text": "请姑娘上马！",
      "text_length": 6
    },
    {
      "event_id": "03089001_e00003",
      "play_id": "03089001",
      "scene_id": "03089001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花上，起霸。四文堂、四女兵同上。",
      "text_length": 18
    },
    {
      "event_id": "03089001_e00004",
      "play_id": "03089001",
