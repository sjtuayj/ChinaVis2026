      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "佘赛花"
      ],
      "text": "我翻身跨上桃花马！",
      "text_length": 9
    },
    {
      "event_id": "03089001_e00005",
      "play_id": "03089001",
      "scene_id": "03089001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "女马童带马，佘赛花上马。",
      "text_length": 12
    },
    {
      "event_id": "03089001_e00006",
      "play_id": "03089001",
