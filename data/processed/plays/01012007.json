    },
    {
      "event_id": "01012007_e00099",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 99,
      "seq_in_scene": 99,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "扶好了。",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00100",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 100,
      "seq_in_scene": 100,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "去也去也，回宫去也！唐明皇将奴骗，辜负好良宵。骗得我欲上欢悦，万岁，只落冷清清独自回宫去也！",
      "text_length": 46
    },
