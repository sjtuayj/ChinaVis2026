      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "01012007_e00088",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "娘娘有话对你说：你若称了我的心，合了我的意，我便来，来，来一本奏当今，卿家吓，管叫你官上加官职！",
      "text_length": 48
    },
    {
