      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "裴力士、高力士同上。",
      "text_length": 10
    },
    {
      "event_id": "01012007_e00002",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "裴力士"
      ],
      "text": "天上神仙府，",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00003",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "高力士"
      ],
      "text": "人间宰相家。",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00004",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "裴力士"
      ],
      "text": "若要真富贵，",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00005",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "高力士"
      ],
      "text": "除非帝王家。",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00006",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "请了！",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00007",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "今日万岁爷同娘娘前往百花亭饮宴，你我小心伺候。香烟缭绕，想必娘娘来也！",
      "text_length": 35
    },
    {
      "event_id": "01012007_e00008",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "你我分班伺候。",
      "text_length": 7
    },
    {
      "event_id": "01012007_e00009",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "01012007_e00010",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "裴力士、高力士分站。",
      "text_length": 10
    },
    {
      "event_id": "01012007_e00011",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "杨玉环"
      ],
      "text": "摆驾！",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00012",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、四宫女同上，杨玉环上。",
      "text_length": 15
    },
    {
      "event_id": "01012007_e00013",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "海岛冰轮初转腾，见玉兔又转东升。冰轮离海岛，乾坤分外明，皓月当空，恰便是嫦娥离月宫。",
      "text_length": 42
    },
    {
      "event_id": "01012007_e00014",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "娘娘千岁！",
      "text_length": 5
    },
    {
      "event_id": "01012007_e00015",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "二卿平身。",
      "text_length": 5
    },
    {
      "event_id": "01012007_e00016",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "千千岁！",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00017",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杨玉环"
      ],
      "text": "独坐皇宫有数年，圣驾宠爱我占先。宫中冷落多寂寞，辜负嫦娥独自眠。",
      "text_length": 32
    },
    {
      "event_id": "01012007_e00018",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "妾乃杨玉环，蒙主宠爱，钦点贵妃，这且不言。昨日圣上命我往百花亭大摆筵宴。吓，高、裴二卿摆驾！",
      "text_length": 46
    },
    {
      "event_id": "01012007_e00019",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00020",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "好似嫦娥下九重，凄凄冷落广寒宫。吓，广寒宫。",
      "text_length": 22
    },
    {
      "event_id": "01012007_e00021",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "启娘娘：来此已是玉石桥！",
      "text_length": 12
    },
    {
      "event_id": "01012007_e00022",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "摆驾。",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00023",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "玉石桥斜依把栏杆靠，",
      "text_length": 10
    },
    {
      "event_id": "01012007_e00024",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "高曲"
      ],
      "text": "金丝鲤鱼朝见娘娘！",
      "text_length": 9
    },
    {
      "event_id": "01012007_e00025",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "欢见鱼戏水，金丝鲤鱼在水面上漂，水上漂。",
      "text_length": 20
    },
    {
      "event_id": "01012007_e00026",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "当空雁儿飞来了！",
      "text_length": 8
    },
    {
      "event_id": "01012007_e00027",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "01012007_e00028",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "当空雁儿飞腾，闻奴声影落画屏。",
      "text_length": 15
    },
    {
      "event_id": "01012007_e00029",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "启娘娘：来此百花亭！",
      "text_length": 10
    },
    {
      "event_id": "01012007_e00030",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "正行时宫人来禀，轻移来在百花厅。",
      "text_length": 16
    },
    {
      "event_id": "01012007_e00031",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "高、裴二卿，",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00032",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "娘娘。",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00033",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "待圣驾前来，速便通报。",
      "text_length": 11
    },
    {
      "event_id": "01012007_e00034",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "公爷，这事瞒不过去，咱俩就禀了罢。启娘娘：驾转西宫去了！",
      "text_length": 28
    },
    {
      "event_id": "01012007_e00035",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "你待怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01012007_e00036",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "驾转西宫去了！",
      "text_length": 7
    },
    {
      "event_id": "01012007_e00037",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "起过了！",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00038",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "谢娘娘！",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00039",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "呀，昨日圣上命我百花厅设宴。哎，怎么今日驾转西宫？哦，谅必是这贱人之意！咳，由他去罢！吓，高、裴二卿看宴，待你娘娘自饮！",
      "text_length": 60
    },
    {
      "event_id": "01012007_e00040",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "领旨！",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00041",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "启娘娘：宫娥们敬酒。",
      "text_length": 10
    },
    {
      "event_id": "01012007_e00042",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "敬的什么酒？",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00043",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "龙凤酒。",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00044",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "何为龙凤酒？",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00045",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "乃是圣上与娘娘所饮之酒，名曰龙凤酒。",
      "text_length": 18
    },
    {
      "event_id": "01012007_e00046",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "好，呈上来。",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00047",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "启娘娘：奴婢敬酒。",
      "text_length": 9
    },
    {
      "event_id": "01012007_e00048",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "敬的什么酒？",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00049",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "太平酒。",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00050",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "何为太平酒？",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00051",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "满朝文武所做，名曰太平酒。",
      "text_length": 13
    },
    {
      "event_id": "01012007_e00052",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "好，呈上来。",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00053",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00054",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "启娘娘：奴婢敬酒。",
      "text_length": 9
    },
    {
      "event_id": "01012007_e00055",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "你敬的什么酒？",
      "text_length": 7
    },
    {
      "event_id": "01012007_e00056",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "通宵酒。",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00057",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "唗！呀呀啐！哪个与你同什么宵！",
      "text_length": 15
    },
    {
      "event_id": "01012007_e00058",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "启娘娘：不要动怒，此酒也是满朝文武不分昼夜所造，故尔叫做通宵酒。",
      "text_length": 32
    },
    {
      "event_id": "01012007_e00059",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "好，呈上来。",
      "text_length": 6
    },
    {
      "event_id": "01012007_e00060",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00061",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "同宵捧金盅，高裴二卿接手捧。人生在世如春梦，奴且开怀饮数盅。",
      "text_length": 30
    },
    {
      "event_id": "01012007_e00062",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "看娘娘酒性不足，只恐还饮酒，你我小心伺候。",
      "text_length": 21
    },
    {
      "event_id": "01012007_e00063",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "高、裴二卿，你娘娘酒性未足，看大觥伺候。",
      "text_length": 20
    },
    {
      "event_id": "01012007_e00064",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01012007_e00065",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同窝下。〖柳腰金〗。裴力士、高力士同上。",
      "text_length": 22
    },
    {
      "event_id": "01012007_e00066",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "你我打扫打扫，摆试起来。有请娘娘！",
      "text_length": 17
    },
    {
      "event_id": "01012007_e00067",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同上，杨玉环穿宫妆上，做身段。杨玉环下腰饮醉三斗醉。",
      "text_length": 28
    },
    {
      "event_id": "01012007_e00068",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "圣驾到，圣驾到！",
      "text_length": 8
    },
    {
      "event_id": "01012007_e00069",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01012007_e00070",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "杨玉环"
      ],
      "text": "听报道万岁驾到百花亭，",
      "text_length": 11
    },
    {
      "event_id": "01012007_e00071",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "娘娘酒性差不多了，你我来接驾。娘娘速去接驾。",
      "text_length": 22
    },
    {
      "event_id": "01012007_e00072",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "急急忙忙跪在地埃尘。",
      "text_length": 10
    },
    {
      "event_id": "01012007_e00073",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同跪。",
      "text_length": 5
    },
    {
      "event_id": "01012007_e00074",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "妾妃杨玉环接驾来迟，望万岁恕罪。",
      "text_length": 16
    },
    {
      "event_id": "01012007_e00075",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "启娘娘：奴婢诓驾。",
      "text_length": 9
    },
    {
      "event_id": "01012007_e00076",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "怎么讲？",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00077",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
