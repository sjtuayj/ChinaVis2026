      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "奴婢没有胆子。",
      "text_length": 7
    },
    {
      "event_id": "01012007_e00085",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "哎，",
      "text_length": 2
    },
    {
      "event_id": "01012007_e00086",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "你若不称奴的心，不合奴的意，我便来，来，来朝一本奏当今，唗，狗才吓，管叫你一命见阎君，哎，见阎君！高力士在哪里？",
      "text_length": 56
    },
    {
      "event_id": "01012007_e00087",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 87,
