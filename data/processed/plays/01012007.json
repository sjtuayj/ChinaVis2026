      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "01012007_e00081",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "娘娘有话对你说：你若是称了我的心，合了我的意，我便来，来，来，来朝一本奏当今，卿家吓，管叫你官上加官职！",
      "text_length": 52
    },
    {
      "event_id": "01012007_e00082",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "裴力士"
      ],
      "text": "奴婢不敢。",
      "text_length": 5
    },
    {
      "event_id": "01012007_e00083",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "你待怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01012007_e00084",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
