      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "啐啐啐！",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00096",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 96,
      "seq_in_scene": 96,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "狗才吓！你若是不称我的心，不合我的意，我便来，来，来朝一本奏当今，唗，狗才吓，管叫你革职为庶民，哎，为庶民！安禄山在哪里？想你当初进宫之时你娘娘怎生待你，何等爱你？至今日你忘恩负义，玉美人倒在鞧韆驾上。",
      "text_length": 101
    },
    {
      "event_id": "01012007_e00097",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 97,
      "seq_in_scene": 97,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "裴力士",
        "高力士"
      ],
      "text": "天色已晚，请娘娘回宫。",
      "text_length": 11
    },
    {
      "event_id": "01012007_e00098",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 98,
      "seq_in_scene": 98,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
