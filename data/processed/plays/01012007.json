      "seq_in_scene": 77,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "奴婢诓驾。",
      "text_length": 5
    },
    {
      "event_id": "01012007_e00078",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨玉环"
      ],
      "text": "呀呀啐！",
      "text_length": 4
    },
    {
      "event_id": "01012007_e00079",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄平板",
      "speakers": [
        "杨玉环"
      ],
      "text": "自古道酒不醉人人自醉，色不迷人人自迷。哎，人自迷。裴力士在哪里？",
      "text_length": 32
    },
    {
      "event_id": "01012007_e00080",
      "play_id": "01012007",
      "scene_id": "01012007_s01",
      "scene_no": 1,
