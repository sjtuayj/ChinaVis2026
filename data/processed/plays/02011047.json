  "events": [
    {
      "event_id": "02011047_e00001",
      "play_id": "02011047",
      "scene_id": "02011047_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥上。",
      "text_length": 5
    },
    {
      "event_id": "02011047_e00002",
      "play_id": "02011047",
      "scene_id": "02011047_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "端正好",
      "speakers": [
        "费贞娥"
      ],
      "text": "蕰君仇，含国恨，切切地，蕰君仇，愤愤地，含国恨。誓捐躯，要把那仇人手刃，因此上苟且偷生一息存。这就里谁知悯，",
      "text_length": 54
    },
    {
      "event_id": "02011047_e00003",
      "play_id": "02011047",
      "scene_id": "02011047_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "滚绣球",
      "speakers": [
        "费贞娥"
      ],
      "text": "俺切着齿点绛唇，揾着泪施脂粉。故意儿花簇簇巧梳着云鬓，锦层层穿蓍衫裙。怀儿里冷飕飕匕首寒光喷，俺佯娇假媚妆凝蠢巧语花言诌佞人。纤纤玉手剜仇人目，细细银牙啖贼子心。要与那漆肤豫让争声誉，断臂要离争智能。拼得个身为齑粉，拼得个骨化飞尘。誓把那九重帝主沉冤泄，四海苍生怨气伸。方显得大明朝有个女佳人。",
      "text_length": 147
    },
    {
      "event_id": "02011047_e00004",
      "play_id": "02011047",
      "scene_id": "02011047_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "奴家费氏，小字贞娥。自幼选入宫闱，以充嫔御。蒙国母娘娘命我服侍公主，不想流贼篡夺我国，逼死君父，一家骨肉死于非命。可笑那些臣子，竟没有一个为国报仇泄恨，难道如此奇冤，就干休了不成？我想忠义之事，男女皆可做得，为此我在宫中将那一匕首藏于身旁，又假装公主模样，指望得近闯贼，杀此巨寇，替君父报仇。不想又将奴赐与他兄弟一只虎为配。罢，且待他来时，奴自有道理。呀！听鼓乐之声，是此贼来也，我不免乔装欢笑去对他便了。",
      "text_length": 203
    },
    {
      "event_id": "02011047_e00005",
      "play_id": "02011047",
      "scene_id": "02011047_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥下。",
      "text_length": 5
    },
    {
      "event_id": "02011047_e00006",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小军、李固同上。",
      "text_length": 9
    },
    {
      "event_id": "02011047_e00007",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "李固"
      ],
      "text": "拓地开疆胆气豪，从龙附凤佐皇朝。龙潜且作赵匡义，有日天心属我曹。",
      "text_length": 32
    },
    {
      "event_id": "02011047_e00008",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "俺，李固。蒙皇兄赐我公主与俺成婚，众将备了筵宴，与俺称贺，被他们你一杯，我一盏，吃得大醉，方才放我回营。呸！好不知趣也！",
      "text_length": 60
    },
    {
      "event_id": "02011047_e00009",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小军"
      ],
      "text": "二大王回营。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00010",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "回避。",
      "text_length": 3
    },
    {
      "event_id": "02011047_e00011",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小军同下。二宫女暗同上。",
      "text_length": 13
    },
    {
      "event_id": "02011047_e00012",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "二大王回营，公主娘娘有请。",
      "text_length": 13
    },
    {
      "event_id": "02011047_e00013",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥上。",
      "text_length": 5
    },
    {
      "event_id": "02011047_e00014",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主，拜揖。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00015",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军万福！",
      "text_length": 5
    },
    {
      "event_id": "02011047_e00016",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "啊哈哈哈哈！妙啊！这一福，就酥了俺半边。",
      "text_length": 20
    },
    {
      "event_id": "02011047_e00017",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军乃盖世英雄，皇朝栋梁。",
      "text_length": 13
    },
    {
      "event_id": "02011047_e00018",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "不敢，愚夫不才，怎当公主称羡。",
      "text_length": 15
    },
    {
      "event_id": "02011047_e00019",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "奴家乃亡国之女，不堪侍寝宫闱。",
      "text_length": 15
    },
    {
      "event_id": "02011047_e00020",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "好说。公主乃金枝玉叶，凤女龙孙，万望勿嫌愚夫粗莽，就是千万之幸。今后宫中之事，悉凭公主掌握。凡有吩咐，小将一一从命。",
      "text_length": 58
    },
    {
      "event_id": "02011047_e00021",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "但夫妇乃人伦之始，当行花烛之礼，合卺之仪，方成大礼。",
      "text_length": 26
    },
    {
      "event_id": "02011047_e00022",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主说得是。侍女们，摆宴过来。待俺与公主交拜。",
      "text_length": 23
    },
    {
      "event_id": "02011047_e00023",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "喜筵俱已完备。",
      "text_length": 7
    },
    {
      "event_id": "02011047_e00024",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主请。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00025",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军请。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00026",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "银台上好辉煌也！",
      "text_length": 8
    },
    {
      "event_id": "02011047_e00027",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "02011047_e00028",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "叨叨令",
      "speakers": [
        "费贞娥"
      ],
      "text": "银台上煌煌的凤烛墩，金猊儿袅袅香烟喷。",
      "text_length": 19
    },
    {
      "event_id": "02011047_e00029",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主，我和你一夜夫妻百夜恩呀。",
      "text_length": 15
    },
    {
      "event_id": "02011047_e00030",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "叨叨令",
      "speakers": [
        "费贞娥"
      ],
      "text": "恁道一夜夫妻百夜恩，试问恁三生石上可有良缘分？",
      "text_length": 23
    },
    {
      "event_id": "02011047_e00031",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主，早些睡了吧。",
      "text_length": 9
    },
    {
      "event_id": "02011047_e00032",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "叨叨令",
      "speakers": [
        "费贞娥"
      ],
      "text": "他只待流苏帐暖洞房春，高堂月满巫山近。恁便逗上了蓝桥几层，还只怕飘飘渺渺的波涛滚。",
      "text_length": 41
    },
    {
      "event_id": "02011047_e00033",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军请。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00034",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主请。干！哈哈哈！我好乐也！",
      "text_length": 15
    },
    {
      "event_id": "02011047_e00035",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "叨叨令",
      "speakers": [
        "费贞娥"
      ],
      "text": "恁道是乐煞人也么哥，",
      "text_length": 10
    },
    {
      "event_id": "02011047_e00036",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "我好喜也！",
      "text_length": 5
    },
    {
      "event_id": "02011047_e00037",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "叨叨令",
      "speakers": [
        "费贞娥"
      ],
      "text": "又道是乐煞人也么哥。",
      "text_length": 10
    },
    {
      "event_id": "02011047_e00038",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "待俺回敬公主一杯。",
      "text_length": 9
    },
    {
      "event_id": "02011047_e00039",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军所赐，奴家自当遵命。也要将军奉陪一大杯。",
      "text_length": 22
    },
    {
      "event_id": "02011047_e00040",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "当得。侍女们，取巨觥来。",
      "text_length": 12
    },
    {
      "event_id": "02011047_e00041",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "02011047_e00042",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主请。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00043",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军请。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00044",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李固吐。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00045",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "02011047_e00046",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "叨叨令",
      "speakers": [
        "费贞娥"
      ],
      "text": "赤紧的蠢不喇沙叱利，也学些丰和韵。",
      "text_length": 17
    },
    {
      "event_id": "02011047_e00047",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军，将军。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00048",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主，俺醉得紧了，安寝了吧。",
      "text_length": 14
    },
    {
      "event_id": "02011047_e00049",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军，侍女们皆辛苦了，将喜筵分散她们去吧。",
      "text_length": 21
    },
    {
      "event_id": "02011047_e00050",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "也要留几个房中服侍。",
      "text_length": 10
    },
    {
      "event_id": "02011047_e00051",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "房中奴家自能侍奉巾栉，可叫她们去吧。",
      "text_length": 18
    },
    {
      "event_id": "02011047_e00052",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "想是公主害羞，不好解衣就寝。也罢，侍女们，公主賞你们酒宴，谢了公主，各自去吧。",
      "text_length": 39
    },
    {
      "event_id": "02011047_e00053",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "多谢公主娘娘。",
      "text_length": 7
    },
    {
      "event_id": "02011047_e00054",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "掌灯送入洞房。",
      "text_length": 7
    },
    {
      "event_id": "02011047_e00055",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女同下。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00056",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军，为何今日还披此铠甲？",
      "text_length": 13
    },
    {
      "event_id": "02011047_e00057",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "向在皇兄帐中护卫，提防奸细，日夜不能卸甲。",
      "text_length": 21
    },
    {
      "event_id": "02011047_e00058",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "如今天下已定，还虑甚奸细？况今宵乃是将军百年喜日，岂可穿此不祥之服。",
      "text_length": 34
    },
    {
      "event_id": "02011047_e00059",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "有理。待我唤侍女们来卸甲。",
      "text_length": 13
    },
    {
      "event_id": "02011047_e00060",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "不消唤她们，待奴亲与将军卸甲，才是妇道。",
      "text_length": 20
    },
    {
      "event_id": "02011047_e00061",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "只是劳动不当。",
      "text_length": 7
    },
    {
      "event_id": "02011047_e00062",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "好说。",
      "text_length": 3
    },
    {
      "event_id": "02011047_e00063",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "脱布衫",
      "speakers": [
        "费贞娥"
      ],
      "text": "除下了铁兜鍪凤翅鳞峋，放下了宝龙泉偷看利刃。松下了狮鸾带玉扣双扪，卸下了煻猊铠锁子龙鳞。",
      "text_length": 44
    },
    {
      "event_id": "02011047_e00064",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "啊呀呀呀！",
      "text_length": 5
    },
    {
      "event_id": "02011047_e00065",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军尊臂为何如此？",
      "text_length": 9
    },
    {
      "event_id": "02011047_e00066",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "前日在宁武关被周遇吉打了一鞭，至今尚未痊愈。",
      "text_length": 22
    },
    {
      "event_id": "02011047_e00067",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "原来如此。待奴扶将军入帐安寝。",
      "text_length": 15
    },
    {
      "event_id": "02011047_e00068",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "公主，我欲火如焚，按纳不定，求你早些睡吧。",
      "text_length": 21
    },
    {
      "event_id": "02011047_e00069",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "待奴除了簪珥，脱了袍服就来。",
      "text_length": 14
    },
    {
      "event_id": "02011047_e00070",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李固"
      ],
      "text": "就要来的呀。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00071",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "就来的。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00072",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "小梁州",
      "speakers": [
        "费贞娥"
      ],
      "text": "除下了翠翘宝髻耳珰瑱，脱却了凤滚龙氲氤。俺把那金莲儿扎凤鞋跟，防滑褪紧扎起绣罗裙。",
      "text_length": 41
    },
    {
      "event_id": "02011047_e00073",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "么篇",
      "speakers": [
        "费贞娥"
      ],
      "text": "听听房栊寂寂悄无人，",
      "text_length": 10
    },
    {
      "event_id": "02011047_e00074",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内打更。",
      "text_length": 4
    },
    {
      "event_id": "02011047_e00075",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "么篇",
      "speakers": [
        "费贞娥"
      ],
      "text": "又听得戍漏频频。",
      "text_length": 8
    },
    {
      "event_id": "02011047_e00076",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军，将军。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00077",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "么篇",
      "speakers": [
        "费贞娥"
      ],
      "text": "觑着他瞇醉眼醒还昏，休惊盹心窝内把宝刀抡。",
      "text_length": 21
    },
    {
      "event_id": "02011047_e00078",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥刺李固。",
      "text_length": 7
    },
    {
      "event_id": "02011047_e00079",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "快活三",
      "speakers": [
        "费贞娥"
      ],
      "text": "钢刀上冤气伸，银灯下冤家殒。",
      "text_length": 14
    },
    {
      "event_id": "02011047_e00080",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "叹苍天不佑。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00081",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "快活三",
      "speakers": [
        "费贞娥"
      ],
      "text": "不能够把巨寇刃，便便死向泉台。犹兀自含余恨，",
      "text_length": 22
    },
    {
      "event_id": "02011047_e00082",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女同上。",
      "text_length": 6
    },
    {
      "event_id": "02011047_e00083",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "二大王与公主成亲，为何房中喧嚷，我们进去看看。哎呀！二大王为何满身鲜血倒在地下？呀，原来被人刺死了。啊，你为何将二大王刺死？拿你去见大王。",
      "text_length": 69
    },
    {
      "event_id": "02011047_e00084",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "唗！谁敢来！我原非公主。",
      "text_length": 12
    },
    {
      "event_id": "02011047_e00085",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "你是何人？",
      "text_length": 5
    },
    {
      "event_id": "02011047_e00086",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "我乃费氏宫人。",
      "text_length": 7
    },
    {
      "event_id": "02011047_e00087",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "呀啐！原来也是我辈。",
      "text_length": 10
    },
    {
      "event_id": "02011047_e00088",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "今日杀此逆贼，替君父报仇，便将我凌迟碎剐，亦不畏惧。",
      "text_length": 26
    },
    {
      "event_id": "02011047_e00089",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "你配了二大王，享荣华，受富贵，也不辱没了你。况何等将你庞爱，你也不该将他剌死。",
      "text_length": 39
    },
    {
      "event_id": "02011047_e00090",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "嗳！",
      "text_length": 2
    },
    {
      "event_id": "02011047_e00091",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "朝天子",
      "speakers": [
        "费贞娥"
      ],
      "text": "恁道谎阳台雨云，哎呀莽巫山秦晋，可知俺女专诸不解江皋韵。俺含羞怯酬语揾泪擎樽，遇冤家难含忍。拼得个柳憔花翠，可也珠残玉殒。哎呀早难道，贪恋荣华，忘却终天恨。",
      "text_length": 78
    },
    {
      "event_id": "02011047_e00092",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 87,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "拿你去见大王，就是个哩。",
      "text_length": 12
    },
    {
      "event_id": "02011047_e00093",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 93,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "嗳！",
      "text_length": 2
    },
    {
      "event_id": "02011047_e00094",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 94,
      "seq_in_scene": 89,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "朝天子",
      "speakers": [
        "费贞娥"
      ],
      "text": "一任他碎骨粉身，一任他扬灰碾尘。今日里含笑归泉。",
      "text_length": 24
    },
    {
      "event_id": "02011047_e00095",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 95,
      "seq_in_scene": 90,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "哎呀费贞娥呀，费贞娥，可惜你大才小用了。",
      "text_length": 20
    },
    {
      "event_id": "02011047_e00096",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 96,
      "seq_in_scene": 91,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "朝天子",
      "speakers": [
        "费贞娥"
      ],
      "text": "喔又又何必多磨吻。",
      "text_length": 9
    },
    {
      "event_id": "02011047_e00097",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 97,
      "seq_in_scene": 92,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "呀，你看此贼又活了。",
      "text_length": 10
    },
    {
      "event_id": "02011047_e00098",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 98,
      "seq_in_scene": 93,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥自刎下。",
      "text_length": 7
    },
    {
      "event_id": "02011047_e00099",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 99,
      "seq_in_scene": 94,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "哎呀，她竟自刎了。好个烈性女子。我们将尸首抬过一边，报与大王知道。正是：",
      "text_length": 36
    },
    {
      "event_id": "02011047_e00100",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 100,
      "seq_in_scene": 95,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "二宫女"
      ],
      "text": "三寸气在千般用，一命无常万事休。",
      "text_length": 16
    },
    {
      "event_id": "02011047_e00101",
      "play_id": "02011047",
      "scene_id": "02011047_s02",
      "scene_no": 2,
      "seq_global": 101,
      "seq_in_scene": 96,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女同下。",
      "text_length": 6
    }
  ],
  "roles_inferred": true
}