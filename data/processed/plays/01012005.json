  "events": [
    {
      "event_id": "01012005_e00001",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王朝、马汉引包拯同上。",
      "text_length": 11
    },
    {
      "event_id": "01012005_e00002",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "包拯"
      ],
      "text": "一片丹心，保宋主，锦绣龙庭。",
      "text_length": 14
    },
    {
      "event_id": "01012005_e00003",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "包拯"
      ],
      "text": "黑暗暗乌纱盖顶，明亮亮玉带随身。上金殿君王见喜，下朝班文武皆尊。",
      "text_length": 32
    },
    {
      "event_id": "01012005_e00004",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "老夫包拯，宋室为臣，官拜龙图阁大学士，兼理开封府尹。只因陈州干旱三载，圣上令马国舅前去散粮，谁想他克扣皇粮万担。众百姓告下御状，万岁令老夫前去查明此事。是我连退数本不去，十家保官上殿，保我出京，游街三日，前去放粮。王朝马汉，人役可齐？",
      "text_length": 117
    },
    {
      "event_id": "01012005_e00005",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "王朝",
        "马汉"
      ],
      "text": "具已齐备。",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00006",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "吩咐外厢开道。",
      "text_length": 7
    },
    {
      "event_id": "01012005_e00007",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "王朝",
        "马汉"
      ],
      "text": "外厢开道！",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00008",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍同上。",
      "text_length": 6
    },
    {
      "event_id": "01012005_e00009",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "包拯"
      ],
      "text": "忆昔当年赴科场，",
      "text_length": 8
    },
    {
      "event_id": "01012005_e00010",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "包拯"
      ],
      "text": "在二堂辞别了我的嫂娘。上京时打从在定远县过，走山西和太原一路奔忙。太行山遇贼人打贿击掌，我得中他人头送上公堂。山岗上辞别了刘贼响马，",
      "text_length": 66
    },
    {
      "event_id": "01012005_e00011",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "包拯"
      ],
      "text": "不分昼夜到科场。三篇文章做得好，试官点我状元郎。跨马游街把官闯，偶遇见宫娥彩女笑一场。宋王爷道我的面貌丑，贬去了试官，摘去了状元郎。多亏了恩师王丞相，他带我包拯二次见君王。大喝一声你就往前闯，游街三日去放粮。",
      "text_length": 104
    },
    {
      "event_id": "01012005_e00012",
      "play_id": "01012005",
      "scene_id": "01012005_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00013",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马妃、二宫女同上。",
      "text_length": 9
    },
    {
      "event_id": "01012005_e00014",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "马妃"
      ],
      "text": "金龙盘玉柱，彩凤绕画梁。",
      "text_length": 12
    },
    {
      "event_id": "01012005_e00015",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "马妃"
      ],
      "text": "头戴珠翠彩凤冠，身穿锦绣滚龙衫。陪王伴驾皇王宠，执掌西宫伴君眠。",
      "text_length": 32
    },
    {
      "event_id": "01012005_e00016",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马妃"
      ],
      "text": "哀家马氏，兄长马龙。只因陈州干旱三载，圣上命我兄长前去放粮，不想他克扣军饷。圣上二次有命，命包拯前去放粮。我想此人铁面无私，恐他查明此事，与我兄长不便，是我今早在正宫国母台前，讨下半副銮驾，去到御街，与黑贼作对。宫娥，",
      "text_length": 109
    },
    {
      "event_id": "01012005_e00017",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "宫女同允。",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00018",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马妃"
      ],
      "text": "吩咐銮仪走上！",
      "text_length": 7
    },
    {
      "event_id": "01012005_e00019",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "宫女"
      ],
      "text": "銮仪走上！",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00020",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "銮驾自两旁分上。",
      "text_length": 8
    },
    {
      "event_id": "01012005_e00021",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马妃"
      ],
      "text": "摆驾御街！",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00022",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同允。",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00023",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "马妃"
      ],
      "text": "兄长做事太不成，",
      "text_length": 8
    },
    {
      "event_id": "01012005_e00024",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "马妃"
      ],
      "text": "不该克扣众黎民。圣上又命包文正，铁面无私不容情。宫娥摆驾御街进，单等南衙小包拯。",
      "text_length": 40
    },
    {
      "event_id": "01012005_e00025",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯、四青袍、王朝、马汉同上。",
      "text_length": 15
    },
    {
      "event_id": "01012005_e00026",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "适才离了文华殿，辞别两班文武官。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00027",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "王朝",
        "马汉"
      ],
      "text": "銮驾挡道！",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00028",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "转道！",
      "text_length": 3
    },
    {
      "event_id": "01012005_e00029",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "只见銮驾御街挡，娘娘为何出宫廷？",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00030",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯、四青袍、王朝、马汉同下。",
      "text_length": 15
    },
    {
      "event_id": "01012005_e00031",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "马妃"
      ],
      "text": "满江撒下千丝网，哪怕鱼儿不上钩。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00032",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯、四青袍、王朝、马汉同上。",
      "text_length": 15
    },
    {
      "event_id": "01012005_e00033",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "包拯生来不怕人，他是君来我是臣。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00034",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "王朝",
        "马汉"
      ],
      "text": "銮驾挡道！",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00035",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "转道！",
      "text_length": 3
    },
    {
      "event_id": "01012005_e00036",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "三番两次把道挡，倒叫包拯解不明。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00037",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯、四青袍、王朝、马汉同下。",
      "text_length": 15
    },
    {
      "event_id": "01012005_e00038",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "马妃"
      ],
      "text": "宫娥摆驾后街进，我看包拯哪里行。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00039",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "包拯、四青袍、王朝、马汉同上。",
      "text_length": 15
    },
    {
      "event_id": "01012005_e00040",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "在金殿奉王命谁敢违抗，黑暗暗出朝堂亚赛阎王！",
      "text_length": 22
    },
    {
      "event_id": "01012005_e00041",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王朝"
      ],
      "text": "銮驾挡道！",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00042",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "转道！",
      "text_length": 3
    },
    {
      "event_id": "01012005_e00043",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王朝"
      ],
      "text": "转道不及！",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00044",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "住轿！",
      "text_length": 3
    },
    {
      "event_id": "01012005_e00045",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "包拯"
      ],
      "text": "御街落下一只凤，",
      "text_length": 8
    },
    {
      "event_id": "01012005_e00046",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "包拯"
      ],
      "text": "好一似雀鸟离却山林。上打黄罗伞一把，下有彩旗数十根。左旁抱定玉儿印，宫娥彩女两边分。右边抱的尚方剑，押定满朝文武臣。天大地大皇王大，",
      "text_length": 66
    },
    {
      "event_id": "01012005_e00047",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "包拯"
      ],
      "text": "见君不参有罪人。包文正撩袍忙跪定，",
      "text_length": 17
    },
    {
      "event_id": "01012005_e00048",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "宫女同笑。",
      "text_length": 5
    },
    {
      "event_id": "01012005_e00049",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "01012005_e00050",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "包拯"
      ],
      "text": "宫娥彩女笑连声。是是是来明白了，笑俺包拯黑脸人。人来看过爷的无价宝，遮住包拯黑面人。走向前，忙跪定，头不敢抬来眼不敢睁。",
      "text_length": 60
    },
    {
      "event_id": "01012005_e00051",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "马妃"
      ],
      "text": "明明知道将他问，你是何臣说分明。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00052",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "娘娘把臣忘记了，臣是南衙小包拯。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00053",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "马妃"
      ],
      "text": "不在朝中把君奉，来在御街为何情？",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00054",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "包拯"
      ],
      "text": "陈州干旱三年正，",
      "text_length": 8
    },
    {
      "event_id": "01012005_e00055",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "包拯"
      ],
      "text": "树无枝叶草无根。万岁爷闻之心不忍，命国舅散粮安黎民。谁想国舅心太狠，克扣皇粮数万倾。众百姓告下冤枉状，万岁爷二次宣包拯。在金殿连推数道本，十家保官保定了为臣。",
      "text_length": 79
    },
    {
      "event_id": "01012005_e00056",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "马妃"
      ],
      "text": "十家保官哪一个？快对哀家说分明。",
      "text_length": 16
    },
    {
      "event_id": "01012005_e00057",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "包拯"
      ],
      "text": "头一家保官王丞相，第二家保官八贤君；第三家保官陈世美，第四家保官老陈琳；第五家保官是寇准，第六家保官佘太君；第七家保官吕蒙正，第八家保官老赵斌；第九家保官郭阁老，第十家保官陈翰林。在御街闯了娘娘道，望娘娘开了天地恩。",
      "text_length": 108
    },
    {
      "event_id": "01012005_e00058",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马妃"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "01012005_e00059",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "马妃"
      ],
      "text": "听一言来怒气声，闯了御街罪非轻。哀家上殿奏一本，管叫黑头挂午门。",
      "text_length": 32
    },
    {
      "event_id": "01012005_e00060",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "包拯"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "01012005_e00061",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "包拯"
      ],
      "text": "听一言来心内惊，苦苦作对为何情？包拯正在为难处，",
      "text_length": 24
    },
    {
      "event_id": "01012005_e00062",
      "play_id": "01012005",
      "scene_id": "01012005_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "spoken",
