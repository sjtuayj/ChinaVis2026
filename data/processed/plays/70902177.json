        "太子",
        "公主"
      ],
      "text": "喂呀……",
      "text_length": 4
    },
    {
      "event_id": "70902177_e00020",
      "play_id": "70902177",
      "scene_id": "70902177_s01",
      "scene_no": 1,
      "seq_global": 20,
