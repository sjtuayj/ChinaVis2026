  "events": [
    {
      "event_id": "02007029_e00001",
      "play_id": "02007029",
      "scene_id": "02007029_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜上。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00002",
      "play_id": "02007029",
      "scene_id": "02007029_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "罗卜"
      ],
      "text": "归去来兮，路过金刚势险危。托赖观音庇，苦难相周济。嗏此事尚堪疑，此事尚堪疑。细思之，听得慈悲，道我亲帏事，多周折，应促吾曹急急归家里。因此上三步一拜，拜回家里，待萱堂资福消灾悔，消灾悔。",
      "text_length": 93
    },
    {
      "event_id": "02007029_e00003",
      "play_id": "02007029",
      "scene_id": "02007029_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜下。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00004",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 4,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李老丈上。",
      "text_length": 5
    },
    {
      "event_id": "02007029_e00005",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 5,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "李老丈"
      ],
      "text": "日月如飞，如见梅花三五枝，正是雪后多佳丽。",
      "text_length": 21
    },
    {
      "event_id": "02007029_e00006",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李老丈"
      ],
      "text": "长安有贫者，依瑞不依多。",
      "text_length": 12
    },
    {
      "event_id": "02007029_e00007",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "李老丈"
      ],
      "text": "贫者愁衣食。",
      "text_length": 6
    },
    {
      "event_id": "02007029_e00008",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "嗏。",
      "text_length": 2
    },
    {
      "event_id": "02007029_e00009",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "樵夫上。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00010",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "老爷子，我上山去砍柴，看见罗卜官人，三步一拜，拜回来来咧。",
      "text_length": 29
    },
    {
      "event_id": "02007029_e00011",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "是，我晓得了。你且回避了。",
      "text_length": 13
    },
    {
      "event_id": "02007029_e00012",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "樵夫下。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00013",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "02007029_e00014",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "李老丈"
      ],
      "text": "忽听樵子报因伊，忽听樵子报因伊，罗卜回归。我须是过长堤，待等他来，劝解伊曹，见彼慈帏，且自宽心，休得要争闲气。",
      "text_length": 55
    },
    {
      "event_id": "02007029_e00015",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李老丈"
      ],
      "text": "不为调和更待谁，不为调和更待谁。",
      "text_length": 16
    },
    {
      "event_id": "02007029_e00016",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜上。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00017",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "罗卜"
      ],
      "text": "难报春晖，定省温情叹久违。寸草心空系，百拜身何瘁，嗏。",
      "text_length": 27
    },
    {
      "event_id": "02007029_e00018",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "李老丈"
      ],
      "text": "官人回来了？",
      "text_length": 6
    },
    {
      "event_id": "02007029_e00019",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "罗卜"
      ],
      "text": "忽见父相知，忽见父相知。公公，家中事儿赖携提。",
      "text_length": 23
    },
    {
      "event_id": "02007029_e00020",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "贤侄，瞻前无僧，顾后无佛，三步一拜，为着何来？",
      "text_length": 23
    },
    {
      "event_id": "02007029_e00021",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "公公！",
      "text_length": 3
    },
    {
      "event_id": "02007029_e00022",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "罗卜"
      ],
      "text": "听得慈悲之事，道我亲帏，把盟誓相欺。因此上三步一拜，拜回家里，为慈亲忏悔。尘缘尽，小侄别母三载今日才回来，奈我思亲甚切。归家见老母，来日登门拜谢公公，与你不及匆匆话别离，不及匆匆话别离。",
      "text_length": 93
    },
    {
      "event_id": "02007029_e00023",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "自从令尊亡故，不能再会遗容。",
      "text_length": 14
    },
    {
      "event_id": "02007029_e00024",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "李老丈"
      ],
      "text": "今见你经商买卖回来，如见令尊一般，贤侄，你且暂立须臾，暂立须臾。听我一言说你知。",
      "text_length": 40
    },
    {
      "event_id": "02007029_e00025",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "公公有话请讲。",
      "text_length": 7
    },
    {
      "event_id": "02007029_e00026",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "自从贤侄去后，令堂在家啊——",
      "text_length": 14
    },
    {
      "event_id": "02007029_e00027",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "为何欲言又止？",
      "text_length": 7
    },
    {
      "event_id": "02007029_e00028",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "老夫有一言说来，不要吃恼。",
      "text_length": 13
    },
    {
      "event_id": "02007029_e00029",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "小侄不恼。",
      "text_length": 5
    },
    {
      "event_id": "02007029_e00030",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "既不吃恼，你且听了！",
      "text_length": 10
    },
    {
      "event_id": "02007029_e00031",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "李老丈"
      ],
      "text": "令堂听信谗言语，便把三官毁。",
      "text_length": 14
    },
    {
      "event_id": "02007029_e00032",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "嗏。",
      "text_length": 2
    },
    {
      "event_id": "02007029_e00033",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "哎呀老娘啊！",
      "text_length": 6
    },
    {
      "event_id": "02007029_e00034",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻云飞",
      "speakers": [
        "李老丈"
      ],
      "text": "今劝你，慢伤悲，转庭帏，今劝你，慢伤悲，转庭帏。拜谒尊前，从容谏取，母子同心，自有个相依处。",
      "text_length": 46
    },
    {
      "event_id": "02007029_e00035",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李老丈"
      ],
      "text": "不用忙忙说是非，不用忙忙说是非。",
      "text_length": 16
    },
    {
      "event_id": "02007029_e00036",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "哎呀老娘啊！当初父在之时，曾在花台发愿。如今悔却前言，将何解誓？兀的不痛杀我也！",
      "text_length": 40
    },
    {
      "event_id": "02007029_e00037",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜坐。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00038",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "贤侄醒来！",
      "text_length": 5
    },
    {
      "event_id": "02007029_e00039",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "罗卜"
      ],
      "text": "闻翁语，自怨嗟，闻翁语，自怨嗟，叹我不能够供子职。辜负了老父与孩儿命，持斋与供佛，如依在时，言犹在耳。哎呀老娘！今日里顿相逢，痛得我肝肠碎，痛得我肝肠碎。",
      "text_length": 77
    },
    {
      "event_id": "02007029_e00040",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜坐。金奴随刘青提同上。",
      "text_length": 13
    },
    {
      "event_id": "02007029_e00041",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "刘青提"
      ],
      "text": "闻儿至，喜上眉，闻儿至，喜上眉，他那里三步一拜为母仪。移步过长堤，移步过长堤，探取儿消息。",
      "text_length": 45
    },
    {
      "event_id": "02007029_e00042",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "金奴，前面莫非是李胡子？",
      "text_length": 12
    },
    {
      "event_id": "02007029_e00043",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金奴"
      ],
      "text": "是李胡子。",
      "text_length": 5
    },
    {
      "event_id": "02007029_e00044",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "李公公一向有罪了。",
      "text_length": 9
    },
    {
      "event_id": "02007029_e00045",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "好说。",
      "text_length": 3
    },
    {
      "event_id": "02007029_e00046",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "可曾见我孩儿？",
      "text_length": 7
    },
    {
      "event_id": "02007029_e00047",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李老丈"
      ],
      "text": "那不是！",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00048",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘青提见罗卜，嚷。",
      "text_length": 9
    },
    {
      "event_id": "02007029_e00049",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "哈！",
      "text_length": 2
    },
    {
      "event_id": "02007029_e00050",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "刘青提"
      ],
      "text": "罢了我的儿，因甚的朦倒唤不起？",
      "text_length": 15
    },
    {
      "event_id": "02007029_e00051",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "啊，李厚德，我也晓得了！",
      "text_length": 12
    },
    {
      "event_id": "02007029_e00052",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "刘青提"
      ],
      "text": "向日与你言辩一场，你怀恨在心，今日里访得我孩儿回来，又在途中讲是谈非。想我孩儿一别三载，今日才回来，母子相逢，当加喜色，如何闷倒在地？不消说了，一定是你撺掇甚么言词，撺掇甚么言词。气得我的姣儿死，气得我的姣儿死。",
      "text_length": 106
    },
    {
      "event_id": "02007029_e00053",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "樵夫上，劝。",
      "text_length": 6
    },
    {
      "event_id": "02007029_e00054",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "老爷子，三年前管的闲事，如今你老又管闲事。走罢，走罢。",
      "text_length": 27
    },
    {
      "event_id": "02007029_e00055",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李老丈作诈关儿。樵夫推李老丈同下。",
      "text_length": 17
    },
    {
      "event_id": "02007029_e00056",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "我儿醒来。老娘在此。",
      "text_length": 10
    },
    {
      "event_id": "02007029_e00057",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "罗卜"
      ],
      "text": "三魂渺，七魄驰，三魂渺，七魄驰，非翁谁与我说详细。",
      "text_length": 25
    },
    {
      "event_id": "02007029_e00058",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "儿吓。岂不闻毋以远间亲，事亲者无失其为亲才是。",
      "text_length": 23
    },
    {
      "event_id": "02007029_e00059",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "刘青提"
      ],
      "text": "今日里离间我娘儿，我娘儿，儿若疏违我，定然不放你，哼老狗，我定然不放你。娘到此痛得我珠泪垂，忽闻儿至，许多欢喜。今见你闷倒雪地，顿使我肝肠裂碎了，儿吓，可怜我欢喜无几，悲愁又至。",
      "text_length": 89
    },
    {
      "event_id": "02007029_e00060",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "儿吓，敢是你身体倦了？",
      "text_length": 11
    },
    {
      "event_id": "02007029_e00061",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "罗卜"
      ],
      "text": "非身倦，",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00062",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "刘青提"
      ],
      "text": "想是折了本钱了？",
      "text_length": 8
    },
    {
      "event_id": "02007029_e00063",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "罗卜"
      ],
      "text": "非亏本。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00064",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜起。",
      "text_length": 4
    },
    {
      "event_id": "02007029_e00065",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "孝顺歌",
      "speakers": [
        "罗卜"
      ],
      "text": "非身倦，非亏本。因李公说与儿端底。",
      "text_length": 17
    },
    {
      "event_id": "02007029_e00066",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "他对你讲些什么？",
      "text_length": 8
    },
    {
      "event_id": "02007029_e00067",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "他不曾讲些什么。",
      "text_length": 8
    },
    {
      "event_id": "02007029_e00068",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "既不曾讲些什么，为何闷倒在地？",
      "text_length": 15
    },
    {
      "event_id": "02007029_e00069",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "哎呀，老娘啊！",
      "text_length": 7
    },
    {
      "event_id": "02007029_e00070",
      "play_id": "02007029",
      "scene_id": "02007029_s02",
