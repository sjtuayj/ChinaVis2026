  "events": [
    {
      "event_id": "01005017_e00001",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "秦香莲"
      ],
      "text": "我母子三人进了京，",
      "text_length": 9
    },
    {
      "event_id": "01005017_e00002",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦香莲上。",
      "text_length": 5
    },
    {
      "event_id": "01005017_e00003",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "秦香莲"
      ],
      "text": "泪珠儿不住得湿透衣衾。原郡乡连遭了三年荒旱，饿死了黎民总有万千。草堂上饿死了双父母，无有银钱难把尸灵安。将头上青丝用剪剪去卖，买芦席葬埋二双亲。闻听说强盗身荣贵，我母子三人找到京。进京城无有安身处，张玉龙店房把身存。御街前，不相认，他不该拳打足又踢。你说强盗狠不狠，他将我送到有司衙门。张玉龙责打了四十板，将我母子赶出京。我有心在中途悬梁自尽，撇下了儿和女倚靠何人。手拉着儿女往前进，",
      "text_length": 192
    },
    {
      "event_id": "01005017_e00004",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "韩琪"
      ],
      "text": "民夫人慢走！",
      "text_length": 6
    },
    {
      "event_id": "01005017_e00005",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "三锤。",
      "text_length": 3
    },
    {
      "event_id": "01005017_e00006",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦香莲"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01005017_e00007",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "秦香莲"
      ],
      "text": "忽听后面有人声。是是是来明白了，想必强盗差歹人。急急忙忙朝前走，母子三人逃性命。低头我把庙门进，",
      "text_length": 48
    },
    {
      "event_id": "01005017_e00008",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦香莲进庙。",
      "text_length": 6
    },
    {
      "event_id": "01005017_e00009",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "秦香莲"
      ],
      "text": "那贼过去再动身。",
      "text_length": 8
    },
    {
      "event_id": "01005017_e00010",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "韩琪上。",
      "text_length": 4
    },
    {
      "event_id": "01005017_e00011",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "在宫中领了千岁命，追杀民妇走一程，洒开大步往前赶，又见古庙面前存，",
      "text_length": 33
    },
    {
      "event_id": "01005017_e00012",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "三锤紧。",
      "text_length": 4
    },
    {
      "event_id": "01005017_e00013",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "走向前来击三掌，是何人胆大在庙内存！",
      "text_length": 18
    },
    {
      "event_id": "01005017_e00014",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦香莲"
      ],
      "text": "秦香莲用目睁，耳旁里听得有人声。用手开开门两扇，",
      "text_length": 24
    },
    {
      "event_id": "01005017_e00015",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "一掌打倒地平川！",
      "text_length": 8
    },
    {
      "event_id": "01005017_e00016",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦香莲"
      ],
      "text": "大爷打我因何故，快对民妇说分明。一无仇来二无恨，杀我母子为何情。",
      "text_length": 32
    },
    {
      "event_id": "01005017_e00017",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "韩琪"
      ],
      "text": "民夫人一言问住了我，",
      "text_length": 10
    },
    {
      "event_id": "01005017_e00018",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "韩琪"
      ],
      "text": "倒叫我大张口无有话说。",
      "text_length": 11
    },
    {
      "event_id": "01005017_e00019",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩琪"
      ],
      "text": "你、你、你站起来。",
      "text_length": 9
    },
    {
      "event_id": "01005017_e00020",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "韩琪"
      ],
      "text": "我与她一无仇来二无恨，钢刀怎杀他无罪人。走向前来双膝跪，口儿里就把民夫人称。",
      "text_length": 38
    },
    {
      "event_id": "01005017_e00021",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦香莲"
      ],
      "text": "方才提刀来杀我，为什么又把民夫人称？",
      "text_length": 18
    },
    {
      "event_id": "01005017_e00022",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "非是我提刀来杀你，我千岁差我来凶行。",
      "text_length": 18
    },
    {
      "event_id": "01005017_e00023",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦香莲"
      ],
      "text": "你家千岁哪一个？问大爷你叫什么名？",
      "text_length": 17
    },
    {
      "event_id": "01005017_e00024",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "我家千岁叫陈世美，",
      "text_length": 9
    },
    {
      "event_id": "01005017_e00025",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦香莲"
      ],
      "text": "好贼子！",
      "text_length": 4
    },
    {
      "event_id": "01005017_e00026",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "小韩琪就是我的名。",
      "text_length": 9
    },
    {
      "event_id": "01005017_e00027",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦香莲"
      ],
      "text": "我与他结的什么恨，他苦苦杀我为何情？",
      "text_length": 18
    },
    {
      "event_id": "01005017_e00028",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "他有心不把你来杀，怕的是开封府包明公。",
      "text_length": 19
    },
    {
      "event_id": "01005017_e00029",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦香莲"
      ],
      "text": "要怕只怕宋天子，他怕包公为何情？",
      "text_length": 16
    },
    {
      "event_id": "01005017_e00030",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "韩琪"
      ],
      "text": "五月初六朝天子，",
      "text_length": 8
    },
    {
      "event_id": "01005017_e00031",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "那满朝文武会的齐。宋皇爷未曾登龙位，明公与千岁相过面皮。他相他左眉长来右眉短，左膀高来右膀低。眉长眉短有儿女，膀高膀低有前妻。千岁言说家无有，他二人打赌一百日。百日有人找京里，千岁铜铡输首级；百日无人来京里，包明公输去大印息。如今百日还未满，你母子三人来此地。四次进宫将他认，他将你拳打足又踢。清晨传我进宫去，五十两纹银酒一提。一把钢刀赐与我，追杀你母子在柳林池。",
      "text_length": 182
    },
    {
      "event_id": "01005017_e00032",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦香莲"
      ],
      "text": "忽听大爷讲一番，背转身来自惨然：怪不得强盗不认我，包公铜铡不容宽。走向前来双膝跪，尊声大爷听奴言：自古良言说的好，杀生不如放生还。",
      "text_length": 65
    },
    {
      "event_id": "01005017_e00033",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "韩琪"
      ],
      "text": "民夫人说话莫高声，墙里说话墙外听。这是纹银五十两，你母子三人去逃生。",
      "text_length": 34
    },
    {
      "event_id": "01005017_e00034",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "秦香莲"
      ],
      "text": "叩罢头来谢恩情，大爷还有这点心。手拉儿女出庙去，",
      "text_length": 24
    },
    {
      "event_id": "01005017_e00035",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩琪"
      ],
      "text": "民夫人你、你、你回来！",
      "text_length": 11
    },
    {
      "event_id": "01005017_e00036",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦香莲"
      ],
      "text": "不、不、不好了。",
      "text_length": 8
    },
    {
      "event_id": "01005017_e00037",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "秦香莲"
      ],
      "text": "大爷莫非有追悔心。",
      "text_length": 9
    },
    {
      "event_id": "01005017_e00038",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "韩琪"
      ],
      "text": "非是我有追悔心，千岁刀头他、他、他要验红。",
      "text_length": 21
    },
    {
      "event_id": "01005017_e00039",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "秦香莲"
      ],
      "text": "听说强盗他、他、他要验红，倒叫香莲吃一惊。走上前来双膝跪，再叫大爷听分明：要杀将我杀了罢，儿和女全当大爷你亲生。",
      "text_length": 56
    },
    {
      "event_id": "01005017_e00040",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "韩琪"
      ],
      "text": "他母子三人跪地下，无冤无仇怎杀她。不杀民夫人回去罢，",
      "text_length": 26
    },
    {
      "event_id": "01005017_e00041",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦香莲"
      ],
      "text": "谢大爷！",
      "text_length": 4
    },
    {
      "event_id": "01005017_e00042",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩琪"
      ],
      "text": "不好了！",
      "text_length": 4
    },
    {
      "event_id": "01005017_e00043",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "韩琪"
      ],
      "text": "千岁问我怎回答！待我回去杀了罢，",
      "text_length": 16
    },
    {
      "event_id": "01005017_e00044",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦香莲"
      ],
      "text": "苦吓！",
      "text_length": 3
    },
    {
      "event_id": "01005017_e00045",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "韩琪"
      ],
      "text": "一双儿女不离她。千难万难难坏我，土地堂难坏小韩琪。大丈夫生在三光下，生死二字何惧他！你母子三人庙外看，不如一死染黄沙。",
      "text_length": 59
    },
    {
      "event_id": "01005017_e00046",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "韩琪自刎。",
      "text_length": 5
    },
    {
      "event_id": "01005017_e00047",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦香莲"
      ],
      "text": "哎哎，大爷！",
      "text_length": 6
    },
    {
      "event_id": "01005017_e00048",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "秦香莲"
      ],
      "text": "一见大爷把命丧，怎不叫人两泪汪。我将大爷尸首忙掩下，母子三人好惨伤。手拉儿女出庙外，忽听道锣连声响。是是是来明白了，来的想必是包相。我在此处莫久站，包大人台前诉诉冤枉。",
      "text_length": 84
    },
    {
      "event_id": "01005017_e00049",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦香莲"
      ],
      "text": "哎，大爷吓！",
      "text_length": 6
    },
    {
      "event_id": "01005017_e00050",
      "play_id": "01005017",
      "scene_id": "01005017_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦香莲下。",
      "text_length": 5
    }
  ],
