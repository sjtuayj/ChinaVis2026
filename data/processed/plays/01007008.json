  "events": [
    {
      "event_id": "01007008_e00001",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香上，二宫女同上。",
      "text_length": 11
    },
    {
      "event_id": "01007008_e00002",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "孙尚香"
      ],
      "text": "身坐宫院，怎能消，终日愁闷。",
      "text_length": 14
    },
    {
      "event_id": "01007008_e00003",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙尚香"
      ],
      "text": "别君常挂念，难忘故日情。虽无千丈锦，万里惊人心。",
      "text_length": 24
    },
    {
      "event_id": "01007008_e00004",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "奴家孙氏尚香。配夫刘使君，夫妻倒也恩爱。回转荆州三载，儿夫领兵征西，谁知周郎用计诓我，言说我母后染病在床，将我接回江东，母女见面，我母未曾染病，是我不能回去，在此住了数载，思想起来，好不愁闷人也。",
      "text_length": 98
    },
    {
      "event_id": "01007008_e00005",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "孙尚香坐宫院心中寂寞，思一思想一想奴好命薄。遭不幸我父王早已亡故，遗下了兄仲谋执掌江河。坐江南八九郡有何不可，一心要取荆州惹动干戈。将奴家定一计诓虎离窝，又谁知弄假成真反配嫦娥。嫁荆州未三载将我诓过，因此上与皇叔恩爱相割。奴好比走风船失了艄舵，奴好比抢食鱼自投在网罗；奴好比花正开不曾结果，奴好比织女星隔断银河。恨兄王把我的牙关咬破，那一旁又来了报事宫娥。",
      "text_length": 178
    },
    {
      "event_id": "01007008_e00006",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "宫女上。",
      "text_length": 4
    },
    {
      "event_id": "01007008_e00007",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "参见公主。",
      "text_length": 5
    },
    {
      "event_id": "01007008_e00008",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "罢了。起来。",
      "text_length": 6
    },
    {
      "event_id": "01007008_e00009",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "谢公主。有大事不好。",
      "text_length": 10
    },
    {
      "event_id": "01007008_e00010",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "01007008_e00011",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "皇叔白帝城晏驾。",
      "text_length": 8
    },
    {
      "event_id": "01007008_e00012",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "你话怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01007008_e00013",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女"
      ],
      "text": "皇叔白帝城晏驾。",
      "text_length": 8
    },
    {
      "event_id": "01007008_e00014",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香哭。",
      "text_length": 5
    },
    {
      "event_id": "01007008_e00015",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "皇叔，我夫，哎吓夫吓！",
      "text_length": 11
    },
    {
      "event_id": "01007008_e00016",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "孙尚香"
      ],
      "text": "听一言不由我心如刀剜，",
      "text_length": 11
    },
    {
      "event_id": "01007008_e00017",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "皇叔，我夫，夫吓！",
      "text_length": 9
    },
    {
      "event_id": "01007008_e00018",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "我夫君为江山性命不全。",
      "text_length": 11
    },
    {
      "event_id": "01007008_e00019",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "且住。我想皇叔一死，吾在东吴苦守无益，不免备下祭礼，身穿孝服，往江边祭奠，以表夫妻之情。来，看衣更换。",
      "text_length": 51
    },
    {
      "event_id": "01007008_e00020",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香换衣。",
      "text_length": 6
    },
    {
      "event_id": "01007008_e00021",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01007008_e00022",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "叹先帝下江南报仇起意，叹兄王用陆逊巧定兵机。用火攻烧连营七百余里，最可叹汉皇叔一命归西。我与他鸾凤交三载恩义，奴不免见母后细说端的。",
      "text_length": 66
    },
    {
      "event_id": "01007008_e00023",
      "play_id": "01007008",
      "scene_id": "01007008_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香、宫女同下。",
      "text_length": 9
    },
    {
      "event_id": "01007008_e00024",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "吴国太"
      ],
      "text": "一日偷闲一日安，",
      "text_length": 8
    },
    {
      "event_id": "01007008_e00025",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴国太、二宫女同上。",
      "text_length": 10
    },
    {
      "event_id": "01007008_e00026",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "吴国太"
      ],
      "text": "光阴迅速不回还。孙权他把大事管，每日兴兵不时闲。只恨曹丕把位篡，篡夺汉室锦江山。吾婿刘备重兴汉，称孤道寡坐西川。闻说白帝把驾晏，叫人暗地泪涟涟。将身且坐皇宫院，等候尚香把我参。",
      "text_length": 88
    },
    {
      "event_id": "01007008_e00027",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香上，二宫女同上。",
      "text_length": 11
    },
    {
      "event_id": "01007008_e00028",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "宫娥女摆驾养老院，见了母后把驾参。",
      "text_length": 17
    },
    {
      "event_id": "01007008_e00029",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "儿臣见驾，母后千岁。",
      "text_length": 10
    },
    {
      "event_id": "01007008_e00030",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "王儿平身。",
      "text_length": 5
    },
    {
      "event_id": "01007008_e00031",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "谢母后。",
      "text_length": 4
    },
    {
      "event_id": "01007008_e00032",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "赐坐。",
      "text_length": 3
    },
    {
      "event_id": "01007008_e00033",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "谢坐。",
      "text_length": 3
    },
    {
      "event_id": "01007008_e00034",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "吓，儿吓，今日进宫，为何不戴凤冠，不穿霞帔，身着孝服来见为娘，所为何事？",
      "text_length": 36
    },
    {
      "event_id": "01007008_e00035",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后有所不知，今有刘皇叔在白帝城晏驾，因此上儿臣身穿缟素。",
      "text_length": 29
    },
    {
      "event_id": "01007008_e00036",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "吓，刘先主晏驾了？",
      "text_length": 9
    },
    {
      "event_id": "01007008_e00037",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "01007008_e00038",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "可叹吓可惜！",
      "text_length": 6
    },
    {
      "event_id": "01007008_e00039",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "启奏母后：儿臣要到江边一祭，以表夫妻之情。",
      "text_length": 21
    },
    {
      "event_id": "01007008_e00040",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "儿虽然与刘先主有夫妻之份，况且分别数载，他与你兄王又有敌国之仇，你还祭他则甚？",
      "text_length": 39
    },
    {
      "event_id": "01007008_e00041",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后吓，",
      "text_length": 4
    },
    {
      "event_id": "01007008_e00042",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后说话言语颠，细听孩儿把话言：男大当婚愁眉散，女大须嫁礼当然。孩儿青春二十满，未曾与儿配婚男。都只为荆州未讨转，将奴定计礼不端。不说东吴见识浅，反道他人礼不然。孤衾独枕谁人伴，年少青春独自眠。儿好比南来失群雁，叫人泪涟不泪涟。",
      "text_length": 114
    },
    {
      "event_id": "01007008_e00043",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿不必来埋怨，细听为娘说根源：不幸你父寿命短，早年一命丧黄泉。抛下基业无人管，江南九郡付孙权。只为荆州讨不转，才将我儿配凤鸾。定计本是周郎想，以免将士不安然。儿嫁刘备娘心愿，送儿荆州有三年。接儿回转是周善，母女分别又团圆。江边祭奠空祭奠，一滴何曾到九泉。",
      "text_length": 128
    },
    {
      "event_id": "01007008_e00044",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后说话理太偏，往日贤来今不贤。说什么江边祭奠空祭奠，一滴何曾到九泉？老母枉把弥陀念，从前事儿想一番。",
      "text_length": 51
    },
    {
      "event_id": "01007008_e00045",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "蠢才不必强舌辩，细听为娘把话言：夫妻好比同林鸟，大限来时各一边。我儿曾把书来念，一生须当孝为先。孙权他把大事管，膝下不敢乱胡言。我儿本是闺中女，开口反道娘不贤。要到江边去祭奠，为娘不准枉徒然。",
      "text_length": 96
    },
    {
      "event_id": "01007008_e00046",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后不必把脸翻，有辈古人请听言：昔日姬妃大交战，战死沙场命不全；姜氏痛哭长城断，千里寻夫万古贤。儿虽然学不得姜氏女，一点诚心到江边。",
      "text_length": 66
    },
    {
      "event_id": "01007008_e00047",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "任儿说得莲花现，讲什么古来论什么贤。为娘坐在皇宫院，看哪个大胆到江边。",
      "text_length": 35
    },
    {
      "event_id": "01007008_e00048",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "今日不容儿祭奠，",
      "text_length": 8
    },
    {
      "event_id": "01007008_e00049",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "也罢！",
      "text_length": 3
    },
    {
      "event_id": "01007008_e00050",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "不如一死染黄泉。",
      "text_length": 8
    },
    {
      "event_id": "01007008_e00051",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿休要寻短见，为娘送你到江边。",
      "text_length": 16
    },
    {
      "event_id": "01007008_e00052",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿一定要去，为娘也不再三阻拦于你，待为娘同你前去就是了。",
      "text_length": 29
    },
    {
      "event_id": "01007008_e00053",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "不烦母后前往，儿有宫娥相伴。",
      "text_length": 14
    },
    {
      "event_id": "01007008_e00054",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 31,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "这却使得。宫娥们，此番同郡主去往江边祭奠，须要早去早回，休令主公知道。",
      "text_length": 35
    },
    {
      "event_id": "01007008_e00055",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 32,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "孩儿知道。母后请上，受孩儿拜别。",
      "text_length": 16
    },
    {
      "event_id": "01007008_e00056",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 33,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "儿吓！分别一时，何言“拜别”二字？",
      "text_length": 17
    },
    {
      "event_id": "01007008_e00057",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 34,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "礼当拜过母后吓。",
      "text_length": 8
    },
    {
      "event_id": "01007008_e00058",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 35,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "孙尚香"
      ],
      "text": "虽然暂时别宫院，人生须当礼为先。去了愁容换笑脸，双膝跪在地平川。儿愿老母身康健，儿愿老母福寿全。叩罢头来回身转，心中有事不敢言。宫娥摆驾出宫院，要想回头难上难。",
      "text_length": 80
    },
    {
      "event_id": "01007008_e00059",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 36,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女引孙尚香同下。",
      "text_length": 10
    },
    {
      "event_id": "01007008_e00060",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 37,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "娇儿出宫去祭奠，袖内机关不好言。怕的是娇儿寻短见，一心要学古圣贤。尚香女若有长和短，暮景逢春谁问安。将身且坐皇宫院，日落西山望儿还。",
      "text_length": 66
    },
    {
      "event_id": "01007008_e00061",
      "play_id": "01007008",
      "scene_id": "01007008_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 38,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴国太下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}