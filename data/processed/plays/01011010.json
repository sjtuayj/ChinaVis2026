  "events": [
    {
      "event_id": "01011010_e00001",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "小姐"
      ],
      "text": "叫彩屏掌银灯西厢月下，",
      "text_length": 11
    },
    {
      "event_id": "01011010_e00002",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟掌灯引小姐同上。",
      "text_length": 10
    },
    {
      "event_id": "01011010_e00003",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "小姐"
      ],
      "text": "耳旁里忽听得鼓更起发。",
      "text_length": 11
    },
    {
      "event_id": "01011010_e00004",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "丫鬟"
      ],
      "text": "满天上雾沉沉云霄雾下，花园里寂静冷露满桃花。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00005",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "小姐"
      ],
      "text": "将身儿坐至在花园以下，奴好比西施女半点不差。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00006",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "丫鬟"
      ],
      "text": "见小姐坐花园双目泪下，倒叫我作奴婢暗自嗟呀。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00007",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "彩屏姐，你家解元爷到此为何？",
      "text_length": 14
    },
    {
      "event_id": "01011010_e00008",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "我家解元爷到此，一为头上功名，二为这个。",
      "text_length": 20
    },
    {
      "event_id": "01011010_e00009",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "什么？",
      "text_length": 3
    },
    {
      "event_id": "01011010_e00010",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "婚姻之事。",
      "text_length": 5
    },
    {
      "event_id": "01011010_e00011",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "太老爷怎样吩咐？",
      "text_length": 8
    },
    {
      "event_id": "01011010_e00012",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "太老爷朝事慌忙，将府下大小之事，托付老夫人掌管。",
      "text_length": 24
    },
    {
      "event_id": "01011010_e00013",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "老夫人待解元爷如何？",
      "text_length": 10
    },
    {
      "event_id": "01011010_e00014",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "老夫人待解元爷好吓。",
      "text_length": 10
    },
    {
      "event_id": "01011010_e00015",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "丫鬟"
      ],
      "text": "老夫人待解元十分俊雅，要完婚除非是自挣乌纱。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00016",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "小姐"
      ],
      "text": "叫彩屏你说的哪里之话。难道说新秀才不娶浑家？",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00017",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "丫鬟"
      ],
      "text": "想当年缇莹女到老不嫁，难道说你也要白鬓白发？",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00018",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "小姐"
      ],
      "text": "小彩屏讲的我伤心之话，倒叫我低下头难把泪擦。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00019",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "姑娘不必痛哭，今天十四，明天十五，就是解元爷入场之日。",
      "text_length": 27
    },
    {
      "event_id": "01011010_e00020",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "解元爷现在那里安身？",
      "text_length": 10
    },
    {
      "event_id": "01011010_e00021",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "解元爷现在东亭书馆安身。",
      "text_length": 12
    },
    {
      "event_id": "01011010_e00022",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "奴家有意，命人将他请来，月下相谈，你看如何？",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00023",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "这命何人去请？",
      "text_length": 7
    },
    {
      "event_id": "01011010_e00024",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "命你去请。",
      "text_length": 5
    },
    {
      "event_id": "01011010_e00025",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "晓得了晓得了。哎呀呀，不去了，不去了，我不去了。",
      "text_length": 24
    },
    {
      "event_id": "01011010_e00026",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "彩屏为何去而复返？",
      "text_length": 9
    },
    {
      "event_id": "01011010_e00027",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "非是我去而复返，倘若老夫人知道，那时我定讨没趣，我才不去了。",
      "text_length": 30
    },
    {
      "event_id": "01011010_e00028",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "彩屏吓！",
      "text_length": 4
    },
    {
      "event_id": "01011010_e00029",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "小姐"
      ],
      "text": "我本是姑表亲必真不假，老夫人她知道大理不差。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00030",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "丫鬟"
      ],
      "text": "有张生戏莺莺西厢月下，穿针的小红娘就是奴家。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00031",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟下。",
      "text_length": 4
    },
    {
      "event_id": "01011010_e00032",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "小姐"
      ],
      "text": "将身儿坐在了西厢月下，等表兄他到来细说根芽。",
      "text_length": 22
    },
    {
      "event_id": "01011010_e00033",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "公子、丫鬟同上。",
      "text_length": 8
    },
    {
      "event_id": "01011010_e00034",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "解元爷请吓。",
      "text_length": 6
    },
    {
      "event_id": "01011010_e00035",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "公子"
      ],
      "text": "今夜晚夜明灯竹簾高挂，倒叫我读书人喜在心间。我这里正行走用目观看，彩屏姐你不走所为哪桩？",
      "text_length": 44
    },
    {
      "event_id": "01011010_e00036",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "走吓。",
      "text_length": 3
    },
    {
      "event_id": "01011010_e00037",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "不要走了，来到了。",
      "text_length": 9
    },
    {
      "event_id": "01011010_e00038",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "待我进去。",
      "text_length": 5
    },
    {
      "event_id": "01011010_e00039",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "慢着，待我与你通禀一声。",
      "text_length": 12
    },
    {
      "event_id": "01011010_e00040",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "好吓，你与我通禀一声。",
      "text_length": 11
    },
    {
      "event_id": "01011010_e00041",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "启禀小姐：解元爷到。",
      "text_length": 10
    },
    {
      "event_id": "01011010_e00042",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "说我这里有请。",
      "text_length": 7
    },
    {
      "event_id": "01011010_e00043",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "她倒不出来了。待我自己进去罢。",
      "text_length": 15
    },
    {
      "event_id": "01011010_e00044",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "哎呀呀，解元爷不用请，他自己进来了。",
      "text_length": 18
    },
    {
      "event_id": "01011010_e00045",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "哎彩屏姐。",
      "text_length": 5
    },
    {
      "event_id": "01011010_e00046",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "彩屏过来，对他说道，我这里修书不及，未完花烛，还是姑表兄妹相称。叫他稳重些。还要往下站。",
      "text_length": 44
    },
    {
      "event_id": "01011010_e00047",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "哎解元爷。",
      "text_length": 5
    },
    {
      "event_id": "01011010_e00048",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "哎，彩屏姐。",
      "text_length": 6
    },
    {
      "event_id": "01011010_e00049",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "我家姑娘说道，修书不及，未完花烛，还是姑表兄妹相称。叫你放稳重些，还要往下站。",
      "text_length": 39
    },
    {
      "event_id": "01011010_e00050",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "哦，叫我往下站。",
      "text_length": 8
    },
    {
      "event_id": "01011010_e00051",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "往下站。",
      "text_length": 4
    },
    {
      "event_id": "01011010_e00052",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "我就往下站。",
      "text_length": 6
    },
    {
      "event_id": "01011010_e00053",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "还要往下站。",
      "text_length": 6
    },
    {
      "event_id": "01011010_e00054",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "啊，还要往下站，哦哦哦。",
      "text_length": 12
    },
    {
      "event_id": "01011010_e00055",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "公子"
      ],
      "text": "见表妹说的是真情实话，倒叫我大张口无有话答。她本是千金女必真不假，况且那我也是宦门根芽。",
      "text_length": 44
    },
    {
      "event_id": "01011010_e00056",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "彩屏与解元爷看坐。",
      "text_length": 9
    },
    {
      "event_id": "01011010_e00057",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "01011010_e00058",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "有坐。请问表妹，一向可好？",
      "text_length": 13
    },
    {
      "event_id": "01011010_e00059",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "有何德能，敢劳表兄动问，请问表兄可好？",
      "text_length": 19
    },
    {
      "event_id": "01011010_e00060",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "有劳表妹承问。",
      "text_length": 7
    },
    {
      "event_id": "01011010_e00061",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "请问表兄，几时入场赴试？",
      "text_length": 12
    },
    {
      "event_id": "01011010_e00062",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "今天十四，明天十五，就是我入场之日。",
      "text_length": 18
    },
    {
      "event_id": "01011010_e00063",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "此去可得会元？",
      "text_length": 7
    },
    {
      "event_id": "01011010_e00064",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "虽然不得中，不落于人后。",
      "text_length": 12
    },
    {
      "event_id": "01011010_e00065",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "好一个虽然不得中，不落于人后。彩屏过来，花园之中，姑娘未带什么含心之物，带来明月珠一颗，送与解元爷带进场去，文章不中，宝上便取。来来来，付珠过去。",
      "text_length": 73
    },
    {
      "event_id": "01011010_e00066",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "解元爷，我家姑娘言道：花园之中，未带什么含心之物，今有明月珠一颗，赠与解元爷带进场去，文章不中，宝上便取。来来来，付珠过去。",
      "text_length": 62
    },
    {
      "event_id": "01011010_e00067",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "彩屏姐，观见此宝明晃闪闪，日后必中花中之连。彩屏姐，就说我谢赠珠之恩。",
      "text_length": 35
    },
    {
      "event_id": "01011010_e00068",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "解元爷，谢过小姐赠珠之恩。",
      "text_length": 13
    },
    {
      "event_id": "01011010_e00069",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "彩屏对我表兄说道：叫他回到东亭书馆安身，明天好去得中花中之连。",
      "text_length": 31
    },
    {
      "event_id": "01011010_e00070",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "解元爷，我家姑娘言道：请回东亭书馆安身，明天好去得中魁元。",
      "text_length": 29
    },
    {
      "event_id": "01011010_e00071",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
      "text": "就说我告辞。",
      "text_length": 6
    },
    {
      "event_id": "01011010_e00072",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "解元爷告辞。",
      "text_length": 6
    },
    {
      "event_id": "01011010_e00073",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小姐"
      ],
      "text": "奉送。",
      "text_length": 3
    },
    {
      "event_id": "01011010_e00074",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "小姐奉送。",
      "text_length": 5
    },
    {
      "event_id": "01011010_e00075",
      "play_id": "01011010",
      "scene_id": "01011010_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公子"
      ],
