  "events": [
    {
      "event_id": "03033006_e00001",
      "play_id": "03033006",
      "scene_id": "03033006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼上。",
      "text_length": 4
    },
    {
      "event_id": "03033006_e00002",
      "play_id": "03033006",
      "scene_id": "03033006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "太爷堂上发了签，护送皇家钦命官。",
      "text_length": 16
    },
    {
      "event_id": "03033006_e00003",
      "play_id": "03033006",
      "scene_id": "03033006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "俺，秦琼。在历城县当了一名捕快手。奉了太爷之命，护送钦差黄大人。钦差见喜，赐俺黄骠马一骑。俺得此马，犹如胁生双翅。昨日过了金顶太行山，平安无事。看前面已是枣阳山，闻昕此地，惯出响马，俺不免先往前途探路，就此马上加鞭！",
      "text_length": 108
    },
    {
      "event_id": "03033006_e00004",
      "play_id": "03033006",
      "scene_id": "03033006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "此马生来好威严，登山越岭如虎蹿。豪杰催马朝前趱，舍死忘生保清官。",
      "text_length": 32
    },
    {
      "event_id": "03033006_e00005",
      "play_id": "03033006",
      "scene_id": "03033006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼下。",
      "text_length": 4
    },
    {
      "event_id": "03033006_e00006",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、院子、丫鬟、黄夫人、黄大人同上。",
      "text_length": 20
    },
    {
      "event_id": "03033006_e00007",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "黄大人"
      ],
      "text": "天下荒荒烟尘乱，当今无道信用权奸。可叹我十载寒窗磨穿铁砚，一举成名不想为官。都只为天堂潞州民遭涂炭，此一番放我去为把民安。那一日路过历城县，年兄对我把话谈：他道此去多凶险，有两座高山把路拦。怕的是中途遭磨难，亲派马步与三班。一路行来三、四站，金顶太行保平安。三班引路往前趱，又见山峰甚威严。",
      "text_length": 145
    },
    {
      "event_id": "03033006_e00008",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄大人"
      ],
      "text": "且住！看此山高大，必有凶险之处。候秦快班到来，一同过山便了！",
      "text_length": 30
    },
    {
      "event_id": "03033006_e00009",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四青袍"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03033006_e00010",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "单雄信"
      ],
      "text": "众喽兵，将旗扯起！",
      "text_length": 9
    },
    {
      "event_id": "03033006_e00011",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "内唱",
      "speakers": [
        "单雄信"
      ],
      "text": "枣阳山前旌旗展，",
      "text_length": 8
    },
    {
      "event_id": "03033006_e00012",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四喽兵、大纛旗引单雄信同上。",
      "text_length": 14
    },
    {
      "event_id": "03033006_e00013",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "山冈下又来了过路的官员。见许多轿马人夫在山下站，我看他好一似钦命官员。叫一声过路的人真个大胆！你擅敢闯过爷的枣阳山？我劝你早把那珠宝来献，有金银早献出好做爷的买路钱！",
      "text_length": 83
    },
    {
      "event_id": "03033006_e00014",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "黄大人"
      ],
      "text": "坐在轿中心惊战，见许多强人站在山前。为首的赤发红须蓝靛面，喊一声如霹雳震破了天。我看他也是条英雄好汉，相劝他必须要以礼当先。出轿来走向前躬身立站，尊一声好汉细听我言：天下荒荒刀兵乱，朝内无人掌兵权。若听本官来相劝，落个美名在万古传。",
      "text_length": 116
    },
    {
      "event_id": "03033006_e00015",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "单雄信"
      ],
      "text": "雄信闻言自思叹，你又何须相劝咱？某祖父在朝为官宦，河南一带有某的庄田。自幼儿习学弓马箭，原为出头在朝班。昏王无道皇宫乱，信用了奸佞掌兵权。父忠无用反遭斩，英雄出头就实实难。因此上扯起了大纛旗一面，混天大王扫狼烟。招聚喽兵做好汉，不日打破天成关。满朝文武俱问斩，推倒炀帝坐江山！",
      "text_length": 138
    },
    {
      "event_id": "03033006_e00016",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "黄大人"
      ],
      "text": "下官好言来相劝，口口声声出反言。你若不听良言劝，船到江心补漏难！",
      "text_length": 32
    },
    {
      "event_id": "03033006_e00017",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "听一言来怒气冲冠，你敢恶言回复咱！俺本是顶天立地英雄汉，雄信聚众枣阳山。谁敢与某来交战！",
      "text_length": 44
    },
    {
      "event_id": "03033006_e00018",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖急急风〗。秦琼上。",
      "text_length": 10
    },
    {
      "event_id": "03033006_e00019",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "秦叔宝催马到山前。",
      "text_length": 9
    },
    {
      "event_id": "03033006_e00020",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "呔！大胆贼寇，擅敢阻挡皇家命官，尔敢是造反？",
      "text_length": 22
    },
    {
      "event_id": "03033006_e00021",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "啊！你来在山前，口出大话，必有本领。也罢！你我比比雌雄，你若胜得过俺，俺便马前归顺；你若不胜，便怎么样？",
      "text_length": 52
    },
    {
      "event_id": "03033006_e00022",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "俺若不胜，愿将车辆奉送。",
      "text_length": 12
    },
    {
      "event_id": "03033006_e00023",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "丈夫一言？",
      "text_length": 5
    },
    {
      "event_id": "03033006_e00024",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "岂能反悔！三班的，松林保护大人！",
      "text_length": 16
    },
    {
      "event_id": "03033006_e00025",
      "play_id": "03033006",
      "scene_id": "03033006_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四青袍"
      ],
      "text": "啊！（四青袍、院子、丫鬟、黄夫人、黄大人同下。四喽兵、大纛旗同下。秦琼、单雄信同起打。秦琼败下。单雄信追下。）",
      "text_length": 55
    },
    {
      "event_id": "03033006_e00026",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼上。",
      "text_length": 4
    },
    {
      "event_id": "03033006_e00027",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "且住！山寇来得厉害。他若追来，撒手锏伤他！",
      "text_length": 21
    },
    {
      "event_id": "03033006_e00028",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼下。单雄信上。",
      "text_length": 9
    },
    {
      "event_id": "03033006_e00029",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "哪里走？",
      "text_length": 4
    },
    {
      "event_id": "03033006_e00030",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼上，打单雄信坠马。",
      "text_length": 11
    },
    {
      "event_id": "03033006_e00031",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "我这里暗发撒手锏，只见山寇落马前。不看你是英雄汉，这一锏叫你尸骨不全。",
      "text_length": 35
    },
    {
      "event_id": "03033006_e00032",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03033006_e00033",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "我这里被他打一锏，好汉坠落马雕鞍。跌跪尘埃求好汉，尊一声英雄听我言：你若放我活命转，来生结草报衔环。",
      "text_length": 50
    },
    {
      "event_id": "03033006_e00034",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "听罢言来心暗转，看他也非无义男。下得马来用手搀，",
      "text_length": 24
    },
    {
      "event_id": "03033006_e00035",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "你把名姓对咱言。",
      "text_length": 8
    },
    {
      "event_id": "03033006_e00036",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "家住山东历城县，姓秦名琼当快班。",
      "text_length": 16
    },
    {
      "event_id": "03033006_e00037",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "你是山东好汉秦叔宝、秦二哥？",
      "text_length": 14
    },
    {
      "event_id": "03033006_e00038",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "不敢！就是在下。",
      "text_length": 8
    },
    {
      "event_id": "03033006_e00039",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "久仰了！",
      "text_length": 4
    },
    {
      "event_id": "03033006_e00040",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "单雄信"
      ],
      "text": "啊哈哈哈……",
      "text_length": 6
    },
    {
      "event_id": "03033006_e00041",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "久闻二哥今相见，为何事故到此山？",
      "text_length": 16
    },
    {
      "event_id": "03033006_e00042",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "我今奉了太爷签，护送皇家钦命官。",
      "text_length": 16
    },
    {
      "event_id": "03033006_e00043",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "有劳二哥把大人见，施礼赔罪到台前。",
      "text_length": 17
    },
    {
      "event_id": "03033006_e00044",
      "play_id": "03033006",
      "scene_id": "03033006_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼、单雄信同下。",
      "text_length": 9
    },
    {
      "event_id": "03033006_e00045",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 45,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、院子、丫鬟、黄夫人、黄大人同上。",
      "text_length": 20
    },
    {
      "event_id": "03033006_e00046",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 46,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "黄大人"
      ],
      "text": "壮士秦琼把贼战，一去半日不见还。三班谨慎保家眷！",
      "text_length": 24
    },
    {
      "event_id": "03033006_e00047",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 47,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼、单雄信同上。",
      "text_length": 9
    },
    {
      "event_id": "03033006_e00048",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 48,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "带来雄信见恩官。",
      "text_length": 8
    },
    {
      "event_id": "03033006_e00049",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 49,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "参见大人！死罪呀死罪！",
      "text_length": 11
    },
    {
      "event_id": "03033006_e00050",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 50,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄大人"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "03033006_e00051",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 51,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "黄大人"
      ],
      "text": "山寇做事理不端，擅敢拦路劫官员？按律就该来问斩！",
      "text_length": 24
    },
    {
      "event_id": "03033006_e00052",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 52,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼跪。黄大人搀。",
      "text_length": 9
    },
    {
      "event_id": "03033006_e00053",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 53,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "黄大人"
      ],
      "text": "看在壮士且放宽。从今以后要行善，早早归乡种庄田。",
      "text_length": 24
    },
    {
      "event_id": "03033006_e00054",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 54,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "谢大人！",
      "text_length": 4
    },
    {
      "event_id": "03033006_e00055",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 55,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "大人释放恩匪浅，",
      "text_length": 8
    },
    {
      "event_id": "03033006_e00056",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 56,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦琼"
      ],
      "text": "今日相逢天凑缘。",
      "text_length": 8
    },
    {
      "event_id": "03033006_e00057",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 57,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "待草民护送大人一程。",
      "text_length": 10
    },
    {
      "event_id": "03033006_e00058",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 58,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "且慢！过了枣阳山，前面一带，平安无事。请大人前行！",
      "text_length": 25
    },
    {
      "event_id": "03033006_e00059",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 59,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄大人"
      ],
      "text": "引路！",
      "text_length": 3
    },
    {
      "event_id": "03033006_e00060",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 60,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "黄大人"
      ],
      "text": "山寨必须火焚散，勿得再犯扰民间。待等皇家开恩选，壮士在家候招安。",
      "text_length": 32
    },
    {
      "event_id": "03033006_e00061",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 61,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、院子、丫鬟、黄夫人、黄大人同下。",
      "text_length": 20
    },
    {
      "event_id": "03033006_e00062",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "秦仁兄请转！",
      "text_length": 6
    },
    {
      "event_id": "03033006_e00063",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 19,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "何事？",
      "text_length": 3
    },
    {
      "event_id": "03033006_e00064",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 64,
      "seq_in_scene": 20,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "将大人送至任所。小弟在河南二贤庄等候仁兄便了。",
      "text_length": 23
    },
    {
      "event_id": "03033006_e00065",
      "play_id": "03033006",
      "scene_id": "03033006_s04",
      "scene_no": 4,
      "seq_global": 65,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
