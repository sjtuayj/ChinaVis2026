  "events": [
    {
      "event_id": "01010016_e00001",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八龙套引赵匡胤同上，四太监同上。",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00002",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "赵匡胤"
      ],
      "text": "龙争虎斗，这干戈，何日里罢休？",
      "text_length": 15
    },
    {
      "event_id": "01010016_e00003",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵匡胤"
      ],
      "text": "蛟龙无水困沙滩，似却明珠土内埋。奸贼诓孤河东地，不知何日转回还。",
      "text_length": 32
    },
    {
      "event_id": "01010016_e00004",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "孤，乾德王赵。可恨欧阳藩将孤诓至河东，七载有余。困得孤内无粮草，外无救兵。命黄兴前去打探，未见回报。",
      "text_length": 50
    },
    {
      "event_id": "01010016_e00005",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄兴上。",
      "text_length": 4
    },
    {
      "event_id": "01010016_e00006",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "黄兴"
      ],
      "text": "打探军情事，奏与万岁知。",
      "text_length": 12
    },
    {
      "event_id": "01010016_e00007",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄兴"
      ],
      "text": "臣黄兴见驾，吾王万岁！",
      "text_length": 11
    },
    {
      "event_id": "01010016_e00008",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "打探哪路军情，一一奏来。",
      "text_length": 12
    },
    {
      "event_id": "01010016_e00009",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄兴"
      ],
      "text": "臣探得罗家山发来一哨人马，昨日鞭坠白龙，今日叫骂御营，特来奏与万岁得知。",
      "text_length": 36
    },
    {
      "event_id": "01010016_e00010",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "再探！",
      "text_length": 3
    },
    {
      "event_id": "01010016_e00011",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄兴"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01010016_e00012",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄兴下。",
      "text_length": 4
    },
    {
      "event_id": "01010016_e00013",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "且住，黄兴奏道：罗家山发来一哨人马，昨日鞭坠白龙，今日叫骂御营。此誓叫孤难解也！",
      "text_length": 40
    },
    {
      "event_id": "01010016_e00014",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "唢呐二黄慢板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "探马儿不住得飞来报：他报道罗家山兵发一哨。杏黄旗不住得空中飘摇，吓坏了满营中大小英豪。恨河东刘冲贼打来战表，他要夺孤王的锦绣龙朝。欧阳藩在金殿帅印挂了，呼寿廷倒作了马前先行。困河东有七载须发白了，但不知何日里才的回朝？在头上摘下了飞龙帽，在身上脱下了滚龙袍。",
      "text_length": 129
    },
    {
      "event_id": "01010016_e00015",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "孤的玲珑吓！",
      "text_length": 6
    },
    {
      "event_id": "01010016_e00016",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "唢呐二黄慢板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "玲珑铠甲丝条绕，杀人妙计有千条。御林军与孤巡营哨，",
      "text_length": 25
    },
    {
      "event_id": "01010016_e00017",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八龙套同下。",
      "text_length": 6
    },
    {
      "event_id": "01010016_e00018",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄慢板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "把守御营要勤劳。叫槽头将孤的龙驹马鞍韂备好，",
      "text_length": 22
    },
    {
      "event_id": "01010016_e00019",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤下。马童上，备马。",
      "text_length": 12
    },
    {
      "event_id": "01010016_e00020",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "请爷上马。",
      "text_length": 5
    },
    {
      "event_id": "01010016_e00021",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤上。",
      "text_length": 5
    },
    {
      "event_id": "01010016_e00022",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄慢板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "这是孤无能将亲把兵交。",
      "text_length": 11
    },
    {
      "event_id": "01010016_e00023",
      "play_id": "01010016",
      "scene_id": "01010016_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、马童同下。",
      "text_length": 9
    },
    {
      "event_id": "01010016_e00024",
      "play_id": "01010016",
      "scene_id": "01010016_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖急急风〗。呼延赞、八龙套同上。",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00025",
      "play_id": "01010016",
      "scene_id": "01010016_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "呼延赞"
      ],
      "text": "哈哈哈，吓，哈哈哈！",
      "text_length": 10
    },
    {
      "event_id": "01010016_e00026",
      "play_id": "01010016",
      "scene_id": "01010016_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "呼延赞、八龙套同下。",
      "text_length": 10
    },
    {
      "event_id": "01010016_e00027",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤上。",
      "text_length": 5
    },
    {
      "event_id": "01010016_e00028",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "催马来在战场道，会一会罗家山那家英豪。",
      "text_length": 19
    },
    {
      "event_id": "01010016_e00029",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "呼延赞"
      ],
      "text": "乌骓马不住得吮声吼，",
      "text_length": 10
    },
    {
      "event_id": "01010016_e00030",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "呼延赞上。",
      "text_length": 5
    },
    {
      "event_id": "01010016_e00031",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "呼延赞"
      ],
      "text": "打将鞭一举鬼神愁！催马儿来至在御营口，",
      "text_length": 19
    },
    {
      "event_id": "01010016_e00032",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "呀呔！",
      "text_length": 3
    },
    {
      "event_id": "01010016_e00033",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "呼延赞"
      ],
      "text": "叫一声乾德王快出营头！",
      "text_length": 11
    },
    {
      "event_id": "01010016_e00034",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "只见他乌油盔乌油甲，皂罗袍上绣团花。跨下了一骑乌骓马，打将钢鞭手内拿。问一声小将名和姓，通上名来好动杀法！",
      "text_length": 53
    },
    {
      "event_id": "01010016_e00035",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "呼延赞"
      ],
      "text": "家住在河南汴梁城，我的父名叫呼寿廷。若问小将名和姓，呼延赞，",
      "text_length": 30
    },
    {
      "event_id": "01010016_e00036",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "就是少爷的名！",
      "text_length": 7
    },
    {
      "event_id": "01010016_e00037",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "孤道呼家无有后，原来还有后代根。不通名姓走了罢，",
      "text_length": 24
    },
    {
      "event_id": "01010016_e00038",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "钢鞭不打无名人！",
      "text_length": 8
    },
    {
      "event_id": "01010016_e00039",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "乾德王现在黄罗帐，我是他驾前一小军。",
      "text_length": 18
    },
    {
      "event_id": "01010016_e00040",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "看你不像军家样，定是御营乾德王！",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00041",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "少有关西闯帝邦，岂肯过伏小儿郎？若问孤王名和姓，孤就是御营乾德王！",
      "text_length": 33
    },
    {
      "event_id": "01010016_e00042",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、呼延赞同开打，赵匡胤下，呼延赞追下。赵匡胤上。",
      "text_length": 27
    },
    {
      "event_id": "01010016_e00043",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "催马来在战场下，小将到来顺说他。",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00044",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "呼延赞上。",
      "text_length": 5
    },
    {
      "event_id": "01010016_e00045",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "我父身犯何条律，为何一命问斩刑？",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00046",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "小将军暂息雷霆怒，",
      "text_length": 9
    },
    {
      "event_id": "01010016_e00047",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "细听孤王说分明：恨河东刘冲贼战表打定，他要夺孤王的锦绣龙廷。欧阳藩在金殿挂了帅印，你的父倒作了马前先行。三更时那胡儿前来偷营，满营中俱言道反了寿廷。一个斩字未曾出口，欧阳藩拔宝剑杀尔的父亲！",
      "text_length": 95
    },
    {
      "event_id": "01010016_e00048",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "君不传旨谁敢斩？哪一个大胆乱杀人！",
      "text_length": 17
    },
    {
      "event_id": "01010016_e00049",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "兵权落在奸贼手，孤王也要听令行。",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00050",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "不会为君死了罢，苍天再降紫微星！",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00051",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "小将保孤回朝转，孤封你前殿王？",
      "text_length": 15
    },
    {
      "event_id": "01010016_e00052",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "不要！",
      "text_length": 3
    },
    {
      "event_id": "01010016_e00053",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "后殿王？",
      "text_length": 4
    },
    {
      "event_id": "01010016_e00054",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "不要！",
      "text_length": 3
    },
    {
      "event_id": "01010016_e00055",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "一十八驾总兵王？",
      "text_length": 8
    },
    {
      "event_id": "01010016_e00056",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "呸！",
      "text_length": 2
    },
    {
      "event_id": "01010016_e00057",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "万里江山我不要，一心要报杀父仇！",
      "text_length": 16
    },
    {
      "event_id": "01010016_e00058",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "小将不必逞刚强，",
      "text_length": 8
    },
    {
      "event_id": "01010016_e00059",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "罗家山前自为王！",
      "text_length": 8
    },
    {
      "event_id": "01010016_e00060",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "孤王与你分上下！",
      "text_length": 8
    },
    {
      "event_id": "01010016_e00061",
      "play_id": "01010016",
      "scene_id": "01010016_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、呼延赞同开打，赵匡胤下，呼延赞追下。",
      "text_length": 22
    },
    {
      "event_id": "01010016_e00062",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "龙形、虎形同上。赵匡胤上，呼延赞追上。",
      "text_length": 19
    },
    {
      "event_id": "01010016_e00063",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "人困马乏难交战，",
      "text_length": 8
    },
    {
      "event_id": "01010016_e00064",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 64,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "01010016_e00065",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 65,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "只见小将睡雕鞍。手使金锏朝下打，只见黑虎奔了山！",
      "text_length": 24
    },
    {
      "event_id": "01010016_e00066",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 66,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "呼延赞"
      ],
      "text": "梦儿里梦见了我父到，",
      "text_length": 10
    },
    {
      "event_id": "01010016_e00067",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 67,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "01010016_e00068",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 68,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "呼延赞"
      ],
      "text": "只见昏王睡鞍鞒。手使钢鞭朝下打，只见赤火龙一条！扳鞍离镫下战马，三呼万岁饶恕咱！",
      "text_length": 40
    },
    {
      "event_id": "01010016_e00069",
      "play_id": "01010016",
      "scene_id": "01010016_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "赵匡胤"
      ],
