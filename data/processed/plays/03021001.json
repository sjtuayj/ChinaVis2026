  "events": [
    {
      "event_id": "03021001_e00001",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00002",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王宝钏"
      ],
      "text": "每日刺绣龙凤袄，侍奉双亲到白头。",
      "text_length": 16
    },
    {
      "event_id": "03021001_e00003",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟暗上。",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00004",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "奴家，王宝钏。爹爹王允，官居首相。母亲陈氏，生我姐妹三人——大姐金钏，许配苏龙。二姐银钏，许配魏虎。只有奴家尚未婚配。这且不言。只因昨夜偶得一梦，梦见一颗斗大红星，坠落卧房，将我惊醒。不知主何吉凶？我不免去到花园焚香祝告。丫鬟！",
      "text_length": 114
    },
    {
      "event_id": "03021001_e00005",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "03021001_e00006",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "捧定香盘，带路花园！",
      "text_length": 10
    },
    {
      "event_id": "03021001_e00007",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "03021001_e00008",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏离座。",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00009",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮三眼板",
      "speakers": [
        "王宝钏"
      ],
      "text": "昨夜晚一梦甚稀奇，斗大的红星坠落房里。只惊得奴家汗满体，不知是凶还是吉？叫丫鬟带路花园里，",
      "text_length": 45
    },
    {
      "event_id": "03021001_e00010",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟捧香盘引王宝钏同进园门。丫鬟摆香盘，王宝钏上香跪拜。",
      "text_length": 28
    },
    {
      "event_id": "03021001_e00011",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮三眼板",
      "speakers": [
        "王宝钏"
      ],
      "text": "双膝跌跪——",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00012",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "王宝钏"
      ],
      "text": "在丹墀。夜梦红星甚稀奇，因此到花园将神祈。叩罢头来——",
      "text_length": 27
    },
    {
      "event_id": "03021001_e00013",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "身站起，",
      "text_length": 4
    },
    {
      "event_id": "03021001_e00014",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏站起，归座。丫鬟撤去香盘。",
      "text_length": 16
    },
    {
      "event_id": "03021001_e00015",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "小坐片时暂歇息。",
      "text_length": 8
    },
    {
      "event_id": "03021001_e00016",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵上。",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00017",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "薛平贵"
      ],
      "text": "身上无衣御寒凉，肚内饥饿实难当。将身来在大街上，",
      "text_length": 24
    },
    {
      "event_id": "03021001_e00018",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵走小圆场。",
      "text_length": 8
    },
    {
      "event_id": "03021001_e00019",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "薛平贵"
      ],
      "text": "抬头只见府门墙。",
      "text_length": 8
    },
    {
      "event_id": "03021001_e00020",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "俺，薛平贵。乃长安人氏。只因时运不佳，落在这乞讨之中。来此已是王相府的花园门首。身体困倦，不免在此打睡片时。正是：",
      "text_length": 57
    },
    {
      "event_id": "03021001_e00021",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "薛平贵"
      ],
      "text": "丢开心中事，昏沉睡阳台。",
      "text_length": 12
    },
    {
      "event_id": "03021001_e00022",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵卧睡。",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00023",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "丫鬟！",
      "text_length": 3
    },
    {
      "event_id": "03021001_e00024",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟允。",
      "text_length": 4
    },
    {
      "event_id": "03021001_e00025",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我闷坐花园，甚是无聊，到哪里去玩耍玩耍？",
      "text_length": 20
    },
    {
      "event_id": "03021001_e00026",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "咱们到花园门外，玩玩去吧！",
      "text_length": 13
    },
    {
      "event_id": "03021001_e00027",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "如此，带路！",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00028",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "03021001_e00029",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏离座，随丫鬟同出门。",
      "text_length": 13
    },
    {
      "event_id": "03021001_e00030",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "呦，小姐，大事不好啦！",
      "text_length": 11
    },
    {
      "event_id": "03021001_e00031",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00032",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "外面着火啦！",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00033",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "待我看来。",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00034",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏看薛平贵。",
      "text_length": 8
    },
    {
      "event_id": "03021001_e00035",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03021001_e00036",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏想。",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00037",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "丫鬟，你远看？",
      "text_length": 7
    },
    {
      "event_id": "03021001_e00038",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是火！",
      "text_length": 3
    },
    {
      "event_id": "03021001_e00039",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "近观呢？",
      "text_length": 4
    },
    {
      "event_id": "03021001_e00040",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是一个花郎。",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00041",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "你去将那花郎唤醒，带进花园，我有话讲。",
      "text_length": 19
    },
    {
      "event_id": "03021001_e00042",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "03021001_e00043",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏进门，归座。",
      "text_length": 9
    },
    {
      "event_id": "03021001_e00044",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "花郎醒来！",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00045",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "原来是丫鬟姐。唤我何事？",
      "text_length": 12
    },
    {
      "event_id": "03021001_e00046",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "我家小姐叫你进去，有话问你。",
      "text_length": 14
    },
    {
      "event_id": "03021001_e00047",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "有劳了！",
      "text_length": 4
    },
    {
      "event_id": "03021001_e00048",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵站。丫鬟引薛平贵同进门。薛平贵向王宝钏作揖。",
      "text_length": 25
    },
    {
      "event_id": "03021001_e00049",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "参见小姐！",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00050",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "罢了。",
      "text_length": 3
    },
    {
      "event_id": "03021001_e00051",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏自想。",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00052",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "哎呀且住！看这花郎，两耳垂肩，双手过膝，乃大贵之相，为何落在乞讨之中？嗯！我自有道理。",
      "text_length": 43
    },
    {
      "event_id": "03021001_e00053",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏对薛平贵。",
      "text_length": 8
    },
    {
      "event_id": "03021001_e00054",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊花郎，你家住哪里，姓甚名谁？一一讲来，也好周济于你。",
      "text_length": 27
    },
    {
      "event_id": "03021001_e00055",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "小姐容禀！",
      "text_length": 5
    },
    {
      "event_id": "03021001_e00056",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "薛平贵"
      ],
      "text": "小姐在上容我禀，细听花郎说分明：家住本国长安地，父母早已命归阴。若问花郎名和姓，薛平贵就是我的名。",
      "text_length": 49
    },
    {
      "event_id": "03021001_e00057",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03021001_e00058",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "听他言来自思忖：容貌不像受苦的人——两耳垂肩贵相品，龙眉虎目帝王尊。夜梦红星是有准，莫非应在此人的身？彩球之事——",
      "text_length": 57
    },
    {
      "event_id": "03021001_e00059",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "对他论，",
      "text_length": 4
    },
    {
      "event_id": "03021001_e00060",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏左右两顾。",
      "text_length": 8
    },
    {
      "event_id": "03021001_e00061",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "又恐丫鬟在旁听。",
      "text_length": 8
    },
    {
      "event_id": "03021001_e00062",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊丫鬟，去到绣房取银子一锭、衣服一件。",
      "text_length": 19
    },
    {
      "event_id": "03021001_e00063",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "03021001_e00064",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟下。",
      "text_length": 4
    },
    {
      "event_id": "03021001_e00065",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊花郎，方才你言道家中父母双亡，你可有……",
      "text_length": 21
    },
    {
      "event_id": "03021001_e00066",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "有什么？",
      "text_length": 4
    },
    {
      "event_id": "03021001_e00067",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "可有妻室呀？",
      "text_length": 6
    },
    {
      "event_id": "03021001_e00068",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏用袖掩面作羞。",
      "text_length": 10
    },
    {
      "event_id": "03021001_e00069",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "小姐说哪里话来！落在乞讨之中，哪里来得银钱娶妻呀？",
      "text_length": 25
    },
    {
      "event_id": "03021001_e00070",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我有一言，不好启齿。",
      "text_length": 10
    },
    {
      "event_id": "03021001_e00071",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "小姐有何金言，尽管请讲。",
      "text_length": 12
    },
    {
      "event_id": "03021001_e00072",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊花郎，我对你实说了吧：我父约定二月二日，在十字街前，高搭彩楼，抛球招赘。是日你可站在楼前。倘若姻缘有分，也未可知。",
      "text_length": 58
    },
    {
      "event_id": "03021001_e00073",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "里面都是王孙公子，哪有花郎之份？",
      "text_length": 16
    },
    {
      "event_id": "03021001_e00074",
      "play_id": "03021001",
      "scene_id": "03021001_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我有一言，你且听了！",
      "text_length": 10
    },
    {
