      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "石敬塘",
        "高行周"
      ],
      "text": "家将，",
      "text_length": 3
    },
    {
      "event_id": "01012016_e00013",
