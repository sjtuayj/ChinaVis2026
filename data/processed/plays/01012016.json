      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "石敬塘",
        "高行周"
      ],
      "text": "掌灯。",
      "text_length": 3
    },
    {
      "event_id": "01012016_e00015",
      "play_id": "01012016",
      "scene_id": "01012016_s01",
      "scene_no": 1,
      "seq_global": 15,
