      "speakers": [
        "高行周"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "01012016_e00010",
      "play_id": "01012016",
      "scene_id": "01012016_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "石敬塘"
      ],
      "text": "奉了母亲之命，前来要报杀父之仇。昨日阵前，与那贼王彦章打了一仗，两家不分胜败。今晚你我私出唐营，不免去到观星台上，看看此贼什么星宿临凡下降。",
      "text_length": 70
    },
    {
      "event_id": "01012016_e00011",
      "play_id": "01012016",
      "scene_id": "01012016_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高行周"
      ],
      "text": "如此，小弟奉陪。",
      "text_length": 8
    },
    {
      "event_id": "01012016_e00012",
      "play_id": "01012016",
      "scene_id": "01012016_s01",
      "scene_no": 1,
      "seq_global": 12,
