  "events": [
    {
      "event_id": "01031006_e00001",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手执水旗、四水怪、老龙、母龙、小龙同上。",
      "text_length": 22
    },
    {
      "event_id": "01031006_e00002",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "老龙"
      ],
      "text": "波浪滔天，水晶宫殿，乐安然，学道成仙，神通真无限。",
      "text_length": 25
    },
    {
      "event_id": "01031006_e00003",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老龙"
      ],
      "text": "吾本海岛一虬龙，每日居住水晶宫。莲花万朵波千顷，快乐逍遥永安宁。",
      "text_length": 32
    },
    {
      "event_id": "01031006_e00004",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老龙"
      ],
      "text": "吾乃，赤发虬龙是也。在这莲花塘内，修炼千年，倒也逍遥自在。吓夫人！",
      "text_length": 33
    },
    {
      "event_id": "01031006_e00005",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "母龙"
      ],
      "text": "大王。",
      "text_length": 3
    },
    {
      "event_id": "01031006_e00006",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老龙"
      ],
      "text": "今乃九华山天仙圣母寿诞之期，吾等备得寿礼，前去拜寿。夫人要一同前往。",
      "text_length": 34
    },
    {
      "event_id": "01031006_e00007",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "母龙"
      ],
      "text": "妾身奉陪。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00008",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老龙"
      ],
      "text": "众水卒，恭备寿礼一份，随吾同往。",
      "text_length": 16
    },
    {
      "event_id": "01031006_e00009",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四水怪同允。",
      "text_length": 6
    },
    {
      "event_id": "01031006_e00010",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "孩儿也要前往。",
      "text_length": 7
    },
    {
      "event_id": "01031006_e00011",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老龙"
      ],
      "text": "我儿好好看守洞府，为父去去就回。",
      "text_length": 16
    },
    {
      "event_id": "01031006_e00012",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "孩儿遵命。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00013",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手、四水怪、老龙、母龙同下。",
      "text_length": 16
    },
    {
      "event_id": "01031006_e00014",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "看吾父母去往九华山，与圣母拜寿，吾不免出得洞府，去到人间走走便了。",
      "text_length": 33
    },
    {
      "event_id": "01031006_e00015",
      "play_id": "01031006",
      "scene_id": "01031006_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小龙下。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00016",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨氏上。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00017",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "杨氏"
      ],
      "text": "嫁汉嫁汉，穿衣吃饭。",
      "text_length": 10
    },
    {
      "event_id": "01031006_e00018",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杨氏"
      ],
      "text": "奴家生来命运差，嫁个丈夫丑如麻。纵有家财无处用，终朝念佛把香插。",
      "text_length": 32
    },
    {
      "event_id": "01031006_e00019",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "我杨氏。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00020",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟暗上。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00021",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "嫁与金钱子为妻，虽有家财万贯。怎奈他长的四六不成材，三分不像人，七分倒像鬼。我不见他倒好。一见他我就有气。每天无事，只是烧香念佛。这日子也不知到何日是个了吓！",
      "text_length": 79
    },
    {
      "event_id": "01031006_e00022",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "我说大奶奶，我自嫁了您们大爷，吃的是珍馐美味，穿的是绫罗绸缎，哪有一点不好？等到明年，再生养一位少爷，您岂不是更乐啦吗？",
      "text_length": 60
    },
    {
      "event_id": "01031006_e00023",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "你再也不要说啦。不提养儿子到好，提起了养儿子，反倒叫我生气。你看你们大爷，那个长相儿，三分不像人，七分倒像鬼，不见他倒好，一见他我就生气。",
      "text_length": 69
    },
    {
      "event_id": "01031006_e00024",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "大奶奶，您倒不要这样说。我们大爷，虽然相貌丑陋，到了晚上，办起事来，同人家是一样的滋味。",
      "text_length": 44
    },
    {
      "event_id": "01031006_e00025",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "我告诉你说罢，我宁可一辈子长斋，我也不贪他那一口荤食。",
      "text_length": 27
    },
    {
      "event_id": "01031006_e00026",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "大奶奶也不必烦闷，咱们到花园里去玩玩去，好不好？",
      "text_length": 24
    },
    {
      "event_id": "01031006_e00027",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "如此带路。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00028",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "杨氏"
      ],
      "text": "艳阳日春光好花红一片，桃花红杨柳绿百鸟声喧。来至在花园内抬头观看，又只见双燕子飞落池边。",
      "text_length": 44
    },
    {
      "event_id": "01031006_e00029",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小龙上。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00030",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "小龙"
      ],
      "text": "离却了莲花塘大街游玩，有男女和老少闹嚷声喧。来在了花园门用目观看，假装做一道士沿门化缘。",
      "text_length": 44
    },
    {
      "event_id": "01031006_e00031",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "呀，这门外头，是什么人在此敲木鱼儿，待我出去看看。嗳呀，敢自是一位小道士在这里化缘呐。我说大奶奶，瞧您门外头，来了一位小道童，在咱们这儿化缘呐。",
      "text_length": 72
    },
    {
      "event_id": "01031006_e00032",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "待我出去看看。我说那一位道童，你是从哪里来的？你要一一讲来。",
      "text_length": 30
    },
    {
      "event_id": "01031006_e00033",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "听了！",
      "text_length": 3
    },
    {
      "event_id": "01031006_e00034",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "小龙"
      ],
      "text": "家住在盘陀山玄真庙院，每日里在山中修道参禅。都只为庙残破欲修宫殿，因此上求施主资助银钱。",
      "text_length": 44
    },
    {
      "event_id": "01031006_e00035",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "原来如此，你请进来坐坐罢。",
      "text_length": 13
    },
    {
      "event_id": "01031006_e00036",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "对啦，我们大奶奶是最爱行善的。你今天可是来巧啦！",
      "text_length": 24
    },
    {
      "event_id": "01031006_e00037",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "我说你还不曾吃饭啦罢？",
      "text_length": 11
    },
    {
      "event_id": "01031006_e00038",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "这……正是。不曾用饭。",
      "text_length": 11
    },
    {
      "event_id": "01031006_e00039",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "那么你就随我来罢。",
      "text_length": 9
    },
    {
      "event_id": "01031006_e00040",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨氏拉小龙同下。",
      "text_length": 8
    },
    {
      "event_id": "01031006_e00041",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "好吓，我们大奶奶，今天可遇见了小白脸好面孔的人啦。我去跟着他们，看他们做些什么事情？",
      "text_length": 42
    },
    {
      "event_id": "01031006_e00042",
      "play_id": "01031006",
      "scene_id": "01031006_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟下。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00043",
      "play_id": "01031006",
      "scene_id": "01031006_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金钱子上。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00044",
      "play_id": "01031006",
      "scene_id": "01031006_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "金钱子"
      ],
      "text": "生在了富豪家十分侥幸，有田产和家财骡马成群。时才间在长街闲游散闷，只吃得醉醺醺转回家门。",
      "text_length": 44
    },
    {
      "event_id": "01031006_e00045",
      "play_id": "01031006",
      "scene_id": "01031006_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金钱子下。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00046",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 46,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨氏引小龙同上，丫鬟随上。",
      "text_length": 13
    },
    {
      "event_id": "01031006_e00047",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 47,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "小龙"
      ],
      "text": "男贪女爱多缱绻，",
      "text_length": 8
    },
    {
      "event_id": "01031006_e00048",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 48,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "杨氏"
      ],
      "text": "千里姻缘一线牵。",
      "text_length": 8
    },
    {
      "event_id": "01031006_e00049",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 49,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "娘子请坐。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00050",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 50,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "请坐，我说你这样的年轻，你也有点道行靡有？",
      "text_length": 21
    },
    {
      "event_id": "01031006_e00051",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 51,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "若问俺的神通，俺降妖捉怪，无一不能。俺看你这里妖气冲天，定有妖魔鬼怪。",
      "text_length": 35
    },
    {
      "event_id": "01031006_e00052",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 52,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "怎么，这儿有妖怪，那倒巧啦。就请你就替我们给捉捉吧。",
      "text_length": 26
    },
    {
      "event_id": "01031006_e00053",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 53,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金钱子上。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00054",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 54,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "金钱子"
      ],
      "text": "将身来在卧房外，见一道童怒冲怀。",
      "text_length": 16
    },
    {
      "event_id": "01031006_e00055",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 55,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金钱子"
      ],
      "text": "胆大道童，来到我的卧房作甚？",
      "text_length": 14
    },
    {
      "event_id": "01031006_e00056",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 56,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "方才我说有妖怪，果然妖怪来了，",
      "text_length": 15
    },
    {
      "event_id": "01031006_e00057",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 57,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "这不是妖怪，这就是我们家的大爷。",
      "text_length": 16
    },
    {
      "event_id": "01031006_e00058",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 58,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "你说不是妖怪，这一时三刻，管叫他化为脓血而亡。天灵灵，地灵灵，唵嘛呢，叭咪吽。",
      "text_length": 39
    },
    {
      "event_id": "01031006_e00059",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 59,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金钱子倒地。火彩。风婆、雨师、雷公、电母同上。小龙急下。风婆、雨师、雷公、电母同追下。",
      "text_length": 43
    },
    {
      "event_id": "01031006_e00060",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 60,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "嗳呀，可吓死我啦！",
      "text_length": 9
    },
    {
      "event_id": "01031006_e00061",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 61,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "嗳呀，我的妈呀，这一刻的工夫，我们大爷也化成了血泥啦.这小道童，也被雷给殛啦，这怎么好？",
      "text_length": 44
    },
    {
      "event_id": "01031006_e00062",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨氏"
      ],
      "text": "从今以后，我可再也不敢相遇人啦。阿弥陀佛。",
      "text_length": 21
    },
    {
      "event_id": "01031006_e00063",
      "play_id": "01031006",
      "scene_id": "01031006_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨氏、丫鬟同下。",
      "text_length": 8
    },
    {
      "event_id": "01031006_e00064",
      "play_id": "01031006",
      "scene_id": "01031006_s05",
      "scene_no": 5,
      "seq_global": 64,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手、八水卒、老龙、母龙同上。小龙跑上。",
      "text_length": 21
    },
    {
      "event_id": "01031006_e00065",
      "play_id": "01031006",
      "scene_id": "01031006_s05",
      "scene_no": 5,
      "seq_global": 65,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小龙"
      ],
      "text": "雷电殛儿，望乞爹娘救我。",
      "text_length": 12
    },
    {
      "event_id": "01031006_e00066",
      "play_id": "01031006",
      "scene_id": "01031006_s05",
      "scene_no": 5,
      "seq_global": 66,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老龙"
      ],
      "text": "众水卒，随吾出洞。",
      "text_length": 9
    },
    {
      "event_id": "01031006_e00067",
      "play_id": "01031006",
      "scene_id": "01031006_s05",
      "scene_no": 5,
      "seq_global": 67,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众民人同跑上，同绕场，被水淹。众民人同下。",
      "text_length": 21
    },
    {
      "event_id": "01031006_e00068",
      "play_id": "01031006",
      "scene_id": "01031006_s06",
      "scene_no": 6,
      "seq_global": 68,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "县官捧香盘上。",
      "text_length": 7
    },
    {
      "event_id": "01031006_e00069",
      "play_id": "01031006",
      "scene_id": "01031006_s06",
      "scene_no": 6,
      "seq_global": 69,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "县官"
      ],
      "text": "四面洪水滔滔滚，波浪翻天淹没城。男女百姓皆丧命，好不叫人恸伤情。将身且把后衙进，祷告天地众神灵。但愿早把水退尽，满斗焚香谢神灵。叩罢头来忙站定，上天保佑众生灵。",
      "text_length": 80
    },
    {
      "event_id": "01031006_e00070",
      "play_id": "01031006",
      "scene_id": "01031006_s06",
      "scene_no": 6,
      "seq_global": 70,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "县官下。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00071",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 71,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "达摩上。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00072",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 72,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锦金香",
      "speakers": [
        "达摩"
      ],
      "text": "怎见得，为菩提，怎见得，轮回脱。必须受尽恓惶，脱此磨折，信道超凡，得功烈。妙理谁知，妙法难说，这九年面壁，消受清风明月。运精神贯澈，到功德圆满，参禅悟道，只消一霎。",
      "text_length": 82
    },
    {
      "event_id": "01031006_e00073",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 73,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙悟空上。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00074",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 74,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "我道是谁，原来是达摩祖师。",
      "text_length": 13
    },
    {
      "event_id": "01031006_e00075",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 75,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "达摩"
      ],
      "text": "原来是大圣，吾这里稽首了。",
      "text_length": 13
    },
    {
      "event_id": "01031006_e00076",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 76,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "我闲听人言，你在那少林寺，参禅悟道，养性修真。面壁九年，头上喜鹊成巢，耳朵内长出青草来，人人都道你圆寂了。怎么你还不会死么？",
      "text_length": 62
    },
    {
      "event_id": "01031006_e00077",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 77,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "达摩"
      ],
      "text": "吾本无生，哪得有死？",
      "text_length": 10
    },
    {
      "event_id": "01031006_e00078",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 78,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "阿弥陀佛。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00079",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 79,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "达摩"
      ],
      "text": "大圣，我看你匆匆忙忙，莫非也要往昊天路上去么？",
      "text_length": 23
    },
    {
      "event_id": "01031006_e00080",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 80,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "嗳呀祖师吓！此事你还不知道么？",
      "text_length": 15
    },
    {
      "event_id": "01031006_e00081",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 81,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "达摩"
      ],
      "text": "吾却不晓。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00082",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 82,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "只因莲花塘，赤发虬龙作乱，水淹百里，伤害无数生灵。玉帝大怒，点动天兵天将，扫荡孽龙。连俺老孙，也在其内。",
      "text_length": 52
    },
    {
      "event_id": "01031006_e00083",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 83,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "达摩"
      ],
      "text": "原来如此。看今日你我相逢，可算有缘，吾同你去到十洲三岛游玩一回，你意如何？",
      "text_length": 37
    },
    {
      "event_id": "01031006_e00084",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 84,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "不得工夫，改日再会。少陪了。",
      "text_length": 14
    },
    {
      "event_id": "01031006_e00085",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 85,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙悟空下。",
      "text_length": 5
    },
    {
      "event_id": "01031006_e00086",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 86,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "达摩"
      ],
      "text": "你看这个猴头，头也不回。竟自去了。",
      "text_length": 17
    },
    {
      "event_id": "01031006_e00087",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 87,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "端正好",
      "speakers": [
        "达摩"
      ],
      "text": "你看他，势匆匆，来无影，去无踪。驾觔斗，影无形，迹无踪，他心中，恋、恋、恋，意欲动刀兵。一个个，逞雄威，施法力，彼此耍显神通。俺这里，心旷神怡，踏遍碧苍穹。",
      "text_length": 78
    },
    {
      "event_id": "01031006_e00088",
      "play_id": "01031006",
      "scene_id": "01031006_s07",
      "scene_no": 7,
      "seq_global": 88,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "达摩下。",
      "text_length": 4
    },
    {
      "event_id": "01031006_e00089",
      "play_id": "01031006",
      "scene_id": "01031006_s08",
      "scene_no": 8,
      "seq_global": 89,
      "seq_in_scene": 1,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖急急风〗。四上手、金吒、木吒、哪吒、伽蓝、青龙、白虎、二郎神同上。",
      "text_length": 34
    },
    {
      "event_id": "01031006_e00090",
      "play_id": "01031006",
      "scene_id": "01031006_s08",
      "scene_no": 8,
      "seq_global": 90,
      "seq_in_scene": 2,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "二郎神"
      ],
      "text": "众神将，莲花塘去者。（四上手、金吒、木吒、哪吒、伽蓝、青龙、白虎同允。四下手、四水卒、四水怪、老龙、母龙同上，同会阵，同起打连环。母龙下枪花，打出手。四上手、金吒、木吒、哪吒、伽蓝、青龙、白虎、二郎神同败下。母龙耍大刀花，下。打十二股荡。孙悟空对老龙败下。母龙上，孙悟空打母龙下。孙悟空耍棍花，下。四上手、金吒、木吒、哪吒、伽蓝、青龙、白虎、二郎神同上，同摆阵。四下手、四水卒、四水怪同翻跟头。布景开幕，满台莲花灯彩。老龙形、母龙形同被擒。）",
      "text_length": 221
    },
    {
      "event_id": "01031006_e00091",
      "play_id": "01031006",
      "scene_id": "01031006_s08",
      "scene_no": 8,
      "seq_global": 91,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "二郎神"
      ],
      "text": "众神将，回复玉帝去者！",
      "text_length": 11
    },
    {
      "event_id": "01031006_e00092",
      "play_id": "01031006",
      "scene_id": "01031006_s08",
      "scene_no": 8,
      "seq_global": 92,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。〖牌子〗。",
      "text_length": 10
    }
  ],
  "roles_inferred": true
}