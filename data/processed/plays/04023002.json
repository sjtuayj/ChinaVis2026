  "events": [
    {
      "event_id": "04023002_e00001",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松上。",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00002",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "武松"
      ],
      "text": "老天何苦困英雄，叹豪杰不如蒿蓬！不承望奋云程九万里，只落得沸尘海数千重。",
      "text_length": 36
    },
    {
      "event_id": "04023002_e00003",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "俺武松呵！",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00004",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "武松"
      ],
      "text": "好一似浪迹浮踪，也曾遭鱼虾弄。",
      "text_length": 15
    },
    {
      "event_id": "04023002_e00005",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "呀！看酒旗上写“三碗不过岗”，这是怎么说？待俺沽饮几杯，问个明白。酒家！",
      "text_length": 36
    },
    {
      "event_id": "04023002_e00006",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "酒保"
      ],
      "text": "啊哈！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00007",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保上。",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00008",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "酒保"
      ],
      "text": "酒酒酒，有有有；赊赊赊，走走走。",
      "text_length": 16
    },
    {
      "event_id": "04023002_e00009",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，您喝酒吗？",
      "text_length": 8
    },
    {
      "event_id": "04023002_e00010",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00011",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "请到里面。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00012",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "酒家，你那酒旗上写“三碗不过岗”，这是怎么说？",
      "text_length": 23
    },
    {
      "event_id": "04023002_e00013",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，因为小店的酒好，力量太大，您要是喝三碗，就过不去前面的景阳岗啦。",
      "text_length": 35
    },
    {
      "event_id": "04023002_e00014",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "俺却不信。取酒来，待俺吃它三十碗。取酒来！",
      "text_length": 21
    },
    {
      "event_id": "04023002_e00015",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "好大口气。我拿酒去，您一喝就知道啦。好酒一壶。",
      "text_length": 23
    },
    {
      "event_id": "04023002_e00016",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保取酒。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00017",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，酒到啦。我给您斟上。",
      "text_length": 13
    },
    {
      "event_id": "04023002_e00018",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "就是这个碗？",
      "text_length": 6
    },
    {
      "event_id": "04023002_e00019",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "就这碗，喝三碗就过不去岗啦！",
      "text_length": 14
    },
    {
      "event_id": "04023002_e00020",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松饮酒。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00021",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "干。斟上！",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00022",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "给您斟哪。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00023",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保斟酒，武松饮尽。",
      "text_length": 10
    },
    {
      "event_id": "04023002_e00024",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，给您来点甚么酒菜？",
      "text_length": 12
    },
    {
      "event_id": "04023002_e00025",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保斟酒。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00026",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "酒家！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00027",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "折桂令",
      "speakers": [
        "武松"
      ],
      "text": "又何须炙凤烹龙。",
      "text_length": 8
    },
    {
      "event_id": "04023002_e00028",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松饮酒。酒保自语。",
      "text_length": 10
    },
    {
      "event_id": "04023002_e00029",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "这位客人爱喝寡酒。",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00030",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "斟上。",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00031",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "没啦！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00032",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "怎么刚吃就无有了？",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00033",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "我们这酒壶就盛三碗，一滴不会多，一滴也不会少。",
      "text_length": 23
    },
    {
      "event_id": "04023002_e00034",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "嗳！说甚么三碗四碗，取酒来，待俺吃它一坛。",
      "text_length": 21
    },
    {
      "event_id": "04023002_e00035",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "啊？",
      "text_length": 2
    },
    {
      "event_id": "04023002_e00036",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "取酒来。",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00037",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "嗳嗳，我给您取去。好酒一坛哪！",
      "text_length": 15
    },
    {
      "event_id": "04023002_e00038",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保取酒坛放在桌上，打开泥头，吹土，武松用袖拂面。",
      "text_length": 25
    },
    {
      "event_id": "04023002_e00039",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "蠢才！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00040",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "您闻，喷鼻儿香。我给您斟上。",
      "text_length": 14
    },
    {
      "event_id": "04023002_e00041",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保斟酒。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00042",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，您瞧，真是琥珀的颜色。",
      "text_length": 14
    },
    {
      "event_id": "04023002_e00043",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "妙哇！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00044",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "折桂令",
      "speakers": [
        "武松"
      ],
      "text": "鹦鹉杯浮琥珀光浓。",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00045",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松饮酒。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00046",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "斟上！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00047",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "04023002_e00048",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保斟酒。武松饮酒。",
      "text_length": 10
    },
    {
      "event_id": "04023002_e00049",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "果然好酒。斟上！",
      "text_length": 8
    },
    {
      "event_id": "04023002_e00050",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "04023002_e00051",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保斟酒。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00052",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，您前后喝了五碗啦。",
      "text_length": 12
    },
    {
      "event_id": "04023002_e00053",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "酒家！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00054",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "折桂令",
      "speakers": [
        "武松"
      ],
      "text": "却不道五斗消醒，三杯合道自有神功。",
      "text_length": 17
    },
    {
      "event_id": "04023002_e00055",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松饮酒。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00056",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "斟上！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00057",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，您怎么还喝呀？",
      "text_length": 10
    },
    {
      "event_id": "04023002_e00058",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "斟上！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00059",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "嗳！",
      "text_length": 2
    },
    {
      "event_id": "04023002_e00060",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保斟酒。武松饮酒。",
      "text_length": 10
    },
    {
      "event_id": "04023002_e00061",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "嗳！",
      "text_length": 2
    },
    {
      "event_id": "04023002_e00062",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "折桂令",
      "speakers": [
        "武松"
      ],
      "text": "何用恁虚担惊恐。",
      "text_length": 8
    },
    {
      "event_id": "04023002_e00063",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松抢坛子，抱坛痛饮。酒保见酒自坛口洒在地上。",
      "text_length": 23
    },
    {
      "event_id": "04023002_e00064",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "哎呀，糟蹋啦，糟蹋啦！可惜了的，可惜了的！",
      "text_length": 21
    },
    {
      "event_id": "04023002_e00065",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保急用嘴接酒。",
      "text_length": 8
    },
    {
      "event_id": "04023002_e00066",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "这酒真好，是厉害！",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00067",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "酒家，酒钱多少？",
      "text_length": 8
    },
    {
      "event_id": "04023002_e00068",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "四钱六分七厘八毫三。",
      "text_length": 10
    },
    {
      "event_id": "04023002_e00069",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "酒钱在此。“三碗不过岗”，俺吃了一坛，你看俺过得去岗过不去岗！",
      "text_length": 31
    },
    {
      "event_id": "04023002_e00070",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "客人，您上哪儿去？",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00071",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "景阳岗。",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00072",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "您真过景阳岗，那可不行。岗上出了一只吊睛白额大老虎，伤人甚众。您要过岗不是白白的送死吗？",
      "text_length": 44
    },
    {
      "event_id": "04023002_e00073",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "你不提猛虎，俺倒可不去；如今，你道岗上出了猛虎，俺是偏要过岗！",
      "text_length": 31
    },
    {
      "event_id": "04023002_e00074",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "去不得，您这不是给老虎送点心去吗！",
      "text_length": 17
    },
    {
      "event_id": "04023002_e00075",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "折桂令",
      "speakers": [
        "武松"
      ],
      "text": "分明无事生风，依仗口巧舌能；妄想要把俺播弄，休看俺醉眼朦胧！",
      "text_length": 30
    },
    {
      "event_id": "04023002_e00076",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "去不得，去不得！",
      "text_length": 8
    },
    {
      "event_id": "04023002_e00077",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松甩脱酒保，下。",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00078",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "去不得，哎呀！",
      "text_length": 7
    },
    {
      "event_id": "04023002_e00079",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保酒上涌，呕吐。",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00080",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "酒保"
      ],
      "text": "噁！",
      "text_length": 2
    },
    {
      "event_id": "04023002_e00081",
      "play_id": "04023002",
      "scene_id": "04023002_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "酒保抱酒坛，醉步蹒跚下。",
      "text_length": 12
    },
    {
      "event_id": "04023002_e00082",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松上。",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00083",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "沽美酒",
      "speakers": [
        "武松"
      ],
      "text": "道崎岖，路不平，吃得个醉醺醺，只觉得站立不稳。",
      "text_length": 23
    },
    {
      "event_id": "04023002_e00084",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "嘿！酒家言道，这景阳岗上出了猛虎。分明是大话欺人，俺武松岂能受他的摆布！待俺趱路。",
      "text_length": 41
    },
    {
      "event_id": "04023002_e00085",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松呕吐。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00086",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "唔……酒气上涌。那旁有一大石，待俺打睡片刻，有何不可！",
      "text_length": 27
    },
    {
      "event_id": "04023002_e00087",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松假寐，虎上，武松醒。",
      "text_length": 12
    },
    {
      "event_id": "04023002_e00088",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "呀！好大风，好大风！",
      "text_length": 10
    },
    {
      "event_id": "04023002_e00089",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松见虎。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00090",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "04023002_e00091",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "雁儿落",
      "speakers": [
        "武松"
      ],
      "text": "觑着这泼毛团体势雄，狼牙棒先摧迸；俺这里趋前退后忙，这孽畜舞爪张牙横。",
      "text_length": 35
    },
    {
      "event_id": "04023002_e00092",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "得胜令",
      "speakers": [
        "武松"
      ],
      "text": "呀！哦呵闪——闪得它回身处扑着空，转眼处乱着踪。这才是虎有伤人意，狭路上冤家对面逢。",
      "text_length": 42
    },
    {
      "event_id": "04023002_e00093",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 93,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "虎啊！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00094",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 94,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "得胜令",
      "speakers": [
        "武松"
      ],
      "text": "你要显神通，便做道力有千斤重，管教你拳下尸骨横，拳下尸骨横。",
      "text_length": 30
    },
    {
      "event_id": "04023002_e00095",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 95,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "死了。",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00096",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 96,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松喘息。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00097",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 97,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "待俺下岗趱路。",
      "text_length": 7
    },
    {
      "event_id": "04023002_e00098",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 98,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二猎户扮假虎同上，武松见虎欲打。众猎户急同上。",
      "text_length": 23
    },
    {
      "event_id": "04023002_e00099",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 99,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众猎户"
      ],
      "text": "且慢！",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00100",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 100,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松呕吐。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00101",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 101,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "唔……",
      "text_length": 3
    },
    {
      "event_id": "04023002_e00102",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 102,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众猎户"
      ],
      "text": "你是何人？",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00103",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 103,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "俺乃行路的。",
      "text_length": 6
    },
    {
      "event_id": "04023002_e00104",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 104,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众猎户"
      ],
      "text": "这猛虎？",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00105",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 105,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "被俺打死了。",
      "text_length": 6
    },
    {
      "event_id": "04023002_e00106",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 106,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众猎户"
      ],
      "text": "哎呀呀，这样一只大虫竟被你打死，真乃英雄也！",
      "text_length": 22
    },
    {
      "event_id": "04023002_e00107",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 107,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "夸奖了。",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00108",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 108,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "猎户甲"
      ],
      "text": "请问壮士尊姓大名？",
      "text_length": 9
    },
    {
      "event_id": "04023002_e00109",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 109,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "在下武松。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00110",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 110,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众猎户"
      ],
      "text": "哎呀呀，原来是武壮士。",
      "text_length": 11
    },
    {
      "event_id": "04023002_e00111",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 111,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "猎户甲"
      ],
      "text": "就请壮士随我等一同回去，教大家看看你这打虎的英雄。",
      "text_length": 25
    },
    {
      "event_id": "04023002_e00112",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 112,
      "seq_in_scene": 31,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "这就不敢。",
      "text_length": 5
    },
    {
      "event_id": "04023002_e00113",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 113,
      "seq_in_scene": 32,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众猎户"
      ],
      "text": "壮士请！",
      "text_length": 4
    },
    {
      "event_id": "04023002_e00114",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 114,
      "seq_in_scene": 33,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众猎户同抬死虎，同走圆场。",
      "text_length": 13
    },
    {
      "event_id": "04023002_e00115",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 115,
      "seq_in_scene": 34,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "同沽美酒",
      "speakers": [
        "众猎户"
      ],
      "text": "孽畜凶暴，路人惊恐，多少人丧生含痛！不承望今朝侥幸，天降下打虎英雄。",
      "text_length": 34
    },
    {
      "event_id": "04023002_e00116",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 116,
      "seq_in_scene": 35,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "沽美酒",
      "speakers": [
        "武松"
      ],
      "text": "教众口将咱称颂，无意中做了个打虎的英雄。",
      "text_length": 20
    },
    {
      "event_id": "04023002_e00117",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 117,
      "seq_in_scene": 36,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "同沽美酒",
      "speakers": [
        "众猎户"
      ],
      "text": "也非是肆唇舌称颂，活生生凶猛大虫，在你那拳下尸横。",
      "text_length": 25
    },
    {
      "event_id": "04023002_e00118",
      "play_id": "04023002",
      "scene_id": "04023002_s02",
      "scene_no": 2,
      "seq_global": 118,
      "seq_in_scene": 37,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}