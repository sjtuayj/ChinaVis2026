  "events": [
    {
      "event_id": "01006015_e00001",
      "play_id": "01006015",
      "scene_id": "01006015_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四鬼卒引罗成同上。",
      "text_length": 9
    },
    {
      "event_id": "01006015_e00002",
      "play_id": "01006015",
      "scene_id": "01006015_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "罗成"
      ],
      "text": "生前为良将，死后作忠魂。",
      "text_length": 12
    },
    {
      "event_id": "01006015_e00003",
      "play_id": "01006015",
      "scene_id": "01006015_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "吾乃罗成鬼魂是也。只因苏烈兴兵犯界，圣上命元吉挂帅，命俺为前战先行。黄道日不出兵，黑道日期叫俺出马。不想误陷淤泥河边，被乱箭射死。今有二主秦王、众家国公前来吊祭，伴宿吾府。待吾前去托妻寄子，把吾的苦处细表一番。",
      "text_length": 105
    },
    {
      "event_id": "01006015_e00004",
      "play_id": "01006015",
      "scene_id": "01006015_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "黑暗暗雾沉沉随风飘荡，冷飕飕凄惨惨转回故乡。我主爷来吊祭龙恩光降，众王侯见灵位亦要悲伤。叫鬼卒驾阴风急忙前往，",
      "text_length": 55
    },
    {
      "event_id": "01006015_e00005",
      "play_id": "01006015",
      "scene_id": "01006015_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "罗成"
      ],
      "text": "可怜我英雄汉一命身亡。",
      "text_length": 11
    },
    {
      "event_id": "01006015_e00006",
      "play_id": "01006015",
      "scene_id": "01006015_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成下。",
      "text_length": 4
    },
    {
      "event_id": "01006015_e00007",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "门子上，扫灵堂。罗妻抱罗通哭上，四青袍同上。",
      "text_length": 22
    },
    {
      "event_id": "01006015_e00008",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "罗妻"
      ],
      "text": "哎吓！",
      "text_length": 3
    },
    {
      "event_id": "01006015_e00009",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "门子"
      ],
      "text": "圣驾到。",
      "text_length": 4
    },
    {
      "event_id": "01006015_e00010",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗妻"
      ],
      "text": "有请。",
      "text_length": 3
    },
    {
      "event_id": "01006015_e00011",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李世民、四龙套、众国公同上。",
      "text_length": 14
    },
    {
      "event_id": "01006015_e00012",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗妻"
      ],
      "text": "臣妻有何德能，敢劳二主、众家国公前来吊祭。",
      "text_length": 21
    },
    {
      "event_id": "01006015_e00013",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "李世民",
        "众国公"
      ],
      "text": "岂敢。为国身亡，理当如此。",
      "text_length": 13
    },
    {
      "event_id": "01006015_e00014",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同下。李世民、众国公同祭灵。",
      "text_length": 17
    },
    {
      "event_id": "01006015_e00015",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗妻"
      ],
      "text": "真乃有道明君。",
      "text_length": 7
    },
    {
      "event_id": "01006015_e00016",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "小王要在此伴灵一夜，众家国公，俱在灵堂陪伴小王一宵。",
      "text_length": 26
    },
    {
      "event_id": "01006015_e00017",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众国公"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01006015_e00018",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李世民、众国公同伏桌睡。",
      "text_length": 12
    },
    {
      "event_id": "01006015_e00019",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "罗成"
      ],
      "text": "天下荒荒无真主，",
      "text_length": 8
    },
    {
      "event_id": "01006015_e00020",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成上。",
      "text_length": 4
    },
    {
      "event_id": "01006015_e00021",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "罗成"
      ],
      "text": "上苍降下紫微星。",
      "text_length": 8
    },
    {
      "event_id": "01006015_e00022",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "青龙投胎太原省，那燕山降下白虎星。俺在罗门为公子，长大成人武艺超群。一十六岁保唐王，",
      "text_length": 42
    },
    {
      "event_id": "01006015_e00023",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄垛板",
      "speakers": [
        "罗成"
      ],
      "text": "俺亦曾东荡西除、南征北剿、马不停蹄、血战疆场，到如今只落得一命归阴！",
      "text_length": 34
    },
    {
      "event_id": "01006015_e00024",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "将身儿且把灵堂进，",
      "text_length": 9
    },
    {
      "event_id": "01006015_e00025",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成上高台。",
      "text_length": 6
    },
    {
      "event_id": "01006015_e00026",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "又只见吾主爷瞌睡沉沉。众家国公俱已困，苦命的贤妻傍伴灵。义子罗春身带孝，最可叹无依无靠、孤苦伶仃，三岁的罗通，好不伤心。我的苦命的儿吓！",
      "text_length": 68
    },
    {
      "event_id": "01006015_e00027",
      "play_id": "01006015",
      "scene_id": "01006015_s02",
      "scene_no": 2,
      "seq_global": 27,
