  "events": [
    {
      "event_id": "03057002_e00001",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉上。",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00002",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "贾宝玉"
      ],
      "text": "九十春光，半消磨，病榻愁肠。",
      "text_length": 14
    },
    {
      "event_id": "03057002_e00003",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贾宝玉"
      ],
      "text": "碧桃花下探春回，烧尽心香志不灰。恼煞画梁双燕子，放春归去有余哀。",
      "text_length": 32
    },
    {
      "event_id": "03057002_e00004",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "我、贾宝玉。自从那日与林妹妹，偷看《会真记》，她笑我是个银样镴枪头。我一怒之下，大病一月有余，未出“怡红院”大门一步。想她独坐潇湘，定是一样的愁损人也！",
      "text_length": 76
    },
    {
      "event_id": "03057002_e00005",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贾宝玉"
      ],
      "text": "病回春去感纷如，室近潇湘人迹疏。竟月未将织手握，何时重见黛眉舒？",
      "text_length": 32
    },
    {
      "event_id": "03057002_e00006",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "我今病体痊愈，不免去到“潇湘馆”寻她便了！",
      "text_length": 21
    },
    {
      "event_id": "03057002_e00007",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贾宝玉"
      ],
      "text": "步出怡红日已哺，移将花影过庭除。遥闻鹦鹉声声唤，不见潇湘心辘辘。",
      "text_length": 32
    },
    {
      "event_id": "03057002_e00008",
      "play_id": "03057002",
      "scene_id": "03057002_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉下。",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00009",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉上。",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00010",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "林黛玉"
      ],
      "text": "春去魂消，葬花归，梦冷珠帘。",
      "text_length": 14
    },
    {
      "event_id": "03057002_e00011",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "林黛玉"
      ],
      "text": "东风似剪拂帘钩，只剪韶光不剪愁。欲诉无言惟有泪，可怜鹦鹉在前头。",
      "text_length": 32
    },
    {
      "event_id": "03057002_e00012",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "我、林黛玉。生不逢辰，命途多舛。自从双亲见背，寄居舅氏家中，镇日与宝玉哥哥晤言一室，十分相得。那日沁芳桥前，桃花树下，我二人偷看《会真记》，宝玉言道，他是一个“多愁多病的身”，我就是那“倾国倾城貌”。是我一时羞愤，假意要去告诉舅父、舅母。走到“梨香院”前，恰值那伶官等在内演习戏文，偶尔听得几句道：“原来是姹紫嫣红开遍，似这般都付与断井颓垣，良辰美景奈何天，赏心乐事谁家院？”又道是：“只为你如花美眷，似水流年。”情词悱恻，感慨良深，一直记在心头，不曾忘记。这几日宝玉哥哥他又病了，我这满腔心事，更向谁言？思想起来，好不伤感人也！",
      "text_length": 265
    },
    {
      "event_id": "03057002_e00013",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "林黛玉"
      ],
      "text": "西厢记牡丹亭潇湘写照，似有意若无意怎不魂消！侬本当狠心肠将他弃掉，怎奈这困人天燕姤莺撩。",
      "text_length": 44
    },
    {
      "event_id": "03057002_e00014",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "咳，独坐无聊，空思何益！不免收拾香案，将琴示意，以解闲愁。",
      "text_length": 29
    },
    {
      "event_id": "03057002_e00015",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉起身拂尘，焚香，理琴坐。",
      "text_length": 15
    },
    {
      "event_id": "03057002_e00016",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "一封书",
      "speakers": [
        "林黛玉"
      ],
      "text": "抛书午梦余，悄焚香，春怨虑。不见那惜玉怜香花下侣，选胜寻芳帘外履，教我惜春无计。春光暗移，惜花良苦，花期渐逾，镇日弹琴独坐，短叹长吁。",
      "text_length": 67
    },
    {
      "event_id": "03057002_e00017",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃上。",
      "text_length": 4
    },
    {
      "event_id": "03057002_e00018",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "姑娘琴音缭乱，必然又有什么心事。待我来将她打断。姑娘，明日乃是饯花之期，姑娘你该休养休养才是呀！",
      "text_length": 48
    },
    {
      "event_id": "03057002_e00019",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉惊。",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00020",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "怎么，就要送春了么！",
      "text_length": 10
    },
    {
      "event_id": "03057002_e00021",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "03057002_e00022",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "春去了，它还来是不来？",
      "text_length": 11
    },
    {
      "event_id": "03057002_e00023",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "春去无言，我哪儿知道哪！",
      "text_length": 12
    },
    {
      "event_id": "03057002_e00024",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "春光既去，花事阑珊。你与我收拾花锄、花囊，明日好去葬花，了此一春光景。",
      "text_length": 35
    },
    {
      "event_id": "03057002_e00025",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "03057002_e00026",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃下。",
      "text_length": 4
    },
    {
      "event_id": "03057002_e00027",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "咳，似水流年，今果如此，杜丽娘有词伤春，我岂得无词寄兴，待我来题诗一首！",
      "text_length": 36
    },
    {
      "event_id": "03057002_e00028",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉研磨，蘸笔，沉思。",
      "text_length": 12
    },
    {
      "event_id": "03057002_e00029",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "林黛玉"
      ],
      "text": "侬今制就送春词，望春归兮是何时！伤心从此长相别，未死春蚕忍断丝！",
      "text_length": 32
    },
    {
      "event_id": "03057002_e00030",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉起身。",
      "text_length": 6
    },
    {
      "event_id": "03057002_e00031",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "咳，身体困乏，不免稍睡一时。",
      "text_length": 14
    },
    {
      "event_id": "03057002_e00032",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉上。",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00033",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "风竹萧萧，悄无人语。想是林妹妹春困未醒，待我偷看片时，免得扰她清梦。",
      "text_length": 34
    },
    {
      "event_id": "03057002_e00034",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉翻身卧被坐床。",
      "text_length": 10
    },
    {
      "event_id": "03057002_e00035",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "每日价情思睡昏昏。",
      "text_length": 9
    },
    {
      "event_id": "03057002_e00036",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉掀帘笑。",
      "text_length": 7
    },
    {
      "event_id": "03057002_e00037",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "为什么情思睡昏昏？",
      "text_length": 9
    },
    {
      "event_id": "03057002_e00038",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉惊羞，举被掩面倒身伪睡，贾宝玉坐床，推林黛玉。",
      "text_length": 26
    },
    {
      "event_id": "03057002_e00039",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "妹妹，你为何不理我呀？",
      "text_length": 11
    },
    {
      "event_id": "03057002_e00040",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃上。",
      "text_length": 4
    },
    {
      "event_id": "03057002_e00041",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "鹦鹉传呼，想是宝二爷来啦，待我进去看来。啊二爷，姑娘现在酣睡，你有话，等她起来再说吧。",
      "text_length": 43
    },
    {
      "event_id": "03057002_e00042",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉翻身坐起。",
      "text_length": 8
    },
    {
      "event_id": "03057002_e00043",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "哪个睡觉？",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00044",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "我当是姑娘睡着了哪。",
      "text_length": 10
    },
    {
      "event_id": "03057002_e00045",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉理发。",
      "text_length": 6
    },
    {
      "event_id": "03057002_e00046",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "我正要睡觉，你来此作甚？",
      "text_length": 12
    },
    {
      "event_id": "03057002_e00047",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "给你个榧子吃，我都听见了啊！",
      "text_length": 14
    },
    {
      "event_id": "03057002_e00048",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "二爷听见什么，可是我们姑娘叫我不是？",
      "text_length": 18
    },
    {
      "event_id": "03057002_e00049",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉摇首。",
      "text_length": 6
    },
    {
      "event_id": "03057002_e00050",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "不是，不是。快把你们的好茶倒与我喝。",
      "text_length": 18
    },
    {
      "event_id": "03057002_e00051",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "我们这儿哪有什么好茶？您要好的，等袭人来吧！",
      "text_length": 22
    },
    {
      "event_id": "03057002_e00052",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "休要理他，快去与我舀水。",
      "text_length": 12
    },
    {
      "event_id": "03057002_e00053",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "他是客人，自然是先倒茶来，再给姑娘舀水呀。",
      "text_length": 21
    },
    {
      "event_id": "03057002_e00054",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉怒视。",
      "text_length": 6
    },
    {
      "event_id": "03057002_e00055",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "讨厌！",
      "text_length": 3
    },
    {
      "event_id": "03057002_e00056",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃回顾。",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00057",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "这可怎么好！",
      "text_length": 6
    },
    {
      "event_id": "03057002_e00058",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃下。贾宝玉背供。",
      "text_length": 10
    },
    {
      "event_id": "03057002_e00059",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "好丫头，我若得与你多情小姐同鸳帐，怎舍得叫你叠被铺床。",
      "text_length": 27
    },
    {
      "event_id": "03057002_e00060",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉推贾宝玉。",
      "text_length": 8
    },
    {
      "event_id": "03057002_e00061",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "宝二哥，你说些什么？",
      "text_length": 10
    },
    {
      "event_id": "03057002_e00062",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉拉林黛玉手笑。",
      "text_length": 10
    },
    {
      "event_id": "03057002_e00063",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "我无有说什么呀。",
      "text_length": 8
    },
    {
      "event_id": "03057002_e00064",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "林黛玉以手掩面哭。",
      "text_length": 9
    },
    {
      "event_id": "03057002_e00065",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "如今是新兴头，听了村话来，也说给我听，看了混账书，也拿我取笑，我倒做了替爷们解闷的了。我去告诉舅父、舅母，评评此理。",
      "text_length": 58
    },
    {
      "event_id": "03057002_e00066",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉惊阻林黛玉。",
      "text_length": 9
    },
    {
      "event_id": "03057002_e00067",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "好妹妹，不要如此，我再说这样话，教我嘴上长个疔疮，烂了舌头，一辈子不能说话。",
      "text_length": 38
    },
    {
      "event_id": "03057002_e00068",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃捧茶上。",
      "text_length": 6
    },
    {
      "event_id": "03057002_e00069",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "咳，这是何苦？无缘无故地，又来跟姑娘生气。袭人刚来找你，叫你快去换衣裳，老爷叫你去哪。",
      "text_length": 43
    },
    {
      "event_id": "03057002_e00070",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "你莫骗我，你不怕我去了，你家姑娘更要生气么？",
      "text_length": 22
    },
    {
      "event_id": "03057002_e00071",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "您快着点儿出去，茗烟在外头等着您哪。",
      "text_length": 18
    },
    {
      "event_id": "03057002_e00072",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃推贾宝玉，贾宝玉向内。",
      "text_length": 13
    },
    {
      "event_id": "03057002_e00073",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾宝玉"
      ],
      "text": "我要走了。紫鹃，你好好伺候姑娘，我去去就来，好与你家姑娘陪礼，免得她又要生气。咳，这是哪里说起！",
      "text_length": 48
    },
    {
      "event_id": "03057002_e00074",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贾宝玉下。",
      "text_length": 5
    },
    {
      "event_id": "03057002_e00075",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "适才真是老爷叫二爷么？",
      "text_length": 11
    },
    {
      "event_id": "03057002_e00076",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "正是。姑娘不要跟二爷生气，待我就去与姑娘舀水。",
      "text_length": 23
    },
    {
      "event_id": "03057002_e00077",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "淘气的丫头，方才若不是你多嘴，哪里来的闲气，还不与我拿斗篷来。",
      "text_length": 31
    },
    {
      "event_id": "03057002_e00078",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "这般时候，姑娘要斗篷何用？",
      "text_length": 13
    },
    {
      "event_id": "03057002_e00079",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "老爷呼唤二爷，不知为了何事，我要去探听探听。",
      "text_length": 22
    },
    {
      "event_id": "03057002_e00080",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "二爷刚说去去就来，外面风大，姑娘你不用去啦！",
      "text_length": 22
    },
    {
      "event_id": "03057002_e00081",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "休要多言，快快与我取来！",
      "text_length": 12
    },
    {
      "event_id": "03057002_e00082",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃取斗篷为林黛玉披上。",
      "text_length": 12
    },
    {
      "event_id": "03057002_e00083",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "林黛玉"
      ],
      "text": "明明的我与他心心相印，",
      "text_length": 11
    },
    {
      "event_id": "03057002_e00084",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "姑娘回来还要抚琴吗？",
      "text_length": 10
    },
    {
      "event_id": "03057002_e00085",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "03057002_e00086",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "紫鹃"
      ],
      "text": "待我拿到院中，月光下等候姑娘。",
      "text_length": 15
    },
    {
      "event_id": "03057002_e00087",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "紫鹃下。",
      "text_length": 4
    },
    {
      "event_id": "03057002_e00088",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "林黛玉"
      ],
      "text": "苦衷情无处诉留证无人。离潇湘过蘅芜落红成阵，待明朝收拾起瘗玉埋春。",
      "text_length": 33
    },
    {
