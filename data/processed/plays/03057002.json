      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "林黛玉"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "03057002_e00090",
      "play_id": "03057002",
      "scene_id": "03057002_s02",
