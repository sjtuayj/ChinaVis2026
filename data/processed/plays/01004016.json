      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘禄敬"
      ],
      "text": "为官的这里头里走，",
      "text_length": 9
    },
    {
      "event_id": "01004016_e00073",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
