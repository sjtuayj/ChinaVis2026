  "events": [
    {
      "event_id": "01004016_e00001",
      "play_id": "01004016",
      "scene_id": "01004016_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "两青袍引刘禄敬同上，六幺令。",
      "text_length": 14
    },
    {
      "event_id": "01004016_e00002",
      "play_id": "01004016",
      "scene_id": "01004016_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘禄敬"
      ],
      "text": "受得苦中苦，方为人上人。",
      "text_length": 12
    },
    {
      "event_id": "01004016_e00003",
      "play_id": "01004016",
      "scene_id": "01004016_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "下官，刘禄敬。钦奉圣命，回家祭祖。左右，",
      "text_length": 20
    },
    {
      "event_id": "01004016_e00004",
      "play_id": "01004016",
      "scene_id": "01004016_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "两青袍同允。",
      "text_length": 6
    },
    {
      "event_id": "01004016_e00005",
      "play_id": "01004016",
      "scene_id": "01004016_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "打道回府。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00006",
      "play_id": "01004016",
      "scene_id": "01004016_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖合头〗，众人同下。",
      "text_length": 10
    },
    {
      "event_id": "01004016_e00007",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "萧素贞"
      ],
      "text": "苦吓！",
      "text_length": 3
    },
    {
      "event_id": "01004016_e00008",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "内唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "萧素贞正在房中我便抽身起，",
      "text_length": 13
    },
    {
      "event_id": "01004016_e00009",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "萧素贞上。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00010",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "回头来带上了两扇门。我今日里不往别处去，一心心要上刘家的新坟。正走之间泪满腮，想起了古人蔡伯喈：他上京中去赶考，一去赶考不回来。一双爹娘都饿死，五娘子抱土筑坟台。坟台筑起了三尺土，从空中降下一面琵琶来。身背着琵琶描容相，一心心上京找夫回。找到京中不相认，哭坏了贤妻女裙钗。贤惠的五娘遭马踹，到后来五雷轰顶是那蔡伯喈。正走之间抬头望，来到了刘家新坟台。坟前摆下了千张纸，公公婆婆哭起来。奴家哭到了伤心处，",
      "text_length": 201
    },
    {
      "event_id": "01004016_e00011",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "两青袍引刘禄敬同上。",
      "text_length": 10
    },
    {
      "event_id": "01004016_e00012",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "01004016_e00013",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘禄敬"
      ],
      "text": "来了我为官受禄人。",
      "text_length": 9
    },
    {
      "event_id": "01004016_e00014",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "哭一声儿夫刘禄敬，",
      "text_length": 9
    },
    {
      "event_id": "01004016_e00015",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "青袍"
      ],
      "text": "呵！",
      "text_length": 2
    },
    {
      "event_id": "01004016_e00016",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "禀老爷的话：刘家坟上，有一妇人，在此啼哭。",
      "text_length": 21
    },
    {
      "event_id": "01004016_e00017",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "哦呵且住，想我刘家坟上，哪有什么妇人在此，哭哭啼啼，哦哦哦其中必有原故。",
      "text_length": 36
    },
    {
      "event_id": "01004016_e00018",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "原故。",
      "text_length": 3
    },
    {
      "event_id": "01004016_e00019",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "来，住轿。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00020",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "老爷撤料。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00021",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "你们前去问那妇人：因何在此哭哭啼啼？",
      "text_length": 18
    },
    {
      "event_id": "01004016_e00022",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "青袍甲允。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00023",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍"
      ],
      "text": "那一妇人：因何在此哭哭啼啼？",
      "text_length": 14
    },
    {
      "event_id": "01004016_e00024",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "萧素贞这里把头抬，尊一声老爷你哪里来？",
      "text_length": 19
    },
    {
      "event_id": "01004016_e00025",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "京中来。",
      "text_length": 4
    },
    {
      "event_id": "01004016_e00026",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "坟前里没有关王庙，坟后里没有接官亭。坟东里没有放马场，坟西里没有陷马坑。又不通南北共大道，我的爷吓，你为何到我刘家的新坟？",
      "text_length": 61
    },
    {
      "event_id": "01004016_e00027",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "来，你们对那妇人言道：说你老爷是清官到了，有何冤枉，叫她亲口诉来。",
      "text_length": 33
    },
    {
      "event_id": "01004016_e00028",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "青袍甲允。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00029",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "那一妇人：我家老爷是清官到了，有何冤枉，亲口诉来。",
      "text_length": 25
    },
    {
      "event_id": "01004016_e00030",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "听说一声清官到，",
      "text_length": 8
    },
    {
      "event_id": "01004016_e00031",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "你这妇人，有何冤枉，一一诉来。有你老爷与你作主。",
      "text_length": 24
    },
    {
      "event_id": "01004016_e00032",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "萧素贞"
      ],
      "text": "容禀。",
      "text_length": 3
    },
    {
      "event_id": "01004016_e00033",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "青袍"
      ],
      "text": "老爷吃饼。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00034",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "唗。",
      "text_length": 2
    },
    {
      "event_id": "01004016_e00035",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "我有心状告无人写，口诉的状词句句真。头一状不把别人告，告的是公婆二双亲。终日里打来每日里骂，我的爷吓，打骂着奴家实实的难忍。",
      "text_length": 62
    },
    {
      "event_id": "01004016_e00036",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "世间哪有不是的公婆？公婆打骂，古之常理。头状不准，二状诉来。",
      "text_length": 30
    },
    {
      "event_id": "01004016_e00037",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "萧素贞"
      ],
      "text": "容禀。",
      "text_length": 3
    },
    {
      "event_id": "01004016_e00038",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "老爷吃粽子。",
      "text_length": 6
    },
    {
      "event_id": "01004016_e00039",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "第二状不把别人告，告的是娘舅李大公。他每日三次我家走，挑唆我公婆二双亲。终日里打来每日里骂，打骂着奴家逼我改嫁人。",
      "text_length": 57
    },
    {
      "event_id": "01004016_e00040",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "世间之上，哪有这等公婆。我却不准，三状诉来。",
      "text_length": 22
    },
    {
      "event_id": "01004016_e00041",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "萧素贞"
      ],
      "text": "三状我就不告了。",
      "text_length": 8
    },
    {
      "event_id": "01004016_e00042",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "来，你去对那妇人言道：说你老爷准了状了。",
      "text_length": 20
    },
    {
      "event_id": "01004016_e00043",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "青袍甲允。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00044",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "那一妇人：我家老爷准了状了。",
      "text_length": 14
    },
    {
      "event_id": "01004016_e00045",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "萧素贞"
      ],
      "text": "怎么着，你老爷准了我的状了？",
      "text_length": 14
    },
    {
      "event_id": "01004016_e00046",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "青袍甲允。",
      "text_length": 5
    },
    {
      "event_id": "01004016_e00047",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "萧素贞"
      ],
      "text": "如此还要告。",
      "text_length": 6
    },
    {
      "event_id": "01004016_e00048",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "三状不把别人告，告的是儿夫刘禄敬。",
      "text_length": 17
    },
    {
      "event_id": "01004016_e00049",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二青袍"
      ],
      "text": "呵！",
      "text_length": 2
    },
    {
      "event_id": "01004016_e00050",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "01004016_e00051",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "提老爷杂讳。",
      "text_length": 6
    },
    {
      "event_id": "01004016_e00052",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "下去。",
      "text_length": 3
    },
    {
      "event_id": "01004016_e00053",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "要伺候老爷。",
      "text_length": 6
    },
    {
      "event_id": "01004016_e00054",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "没有你们的事。赏你两张军用钞票，到兰芳里去把老虫跳。",
      "text_length": 26
    },
    {
      "event_id": "01004016_e00055",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "青袍甲"
      ],
      "text": "老爷回府，还是乘轿、骑马？",
      "text_length": 13
    },
    {
      "event_id": "01004016_e00056",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘禄敬"
      ],
      "text": "全不用，我有黄包车，下去。",
      "text_length": 13
    },
    {
      "event_id": "01004016_e00057",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二青袍同下。",
      "text_length": 6
    },
    {
      "event_id": "01004016_e00058",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "我的爷吓！上三年有封家书到，上写着儿夫命丧东京城。",
      "text_length": 25
    },
    {
      "event_id": "01004016_e00059",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘禄敬"
      ],
      "text": "为官这里怒气冲，骂一声娘舅李大公：我在京中恩待你，三百两银子书一封。埋没了我银子是小事，你不该说我命丧东京城。圣上赐我上方剑，先斩我娘舅李大公。叫一声贤妻你认一认，认认你亲夫刘禄敬。",
      "text_length": 91
    },
    {
      "event_id": "01004016_e00060",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "指望你是清官到，原来你是个糊涂虫。公案之下伸双手，人皮包着畜类精。槽头挽着逍遥马，少鞍无髻你也认不成。你若对得上三桩宝，你是我亲夫转家门；你若对不上三桩宝，你就公子王孙，你也认不成。",
      "text_length": 91
    },
    {
      "event_id": "01004016_e00061",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘禄敬"
      ],
      "text": "贤妻打我我不恼，贤妻骂我我不嗔。将她当做裙钗女，桩桩件件记得清。宝贝放在尘埃地，叫一声贤妻你来认分明。",
      "text_length": 51
    },
    {
      "event_id": "01004016_e00062",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "拿起乌绫看一看，四四方方好乌绫。拿起梨花照一照，八月十五放光明。拿起花鞋对一对，千针万线我做成。哎，宝贝乃是真宝贝，禄敬还是假禄敬。",
      "text_length": 66
    },
    {
      "event_id": "01004016_e00063",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 57,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘禄敬"
      ],
      "text": "宝贝本是真宝贝，禄敬本是真禄敬。",
      "text_length": 16
    },
    {
      "event_id": "01004016_e00064",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 58,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "萧素贞"
      ],
      "text": "啐！",
      "text_length": 2
    },
    {
      "event_id": "01004016_e00065",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 59,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "萧素贞"
      ],
      "text": "我亲夫上京去，乃是十七、八岁的念书人。到如今，你回来，满脸上长胡须好不愁人。",
      "text_length": 38
    },
    {
      "event_id": "01004016_e00066",
      "play_id": "01004016",
      "scene_id": "01004016_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 60,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘禄敬"
      ],
      "text": "上京时，我的妻，年方二八的女裙钗。到如今，我回来，满脸的长皱纹好不丑人。",
      "text_length": 36
    },
    {
