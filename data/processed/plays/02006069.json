  "events": [
    {
      "event_id": "02006069_e00001",
      "play_id": "02006069",
      "scene_id": "02006069_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "变律上。",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00002",
      "play_id": "02006069",
      "scene_id": "02006069_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "普贤歌",
      "speakers": [
        "变律"
      ],
      "text": "我作和尚快活多，寺中只少当家婆。欲待将钱娶一个，又恐她要价多。欲待将纸画一个，又恐风吹破。欲待将铁铸一个，又恐她的比我硬多多。南无阿弥陀佛！",
      "text_length": 70
    },
    {
      "event_id": "02006069_e00003",
      "play_id": "02006069",
      "scene_id": "02006069_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "变律"
      ],
      "text": "扫地恐伤蝼蚁命，爱惜飞蛾纱罩灯。",
      "text_length": 16
    },
    {
      "event_id": "02006069_e00004",
      "play_id": "02006069",
      "scene_id": "02006069_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "贫僧，祥梅寺主持便是。因佛殿上有盏琉璃海灯。每次添油十斤，能点三五昼夜。如今添上灯油，不过一宿就完了。哦，是了！想是寺中火头和尚偷去换酒吃，亦未可知。我今躲在供桌底下，偷看他不来便罢，他若来时，一把手拿住，不怕他不赔我的油。正是：",
      "text_length": 115
    },
    {
      "event_id": "02006069_e00005",
      "play_id": "02006069",
      "scene_id": "02006069_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "变律"
      ],
      "text": "世上无难事，只怕有心人。",
      "text_length": 12
    },
    {
      "event_id": "02006069_e00006",
      "play_id": "02006069",
      "scene_id": "02006069_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "变律下。",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00007",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二鬼同上",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00008",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "二鬼"
      ],
      "text": "我本供门一将星，祥梅寺里说原因。黄巢杀人八百万，血流三千里数程。",
      "text_length": 32
    },
    {
      "event_id": "02006069_e00009",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鬼甲"
      ],
      "text": "兄弟，今有黄天子出世，阴司造册，缺少灯油，前来盗取，遇着和尚说与他便了。",
      "text_length": 36
    },
    {
      "event_id": "02006069_e00010",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "变律上。",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00011",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "拿住了，休得逃走。",
      "text_length": 9
    },
    {
      "event_id": "02006069_e00012",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二鬼"
      ],
      "text": "休得高声，我乃阴曹掌案使。今有黄天子出世，阴司造册，缺少灯油，特来取用。叫喊什么！",
      "text_length": 41
    },
    {
      "event_id": "02006069_e00013",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "杀的是谁？",
      "text_length": 5
    },
    {
      "event_id": "02006069_e00014",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "二鬼"
      ],
      "text": "我们记不得许多。",
      "text_length": 8
    },
    {
      "event_id": "02006069_e00015",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "黄天子怎么个模样？",
      "text_length": 9
    },
    {
      "event_id": "02006069_e00016",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "二鬼"
      ],
      "text": "横眉一字，面带金钱，鼻生三孔，牙排二齿。",
      "text_length": 20
    },
    {
      "event_id": "02006069_e00017",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "这等模样。造册我可看得？",
      "text_length": 12
    },
    {
      "event_id": "02006069_e00018",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "二鬼"
      ],
      "text": "有个册底儿拿去看。",
      "text_length": 9
    },
    {
      "event_id": "02006069_e00019",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "“头一名祥梅寺变律。”",
      "text_length": 11
    },
    {
      "event_id": "02006069_e00020",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二鬼夺册同下。",
      "text_length": 7
    },
    {
      "event_id": "02006069_e00021",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "啊吓吓！唬杀我也！我说昨夜做的梦不好，梦见空中一条黄龙飞到寺中，伸出爪来，一爪把我僧帽抓去。我想黄龙就是黄天子，僧帽即是我和尚头。方才二位鬼使，对我说黄天子横眉一字，面带金钱，鼻生三孔，牙排二齿。我如今备下羊羔鹿脯，待他来时，殷勤供奉，或者饶恕与我也未可知。说便是这等说，到底活不久，头一名就是我变律和尚。无量观世音菩萨！",
      "text_length": 161
    },
    {
      "event_id": "02006069_e00022",
      "play_id": "02006069",
      "scene_id": "02006069_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "变律下。",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00023",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄巢上。",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00024",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "黄巢"
      ],
      "text": "思前事，恨怎休，行囊点几番空点头。宝剑仗吴钩，规模自成就。但愿得天心显，霸业收，那其间免遗臭，免遗臭。",
      "text_length": 51
    },
    {
      "event_id": "02006069_e00025",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "俺，黄巢。上京应试，圣上见我人物丑陋，将俺剥去衣冠，逐出朝门。我想大丈夫怎肯居人之下！是俺连夜回来，打点资财，招聚饿夫五十余万，欲图大业。闻知此处祥梅寺中，地方宽阔，正好调练兵马。又闻弥陀最灵，不免讨个吉兆，有何不可。枯松佛殿翠竹映，僧房源水云中露，深山峰里藏，果然好景。来此已是，俺黄巢到此，预求吉兆，大事若成，上上之兆；大事不成，下下之爻。若无是应，难免粉身之灾。",
      "text_length": 184
    },
    {
      "event_id": "02006069_e00026",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "黄巢"
      ],
      "text": "吾生身三十秋，心间日月冲牛斗，指望觅封侯。争乃时乖尚未偶，但愿得图王霸业收。对神灵问休咎。",
      "text_length": 45
    },
    {
      "event_id": "02006069_e00027",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "且喜上上之兆。弥陀菩萨，大事若成，重修庙宇，再整金身。",
      "text_length": 27
    },
    {
      "event_id": "02006069_e00028",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "变律上。",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00029",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "万岁！",
      "text_length": 3
    },
    {
      "event_id": "02006069_e00030",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "我乃布衣闲士，和尚为何口称“万岁”？",
      "text_length": 18
    },
    {
      "event_id": "02006069_e00031",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "万岁乃真命之主，请到禅房。和尚有话，奏上万岁。",
      "text_length": 23
    },
    {
      "event_id": "02006069_e00032",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "引道。",
      "text_length": 3
    },
    {
      "event_id": "02006069_e00033",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "万岁请坐。",
      "text_length": 5
    },
    {
      "event_id": "02006069_e00034",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "和尚甚么话说来？",
      "text_length": 8
    },
    {
      "event_id": "02006069_e00035",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "万岁！",
      "text_length": 3
    },
    {
      "event_id": "02006069_e00036",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "变律"
      ],
      "text": "琉璃内点尽油，黄昏鬼使来只偷。",
      "text_length": 15
    },
    {
      "event_id": "02006069_e00037",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "那鬼使偷油何用？",
      "text_length": 8
    },
    {
      "event_id": "02006069_e00038",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "变律"
      ],
      "text": "他说唐王已将休，真主出世久。",
      "text_length": 14
    },
    {
      "event_id": "02006069_e00039",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "真主是谁？",
      "text_length": 5
    },
    {
      "event_id": "02006069_e00040",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "变律"
      ],
      "text": "黄巢类虎彪，夺乾坤如反手。",
      "text_length": 13
    },
    {
      "event_id": "02006069_e00041",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "黄巢"
      ],
      "text": "因科举，上国投，富贵荣显归故丘。指望一举占鳌头，谁想时乖尚未偶。",
      "text_length": 32
    },
    {
      "event_id": "02006069_e00042",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "变律"
      ],
      "text": "恩意怎酬？如何已过龙门，又遭点漏。念僧家山野愚蒙，寺里哪得有？",
      "text_length": 31
    },
    {
      "event_id": "02006069_e00043",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "黄巢"
      ],
      "text": "唐天子真寇仇，我殿庭受尽羞。",
      "text_length": 14
    },
    {
      "event_id": "02006069_e00044",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "和尚有所不知。俺上京科举，圣上道我人物丑陋，将俺逐出朝门，永不赴考。我想大丈夫怎居人下！我回家打点资财，招聚饿夫五十余万，欲图大业。闻知此处地方宽阔，借此屯兵养马，你意如何？",
      "text_length": 87
    },
    {
      "event_id": "02006069_e00045",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "天下皆是皇爷疆土，何言借乎？贫僧有羊羔鹿脯，不敢进献。",
      "text_length": 27
    },
    {
      "event_id": "02006069_e00046",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "既有美馔取来。",
      "text_length": 7
    },
    {
      "event_id": "02006069_e00047",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "变律"
      ],
      "text": "三杯酒一色秋，微臣助君千万秋。指日秉烛游，神言怎虚谬？",
      "text_length": 27
    },
    {
      "event_id": "02006069_e00048",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "黄巢"
      ],
      "text": "殷勤既酬，倘一日得遂其谋，不忘饭信江边友，江边友。",
      "text_length": 25
    },
    {
      "event_id": "02006069_e00049",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "变律"
      ],
      "text": "心中事，真个忧，欲待诉因缘反成勾。",
      "text_length": 17
    },
    {
      "event_id": "02006069_e00050",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "和尚不必悲啼，有甚么事说上来。",
      "text_length": 15
    },
    {
      "event_id": "02006069_e00051",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "大殿有盏琉璃。每次添油十斤，也点三五昼夜。今来添上油就没有了。我只说是火头和尚偷去换酒吃了，原来是二鬼王偷去。",
      "text_length": 55
    },
    {
      "event_id": "02006069_e00052",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "那鬼偷油何用？",
      "text_length": 7
    },
    {
      "event_id": "02006069_e00053",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "和尚也曾问他，他说黄天子出世，阴司造册，缺少灯油，故此来取。",
      "text_length": 30
    },
    {
      "event_id": "02006069_e00054",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "你问他黄天子何等人物？",
      "text_length": 11
    },
    {
      "event_id": "02006069_e00055",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "他说黄天子横眉一字，面带金钱，鼻生三孔，牙排二齿。杀人八百万，血流三千里。",
      "text_length": 37
    },
    {
      "event_id": "02006069_e00056",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "杀的都是谁？",
      "text_length": 6
    },
    {
      "event_id": "02006069_e00057",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "他说记不得许多，有底册拿去看。头一名……",
      "text_length": 20
    },
    {
      "event_id": "02006069_e00058",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "是谁？",
      "text_length": 3
    },
    {
      "event_id": "02006069_e00059",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "万岁赦过贫僧好奏。",
      "text_length": 9
    },
    {
      "event_id": "02006069_e00060",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "你说俺饶过他。",
      "text_length": 7
    },
    {
      "event_id": "02006069_e00061",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "头一名祥梅寺住持变律。",
      "text_length": 11
    },
    {
      "event_id": "02006069_e00062",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "拿去开刀！",
      "text_length": 5
    },
    {
      "event_id": "02006069_e00063",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "就是贫僧。",
      "text_length": 5
    },
    {
      "event_id": "02006069_e00064",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "怪道和尚这般殷勤。今日已见，他日相逢，乃是故人，怎忍杀之？只是俺明日千军万马，要你躲得好，藏得妙。",
      "text_length": 49
    },
    {
      "event_id": "02006069_e00065",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "黄巢"
      ],
      "text": "邂逅遇殷勤，从今是故人。感恩并积恨，万岁不生尘。",
      "text_length": 24
    },
    {
      "event_id": "02006069_e00066",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "和尚送万岁。",
      "text_length": 6
    },
    {
      "event_id": "02006069_e00067",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "不消。",
      "text_length": 3
    },
    {
      "event_id": "02006069_e00068",
      "play_id": "02006069",
      "scene_id": "02006069_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄巢、变律同下。",
      "text_length": 8
    },
    {
      "event_id": "02006069_e00069",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄巢起兵，过场，同下。",
      "text_length": 11
    },
    {
      "event_id": "02006069_e00070",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "变律上。",
      "text_length": 4
    },
    {
      "event_id": "02006069_e00071",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 71,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "徒弟鸣钟擂鼓。",
      "text_length": 7
    },
    {
      "event_id": "02006069_e00072",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 72,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "挂葫芦",
      "speakers": [
        "变律"
      ],
      "text": "如来望正盟，如来望正盟，慈悲救小僧。大开方便门，搭救弟子免灾星。",
      "text_length": 32
    },
    {
      "event_id": "02006069_e00073",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 73,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人内同喊。",
      "text_length": 6
    },
    {
      "event_id": "02006069_e00074",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 74,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "挂葫芦",
      "speakers": [
        "变律"
      ],
      "text": "心急急，步慌忙，杀声闻四野似豺狼。指日旌旗动，看看将傍。",
      "text_length": 28
    },
    {
      "event_id": "02006069_e00075",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 75,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "来此钟楼，躲在上面，黄天子人马过去，下来未迟。",
      "text_length": 23
    },
    {
      "event_id": "02006069_e00076",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 76,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "挂葫芦",
      "speakers": [
        "变律"
      ],
      "text": "钟楼藏隐好商量，其实真停当，真停当。",
      "text_length": 18
    },
    {
      "event_id": "02006069_e00077",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 77,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "躲得妙，躲得妙！不好！黄天子人马从此处经过，楼上有个和尚，拿下来开刀。",
      "text_length": 35
    },
    {
      "event_id": "02006069_e00078",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 78,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "挂葫芦",
      "speakers": [
        "变律"
      ],
      "text": "虎啖羊，其实不停当，不停当。",
      "text_length": 14
    },
    {
      "event_id": "02006069_e00079",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 79,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "挂葫芦",
      "speakers": [
        "变律"
      ],
      "text": "千思想，万忖量，处处兴兵将。张狂杀声闻四野，看看将傍。",
      "text_length": 27
    },
    {
      "event_id": "02006069_e00080",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 80,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "来此已是山门，不免上去躲在上面，黄天子人马过去，我下来未迟。",
      "text_length": 30
    },
    {
      "event_id": "02006069_e00081",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 81,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "挂葫芦",
      "speakers": [
        "变律"
      ],
      "text": "山门藏隐有商量，其实真停当，真停当。",
      "text_length": 18
    },
    {
      "event_id": "02006069_e00082",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 82,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "躲得妙，躲得妙！不好！黄天子人马从此处经过，山门上有个和尚，拿去开刀。",
      "text_length": 35
    },
    {
      "event_id": "02006069_e00083",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 83,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "挂葫芦",
      "speakers": [
        "变律"
      ],
      "text": "被他拿住。黄兵似虎，镇军民拥贯京都。急忙移步奔前途。菩萨料应相拥护，相拥护。",
      "text_length": 38
    },
    {
      "event_id": "02006069_e00084",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 84,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "变律"
      ],
      "text": "来此一棵枯树，待我躲在里面，黄天子人马过去，出来未迟。欲赴旷山径，躲在深山枯树中。",
      "text_length": 41
    },
    {
      "event_id": "02006069_e00085",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 85,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄巢率众将同上。",
      "text_length": 8
    },
    {
      "event_id": "02006069_e00086",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 86,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "黄巢"
      ],
      "text": "杀气满乾坤，要整山河一统。",
      "text_length": 13
    },
    {
      "event_id": "02006069_e00087",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 87,
      "seq_in_scene": 19,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "大小三军，前面不拘鸡犬牛羊，拿去开刀。",
      "text_length": 19
    },
    {
      "event_id": "02006069_e00088",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 88,
      "seq_in_scene": 20,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "军士"
      ],
      "text": "启大王，无鸡犬牛羊，只有枯树阻路。",
      "text_length": 17
    },
    {
      "event_id": "02006069_e00089",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 89,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "就拿枯树开刀。",
      "text_length": 7
    },
    {
      "event_id": "02006069_e00090",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 90,
      "seq_in_scene": 22,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "军士"
      ],
      "text": "启大王：有一个和尚头。",
      "text_length": 11
    },
    {
      "event_id": "02006069_e00091",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 91,
      "seq_in_scene": 23,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "拿来我看看。吓！原来是变律的首级。未曾起兵，先杀故友，好不败孤之兴也！",
      "text_length": 35
    },
    {
      "event_id": "02006069_e00092",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 92,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "军士"
      ],
      "text": "定业难逃，何足虑哉？",
      "text_length": 10
    },
    {
      "event_id": "02006069_e00093",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 93,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄巢"
      ],
      "text": "就此杀上前去。",
      "text_length": 7
    },
    {
      "event_id": "02006069_e00094",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 94,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "水底鱼",
      "speakers": [
        "黄巢"
      ],
      "text": "擂鼓摇旗，三军号令齐。今番一战，皇家一统归。",
      "text_length": 22
    },
    {
      "event_id": "02006069_e00095",
      "play_id": "02006069",
      "scene_id": "02006069_s04",
      "scene_no": 4,
      "seq_global": 95,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}