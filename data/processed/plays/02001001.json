      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "南极老人"
      ],
      "text": "称觞献寿乐荣年，",
      "text_length": 8
    },
    {
      "event_id": "02001001_e00011",
      "play_id": "02001001",
      "scene_id": "02001001_s01",
      "scene_no": 1,
      "seq_global": 11,
