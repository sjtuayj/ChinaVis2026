      "play_id": "70902156",
      "scene_id": "70902156_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "红娘"
      ],
      "text": "小姐看仔细。",
      "text_length": 6
    },
