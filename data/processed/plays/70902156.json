      "type": "other_vocal",
      "mode_label": "临镜序",
      "speakers": [
        "张珙"
      ],
      "text": "彩云开，月明如水浸楼台。",
      "text_length": 12
    },
    {
      "event_id": "70902156_e00003",
      "play_id": "70902156",
      "scene_id": "70902156_s01",
