      ],
      "text": "红娘回去罢。",
      "text_length": 6
    },
    {
      "event_id": "70902156_e00021",
      "play_id": "70902156",
      "scene_id": "70902156_s01",
      "scene_no": 1,
      "seq_global": 21,
