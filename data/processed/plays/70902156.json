      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "节节高",
      "speakers": [
        "张珙"
      ],
      "text": "梦魂飞绕青霄外，昨夜梦中愁无奈，",
      "text_length": 16
    },
    {
