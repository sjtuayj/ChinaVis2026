      ],
      "text": "看铜锤伺候。",
      "text_length": 6
    },
    {
      "event_id": "02007032_e00030",
      "play_id": "02007032",
      "scene_id": "02007032_s01",
      "scene_no": 1,
      "seq_global": 30,
