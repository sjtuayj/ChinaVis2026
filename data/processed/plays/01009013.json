  "events": [
    {
      "event_id": "01009013_e00001",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八龙套、中军、申包胥同上。〖点绛唇〗。",
      "text_length": 19
    },
    {
      "event_id": "01009013_e00002",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "申包胥"
      ],
      "text": "奉王旨意出朝堂，各国催贡转帝邦。扶保吾主良为上，保定平王锦家邦。",
      "text_length": 32
    },
    {
      "event_id": "01009013_e00003",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "申包胥"
      ],
      "text": "俺，申包胥，楚国为臣。奉了平王旨意，各国催贡。催贡已毕，回朝交旨。众将官，今乃黄道吉日，正好班师回朝。中军！",
      "text_length": 54
    },
    {
      "event_id": "01009013_e00004",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "中军允。",
      "text_length": 4
    },
    {
      "event_id": "01009013_e00005",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "申包胥"
      ],
      "text": "人马可齐？",
      "text_length": 5
    },
    {
      "event_id": "01009013_e00006",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "俱已齐备。",
      "text_length": 5
    },
    {
      "event_id": "01009013_e00007",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "申包胥"
      ],
      "text": "班师回朝。",
      "text_length": 5
    },
    {
      "event_id": "01009013_e00008",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "班师回朝。",
      "text_length": 5
    },
    {
      "event_id": "01009013_e00009",
      "play_id": "01009013",
      "scene_id": "01009013_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八龙套同喝。众人同下。",
      "text_length": 11
    },
    {
      "event_id": "01009013_e00010",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "01009013_e00011",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "俺，伍员。幸喜逃出樊城，去到吴国借兵雪恨。你看前面来了一哨人马，旗帜上面斗大的“申”字，想必是申包胥贤弟到此。等他到来，我将满腹含冤对他一表。",
      "text_length": 71
    },
    {
      "event_id": "01009013_e00012",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八龙套、中军、申包胥同上。",
      "text_length": 13
    },
    {
      "event_id": "01009013_e00013",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "申包胥"
      ],
      "text": "前道为何不行？",
      "text_length": 7
    },
    {
      "event_id": "01009013_e00014",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "八龙套"
      ],
      "text": "伍爷挡道。",
      "text_length": 5
    },
    {
      "event_id": "01009013_e00015",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "申包胥"
      ],
      "text": "人马列开！吓，兄长为何这等狼狈？",
      "text_length": 16
    },
    {
      "event_id": "01009013_e00016",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "贤弟，一言难尽！",
      "text_length": 8
    },
    {
      "event_id": "01009013_e00017",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "伍员"
      ],
      "text": "未曾开言泪双流，尊一声贤弟听从头：临潼关上曾为首，我也曾举鼎压诸侯。双挂明辅印二口，各国不敢统貔貅。只恨平王无道贪色酒，父纳子妻礼还周？我的父谏奏反斩首，只杀得伍家鸡犬也不留。对天发下洪誓咒：不杀平王死不休！",
      "text_length": 104
    },
    {
      "event_id": "01009013_e00018",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "申包胥"
      ],
      "text": "兄长说话没来由，愚弟言来听从头：君叫臣死定斩首，父叫子亡谁敢留？得放手来且放手，得罢休来且罢休。",
      "text_length": 48
    },
    {
      "event_id": "01009013_e00019",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "伍员"
      ],
      "text": "贤弟说话没来由，愚兄言来听从头：君不正来臣要走，父不正来子外游。杀了我家丁数百口，这等冤仇怎罢休？",
      "text_length": 49
    },
    {
      "event_id": "01009013_e00020",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "申包胥"
      ],
      "text": "你若兴兵来争斗，我为公来你为仇。个人怀恨莫泄漏，急速打马把吴投。",
      "text_length": 32
    },
    {
      "event_id": "01009013_e00021",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "伍员"
      ],
      "text": "申包胥与我把舌斗，背转身来自己愁。走上前来兄叩首，有劳你放我往东流。今日相别阳关路，日后相逢在楚吴。辞别贤弟跨走兽，扬鞭打马把吴投。",
      "text_length": 66
    },
    {
      "event_id": "01009013_e00022",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    },
    {
      "event_id": "01009013_e00023",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "申包胥"
      ],
      "text": "一见兄长跨走兽，不由包胥两泪愁。本帅阳关传一令，大小三军听分明：有人回朝风走漏，定将满门刀割头！",
      "text_length": 48
    },
    {
      "event_id": "01009013_e00024",
      "play_id": "01009013",
      "scene_id": "01009013_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 15,
