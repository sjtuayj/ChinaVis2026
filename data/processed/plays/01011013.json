  "events": [
    {
      "event_id": "01011013_e00001",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套引北斗星君、南斗星君同上。",
      "text_length": 16
    },
    {
      "event_id": "01011013_e00002",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "观天地和日月乾坤浩荡，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00003",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "天连水水连天杳杳茫茫。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00004",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "我乃南斗星君是也。",
      "text_length": 9
    },
    {
      "event_id": "01011013_e00005",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "吾乃北斗星君是也。",
      "text_length": 9
    },
    {
      "event_id": "01011013_e00006",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "星君请了。",
      "text_length": 5
    },
    {
      "event_id": "01011013_e00007",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "01011013_e00008",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "你我奉了玉帝敕旨，巡查人间善恶。来此地已是南瞻部洲，不免将历代帝王细表一番。",
      "text_length": 38
    },
    {
      "event_id": "01011013_e00009",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "01011013_e00010",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "南斗星君"
      ],
      "text": "自盘古分天地乾坤首创，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00011",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "北斗星君"
      ],
      "text": "生太极分两仪八卦阴阳。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00012",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "南斗星君"
      ],
      "text": "分金木水火土五行星象，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00013",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "北斗星君"
      ],
      "text": "先君臣后父子三纲五常。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00014",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "南斗星君"
      ],
      "text": "尧传舜舜传禹江山执掌，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00015",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "北斗星君"
      ],
      "text": "夏传商纣淫乱无道昏王。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00016",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "南斗星君"
      ],
      "text": "秦始皇归一统山河独掌，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00017",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "北斗星君"
      ],
      "text": "他不该焚诗书建立阿房。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00018",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "南斗星君"
      ],
      "text": "楚项羽他倒有帝王气象，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00019",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "北斗星君"
      ],
      "text": "他不该杀义帝自称霸王。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00020",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "南斗星君"
      ],
      "text": "将前朝君王事一齐慢讲，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00021",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "南斗星君"
      ],
      "text": "听我把忠良臣细说端详：淮阴侯汉韩信功高名广，为什么被吕后斩首未央？",
      "text_length": 33
    },
    {
      "event_id": "01011013_e00022",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "北斗星君"
      ],
      "text": "休提起汉韩信功高德广，自幼儿行的事丧尽天良：他不该困霸王乌江命丧，因此上被吕后斩首未央。",
      "text_length": 44
    },
    {
      "event_id": "01011013_e00023",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "南斗星君"
      ],
      "text": "汉萧何造律法后人瞻仰，为什么那老儿寿命延长？",
      "text_length": 22
    },
    {
      "event_id": "01011013_e00024",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "北斗星君"
      ],
      "text": "汉萧何造律法治国兴旺，因此上那老儿寿命延长。",
      "text_length": 22
    },
    {
      "event_id": "01011013_e00025",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "有荆轲刺秦王英雄胆壮，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00026",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "有专诸刺王僚盖世无双。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00027",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "痛只痛挖心死比干丞相，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00028",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "叹只叹有苏武白发还乡。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00029",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "叹不尽前朝的忠臣良将，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00030",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "松林内摆棋盘且消愁肠。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00031",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同下。",
      "text_length": 6
    },
    {
      "event_id": "01011013_e00032",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "01011013_e00033",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "01011013_e00034",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "红棋先黑棋后一帅一将，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00035",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "从士相五个卒以炮为强。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00036",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "走一步当头炮风声响亮，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00037",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "先出马后走车二将着忙。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00038",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "红棋子好一比汉高皇上，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00039",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "黑棋子好一比项羽霸王。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00040",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵颜上。",
      "text_length": 4
    },
    {
      "event_id": "01011013_e00041",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "赵颜"
      ],
      "text": "昨日里管先生对我言讲：他道我三日后一命身亡。来至在松林内用目观望，又只见二星君俱在一旁。我这里龙凤酒暗暗献上，含着气闭着声坐在一旁。",
      "text_length": 66
    },
    {
      "event_id": "01011013_e00042",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "哪里的鹿脯酒从空下降？",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00043",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "想必是那上苍赐下琼浆！",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00044",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "我与你棋不胜且饮佳酿，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00045",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "飞来酒吃几杯又待何妨。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00046",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵颜"
      ],
      "text": "二位星君。",
      "text_length": 5
    },
    {
      "event_id": "01011013_e00047",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "耳边厢又听得有人声嚷，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00048",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "猛抬头见小子跪在一旁。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00049",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "那一小子，家住哪里，姓甚名谁，慢慢讲来。",
      "text_length": 20
    },
    {
      "event_id": "01011013_e00050",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵颜"
      ],
      "text": "容禀！",
      "text_length": 3
    },
    {
      "event_id": "01011013_e00051",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "赵颜"
      ],
      "text": "家住在平原县赵家庄，我的名叫赵颜父母在堂。昨日里管先生对我言讲：他道我三日后一命身亡。因此上龙凤酒鹿脯献上，望星君发慈悲添寿一场。",
      "text_length": 65
    },
    {
      "event_id": "01011013_e00052",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "南斗星君"
      ],
      "text": "听小子说此话有些虚谎，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00053",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "北斗星君"
      ],
      "text": "但不知是何人泄漏阴阳？",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00054",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "星君，赵颜来到此地，但不知是何人泄漏天机？",
      "text_length": 21
    },
    {
      "event_id": "01011013_e00055",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "凡间有一管辂，生来一双慧眼，能知未来之事，定是此人。",
      "text_length": 26
    },
    {
      "event_id": "01011013_e00056",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "他既前来，星君何不将他阳寿查看一番。",
      "text_length": 18
    },
    {
      "event_id": "01011013_e00057",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "待我查来：查得山西平原郡陆林村，赵家庄赵范之子，名叫赵颜，前生作恶多端，今生只活一十九岁，夭寿而亡。赵颜，你今年多大年纪？",
      "text_length": 61
    },
    {
      "event_id": "01011013_e00058",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵颜"
      ],
      "text": "一十九岁。",
      "text_length": 5
    },
    {
      "event_id": "01011013_e00059",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "完了！",
      "text_length": 3
    },
    {
      "event_id": "01011013_e00060",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "叫赵颜近前来细看簿上：三日后作注定夭寿而亡。",
      "text_length": 22
    },
    {
      "event_id": "01011013_e00061",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵颜"
      ],
      "text": "二位星君，我家有父母，无人侍奉，望星君大发慈悲。",
      "text_length": 24
    },
    {
      "event_id": "01011013_e00062",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵颜哭。",
      "text_length": 4
    },
    {
      "event_id": "01011013_e00063",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "南斗星君"
      ],
      "text": "见赵颜只哭得泪如雨降，",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00064",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "北斗星君"
      ],
      "text": "临死时还不忘二老高堂。",
      "text_length": 11
    },
    {
      "event_id": "01011013_e00065",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "星君，你看赵颜哭得可怜，何不将他阳寿添上才是。",
      "text_length": 23
    },
    {
      "event_id": "01011013_e00066",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "恐上是闻知，你我吃罪不起。",
      "text_length": 13
    },
    {
      "event_id": "01011013_e00067",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "上苍有百好生之德。",
      "text_length": 9
    },
    {
      "event_id": "01011013_e00068",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "添得的？",
      "text_length": 4
    },
    {
      "event_id": "01011013_e00069",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "南斗星君"
      ],
      "text": "添得的！",
      "text_length": 4
    },
    {
      "event_id": "01011013_e00070",
      "play_id": "01011013",
      "scene_id": "01011013_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "北斗星君"
      ],
      "text": "这便宜酒，星君你要少吃。",
      "text_length": 12
    },
    {
      "event_id": "01011013_e00071",
