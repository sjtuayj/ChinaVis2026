      ],
      "text": "摆驾。",
      "text_length": 3
    },
    {
      "event_id": "01006018_e00002",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监引刘秀同上。",
      "text_length": 9
    },
    {
      "event_id": "01006018_e00003",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "刘秀"
      ],
      "text": "金钟响玉鞭应王登龙廷，喜的是太平年五谷丰登。君有道民安乐天下同庆，普天下众黎民共享太平。文凭着邓先生阴阳有准，武凭着姚皇兄保定乾坤。内侍臣摆御驾九龙口进，又听得后宫院大放悲声。",
      "text_length": 88
    },
    {
      "event_id": "01006018_e00004",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "郭妃"
      ],
      "text": "摆驾。",
      "text_length": 3
    },
    {
      "event_id": "01006018_e00005",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "郭妃上。",
      "text_length": 4
    },
    {
      "event_id": "01006018_e00006",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "郭妃"
      ],
      "text": "内侍摆驾上龙廷，万岁台前奏分明。",
      "text_length": 16
    },
    {
      "event_id": "01006018_e00007",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "郭妃"
      ],
      "text": "哎吓，万岁吓！",
      "text_length": 7
    },
    {
      "event_id": "01006018_e00008",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘秀"
      ],
      "text": "梓童为何这等模样？",
      "text_length": 9
    },
    {
      "event_id": "01006018_e00009",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "郭妃"
      ],
      "text": "今有姚刚，将我父剑劈府门。万岁作主！",
      "text_length": 18
    },
    {
      "event_id": "01006018_e00010",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘秀"
      ],
      "text": "既有此事，梓童暂且回宫，寡人自有道理。",
      "text_length": 19
    },
    {
      "event_id": "01006018_e00011",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "郭妃"
      ],
      "text": "谢万岁！哎吓……",
      "text_length": 8
    },
    {
      "event_id": "01006018_e00012",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "郭妃下。",
      "text_length": 4
    },
    {
      "event_id": "01006018_e00013",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘秀"
      ],
      "text": "内侍！",
      "text_length": 3
    },
    {
      "event_id": "01006018_e00014",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太监甲允。",
      "text_length": 5
    },
    {
      "event_id": "01006018_e00015",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘秀"
      ],
      "text": "宣伴驾王带子上殿。",
      "text_length": 9
    },
    {
      "event_id": "01006018_e00016",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监甲"
      ],
      "text": "伴驾王带子上殿。",
      "text_length": 8
    },
    {
      "event_id": "01006018_e00017",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "姚期"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01006018_e00018",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "姚期"
      ],
      "text": "安定府绑姚刚怒气皆发，",
      "text_length": 11
    },
    {
      "event_id": "01006018_e00019",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "姚期、姚刚同上。",
      "text_length": 8
    },
    {
      "event_id": "01006018_e00020",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚期"
      ],
      "text": "奴才！",
      "text_length": 3
    },
    {
      "event_id": "01006018_e00021",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "姚期"
      ],
      "text": "只气得年迈人二眼昏花。郭太师在朝中势力皆大，满朝中文武臣谁不怕他？似这等犯王法儿全然不怕，少刻间见万岁定把儿的头杀！",
      "text_length": 58
    },
    {
      "event_id": "01006018_e00022",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚刚"
      ],
      "text": "爹爹！",
      "text_length": 3
    },
    {
      "event_id": "01006018_e00023",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "姚刚"
      ],
      "text": "爹爹不必怒气发，孩儿言来听根芽。在府门与郭荣百般叫骂，怒恼了你孩儿将他来杀！",
      "text_length": 38
    },
    {
      "event_id": "01006018_e00024",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "姚期"
      ],
      "text": "小奴才说此话胆比天大，打死人还说是不犯王法！",
      "text_length": 22
    },
    {
      "event_id": "01006018_e00025",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚期"
      ],
      "text": "儿是好汉？",
      "text_length": 5
    },
    {
      "event_id": "01006018_e00026",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚刚"
      ],
      "text": "儿是好汉！",
      "text_length": 5
    },
    {
      "event_id": "01006018_e00027",
      "play_id": "01006018",
      "scene_id": "01006018_s01",
