      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "雁儿落",
      "speakers": [
        "金母"
      ],
      "text": "向金盘取一棵寿果，俺将这蟠桃刊为首。同祝你寿筵前，般般有。",
      "text_length": 29
    },
    {
      "event_id": "02001009_e00087",
      "play_id": "02001009",
      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 87,
