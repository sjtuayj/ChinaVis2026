      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "汉钟离",
        "吕洞宾",
        "张果老",
        "蓝采和",
        "曹国舅",
        "李铁拐",
        "韩湘子",
        "何仙姑"
      ],
      "text": "既如此，一同驾云前往。",
      "text_length": 11
    },
    {
      "event_id": "02001009_e00066",
      "play_id": "02001009",
      "scene_id": "02001009_s01",
