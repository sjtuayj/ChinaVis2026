      "play_id": "02001009",
      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "鹤、鹿、寿物随白猿同上。白猿跳，捧桃放生。鹤、鹿、寿物、白猿同下。",
      "text_length": 33
    },
    {
      "event_id": "02001009_e00084",
      "play_id": "02001009",
      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 84,
