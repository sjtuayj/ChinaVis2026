      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "同驻马听",
      "speakers": [
        "汉钟离",
        "吕洞宾",
        "张果老",
        "蓝采和",
        "曹国舅",
        "李铁拐",
        "韩湘子",
        "何仙姑"
      ],
      "text": "鸾鹤遨游，千风万岫归苍秀。笙簧叠奏，笙萧列锦讴。虚飘飘，恰似天台山下去寻刘。响潺潺，只见那桃园洞口波声流。停猿鹤，驻千秋，早向那白云峰，齐庆祝千年叟。向那白云峰，齐庆祝千年叟。",
      "text_length": 88
    },
    {
      "event_id": "02001009_e00067",
      "play_id": "02001009",
      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 67,
