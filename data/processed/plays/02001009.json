      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "东方朔"
      ],
      "text": "鹤驾云翩，蓬莱踏遍，约仙伴，青鸾书传，倾刻飞身转。十洲三岛会群仙。鹤驾鸾舆下九天。众仙齐赴蟠桃宴。果祝长生不老年。小仙，方朔是也。奉金母之命，约请各洞诸仙。众仙俱已请下。顷刻就到。𠲔！道言未了，金母来了。",
      "text_length": 102
    },
    {
      "event_id": "02001009_e00007",
      "play_id": "02001009",
      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "东方朔下。〖吹打〗。众昭容引金母同上。吹打住。",
      "text_length": 23
    },
    {
      "event_id": "02001009_e00008",
      "play_id": "02001009",
      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "金母"
      ],
      "text": "阆院三千，玉楼金殿，鹤骖转，凤引文鸾，齐赴蟠桃宴。",
      "text_length": 25
    },
    {
      "event_id": "02001009_e00009",
      "play_id": "02001009",
      "scene_id": "02001009_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。金母归座。吹打住。金母",
