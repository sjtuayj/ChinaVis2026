        "罗妻"
      ],
      "text": "有请！",
      "text_length": 3
    },
    {
      "event_id": "03041006_e00022",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "批牌子。四龙套、秦琼、徐勣、尉迟恭、程咬金引李世民同上，同祭灵。四龙套同下。",
      "text_length": 38
    },
    {
      "event_id": "03041006_e00023",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗妻"
      ],
      "text": "妾夫有何德能，敢劳二主与众家国公前来吊祭！",
      "text_length": 21
    },
    {
      "event_id": "03041006_e00024",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "王兄为国身亡，礼当如此。",
      "text_length": 12
    },
    {
      "event_id": "03041006_e00025",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗妻"
      ],
      "text": "真乃有道明君！",
      "text_length": 7
    },
    {
      "event_id": "03041006_e00026",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "小王要在此陪灵。众家国公俱在灵堂陪伴小王一宵。",
      "text_length": 23
    },
    {
      "event_id": "03041006_e00027",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "秦琼",
        "徐勣",
        "尉迟恭",
        "程咬金"
      ],
      "text": "领旨！",
      "text_length": 3
    },
    {
      "event_id": "03041006_e00028",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李世民、秦琼、徐勣、尉迟恭、程咬金、罗妻、罗春同打盹。〖起二更鼓〗。",
      "text_length": 34
    },
    {
      "event_id": "03041006_e00029",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "罗成"
      ],
      "text": "天下荒荒无真主，",
      "text_length": 8
    },
    {
      "event_id": "03041006_e00030",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四鬼卒引罗成同上，罗成立椅。",
      "text_length": 14
    },
    {
      "event_id": "03041006_e00031",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "罗成"
      ],
      "text": "上苍降下了紫薇星。",
      "text_length": 9
    },
    {
      "event_id": "03041006_e00032",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成下椅。",
      "text_length": 5
    },
    {
      "event_id": "03041006_e00033",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "青龙投胎太原郡，那燕山又降下白虎星。俺生在罗门为公子，长大成人武艺超群。一十七岁保唐主，俺也曾东荡西除、南征北战、昼夜杀砍、到如今只落得一命归阴。将身儿且把灵堂进，",
      "text_length": 82
    },
    {
      "event_id": "03041006_e00034",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成进灵堂，上灵台。",
      "text_length": 10
    },
    {
      "event_id": "03041006_e00035",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "又只见我主爷瞌睡沉沉。众国公一个个俱已困，苦命的娇妻伴我灵。义子罗春身戴孝，最可叹无依无靠、孤苦伶仃、三岁的罗通好不伤心。",
      "text_length": 61
    },
    {
      "event_id": "03041006_e00036",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "罗成"
      ],
      "text": "我的儿啊！",
      "text_length": 5
    },
    {
      "event_id": "03041006_e00037",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起三更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "03041006_e00038",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "罗成"
      ],
      "text": "恨只恨三千岁挂了帅印，",
      "text_length": 11
    },
    {
      "event_id": "03041006_e00039",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "罗成"
      ],
      "text": "俺罗成倒作了马前先行。头一阵枪挑了李天寿，有功不赏反加刑——责打了为臣我四十军棍，身带棍伤还要出兵。从清晨杀到了——",
      "text_length": 58
    },
    {
      "event_id": "03041006_e00040",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "罗成"
      ],
      "text": "午时正，午时杀到夜黄昏。紧闭四门——",
      "text_length": 18
    },
    {
      "event_id": "03041006_e00041",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "罗成"
      ],
      "text": "不得进，单人独骑我杀退贼兵。淤泥河，遭围困，飞蝗骤雨箭穿身。望求千岁奏一本，说俺罗成死惨情。母老妻娇要照应，三岁的罗通也要加恩。",
      "text_length": 64
    },
    {
      "event_id": "03041006_e00042",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起四更鼓〗。罗成下灵台。",
      "text_length": 13
    },
    {
      "event_id": "03041006_e00043",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "罗成"
      ],
      "text": "若要君臣重相会，大破龙门臣见君。（四鬼卒引罗成同下。〖起五更鼓〗。李世民、秦琼、徐勣、尉迟恭、程咬金、罗妻、罗春同醒。四龙套同暗上。）",
      "text_length": 67
    },
    {
      "event_id": "03041006_e00044",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "我等告辞了。",
      "text_length": 6
    },
    {
      "event_id": "03041006_e00045",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗妻"
      ],
      "text": "多谢二主与众家国公！",
      "text_length": 10
    },
    {
      "event_id": "03041006_e00046",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "摆驾回宫！",
      "text_length": 5
    },
    {
      "event_id": "03041006_e00047",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "批牌子。四龙套、秦琼、徐勣、尉迟恭、程咬金引李世民同下。",
      "text_length": 28
    },
    {
      "event_id": "03041006_e00048",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗妻"
      ],
      "text": "夫哇！",
      "text_length": 3
    },
    {
      "event_id": "03041006_e00049",
      "play_id": "03041006",
      "scene_id": "03041006_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗妻哭。罗春、罗妻抱罗通同下。",
      "text_length": 15
    }
  ],
  "roles_inferred": true
}