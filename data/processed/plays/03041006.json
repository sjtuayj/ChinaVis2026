  "events": [
    {
      "event_id": "03041006_e00001",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起初更鼓〗。四鬼卒引罗成同上。",
      "text_length": 16
    },
    {
      "event_id": "03041006_e00002",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "罗成"
      ],
      "text": "豪气冲霄，英风飘渺，魂魄绕，胆战心摇，何日将仇报！",
      "text_length": 25
    },
    {
      "event_id": "03041006_e00003",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成上高台。",
      "text_length": 6
    },
    {
      "event_id": "03041006_e00004",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "罗成"
      ],
      "text": "身前为大将，死后作忠魂。捐躯何足论，英名万古存。",
      "text_length": 24
    },
    {
      "event_id": "03041006_e00005",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "吾乃越国公罗成鬼魂是也。只因苏烈兴兵犯界，圣上命元吉挂帅，命俺为前战先行。不想被奸王陷害，在淤泥河乱箭身亡。今有二主秦王与众家国公前来吊祭。不免前去托妻寄子，把我的苦处细表一番。众鬼卒！",
      "text_length": 93
    },
    {
      "event_id": "03041006_e00006",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四鬼卒"
      ],
      "text": "有！",
      "text_length": 2
    },
    {
      "event_id": "03041006_e00007",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "驾风前往！",
      "text_length": 5
    },
    {
      "event_id": "03041006_e00008",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四鬼子"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03041006_e00009",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗成下高台。扯四门。",
      "text_length": 10
    },
    {
      "event_id": "03041006_e00010",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "黑暗暗雾沉沉随风飘荡，冷飕飕凄惨惨转回家乡。我主爷来吊孝龙驾光降，众王侯见灵台也要悲伤。叫鬼卒！",
      "text_length": 48
    },
    {
      "event_id": "03041006_e00011",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四鬼卒"
      ],
      "text": "有！",
      "text_length": 2
    },
    {
      "event_id": "03041006_e00012",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "罗成"
      ],
      "text": "驾阴风急忙——",
      "text_length": 7
    },
    {
      "event_id": "03041006_e00013",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 13,
