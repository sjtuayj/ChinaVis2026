      "speakers": [
        "罗成"
      ],
      "text": "前往，",
      "text_length": 3
    },
    {
      "event_id": "03041006_e00014",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 14,
