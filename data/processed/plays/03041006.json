      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四鬼卒同下。",
      "text_length": 6
    },
    {
      "event_id": "03041006_e00016",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 16,
