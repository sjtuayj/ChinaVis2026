      "mode_label": "唢呐二黄散板",
      "speakers": [
        "罗成"
      ],
      "text": "可叹我英雄汉乱箭身亡。",
      "text_length": 11
    },
    {
      "event_id": "03041006_e00017",
      "play_id": "03041006",
      "scene_id": "03041006_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
