  "events": [
    {
      "event_id": "01014009_e00001",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王晋上。",
      "text_length": 4
    },
    {
      "event_id": "01014009_e00002",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "巧装打扮出衙厅，人人道我是大功勋。",
      "text_length": 17
    },
    {
      "event_id": "01014009_e00003",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "老夫，王晋。晋国为臣，官居宜兴太守，只因此处，出了三害，骚扰百姓，是我出衙私访。",
      "text_length": 40
    },
    {
      "event_id": "01014009_e00004",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "周处"
      ],
      "text": "吓嚇！",
      "text_length": 3
    },
    {
      "event_id": "01014009_e00005",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "那厢来一红脸大汉，想必就是周处。等他到来，我用言语，打动于他，他有来言，我有去语。",
      "text_length": 41
    },
    {
      "event_id": "01014009_e00006",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "将身且在路旁等，言语打动他一片心。",
      "text_length": 17
    },
    {
      "event_id": "01014009_e00007",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "周处"
      ],
      "text": "走吓。",
      "text_length": 3
    },
    {
      "event_id": "01014009_e00008",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周处上。",
      "text_length": 4
    },
    {
      "event_id": "01014009_e00009",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "周处"
      ],
      "text": "适才街坊把酒饮，谁人不知我周子隐。迈开大步往前进，",
      "text_length": 25
    },
    {
      "event_id": "01014009_e00010",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "咳，不成世界了！",
      "text_length": 8
    },
    {
      "event_id": "01014009_e00011",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "周处"
      ],
      "text": "又只见老丈发悲声。",
      "text_length": 9
    },
    {
      "event_id": "01014009_e00012",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "老丈，请了。",
      "text_length": 6
    },
    {
      "event_id": "01014009_e00013",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "原来是一位壮士，请了。",
      "text_length": 11
    },
    {
      "event_id": "01014009_e00014",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "请问老丈，你在此悲叹，莫非有人欺压于你么？若有人欺负于你，待某家替你打个抱不平。",
      "text_length": 40
    },
    {
      "event_id": "01014009_e00015",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "你看老夫偌大年纪，漫说无人欺压于我，就是有人欺压于我，老夫也不与他们较量。",
      "text_length": 37
    },
    {
      "event_id": "01014009_e00016",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "将然如此，为何在此浩叹？",
      "text_length": 12
    },
    {
      "event_id": "01014009_e00017",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "壮士，你还不知么？",
      "text_length": 9
    },
    {
      "event_id": "01014009_e00018",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "我还不知。",
      "text_length": 5
    },
    {
      "event_id": "01014009_e00019",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "此地出了三害了，每日苦害黎民，百姓难以度日。",
      "text_length": 22
    },
    {
      "event_id": "01014009_e00020",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "此地出了三害，但不知是哪三害？",
      "text_length": 15
    },
    {
      "event_id": "01014009_e00021",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "壮士愿闻？",
      "text_length": 5
    },
    {
      "event_id": "01014009_e00022",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "愿闻。",
      "text_length": 3
    },
    {
      "event_id": "01014009_e00023",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "如此，听了。",
      "text_length": 6
    },
    {
      "event_id": "01014009_e00024",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "王晋"
      ],
      "text": "提起了这三害令人好恨，想壮士闻此言也要心惊：头一害终南山出了猛虎，",
      "text_length": 33
    },
    {
      "event_id": "01014009_e00025",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "出了猛虎？这猛虎，是怎样的厉害？",
      "text_length": 16
    },
    {
      "event_id": "01014009_e00026",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "王晋"
      ],
      "text": "遇见了行路人皮骨全吞。",
      "text_length": 11
    },
    {
      "event_id": "01014009_e00027",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "这猛虎，竟如此的厉害！但不知这第二害，是何物件？",
      "text_length": 24
    },
    {
      "event_id": "01014009_e00028",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "听道。",
      "text_length": 3
    },
    {
      "event_id": "01014009_e00029",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄快三眼",
      "speakers": [
        "王晋"
      ],
      "text": "第二害更比那猛虎还狠，长桥下又出了害人的蛟精。",
      "text_length": 23
    },
    {
      "event_id": "01014009_e00030",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "这长桥的蛟精，是怎样的厉害？",
      "text_length": 14
    },
    {
      "event_id": "01014009_e00031",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄快三眼",
      "speakers": [
        "王晋"
      ],
      "text": "每日里兴波浪吞舟荡趸，在旱路食行人当作点心。",
      "text_length": 22
    },
    {
      "event_id": "01014009_e00032",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "这蛟精如此厉害，但不知这第三害，又是个什么东西？",
      "text_length": 24
    },
    {
      "event_id": "01014009_e00033",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王晋"
      ],
      "text": "若提起第三害益发可恨，竟比那南山猛虎、长桥孽蛟还狠十分。",
      "text_length": 28
    },
    {
      "event_id": "01014009_e00034",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "但不知是个什么东西？",
      "text_length": 10
    },
    {
      "event_id": "01014009_e00035",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王晋"
      ],
      "text": "若问他并不是禽兽之类，他也是有须眉，有志量，雄赳赳，气昂昂，是一个有志的能人！",
      "text_length": 39
    },
    {
      "event_id": "01014009_e00036",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "原来他是一人，为何如此的厉害？",
      "text_length": 15
    },
    {
      "event_id": "01014009_e00037",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王晋"
      ],
      "text": "都因他父早死缺少教训，因此上习下流作了匪人。",
      "text_length": 22
    },
    {
      "event_id": "01014009_e00038",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "他既作了匪人，但不知是怎样害人？",
      "text_length": 16
    },
    {
      "event_id": "01014009_e00039",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王晋"
      ],
      "text": "在宜兴逞凶心习为光棍，欺良民诈富户倾害好人。",
      "text_length": 22
    },
    {
      "event_id": "01014009_e00040",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "难道就无人叩告于他么？",
      "text_length": 11
    },
    {
      "event_id": "01014009_e00041",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王晋"
      ],
      "text": "就有那被害人经官理论，怎奈他把住了大小衙门，谁敢哼声！",
      "text_length": 27
    },
    {
      "event_id": "01014009_e00042",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周处"
      ],
      "text": "唔，呀呀呀呀呀呀！",
      "text_length": 9
    },
    {
      "event_id": "01014009_e00043",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "都只为宜兴城出此恶棍，害得那众百姓难度光阴。",
      "text_length": 22
    },
    {
      "event_id": "01014009_e00044",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "周处"
      ],
      "text": "听一言来心头恨，倒叫某家动无名。回头便把老丈问，但不知此人叫何名？",
      "text_length": 33
    },
    {
      "event_id": "01014009_e00045",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "壮士不必问其情，老夫言来听分明：我若说出他名和姓，怕的是我老命活不成。",
      "text_length": 35
    },
    {
      "event_id": "01014009_e00046",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "周处"
      ],
      "text": "老丈不必胆怕惊，细听某家说分明：你且说出他名和姓，任凭他铁打金刚，铜铸罗汉，难近我身。",
      "text_length": 43
    },
    {
      "event_id": "01014009_e00047",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "壮士要问，两厢看来。",
      "text_length": 10
    },
    {
      "event_id": "01014009_e00048",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "此人他姓周名处字子隐！",
      "text_length": 11
    },
    {
      "event_id": "01014009_e00049",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周处退。",
      "text_length": 4
    },
    {
      "event_id": "01014009_e00050",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "如何？",
      "text_length": 3
    },
    {
      "event_id": "01014009_e00051",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "壮士闻言也胆怕惊！",
      "text_length": 9
    },
    {
      "event_id": "01014009_e00052",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "周处"
      ],
      "text": "好似霹雳当头震，我周处作了无义的人。低下头来自思问，我定要杀却猛虎斩蛟精。",
      "text_length": 37
    },
    {
      "event_id": "01014009_e00053",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "请问壮士名和姓？",
      "text_length": 8
    },
    {
      "event_id": "01014009_e00054",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "周处"
      ],
      "text": "周处就是我的名。",
      "text_length": 8
    },
    {
      "event_id": "01014009_e00055",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王晋跪。",
      "text_length": 4
    },
    {
      "event_id": "01014009_e00056",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王晋"
      ],
      "text": "爷爷饶命！",
      "text_length": 5
    },
    {
      "event_id": "01014009_e00057",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "周处"
      ],
      "text": "老丈你在此等一等，我不除三害不为人。",
      "text_length": 18
    },
    {
      "event_id": "01014009_e00058",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周处下。",
      "text_length": 4
    },
    {
      "event_id": "01014009_e00059",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "王晋"
      ],
      "text": "呵哈哈哈哈！",
      "text_length": 6
    },
    {
      "event_id": "01014009_e00060",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "王晋"
      ],
      "text": "他好似朦胧方睡定，我一言惊醒梦中人。他悔过自新邪改正，我除暴安良是忠臣。",
      "text_length": 36
    },
    {
      "event_id": "01014009_e00061",
      "play_id": "01014009",
      "scene_id": "01014009_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王晋下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}