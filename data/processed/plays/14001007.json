  "events": [
    {
      "event_id": "14001007_e00001",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王允上。",
      "text_length": 4
    },
    {
      "event_id": "14001007_e00002",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "王允"
      ],
      "text": "调和鼎鼐，位列三台。",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00003",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "老夫王允，唐室驾前为臣，官拜当朝首相。夫人陈氏，膝下无儿，所生三女：长女金钏，所配苏龙；二女银钏，所配魏虎；只有三女宝钏，尚未婚配。本月二日，曾在十字街前，高搭彩楼，抛球招赘。只望打着哪家王孙公子，不想彩球偏偏打着花郎薛平贵。想我女儿乃是千金之体，怎能与那花郎匹配，待我将女儿唤出堂来。",
      "text_length": 143
    },
    {
      "event_id": "14001007_e00004",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院暗上。",
      "text_length": 5
    },
    {
      "event_id": "14001007_e00005",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "将这门亲事打退，劝她另配王孙公子，一来门当户对，二来也免耽误她的终身。来，家院！",
      "text_length": 40
    },
    {
      "event_id": "14001007_e00006",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "有！",
      "text_length": 2
    },
    {
      "event_id": "14001007_e00007",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "后堂传话，有请三姑娘。",
      "text_length": 11
    },
    {
      "event_id": "14001007_e00008",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "是！后堂传话，有请三姑娘！",
      "text_length": 13
    },
    {
      "event_id": "14001007_e00009",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "14001007_e00010",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "王宝钏"
      ],
      "text": "天子赐绒线，绣彩球，天配良缘。",
      "text_length": 15
    },
    {
      "event_id": "14001007_e00011",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "爹爹万福。",
      "text_length": 5
    },
    {
      "event_id": "14001007_e00012",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "我儿少礼，一旁坐下。",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00013",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "告坐。呀爹爹，唤女儿出来，但不知有何训教？",
      "text_length": 21
    },
    {
      "event_id": "14001007_e00014",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "恭喜我儿，贺喜我儿！",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00015",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿喜从何来？",
      "text_length": 7
    },
    {
      "event_id": "14001007_e00016",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "儿呀，你在那十字街头，抛球招赘，你可知道打着的是哪家的王孙公子？",
      "text_length": 32
    },
    {
      "event_id": "14001007_e00017",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿不知。",
      "text_length": 5
    },
    {
      "event_id": "14001007_e00018",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "就是那花郎平贵。",
      "text_length": 8
    },
    {
      "event_id": "14001007_e00019",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "怎么？就是那花郎平贵。咳，这也是女儿命该如此啊。",
      "text_length": 24
    },
    {
      "event_id": "14001007_e00020",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "依为父之见，我儿乃是千金之体，怎能与那花郎匹配？快将此门亲事打退，另配王孙公子。不知我儿意下如何？",
      "text_length": 49
    },
    {
      "event_id": "14001007_e00021",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "爹爹请上，先恕女儿不孝之罪。只因母亲染病在床，女儿许下心愿，降香三载。三载未满，母亲病体痊愈。后宫娘娘闻之大喜，赐儿五色绒线，绣成彩球。因于二月二日在那十字街前，高搭彩楼，抛球招赘，打富随富，打叟随叟。今日慢说是打着花郎，就是一块顽石，女儿也是要抱。",
      "text_length": 125
    },
    {
      "event_id": "14001007_e00022",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "抱它作甚？",
      "text_length": 5
    },
    {
      "event_id": "14001007_e00023",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "抱它三年五载，以表恩爱之情。圣人云：人而无信，不知其可也。大车无輗，小车无軏，其何以行之哉？昔日孔子困雪山，太公垂钓竿，二大古圣贤，时衰命颠连。丫鬟，打坐向前！",
      "text_length": 80
    },
    {
      "event_id": "14001007_e00024",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "为父与你说话，你敢是同为父生气？https://scripts.xikao.com/play/140010072023-04-03",
      "text_length": 65
    },
    {
      "event_id": "14001007_e00025",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿怎敢与爹爹生气？",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00026",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "既然不是与为父赌气，就该退去此门亲事。",
      "text_length": 19
    },
    {
      "event_id": "14001007_e00027",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "此乃姻缘前定，慢说爹爹，就是圣旨也难以更改，难以更改！",
      "text_length": 27
    },
    {
      "event_id": "14001007_e00028",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "儿说此话，就该掌嘴！",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00029",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "王允"
      ],
      "text": "小奴才说此话全然不想，不由得年迈人怒满胸膛。你大姐配苏龙户部执掌，你二姐配魏虎兵部侍郎。只有你小冤家性情倔强，千金女配花郎怎度时光？",
      "text_length": 66
    },
    {
      "event_id": "14001007_e00030",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老爹爹请息怒容儿细讲，儿命苦怎配得状元才郎？父休笑薛平贵花郎模样，贫穷人得了志比父还强。",
      "text_length": 44
    },
    {
      "event_id": "14001007_e00031",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王允"
      ],
      "text": "薛平贵他生来命运低，每日里在大街去讨乞。半截褴衫怎能遮体？遮住了东来露出了西。",
      "text_length": 39
    },
    {
      "event_id": "14001007_e00032",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王宝钏"
      ],
      "text": "昔日里有一个孟姜女，他与那范郎送寒衣。哭倒长城有万里，至今留名在那万古题。",
      "text_length": 37
    },
    {
      "event_id": "14001007_e00033",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王允"
      ],
      "text": "前朝的事儿——",
      "text_length": 7
    },
    {
      "event_id": "14001007_e00034",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王允"
      ],
      "text": "休提起，千金怎为花郎妻？",
      "text_length": 12
    },
    {
      "event_id": "14001007_e00035",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王宝钏"
      ],
      "text": "张良、韩信、魏苏秦，俱是安邦定国的臣。",
      "text_length": 19
    },
    {
      "event_id": "14001007_e00036",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王允"
      ],
      "text": "既知前朝韩元帅，未央宫死的是什么人？",
      "text_length": 18
    },
    {
      "event_id": "14001007_e00037",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王宝钏"
      ],
      "text": "未央宫斩的是韩信，难道说文官他就不丧身？",
      "text_length": 20
    },
    {
      "event_id": "14001007_e00038",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王允"
      ],
      "text": "沈宏也曾把亲退，另配姻缘为何情？",
      "text_length": 16
    },
    {
      "event_id": "14001007_e00039",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王宝钏"
      ],
      "text": "沈宏虽然把亲退，他乃是不义不肖的人。",
      "text_length": 18
    },
    {
      "event_id": "14001007_e00040",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王允"
      ],
      "text": "要退要退偏要退，",
      "text_length": 8
    },
    {
      "event_id": "14001007_e00041",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王宝钏"
      ],
      "text": "不能不能万不能。",
      "text_length": 8
    },
    {
      "event_id": "14001007_e00042",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王允"
      ],
      "text": "两件宝衣来脱下，",
      "text_length": 8
    },
    {
      "event_id": "14001007_e00043",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王宝钏"
      ],
      "text": "再与爹爹说分明。",
      "text_length": 8
    },
    {
      "event_id": "14001007_e00044",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "请问爹爹，这两件宝衣，从何而得？",
      "text_length": 16
    },
    {
      "event_id": "14001007_e00045",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "乃是圣上所赐。",
      "text_length": 7
    },
    {
      "event_id": "14001007_e00046",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "圣上因何赐予爹爹？",
      "text_length": 9
    },
    {
      "event_id": "14001007_e00047",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "不过是念在君臣之谊罢了。",
      "text_length": 12
    },
    {
      "event_id": "14001007_e00048",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "圣上倒有君臣之谊，怎么爹爹你难道就无父女之情了么？",
      "text_length": 25
    },
    {
      "event_id": "14001007_e00049",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "只要我儿肯将这门亲事打退，慢说两件宝衣，就是府内金银也可以任儿搬取。",
      "text_length": 34
    },
    {
      "event_id": "14001007_e00050",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿不要了。",
      "text_length": 6
    },
    {
      "event_id": "14001007_e00051",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "上脱日月龙凤袄，下脱山河地理裙。两件宝衣俱脱下，",
      "text_length": 24
    },
    {
      "event_id": "14001007_e00052",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏脱宫装，捧衣看，掷与王允。",
      "text_length": 16
    },
    {
      "event_id": "14001007_e00053",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "交与了嫌贫爱富的人。",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00054",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "儿啊，为父嫌贫爱富，为的是哪一个？",
      "text_length": 17
    },
    {
      "event_id": "14001007_e00055",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿不知。https://scripts.xikao.com/play/140010072023-04-03",
      "text_length": 54
    },
    {
      "event_id": "14001007_e00056",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "为的就是你这奴才呀！",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00057",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "也是女儿命该如此，何劳爹爹劝问。你与我坐定了罢。",
      "text_length": 24
    },
    {
      "event_id": "14001007_e00058",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "你手摸胸膛想一想，膝下还有什么人？",
      "text_length": 17
    },
    {
      "event_id": "14001007_e00059",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "我儿既知为父膝下无儿，就当格外尽心孝敬。",
      "text_length": 20
    },
    {
      "event_id": "14001007_e00060",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "倘若是母亲百年后，儿是披麻戴孝的人。",
      "text_length": 18
    },
    {
      "event_id": "14001007_e00061",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "倘若是为父百年之后呢？",
      "text_length": 11
    },
    {
      "event_id": "14001007_e00062",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "倘若是爹爹身亡故，女儿不来哭一声。",
      "text_length": 17
    },
    {
      "event_id": "14001007_e00063",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王允"
      ],
      "text": "宝钏说话太无情，不由老夫怒嗔生。今日与我三击掌，从今后就断了父女情。",
      "text_length": 34
    },
    {
      "event_id": "14001007_e00064",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "在堂前不与父争论。",
      "text_length": 9
    },
    {
      "event_id": "14001007_e00065",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "到哪里去？",
      "text_length": 5
    },
    {
      "event_id": "14001007_e00066",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "到后堂去拜别儿的老娘亲。",
      "text_length": 12
    },
    {
      "event_id": "14001007_e00067",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王允"
      ],
      "text": "丫鬟！好好把守庭堂，若有人去往后堂，定要打断尔的狗腿！",
      "text_length": 27
    },
    {
      "event_id": "14001007_e00068",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿不去了。爹爹呀！",
      "text_length": 10
    },
    {
      "event_id": "14001007_e00069",
      "play_id": "14001007",
      "scene_id": "14001007_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
