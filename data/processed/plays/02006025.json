  "events": [
    {
      "event_id": "02006025_e00001",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "哪吒上，跳。众神引李靖同上。",
      "text_length": 14
    },
    {
      "event_id": "02006025_e00002",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "李靖"
      ],
      "text": "十万熊罴，星辰齐聚，遵天旨，歼灭渠魁，扫尽如斯辈。",
      "text_length": 25
    },
    {
      "event_id": "02006025_e00003",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李靖上高座。",
      "text_length": 6
    },
    {
      "event_id": "02006025_e00004",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李靖"
      ],
      "text": "大将桓桓出玉庭，雄兵十万列连营。天罗地网安排定，管取妖猴一命倾。",
      "text_length": 32
    },
    {
      "event_id": "02006025_e00005",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "某，托塔天王李靖是也。奉御旨前往花果山水帘洞擒拿妖猴。哪吒！",
      "text_length": 30
    },
    {
      "event_id": "02006025_e00006",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "哪吒"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02006025_e00007",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "吩咐擂鼓三通，诸天将上台听点。",
      "text_length": 15
    },
    {
      "event_id": "02006025_e00008",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "哪吒"
      ],
      "text": "得令。呔！父王有令，擂鼓三通，诸天将上台听点。",
      "text_length": 23
    },
    {
      "event_id": "02006025_e00009",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内擂鼓。众天将同上，见礼。",
      "text_length": 13
    },
    {
      "event_id": "02006025_e00010",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众天将"
      ],
      "text": "众天将打躬。",
      "text_length": 6
    },
    {
      "event_id": "02006025_e00011",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "诸天将，",
      "text_length": 4
    },
    {
      "event_id": "02006025_e00012",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众天将"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02006025_e00013",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "俺奉御旨，率领尔等擒拿妖猴。分班听令。",
      "text_length": 19
    },
    {
      "event_id": "02006025_e00014",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众天将同允，分侍。",
      "text_length": 9
    },
    {
      "event_id": "02006025_e00015",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "俺这里神通奇异，妖气不与瑞光沸。俺这里祥天霭霭，他那里，他那里冷气凄凄。俺这里一般雄心多智慧，他那里千般魔力逞机宜。",
      "text_length": 58
    },
    {
      "event_id": "02006025_e00016",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "马天君！",
      "text_length": 4
    },
    {
      "event_id": "02006025_e00017",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 17,
