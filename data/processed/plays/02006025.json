        "李靖"
      ],
      "text": "你领丧门吊客呵！",
      "text_length": 8
    },
    {
      "event_id": "02006025_e00029",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "恁在那山左接战，",
      "text_length": 8
    },
    {
      "event_id": "02006025_e00030",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "温天君允，下。",
      "text_length": 7
    },
    {
      "event_id": "02006025_e00031",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "刘天君！",
      "text_length": 4
    },
    {
      "event_id": "02006025_e00032",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘天君允。",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00033",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "你领天罡、地煞呵！",
      "text_length": 9
    },
    {
      "event_id": "02006025_e00034",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "在山右将他的魂魄追随。",
      "text_length": 11
    },
    {
      "event_id": "02006025_e00035",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘天君允，下。",
      "text_length": 7
    },
    {
      "event_id": "02006025_e00036",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "二十八宿！",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00037",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四神同允。",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00038",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "恁将他巢穴倾倒，",
      "text_length": 8
    },
    {
      "event_id": "02006025_e00039",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四神同允，同下。",
      "text_length": 8
    },
    {
      "event_id": "02006025_e00040",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "十二元辰！",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00041",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四神同允。",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00042",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "恁可也紧守着罗网周围。",
      "text_length": 11
    },
    {
      "event_id": "02006025_e00043",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四神同允，同下。",
      "text_length": 8
    },
    {
      "event_id": "02006025_e00044",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "二郎神！",
      "text_length": 4
    },
    {
      "event_id": "02006025_e00045",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨戬允。",
      "text_length": 4
    },
    {
      "event_id": "02006025_e00046",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "命你为总先锋，今日之事，全仗于汝。",
      "text_length": 17
    },
    {
      "event_id": "02006025_e00047",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "遇妖猴紧追紧赶，休得要半步相离。",
      "text_length": 16
    },
    {
      "event_id": "02006025_e00048",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨戬下。",
      "text_length": 4
    },
    {
      "event_id": "02006025_e00049",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "哪吒！",
      "text_length": 3
    },
    {
      "event_id": "02006025_e00050",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "哪吒允。",
      "text_length": 4
    },
    {
      "event_id": "02006025_e00051",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "你领东南西北四渎五岳以为救应。",
      "text_length": 15
    },
    {
      "event_id": "02006025_e00052",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "必须要齐心努力，必须要歼灭渠魁。",
      "text_length": 16
    },
    {
      "event_id": "02006025_e00053",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "哪吒允，下。",
      "text_length": 6
    },
    {
      "event_id": "02006025_e00054",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "李靖"
      ],
      "text": "俺这里天兵天将施威武，他那里猴卒妖兵各逞威，只杀得星斗依稀。",
      "text_length": 30
    },
    {
      "event_id": "02006025_e00055",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众神同杀。",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00056",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李靖"
      ],
      "text": "好恶妖猴也！",
      "text_length": 6
    },
    {
      "event_id": "02006025_e00057",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "李靖"
      ],
      "text": "俺只见雄威赳赳勇如罴，不枉他，不枉他号天齐。只见他往来南北，摧退东西，他那里奔驰一似如儿戏。俺这里神通广大，恁可也难逃避，俺与他一会价辨个高低。昏惨惨四野征云起，闹垓垓几处的军声沸，恰更似平地上起个轰雷。",
      "text_length": 102
    },
    {
      "event_id": "02006025_e00058",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众神同杀。",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00059",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "天下乐",
      "speakers": [
        "李靖"
      ],
      "text": "只见水怪山魈尽挂铁衣，摇也么旗也却也助军威。可笑那无知物，恁好迷痴，这壁厢吹觱篥，那壁厢擂鼓皮。他怎当俺法力大，可也尽披靡披靡。",
      "text_length": 64
    },
    {
      "event_id": "02006025_e00060",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众神同杀。",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00061",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "哪吒令",
      "speakers": [
        "李靖"
      ],
      "text": "小妖们遍岭沿提奔腾一似飞。有的妖把角吹，有的妖把鼓擂。老妖们头顶盔，小妖们并着腿。这山坡聚几堆，那山坡聚几堆。笑他们闹嚷嚷，意欲何为，意欲何为？",
      "text_length": 72
    },
    {
      "event_id": "02006025_e00062",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "鹊踏枝",
      "speakers": [
        "李靖"
      ],
      "text": "满山头天雾黑，四下里，四下里刀枪密。眼跟前把暗天昏，耳边厢鬼哭神啼。蓦地里山崩海沸，只杀得紫微垣，斗转星移。",
      "text_length": 54
    },
    {
      "event_id": "02006025_e00063",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众神同杀。",
      "text_length": 5
    },
    {
      "event_id": "02006025_e00064",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "胜葫芦",
      "speakers": [
        "李靖"
      ],
      "text": "这妖王法力果精奇，不能够把他欺。又见他狰狞相貌多奇异，他只是三头六臂铜筋铁骨，吼一声恰似野霹雳。",
      "text_length": 48
    },
    {
      "event_id": "02006025_e00065",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众神同列阵。",
      "text_length": 6
    },
    {
      "event_id": "02006025_e00066",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "幺篇",
      "speakers": [
        "李靖"
      ],
      "text": "俺只见六丁六甲显神威，四面列层围。恁就是三头六臂休轻敌，他这里持剑抡枪各逞威。一对对紧相随，一对对紧相随。",
      "text_length": 53
    },
    {
      "event_id": "02006025_e00067",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙悟空、二郎神同入阵。",
      "text_length": 11
    },
    {
      "event_id": "02006025_e00068",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "杀了半日，并无个对手。你且通个名儿上来。",
      "text_length": 20
    },
    {
      "event_id": "02006025_e00069",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨戬"
      ],
      "text": "妖猴听者。吾乃：",
      "text_length": 8
    },
    {
      "event_id": "02006025_e00070",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杨戬"
      ],
      "text": "清源妙道二郎神，法力威灵天地闻。玉殿驰名为上将，今朝擒你泼猴狲。",
      "text_length": 32
    },
    {
      "event_id": "02006025_e00071",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "你这些话只好哄别人，孙爷爷跟前岂是你卖弄得的？你且站稳了，听我道来：",
      "text_length": 34
    },
    {
      "event_id": "02006025_e00072",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙悟空"
      ],
      "text": "天地才分育吾身，参详学道拜昆仑。神通广大超三界，要上灵霄为帝君。",
      "text_length": 32
    },
    {
      "event_id": "02006025_e00073",
      "play_id": "02006025",
      "scene_id": "02006025_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
