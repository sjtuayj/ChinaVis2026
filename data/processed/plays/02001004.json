  "events": [
    {
      "event_id": "02001004_e00001",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四仙官引天官、地官、水官同上。",
      "text_length": 15
    },
    {
      "event_id": "02001004_e00002",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同新水令",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "欣逢化宇日时长，启瞳胧。万年枝上。云璈仙乐响，拂袖筵张。洪幔祥光。盖公照长垣朗，盖公照长垣朗。",
      "text_length": 47
    },
    {
      "event_id": "02001004_e00003",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天官"
      ],
      "text": "上元赐福到人间，",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00004",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "地官"
      ],
      "text": "中元赦罪百禄添。",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00005",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "水官"
      ],
      "text": "下元解厄频增寿，",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00006",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "永祝遐龄亿万年。",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00007",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天官"
      ],
      "text": "吾乃上元一品赐福天官紫微大帝是也。",
      "text_length": 17
    },
    {
      "event_id": "02001004_e00008",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "地官"
      ],
      "text": "吾乃中元二品赦罪地官清虚大帝是也。",
      "text_length": 17
    },
    {
      "event_id": "02001004_e00009",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "水官"
      ],
      "text": "吾乃下元三品解厄水官洞音大帝是也。",
      "text_length": 17
    },
    {
      "event_id": "02001004_e00010",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天官"
      ],
      "text": "今有善门福地，荫功浩大，德行无边。我等奉玉帝敕旨前往赐宝降祥。仙官！",
      "text_length": 34
    },
    {
      "event_id": "02001004_e00011",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四仙官"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "02001004_e00012",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "吩咐摆齐幢旛。往福地去者。",
      "text_length": 13
    },
    {
      "event_id": "02001004_e00013",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四仙官"
      ],
      "text": "领旨。大帝有旨：摆齐幢旛。往福地去者。",
      "text_length": 19
    },
    {
      "event_id": "02001004_e00014",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众瓜棍同上。",
      "text_length": 6
    },
    {
      "event_id": "02001004_e00015",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众瓜棍"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001004_e00016",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同驻马听",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "三素飘扬，鹤驭翩翩。披鹤氅。风骛霞响，十州端嘘五云乡。中流不见海波扬，天空但听罡气响，富贵安康。熙朝绘出升平像。",
      "text_length": 56
    },
    {
      "event_id": "02001004_e00017",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。八如意同上。",
      "text_length": 11
    },
    {
      "event_id": "02001004_e00018",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同沉醉东风",
      "speakers": [
        "八如意"
      ],
      "text": "喜海外仙家疏放，望环中人物殷昌。玉女迎，瑶池降，蟠桃熟，度色提浆。",
      "text_length": 33
    },
    {
      "event_id": "02001004_e00019",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "八如意"
      ],
      "text": "积善之家庆有余，神仙永祝照环区。四时安乐声康泰，八节康宁永不移。",
      "text_length": 32
    },
    {
      "event_id": "02001004_e00020",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "八如意"
      ],
      "text": "我等乃四时嘉祥如意大仙是也。我等奉玉帝敕旨前往福地。赐宝降祥。你我一同前往。请。",
      "text_length": 40
    },
    {
      "event_id": "02001004_e00021",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同沉醉东风",
      "speakers": [
        "八如意"
      ],
      "text": "衣冠身惹御烛香，天保颂齐声高唱，天保颂齐高唱。",
      "text_length": 23
    },
    {
      "event_id": "02001004_e00022",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八如意同下。八如意、天福星、天禄星、天寿星、天财星、天喜星同上。",
      "text_length": 32
    },
    {
      "event_id": "02001004_e00023",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同收江南",
      "speakers": [
        "八如意",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星"
      ],
      "text": "路迢迢皇域地脉长，喜盈盈赐福群星降。步冉冉六珠云外飘香，戈铮铮九奏风中响。",
      "text_length": 37
    },
    {
      "event_id": "02001004_e00024",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八如意同排后，天福星、天禄星、天寿星、天财星、天喜星同排前。",
      "text_length": 30
    },
    {
      "event_id": "02001004_e00025",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天福星"
      ],
      "text": "吾乃天福星君是也。",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00026",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天禄星"
      ],
      "text": "吾乃天禄星君是也。",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00027",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天寿星"
      ],
      "text": "吾乃天寿星君是也。",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00028",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天财星"
      ],
      "text": "吾乃天财星君是也。",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00029",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天喜星"
      ],
      "text": "吾乃天喜星君是也。",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00030",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星"
      ],
      "text": "奉玉帝敕旨前往福地。赐宝降祥。你我一同前往。",
      "text_length": 22
    },
    {
      "event_id": "02001004_e00031",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同收江南",
      "speakers": [
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星"
      ],
      "text": "遥望着金屋恁辉煌，玉珮夜叮当。细微的端霭浮青琐，氤氲的祥烟绕碧幢洋洋。",
      "text_length": 35
    },
    {
      "event_id": "02001004_e00032",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "天官、地官、水官、四仙官同上，众人合一处。",
      "text_length": 21
    },
    {
      "event_id": "02001004_e00033",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同川拨禅",
      "speakers": [
        "天官",
        "地官",
        "水官",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "分道移仙杖，忙忙祝华筵献寿章，忙祝华筵献寿章。",
      "text_length": 23
    },
    {
      "event_id": "02001004_e00034",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "八如意",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星"
      ],
      "text": "请问三位大帝何往？",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00035",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "今有善门福地，荫功浩大，德行无边，我等奉玉帝敕旨前往赐宝降祥。列位大仙何往？",
      "text_length": 38
    },
    {
      "event_id": "02001004_e00036",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "八如意",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星"
      ],
      "text": "我等也为此事而来。",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00037",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "如此一同前往。",
      "text_length": 7
    },
    {
      "event_id": "02001004_e00038",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同挂玉钩",
      "speakers": [
        "天官",
        "地官",
        "水官",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "蔺殿逍遥添寿长，日月光天壤。重润重辉普乐章，揆得金声响。鹤禁中龙楼旁，叠沐天庥，庆贺吉祥，庆贺吉祥。",
      "text_length": 50
    },
    {
      "event_id": "02001004_e00039",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四仙官"
      ],
      "text": "已到福地。",
      "text_length": 5
    },
    {
      "event_id": "02001004_e00040",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "妙哇。但见炉烟结彩，瑞霭缤纷，时逢美景，欣遇良辰。正是：",
      "text_length": 28
    },
    {
      "event_id": "02001004_e00041",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "地灵产瑞草，",
      "text_length": 6
    },
    {
      "event_id": "02001004_e00042",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "天官",
        "地官",
        "水官",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "天相吉人家。",
      "text_length": 6
    },
    {
      "event_id": "02001004_e00043",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同挂玉钩",
      "speakers": [
        "天官",
        "地官",
        "水官",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "早则见善门福地喜非常，听声声仙乐奏铿锵。看纷纷霓珮影飘扬，更重重灿光。共把这吉言称颂献诗章，吉言称颂献诗章。",
      "text_length": 54
    },
    {
      "event_id": "02001004_e00044",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "众位大仙各将吉言献上。",
      "text_length": 11
    },
    {
      "event_id": "02001004_e00045",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "八如意"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001004_e00046",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天福星"
      ],
      "text": "福堂霭霭瑞云生，",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00047",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天禄星"
      ],
      "text": "禄坐千钟享万灵。",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00048",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天寿星"
      ],
      "text": "寿同山岳添筹算，",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00049",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天财星"
      ],
      "text": "财源广聚库填盈。",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00050",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天喜星"
      ],
      "text": "喜从天降重重至，",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00051",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "八如意"
      ],
      "text": "八节康宁事事成。",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00052",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "兰孙桂子多荣耀，",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00053",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "天官",
        "地官",
        "水官",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "满门欢乐贺升平。",
      "text_length": 8
    },
    {
      "event_id": "02001004_e00054",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "同梅花酒",
      "speakers": [
        "天官",
        "地官",
        "水官",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "献蟠桃，帝露扬，见宝炬辉煌，紫气腾祥，瑞霭摇漾，韵悠悠按工商。歌喉转绕画梁，众真捧霞觞。歌喉转，鉴微忱进琼浆，鸾鹤来，任翱翔，乐雍熙，德汪洋。看从今降祯祥，看从今降祯祥。",
      "text_length": 85
    },
    {
      "event_id": "02001004_e00055",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天官",
        "地官",
        "水官",
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "庆贺已毕。",
      "text_length": 5
    },
    {
      "event_id": "02001004_e00056",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天官",
        "地官",
        "水官"
      ],
      "text": "列为大仙各归洞府。",
      "text_length": 9
    },
    {
      "event_id": "02001004_e00057",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001004_e00058",
      "play_id": "02001004",
      "scene_id": "02001004_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "同清江引",
      "speakers": [
        "天福星",
        "天禄星",
        "天寿星",
        "天财星",
        "天喜星",
        "八如意",
        "四仙官"
      ],
      "text": "赏心乐事如天上，德泽千秋旷。紫气自东来，南极西池望。指日里，下纶音恩沛广，下纶音恩沛广。",
      "text_length": 44
    },
