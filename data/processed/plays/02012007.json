  "events": [
    {
      "event_id": "02012007_e00001",
      "play_id": "02012007",
      "scene_id": "02012007_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "走场人上，唱〖唢呐〗，宾白，下。杨香武上。",
      "text_length": 21
    },
    {
      "event_id": "02012007_e00002",
      "play_id": "02012007",
      "scene_id": "02012007_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "寄生草",
      "speakers": [
        "杨香武"
      ],
      "text": "杨香武英名大，论盗寇手段强。收心不再绿林巷，弃邪归正度时光。",
      "text_length": 30
    },
    {
      "event_id": "02012007_e00003",
      "play_id": "02012007",
      "scene_id": "02012007_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杨香武"
      ],
      "text": "只因一时不忿，今朝树倒掀根。恼恨武成把俺训，夸奖三泰人俊。今夜要显手段，偷盗玉杯解恨。从此振动满乾坤，才知英雄一人。",
      "text_length": 58
    },
    {
      "event_id": "02012007_e00004",
      "play_id": "02012007",
      "scene_id": "02012007_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨香武"
      ],
      "text": "俺，杨香武。只因飞天豹口内之言，俺心中不服，因此带了随身之物，来盗九龙玉杯。看天已挂午，难以下去。等到夜静之时，待俺施展走壁之能，暗进王府，盗取玉杯便了。",
      "text_length": 77
    },
    {
      "event_id": "02012007_e00005",
      "play_id": "02012007",
      "scene_id": "02012007_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "寄生草",
      "speakers": [
        "杨香武"
      ],
      "text": "构檐走壁越过墙，寻暗处把身藏，不知玉杯在何处放。",
      "text_length": 24
    },
    {
      "event_id": "02012007_e00006",
      "play_id": "02012007",
      "scene_id": "02012007_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨香武下。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00007",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、四宫女、老王爷、老王妃同上。",
      "text_length": 18
    },
    {
      "event_id": "02012007_e00008",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "老王爷"
      ],
      "text": "腰悬玉带体龙衣，深感洪福恩重。",
      "text_length": 15
    },
    {
      "event_id": "02012007_e00009",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老王爷"
      ],
      "text": "春寿华堂春寿老，寿与天齐百寿高。",
      "text_length": 16
    },
    {
      "event_id": "02012007_e00010",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老王妃"
      ],
      "text": "福如东海福山茂，福寿绵长福寿滔。",
      "text_length": 16
    },
    {
      "event_id": "02012007_e00011",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "今当孤千秋华诞，方才阖家叩拜家庙，因此准备家筵，大家欢饮。https://scripts.xikao.com/play/020120072020-11-13",
      "text_length": 78
    },
    {
      "event_id": "02012007_e00012",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王妃"
      ],
      "text": "正当如此。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00013",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "看酒。",
      "text_length": 3
    },
    {
      "event_id": "02012007_e00014",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "甘州歌",
      "speakers": [
        "老王爷"
      ],
      "text": "寿与天齐，献美酒，痛饮设列筵席。吹唱欢歌，高堂悬挂彩衣。看炉烟绕，直冲天际，恰比那氤氲升仙。",
      "text_length": 46
    },
    {
      "event_id": "02012007_e00015",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武成上。",
      "text_length": 4
    },
    {
      "event_id": "02012007_e00016",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武成"
      ],
      "text": "启爷：外面有四家王爷，前来庆寿。",
      "text_length": 16
    },
    {
      "event_id": "02012007_e00017",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "你们退了，待我出迎。",
      "text_length": 10
    },
    {
      "event_id": "02012007_e00018",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小太监引四王爷同上。",
      "text_length": 11
    },
    {
      "event_id": "02012007_e00019",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "四王爷"
      ],
      "text": "皇王遵旨来拜王颜。",
      "text_length": 9
    },
    {
      "event_id": "02012007_e00020",
      "play_id": "02012007",
      "scene_id": "02012007_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00021",
      "play_id": "02012007",
      "scene_id": "02012007_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨香武上。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00022",
      "play_id": "02012007",
      "scene_id": "02012007_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "杨香武"
      ],
      "text": "乱乱烘烘罕，祝寿人儿非凡。见轿马车辆，堆积府前，好比蓬莱群仙宴。不能盗杯急燥倃。",
      "text_length": 40
    },
    {
      "event_id": "02012007_e00023",
      "play_id": "02012007",
      "scene_id": "02012007_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨香武下。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00024",
      "play_id": "02012007",
      "scene_id": "02012007_s04",
      "scene_no": 4,
      "seq_global": 24,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四官员同上。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00025",
      "play_id": "02012007",
      "scene_id": "02012007_s04",
      "scene_no": 4,
      "seq_global": 25,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "四官员"
      ],
      "text": "皇王遵圣旨，来拜王颜。",
      "text_length": 11
    },
    {
      "event_id": "02012007_e00026",
      "play_id": "02012007",
      "scene_id": "02012007_s04",
      "scene_no": 4,
      "seq_global": 26,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四官员同下。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00027",
      "play_id": "02012007",
      "scene_id": "02012007_s05",
      "scene_no": 5,
      "seq_global": 27,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨香武上。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00028",
      "play_id": "02012007",
      "scene_id": "02012007_s05",
      "scene_no": 5,
      "seq_global": 28,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨香武"
      ],
      "text": "哎呀，你看这府前府后，乱乱烘烘，不能施展手段，如何是好？",
      "text_length": 28
    },
    {
      "event_id": "02012007_e00029",
      "play_id": "02012007",
      "scene_id": "02012007_s05",
      "scene_no": 5,
      "seq_global": 29,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "杨香武"
      ],
      "text": "心急燥哀告上天，不成功枉活人间。王府威威紧密严难下手，到厅前越过墙垣院，悄悄低声把身安。",
      "text_length": 44
    },
    {
      "event_id": "02012007_e00030",
      "play_id": "02012007",
      "scene_id": "02012007_s05",
      "scene_no": 5,
      "seq_global": 30,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨香武下。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00031",
      "play_id": "02012007",
      "scene_id": "02012007_s06",
      "scene_no": 6,
      "seq_global": 31,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四官员同上。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00032",
      "play_id": "02012007",
      "scene_id": "02012007_s06",
      "scene_no": 6,
      "seq_global": 32,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "四官员"
      ],
      "text": "皇王宣，各备寿仪，特来呈参。",
      "text_length": 14
    },
    {
      "event_id": "02012007_e00033",
      "play_id": "02012007",
      "scene_id": "02012007_s06",
      "scene_no": 6,
      "seq_global": 33,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四官员同下。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00034",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 34,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监引老王爷同上。大太监上。",
      "text_length": 15
    },
    {
      "event_id": "02012007_e00035",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 35,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "众位先生，今乃老千岁寿诞，奉旨前来拜寿，你等可曾拜过咧？",
      "text_length": 28
    },
    {
      "event_id": "02012007_e00036",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 36,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四官员"
      ],
      "text": "我们恭候公公到来，一同拜寿。",
      "text_length": 14
    },
    {
      "event_id": "02012007_e00037",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 37,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "哎呀，这还等着我一同拜寿，拜过了大家吃杯寿酒。https://scripts.xikao.com/play/020120072020-11-13",
      "text_length": 72
    },
    {
      "event_id": "02012007_e00038",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 38,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "有劳众公侯到来，又赠厚礼，焉敢受拜。",
      "text_length": 18
    },
    {
      "event_id": "02012007_e00039",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 39,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四官员"
      ],
      "text": "理当拜的。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00040",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 40,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "实实不敢当。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00041",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 41,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "哎呀，众位大人，倃们磕头，老千岁又不受，难道你我白来不成？咱们倒有一番主意，请千岁就将圣上恩赐的四件东西，摆在上面，我们大家叩拜叩拜，犹如叩拜了王驾一般。",
      "text_length": 77
    },
    {
      "event_id": "02012007_e00042",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 42,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四官员"
      ],
      "text": "有理。",
      "text_length": 3
    },
    {
      "event_id": "02012007_e00043",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 43,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四官员同声各坐。",
      "text_length": 8
    },
    {
      "event_id": "02012007_e00044",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 44,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "四官员"
      ],
      "text": "皇王宣，各备寿仪，特来呈参。",
      "text_length": 14
    },
    {
      "event_id": "02012007_e00045",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 45,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "问问老千岁，今日不是有戏么，叫他们预备预备，倃们也听听。",
      "text_length": 28
    },
    {
      "event_id": "02012007_e00046",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 46,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四官员同宾白，同唱合前。",
      "text_length": 12
    },
    {
      "event_id": "02012007_e00047",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 47,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "我的人呢，将那九龙杯取来，咱家看看。",
      "text_length": 18
    },
    {
      "event_id": "02012007_e00048",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 48,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监取。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00049",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 49,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "众位大人，你们来瞧瞧。这宗九龙玉杯，是当初日南交趾国进与当今万岁的，有许多的好处哩。咱们把寿酒斟在里头，大家喝他点儿，哎呀，多活十年。哈哈，你们再看看，圣上赐的一轴图画，那是老王爷常常御览的，你们瞧瞧就知道了。来，挂起它来。",
      "text_length": 112
    },
    {
      "event_id": "02012007_e00050",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 50,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四官员同应。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00051",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 51,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四官员"
      ],
      "text": "真正画得好！",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00052",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 52,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "四官员"
      ],
      "text": "眼似水铃鬃似针，尾长毛细都似真。配就山水多清雅，蹄跳咆哮似活龙。",
      "text_length": 32
    },
    {
      "event_id": "02012007_e00053",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 53,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "你赞的尽是骠满肥壮的马，咱家不喜，咱很爱这匹瘦小的马，倒有个看头儿。",
      "text_length": 34
    },
    {
      "event_id": "02012007_e00054",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 54,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四官员"
      ],
      "text": "公公那匹马骨瘦如柴，要它何用？",
      "text_length": 15
    },
    {
      "event_id": "02012007_e00055",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 55,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "咱家当先也爱的是骠满的劣马，鞍鞯备好，乘跨起来，我就跑了马了么。",
      "text_length": 32
    },
    {
      "event_id": "02012007_e00056",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 56,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四官员"
      ],
      "text": "公公爱跑马。如今呢？",
      "text_length": 10
    },
    {
      "event_id": "02012007_e00057",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 57,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "如今有了年纪，所以这瘦马好，咱不能跑马，尽剩了收马咧。",
      "text_length": 27
    },
    {
      "event_id": "02012007_e00058",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 58,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "expression",
      "mode_label": "同笑",
      "speakers": [
        "四官员"
      ],
      "text": "哈哈！",
      "text_length": 3
    },
    {
      "event_id": "02012007_e00059",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 59,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨香武暗上，偷杯，下。",
      "text_length": 11
    },
    {
      "event_id": "02012007_e00060",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 60,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "天也是时候了。大家敬老千岁一玉杯寿酒，也好散席。来，快取九龙杯来。",
      "text_length": 33
    },
    {
      "event_id": "02012007_e00061",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 61,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监甲"
      ],
      "text": "启爷：九龙杯不见了。",
      "text_length": 10
    },
    {
      "event_id": "02012007_e00062",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 62,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "方才还在桌案上放著，怎生便不见了，好生奇怪？",
      "text_length": 22
    },
    {
      "event_id": "02012007_e00063",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 63,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "老王爷"
      ],
      "text": "九龙杯因何不见，奇巧事令人憾然。失杯怎去见天颜，玉杯失去非等闲。",
      "text_length": 32
    },
    {
      "event_id": "02012007_e00064",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 64,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "老千岁不必着紧，桌儿上桌儿以下，叫人细细找找罢。",
      "text_length": 24
    },
    {
      "event_id": "02012007_e00065",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 65,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监同找。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00066",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 66,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四太监"
      ],
      "text": "寻找不着。",
      "text_length": 5
    },
    {
      "event_id": "02012007_e00067",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 67,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "唗！我想这王府是禁地，难道有外人前来，再无此事。此府内外上下人等，不敢擅偷此杯。",
      "text_length": 40
    },
    {
      "event_id": "02012007_e00068",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 68,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "大太监"
      ],
      "text": "此事蹊跷难分辨，哪有外人到此间。",
      "text_length": 16
    },
    {
      "event_id": "02012007_e00069",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 69,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "咱家倒想起来了，这件事总在老千岁身上所起。",
      "text_length": 21
    },
    {
      "event_id": "02012007_e00070",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 70,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四官员"
      ],
      "text": "怎见得？",
      "text_length": 4
    },
    {
      "event_id": "02012007_e00071",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 71,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "你们不知道：前者老千岁在驾前奏道，洪海擒虎，是什么黄三泰，口称他是绿林中的大盗。他既然是贼，应当将他拿住正法。倒赏了他件黄褂，这是自招其祸，定是作贼人贪心无厌，又来盗取玉杯。千岁爷，这是因行善事招出祸来了。",
      "text_length": 103
    },
    {
      "event_id": "02012007_e00072",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 72,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "圣上闻知失落此杯，那时怎生得了？",
      "text_length": 16
    },
    {
      "event_id": "02012007_e00073",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 73,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "但请放心，咱去奏明圣上，管保千岁无事。也不过奉旨到江南边，什么绍兴地方，把黄三泰拿进京来，这九龙杯就望他要定了。",
      "text_length": 56
    },
    {
      "event_id": "02012007_e00074",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 74,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "倘若不是他呢？",
      "text_length": 7
    },
    {
      "event_id": "02012007_e00075",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 75,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "我的老千岁爷，是他也得问他要，不是他也得问他要定了。不怕他不献出此杯https://scripts.xikao.com/play/020120072020-11-13来。",
      "text_length": 85
    },
    {
      "event_id": "02012007_e00076",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 76,
      "seq_in_scene": 43,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "此事全仗公公。",
      "text_length": 7
    },
    {
      "event_id": "02012007_e00077",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 77,
      "seq_in_scene": 44,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "老千岁！",
      "text_length": 4
    },
    {
      "event_id": "02012007_e00078",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 78,
      "seq_in_scene": 45,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "大太监"
      ],
      "text": "我怎怠慢，明日五鼓面奏天颜。",
      "text_length": 14
    },
    {
      "event_id": "02012007_e00079",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 79,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监、四官员同下。",
      "text_length": 10
    },
    {
      "event_id": "02012007_e00080",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 80,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老王爷"
      ],
      "text": "武成过来，你如今外面密密访查，但有九龙杯的踪迹，急急前来禀我知道。",
      "text_length": 33
    },
    {
      "event_id": "02012007_e00081",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 81,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武成应，下。",
      "text_length": 6
    },
    {
      "event_id": "02012007_e00082",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 82,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老王爷"
      ],
      "text": "慈心放虎去，反被虎伤人。",
      "text_length": 12
    },
    {
      "event_id": "02012007_e00083",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 83,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老王爷下。杨香武上。",
      "text_length": 10
    },
    {
      "event_id": "02012007_e00084",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 84,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "杨香武"
      ],
      "text": "哈哈哈！",
      "text_length": 4
    },
    {
      "event_id": "02012007_e00085",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 85,
      "seq_in_scene": 52,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨香武"
      ],
      "text": "妙吓，且喜九龙杯已到吾手，不免急到武成家中。单叫飞天豹，见见此物，方显俺杨香武的手段。",
      "text_length": 43
    },
    {
      "event_id": "02012007_e00086",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 86,
      "seq_in_scene": 53,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "杨香武"
      ],
      "text": "双手破开生死路，一身跳出是非门，俺也算绿林之中头，头一人。",
      "text_length": 29
    },
    {
      "event_id": "02012007_e00087",
      "play_id": "02012007",
      "scene_id": "02012007_s07",
      "scene_no": 7,
      "seq_global": 87,
      "seq_in_scene": 54,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨香武下。https://scripts.xikao.com/play/020120072020-11-13",
      "text_length": 54
    }
  ],
