  "events": [
    {
      "event_id": "02012011_e00001",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小太监引梁九公同上。",
      "text_length": 11
    },
    {
      "event_id": "02012011_e00002",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "梁九公"
      ],
      "text": "龙恩宠爱待至尊，总理内宫第一人。",
      "text_length": 16
    },
    {
      "event_id": "02012011_e00003",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "咱家六院三宫总理梁九公便是。每日早朝传进皇本奏事，须得咱家。龙恩宠爱，说一不二。今当早朝，只得在此伺候。",
      "text_length": 52
    },
    {
      "event_id": "02012011_e00004",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监引庆花王同上。",
      "text_length": 10
    },
    {
      "event_id": "02012011_e00005",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "出对子",
      "speakers": [
        "庆花王"
      ],
      "text": "身子随朝，皇王有道，乐乐遥遥。每日待漏五更晓，参拜君王，三五道。品级山前，忙忙拜倒。",
      "text_length": 42
    },
    {
      "event_id": "02012011_e00006",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "庆花老王爷临朝特早。",
      "text_length": 10
    },
    {
      "event_id": "02012011_e00007",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庆花王"
      ],
      "text": "今日有本启奏圣上。",
      "text_length": 9
    },
    {
      "event_id": "02012011_e00008",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "有何本奏？",
      "text_length": 5
    },
    {
      "event_id": "02012011_e00009",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庆花王"
      ],
      "text": "公公有所不知：只因我府有一壮丁，他在通州住家。昨天来府说到，通州知州彭朋拿住响马黄三泰，要往京中送部。我想那些响马甚多，惟恐一路有些疎虞，反为不美。因此奏明圣上，不如遣官往通州，前去严审方为上策。",
      "text_length": 98
    },
    {
      "event_id": "02012011_e00010",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "哎呀，哎呀，黄三泰拿住了很好，很好。老王爷方才的言词，到与咱家的心中一样，这如今老主爷不曾升殿，老王爷将本交与咱家，待等圣上登殿，咱家替王爷奏明，保管准依著老千岁行事，好不好？",
      "text_length": 88
    },
    {
      "event_id": "02012011_e00011",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庆花王"
      ],
      "text": "全仗公公。https://scripts.xikao.com/play/020120112020-11-20",
      "text_length": 54
    },
    {
      "event_id": "02012011_e00012",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "庆花王"
      ],
      "text": "莫把此事当等闲，",
      "text_length": 8
    },
    {
      "event_id": "02012011_e00013",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "梁九公"
      ],
      "text": "咱家少时奏天颜。",
      "text_length": 8
    },
    {
      "event_id": "02012011_e00014",
      "play_id": "02012011",
      "scene_id": "02012011_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "02012011_e00015",
      "play_id": "02012011",
      "scene_id": "02012011_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老道上。",
      "text_length": 4
    },
    {
      "event_id": "02012011_e00016",
      "play_id": "02012011",
      "scene_id": "02012011_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老道"
      ],
      "text": "初一十五开庙门，打扫干净要殷勤。方才官人来送信，准备钦差到此临。",
      "text_length": 32
    },
    {
      "event_id": "02012011_e00017",
      "play_id": "02012011",
      "scene_id": "02012011_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "咱家东岳庙的老道便是。方才有官人前来送信，说有三位钦差，奉旨往通州审事，就从此地起身。只得在此伺候。",
      "text_length": 50
    },
    {
      "event_id": "02012011_e00018",
      "play_id": "02012011",
      "scene_id": "02012011_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老道下。",
      "text_length": 4
    },
    {
      "event_id": "02012011_e00019",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 19,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八卒将、四军牢、四校尉、黄国瑞、赵兴本同上。",
      "text_length": 22
    },
    {
      "event_id": "02012011_e00020",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 20,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同六么令",
      "speakers": [
        "黄国瑞",
        "赵兴本"
      ],
      "text": "奉王勅诏，前到通州，去问强盗，军兵校尉离皇朝。",
      "text_length": 23
    },
    {
      "event_id": "02012011_e00021",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵兴本"
      ],
      "text": "大人请了。",
      "text_length": 5
    },
    {
      "event_id": "02012011_e00022",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄国瑞"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "02012011_e00023",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵兴本"
      ],
      "text": "你我奉圣旨往通州审问贼寇，待等张大人到来，起程便了。",
      "text_length": 26
    },
    {
      "event_id": "02012011_e00024",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄三泰"
      ],
      "text": "有理。",
      "text_length": 3
    },
    {
      "event_id": "02012011_e00025",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四校尉、四将官引张朋阁同上。",
      "text_length": 14
    },
    {
      "event_id": "02012011_e00026",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "六么令",
      "speakers": [
        "张朋阁"
      ],
      "text": "拷问强盗在今朝，审明此事，奏皇朝。",
      "text_length": 17
    },
    {
      "event_id": "02012011_e00027",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张朋阁"
      ],
      "text": "二位大人先到了。",
      "text_length": 8
    },
    {
      "event_id": "02012011_e00028",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "黄国瑞",
        "赵兴本"
      ],
      "text": "我二人恭候大人到来，一同候至起程。",
      "text_length": 17
    },
    {
      "event_id": "02012011_e00029",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "梁九公"
      ],
      "text": "旨意下。",
      "text_length": 4
    },
    {
      "event_id": "02012011_e00030",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "手下"
      ],
      "text": "启爷：旨意下。",
      "text_length": 7
    },
    {
      "event_id": "02012011_e00031",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张朋阁",
        "黄国瑞",
        "赵兴本"
      ],
      "text": "我等出迎。",
      "text_length": 5
    },
    {
      "event_id": "02012011_e00032",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "梁九公上。",
      "text_length": 5
    },
    {
      "event_id": "02012011_e00033",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "所奏皇上，圣旨晓谕三法司，圣旨已到，跪所宣读诏曰。",
      "text_length": 25
    },
    {
      "event_id": "02012011_e00034",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张朋阁",
        "黄国瑞",
        "赵兴本"
      ],
      "text": "万岁！",
      "text_length": 3
    },
    {
      "event_id": "02012011_e00035",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "今有刑部正堂黄国瑞奏到，说通州知州彭朋拿住响马黄三泰，本当解进京都，有恐路有疎虞，朕钦命大理司张朋阁、都察院赵兴本、刑部正堂王国瑞，前去严审黄三泰，外命总理内宫梁九公监管。朕想黄三泰乃强盗，必须非刑严问，追还九龙杯。钦遵望诏谢恩。",
      "text_length": 115
    },
    {
      "event_id": "02012011_e00036",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张朋阁",
        "黄国瑞",
        "赵兴本"
      ],
      "text": "万岁！有劳公公，奉旨而来，多多劳乏。",
      "text_length": 18
    },
    {
      "event_id": "02012011_e00037",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "为国当然，怎道“劳乏”二字？",
      "text_length": 14
    },
    {
      "event_id": "02012011_e00038",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张朋阁",
        "黄国瑞",
        "赵兴本"
      ],
      "text": "圣上命公公一同前去审问黄三泰。若有不到之处，须望公公指点一二。",
      "text_length": 31
    },
    {
      "event_id": "02012011_e00039",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "三位老先生说哪里话来，你等尽是随龙伴驾之臣，想这样之事办的很多了。添上咱家，倒是搅屎的棍子咧。到了那里，我就只是听喝。https://scripts.xikao.com/play/020120112020-11-20",
      "text_length": 108
    },
    {
      "event_id": "02012011_e00040",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张朋阁",
        "黄国瑞",
        "赵兴本"
      ],
      "text": "公公取笑了。",
      "text_length": 6
    },
    {
      "event_id": "02012011_e00041",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "梁九公"
      ],
      "text": "依我说，天不早了，大家起程罢。",
      "text_length": 15
    },
    {
      "event_id": "02012011_e00042",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张朋阁",
        "黄国瑞",
        "赵兴本"
      ],
      "text": "公公言之有理。中军。",
      "text_length": 10
    },
    {
      "event_id": "02012011_e00043",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02012011_e00044",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张朋阁",
        "黄国瑞",
        "赵兴本"
      ],
      "text": "带马直往通州大路去者。",
      "text_length": 11
    },
    {
      "event_id": "02012011_e00045",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "直往通州大路去者。",
      "text_length": 9
    },
    {
      "event_id": "02012011_e00046",
      "play_id": "02012011",
      "scene_id": "02012011_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同五马江儿水",
      "speakers": [
        "八卒将",
        "四军牢",
        "八校尉",
