      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许褚"
      ],
      "text": "事到如今，谢什么天地？",
      "text_length": 11
    },
    {
      "event_id": "01002013_e00025",
      "play_id": "01002013",
      "scene_id": "01002013_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
