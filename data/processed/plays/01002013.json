      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许褚看。",
      "text_length": 4
    },
    {
      "event_id": "01002013_e00022",
      "play_id": "01002013",
      "scene_id": "01002013_s01",
      "scene_no": 1,
      "seq_global": 22,
