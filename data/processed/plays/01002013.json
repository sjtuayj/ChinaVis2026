      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许褚"
      ],
      "text": "那是“关”字旗号。",
      "text_length": 9
    },
    {
      "event_id": "01002013_e00023",
      "play_id": "01002013",
      "scene_id": "01002013_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "待我谢天谢地！",
      "text_length": 7
    },
    {
      "event_id": "01002013_e00024",
      "play_id": "01002013",
      "scene_id": "01002013_s01",
      "scene_no": 1,
      "seq_global": 24,
