        "张果老"
      ],
      "text": "圣母在上，我等拜寿。",
      "text_length": 10
    },
    {
      "event_id": "90000002_e00015",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 15,
