      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "吕洞宾",
        "张果老"
      ],
      "text": "画堂今日寿筵开，",
      "text_length": 8
    },
    {
      "event_id": "90000002_e00018",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "圣母"
      ],
      "text": "相邀众仙到此来。",
      "text_length": 8
    },
    {
      "event_id": "90000002_e00019",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "吕洞宾",
        "张果老"
      ],
      "text": "殷勤祝寿瑶池界，",
      "text_length": 8
    },
    {
      "event_id": "90000002_e00020",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "圣母"
      ],
      "text": "共祝长生赴瑶台。",
      "text_length": 8
    },
    {
      "event_id": "90000002_e00021",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "吕洞宾",
        "张果老"
      ],
      "text": "圣寿无疆！",
      "text_length": 5
    },
    {
      "event_id": "90000002_e00022",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "开筵，待我把盏。",
      "text_length": 8
    },
    {
      "event_id": "90000002_e00023",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "吕洞宾",
        "张果老"
      ],
      "text": "摆下就是。",
      "text_length": 5
    },
    {
      "event_id": "90000002_e00024",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。",
      "text_length": 5
    },
    {
      "event_id": "90000002_e00025",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "众位大仙，仙子请！",
      "text_length": 9
    },
    {
      "event_id": "90000002_e00026",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "吕洞宾",
        "张果老"
      ],
      "text": "圣母请！",
      "text_length": 4
    },
    {
      "event_id": "90000002_e00027",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。麻姑上。",
      "text_length": 9
    },
    {
      "event_id": "90000002_e00028",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "麻姑"
      ],
      "text": "手捧佳酿瑶池献，整来彩衣拜金阶。",
      "text_length": 16
    },
    {
      "event_id": "90000002_e00029",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "麻姑"
      ],
      "text": "圣母在上，小仙麻姑拜寿。",
      "text_length": 12
    },
    {
      "event_id": "90000002_e00030",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "麻姑仙子平身。",
      "text_length": 7
    },
    {
      "event_id": "90000002_e00031",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "麻姑"
      ],
      "text": "圣寿无疆！",
      "text_length": 5
    },
    {
      "event_id": "90000002_e00032",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "手捧何物？",
      "text_length": 5
    },
    {
      "event_id": "90000002_e00033",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "麻姑"
      ],
      "text": "小仙特制的圣寿长生不老酒。",
      "text_length": 13
    },
    {
      "event_id": "90000002_e00034",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "何谓圣寿长生不老酒？",
      "text_length": 10
    },
    {
      "event_id": "90000002_e00035",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "麻姑"
      ],
      "text": "此酒本是鲜花炼，灵芝仙草精益鲜。凡人若得饮此酒，可得长生永绵绵。",
      "text_length": 32
    },
    {
      "event_id": "90000002_e00036",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "如此身受你一杯。",
      "text_length": 8
    },
    {
      "event_id": "90000002_e00037",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李铁拐"
      ],
      "text": "啊圣母，麻姑仙子之长生不老酒，可能给我等饮一杯否？",
      "text_length": 25
    },
    {
      "event_id": "90000002_e00038",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "那是理当奉敬，今日众仙驾临，乃是仙池之大幸也，现今园内蟠桃也熟，各敬一枚，以为结缘之品。侍女们，将蟠桃各敬一枚。麻姑仙子，命你在众仙面前执壶敬酒一杯。",
      "text_length": 75
    },
    {
      "event_id": "90000002_e00039",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "麻姑"
      ],
      "text": "遵法旨。",
      "text_length": 4
    },
    {
      "event_id": "90000002_e00040",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "麻姑"
      ],
      "text": "瑶池奉了圣母命，回身取过酒一樽。进前忙把仙姑敬，金壶玉液仔细斟。饮一杯来增福命，饮一杯来延寿龄。愿祝仙师万年庆，愿祝仙子比那南极天星。霎时琼浆都倾尽，愿年年如此日不老长生。",
      "text_length": 86
    },
    {
      "event_id": "90000002_e00041",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "众位大仙，这里有编戏上寿词一首，请麻姑仙子跳舞一番如何？",
      "text_length": 28
    },
    {
      "event_id": "90000002_e00042",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "张果老"
      ],
      "text": "好，我等幸会。",
      "text_length": 7
    },
    {
      "event_id": "90000002_e00043",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "麻姑"
      ],
      "text": "小仙当得奉命。",
      "text_length": 7
    },
    {
      "event_id": "90000002_e00044",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "山花子",
      "speakers": [
        "麻姑"
      ],
      "text": "寿筵开处风光好，争看寿星荣耀。羡麻姑玉女并超，寿同王母年高。寿香腾寿烛影高，玉杯寿酒增寿考。今盘寿果长寿桃，愿福如东海得寿比南山。",
      "text_length": 65
    },
    {
      "event_id": "90000002_e00045",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "大和佛",
      "speakers": [
        "麻姑"
      ],
      "text": "青鹿御芝呈瑞草，齐祝愿寿弥高。画堂寿日多喧闹，寿基巩固寿坚牢。京寿绵绵乐寿滔滔，展寿席人人欢笑。齐庆寿诞中祝寿间妙。",
      "text_length": 58
    },
    {
      "event_id": "90000002_e00046",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "红绣鞋",
      "speakers": [
        "麻姑"
      ],
      "text": "寿炉宝篆香消香消，寿桃结子堪描堪描。斟寿酒寿杯交，歌寿曲寿多娇。齐祝寿比南山高。",
      "text_length": 40
    },
    {
      "event_id": "90000002_e00047",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "麻姑"
      ],
      "text": "长生寿域宏开了，寿烛辉煌彻夜烧。",
      "text_length": 16
    },
    {
      "event_id": "90000002_e00048",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "圣母"
      ],
      "text": "众仙如此殷勤，乃我神之幸也，你等随我往凌宵宝殿谢恩去者。",
      "text_length": 28
    },
    {
      "event_id": "90000002_e00049",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "吕洞宾",
        "张果老"
      ],
      "text": "遵法旨。",
      "text_length": 4
    },
    {
      "event_id": "90000002_e00050",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "同合头",
      "speakers": [
        "圣母",
        "何仙姑",
        "韩湘子",
        "曹国舅",
        "蓝采和",
        "汉钟离",
        "李铁拐",
        "吕洞宾",
        "张果老"
      ],
      "text": "愿岁岁年年增寿考。",
      "text_length": 9
    },
    {
      "event_id": "90000002_e00051",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}