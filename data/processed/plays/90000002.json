      "speakers": [
        "圣母"
      ],
      "text": "众位大仙不用拜了。",
      "text_length": 9
    },
    {
      "event_id": "90000002_e00016",
      "play_id": "90000002",
      "scene_id": "90000002_s01",
      "scene_no": 1,
      "seq_global": 16,
