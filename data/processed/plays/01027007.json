  "events": [
    {
      "event_id": "01027007_e00001",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云童引牡丹同上。",
      "text_length": 9
    },
    {
      "event_id": "01027007_e00002",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "牡丹"
      ],
      "text": "晨看泉水淹蝼蚁，夜护纱灯救飞娥。",
      "text_length": 16
    },
    {
      "event_id": "01027007_e00003",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "牡丹"
      ],
      "text": "奴本家住在崂山，师父妙法得真传。洞中每日来修炼，炼就武艺十八般。",
      "text_length": 32
    },
    {
      "event_id": "01027007_e00004",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "奴家牡丹是也。生长在崂山，曾在天香洞中修炼多年。师父黄龙，传授奴十八般武艺，倒也是逍遥自在。今日师父去到昆仑山，赴龙华大会，曾对奴言讲，早晚定得纯阳。奴不免打扮整齐，就此等候机缘。",
      "text_length": 90
    },
    {
      "event_id": "01027007_e00005",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "柳摇金牌。牡丹换衣。",
      "text_length": 10
    },
    {
      "event_id": "01027007_e00006",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "尔等两厢退下。",
      "text_length": 7
    },
    {
      "event_id": "01027007_e00007",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云童同下。",
      "text_length": 6
    },
    {
      "event_id": "01027007_e00008",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "牡丹"
      ],
      "text": "山妖水怪各有形，草魅花精岂无情。阴阳难合分男女，各有因缘自不同。",
      "text_length": 32
    },
    {
      "event_id": "01027007_e00009",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "牡丹"
      ],
      "text": "自幼儿发现在崂山前，受天地秉正气生在了世间。白日里经风日夜受霜露，受山川精灵气成了地仙。我师父叫黄龙道法高显，他教奴各妙法件件周全。每日里在洞中虔心修炼，说因果证菩提悟道参禅。在先前学的是把人形变幻，到后来学的是拘鬼请仙。白日里习练那腾云驾雾，黑夜里习练的倒海翻山。遣六丁和六甲神机妙算，但只是无纯阳不能升天。奴师父临行时曾对我讲，他言道这日内必有机缘。奴这里出洞来用目观看，又只见山峰秀一带相连。有松柏合绿竹连接不断，有绿水曲弯弯团绕山前。各样的花草十分鲜艳，深林内不住的百鸟声喧。在洞外不住的闲游观看，但不知有何人来到此间。",
      "text_length": 264
    },
    {
      "event_id": "01027007_e00010",
      "play_id": "01027007",
      "scene_id": "01027007_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "牡丹走浪头，下。",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00011",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 11,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "离却了蓬莱岛驾云前进，",
      "text_length": 11
    },
    {
      "event_id": "01027007_e00012",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 12,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云童同上，由桌子同下。吕洞宾上，站桌子上。",
      "text_length": 22
    },
    {
      "event_id": "01027007_e00013",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 13,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "在瑶池赴酒宴沉醉醺醺。收住了云头仔细观定，高山清曲水秀柳暗花明。我这里下云端将身立稳，",
      "text_length": 43
    },
    {
      "event_id": "01027007_e00014",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 14,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四云童同下。牡丹上，坐。",
      "text_length": 12
    },
    {
      "event_id": "01027007_e00015",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 15,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "又只见那一旁坐一美人。",
      "text_length": 11
    },
    {
      "event_id": "01027007_e00016",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 16,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "看那山洞以外，坐着一位道姑，待我向前，打动她一番。啊，道姑，贫道这厢稽首了。",
      "text_length": 38
    },
    {
      "event_id": "01027007_e00017",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 17,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "还礼。请问道家，是哪位神仙？",
      "text_length": 14
    },
    {
      "event_id": "01027007_e00018",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 18,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "在下山石道人。",
      "text_length": 7
    },
    {
      "event_id": "01027007_e00019",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 19,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "原来是一位大仙。但不知大仙到此为何？",
      "text_length": 18
    },
    {
      "event_id": "01027007_e00020",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 20,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "贫道度化世人，云游天下，行至此地，只是口中焦烦，要求仙姑赐茶一杯，贫道解渴。",
      "text_length": 38
    },
    {
      "event_id": "01027007_e00021",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "大仙既要用茶，待奴到洞中取来。",
      "text_length": 15
    },
    {
      "event_id": "01027007_e00022",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "牡丹取茶。",
      "text_length": 5
    },
    {
      "event_id": "01027007_e00023",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "大仙请用。",
      "text_length": 5
    },
    {
      "event_id": "01027007_e00024",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "多谢了。",
      "text_length": 4
    },
    {
      "event_id": "01027007_e00025",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "大仙要用，待奴家再取一杯来。",
      "text_length": 14
    },
    {
      "event_id": "01027007_e00026",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "一杯仅够，不用了。请问仙姑，这洞叫什么洞？",
      "text_length": 21
    },
    {
      "event_id": "01027007_e00027",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "此名天香洞。",
      "text_length": 6
    },
    {
      "event_id": "01027007_e00028",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "天香洞！贫道要到洞中一游。",
      "text_length": 13
    },
    {
      "event_id": "01027007_e00029",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "大仙就请进得洞来，又有何妨。请。",
      "text_length": 16
    },
    {
      "event_id": "01027007_e00030",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吕洞宾、牡丹同进。",
      "text_length": 9
    },
    {
      "event_id": "01027007_e00031",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "大仙请坐。",
      "text_length": 5
    },
    {
      "event_id": "01027007_e00032",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "请坐。请问道姑尊姓，道号何名？",
      "text_length": 15
    },
    {
      "event_id": "01027007_e00033",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "奴家姓花，名唤牡丹。",
      "text_length": 10
    },
    {
      "event_id": "01027007_e00034",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "但不知尊师何人？为何不见？",
      "text_length": 13
    },
    {
      "event_id": "01027007_e00035",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "师父黄龙，今日去往昆仑，赴龙华大会去了。",
      "text_length": 20
    },
    {
      "event_id": "01027007_e00036",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "但不知道姑可有父母、姊妹、兄弟无有？",
      "text_length": 18
    },
    {
      "event_id": "01027007_e00037",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "奴家父母早亡，并无兄弟姊妹。",
      "text_length": 14
    },
    {
      "event_id": "01027007_e00038",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "道姑既无父母、兄妹，只你一人，在这洞中，岂不冷清孤单？",
      "text_length": 27
    },
    {
      "event_id": "01027007_e00039",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "大仙听道。",
      "text_length": 5
    },
    {
      "event_id": "01027007_e00040",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "牡丹"
      ],
      "text": "奴家虽然无父母，一人清净甚悠闲。每日洞中来修炼，胜似荣华在世间。",
      "text_length": 32
    },
    {
      "event_id": "01027007_e00041",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "好一个“胜似荣华在世间”。道姑！贫道有一言，你可愿听？",
      "text_length": 27
    },
    {
      "event_id": "01027007_e00042",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "大仙请讲！",
      "text_length": 5
    },
    {
      "event_id": "01027007_e00043",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "你听来。",
      "text_length": 4
    },
    {
      "event_id": "01027007_e00044",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "吕纯阳在洞中便开言，尊一声道姑你细听我言：说什么一身甚清闲，说什么胜似荣华在世间。看人生在世三光现，你可知这三光在哪边？",
      "text_length": 60
    },
    {
      "event_id": "01027007_e00045",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "牡丹"
      ],
      "text": "说什么人世三光现，日月星三光尽在上天。老君炉也把三光炼，丹九转成了功就在身边。",
      "text_length": 39
    },
    {
      "event_id": "01027007_e00046",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "功成圆满丹九转，你可知三纲为哪般？君臣父子且休管，夫妇二字须详参。",
      "text_length": 33
    },
    {
      "event_id": "01027007_e00047",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "牡丹"
      ],
      "text": "虽然是男女成夫妇，那也是前世里注定姻缘。",
      "text_length": 20
    },
    {
      "event_id": "01027007_e00048",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "自从盘古分天地，阴阳男女须两全。天地交泰有云雨，阴阳不合气连偏。叫道姑与我且打坐！",
      "text_length": 41
    },
    {
      "event_id": "01027007_e00049",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吕洞宾、牡丹同搬椅到台口对坐。",
      "text_length": 15
    },
    {
      "event_id": "01027007_e00050",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "叫道姑你且细听言：夫唱妇随是正理，阴阳相配两相欢。你本灵山鲜花种，我就是采花一散仙。今日若能够成婚配，好似那仙女会巫山。",
      "text_length": 60
    },
    {
      "event_id": "01027007_e00051",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "牡丹"
      ],
      "text": "说什么云雨会巫山，男女私合理不端。你我二人无媒证，哪一个来做撮合山？",
      "text_length": 34
    },
    {
      "event_id": "01027007_e00052",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "吕洞宾"
      ],
      "text": "听一言来甚稀罕，何用人做撮合山？你我今日若肯成婚配，这也是五百年前造定的好姻缘。",
      "text_length": 40
    },
    {
      "event_id": "01027007_e00053",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "牡丹"
      ],
      "text": "好姻缘来恶姻缘，千里姻缘一线牵。萍水相逢成连理，此事叫我费详参。低下头来暗盘算，这也是前生造定一姻缘。回头再把大仙叫，奴家言来听心间：非是奴家不应允，这有一事不周全。指着何物为媒证，还须上前拜一番。",
      "text_length": 99
    },
    {
      "event_id": "01027007_e00054",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "啊，大仙。既然你我要成此事，无有媒人，成何道理？",
      "text_length": 24
    },
    {
      "event_id": "01027007_e00055",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "这边一旁是什么？",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00056",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "此乃是一太湖石。",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00057",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吕洞宾"
      ],
      "text": "就向太湖石一拜有何不可？",
      "text_length": 12
    },
    {
      "event_id": "01027007_e00058",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牡丹"
      ],
      "text": "哎呀且住！看这大仙，要同奴成却此事，我想师父临行之时，言道，日内定有纯阳，想是应在他的身上。奴若得真阳，日后超拔升天，飞升得道，成其成果，岂不妙哉！",
      "text_length": 74
    },
    {
      "event_id": "01027007_e00059",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "牡丹"
      ],
      "text": "今日里果然应师言，得了纯阳就飞升就天。",
      "text_length": 19
    },
    {
      "event_id": "01027007_e00060",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "吕洞宾"
      ],
      "text": "二人一同双双拜，",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00061",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "牡丹"
      ],
      "text": "夫妻齐跪就拜地天。",
      "text_length": 9
    },
    {
      "event_id": "01027007_e00062",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 52,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "吕洞宾"
      ],
      "text": "交拜已毕忙站起，",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00063",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 53,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "牡丹"
      ],
      "text": "羞羞惭惭站在一边。",
      "text_length": 9
    },
    {
      "event_id": "01027007_e00064",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 54,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。吕洞宾示意同睡，牡丹做羞，吕洞宾拉牡丹同下。〖牌子〗。牡丹紧裙跑上，吕洞宾随上。",
      "text_length": 45
    },
    {
      "event_id": "01027007_e00065",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 55,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "吕洞宾"
      ],
      "text": "鸳鸯交颈喜连连，",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00066",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 56,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "牡丹"
      ],
      "text": "好似倒凤并颠鸾。",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00067",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 57,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "吕洞宾"
      ],
      "text": "良缘有数人难算，",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00068",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 58,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "牡丹"
      ],
      "text": "再会佳期待何年？",
      "text_length": 8
    },
    {
      "event_id": "01027007_e00069",
      "play_id": "01027007",
      "scene_id": "01027007_s03",
      "scene_no": 3,
      "seq_global": 69,
      "seq_in_scene": 59,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "擂鼓。",
      "text_length": 3
    },
    {
