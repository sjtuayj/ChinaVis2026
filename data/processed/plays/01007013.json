  "events": [
    {
      "event_id": "01007013_e00001",
      "play_id": "01007013",
      "scene_id": "01007013_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四将、四校尉同上，姬僚上。",
      "text_length": 17
    },
    {
      "event_id": "01007013_e00002",
      "play_id": "01007013",
      "scene_id": "01007013_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "姬僚"
      ],
      "text": "大地山河，图霸业，一统吴国。",
      "text_length": 14
    },
    {
      "event_id": "01007013_e00003",
      "play_id": "01007013",
      "scene_id": "01007013_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "姬僚"
      ],
      "text": "诸侯一概举心计，霸占江土地无余。开疆占土立大业，列国群雄谁敢欺？",
      "text_length": 32
    },
    {
      "event_id": "01007013_e00004",
      "play_id": "01007013",
      "scene_id": "01007013_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "孤，姬僚。老王晏驾，无人接位，是孤霸占山河。御弟心怀不臣，在秦小府设下鱼肠大会，请孤前去赴宴。是孤内穿长猊宝铠，外罩锦袍，以防不测。众位将军，人马可齐？",
      "text_length": 76
    },
    {
      "event_id": "01007013_e00005",
      "play_id": "01007013",
      "scene_id": "01007013_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四将"
      ],
      "text": "齐备多时。",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00006",
      "play_id": "01007013",
      "scene_id": "01007013_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "摆驾秦小府。",
      "text_length": 6
    },
    {
      "event_id": "01007013_e00007",
      "play_id": "01007013",
      "scene_id": "01007013_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00008",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监同上，姬光上。",
      "text_length": 10
    },
    {
      "event_id": "01007013_e00009",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "姬光"
      ],
      "text": "计就月中擒玉兔，安排香饵钓海鳖。",
      "text_length": 16
    },
    {
      "event_id": "01007013_e00010",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "报子上。",
      "text_length": 4
    },
    {
      "event_id": "01007013_e00011",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "报子"
      ],
      "text": "大殿下到！",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00012",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "有请！",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00013",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "报子下。〖吹打〗。姬僚、四龙套、四将、四校尉同上。",
      "text_length": 25
    },
    {
      "event_id": "01007013_e00014",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "御弟！",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00015",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "兄王！不知兄王驾到，未曾远迎，恕罪！",
      "text_length": 18
    },
    {
      "event_id": "01007013_e00016",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "御弟相邀，有何见谕？",
      "text_length": 10
    },
    {
      "event_id": "01007013_e00017",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "兄王有所不知，只因太湖有人进得鲜鱼一尾，烹炙好了，其味无穷。故而请兄过府同饮。",
      "text_length": 39
    },
    {
      "event_id": "01007013_e00018",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "到此就要讨扰！",
      "text_length": 7
    },
    {
      "event_id": "01007013_e00019",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "内侍看宴！",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00020",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "摆下就是。",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00021",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00022",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "众将！",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00023",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四将同允。",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00024",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "两厢搜来！",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00025",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四将同搜。",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00026",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四将"
      ],
      "text": "没有！",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00027",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "站立两厢。",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00028",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "兄王过府饮宴，为何这等见疑？",
      "text_length": 14
    },
    {
      "event_id": "01007013_e00029",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "想想列国之中，兄不得不如此——",
      "text_length": 15
    },
    {
      "event_id": "01007013_e00030",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "姬僚"
      ],
      "text": "列国相争干戈厚，",
      "text_length": 8
    },
    {
      "event_id": "01007013_e00031",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "姬僚"
      ],
      "text": "弑君不如宰鸡牛。虽然是御弟的恩情厚，各自机来各自谋。孤昨晚一梦真少有，有孤王坐至在打鱼一个小舟。见一个那鱼儿在那水上走，它口吐寒光就照孤的双眸。它的冷气搜身孤难消受，高叫声那打鱼的人儿，你就快把那个船来收。有孤王我正在那高声喊叫无人救，扭回头我又不见那个打鱼那个小舟。孤醒来正在那三更后，止不住我浑身上下一阵一阵，阵阵冷汗流。吉凶二字孤解也解不透，御弟与孤你就解根由。",
      "text_length": 184
    },
    {
      "event_id": "01007013_e00032",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "姬光"
      ],
      "text": "兄王说话没来由，梦寐之事何须挂心头！人来看过葡萄酿，小弟保兄坐龙楼。",
      "text_length": 34
    },
    {
      "event_id": "01007013_e00033",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "姬僚"
      ],
      "text": "御弟说话孤心受，你保孤王押诸侯。天下的举子孤为首，押定了一十一国，各国不敢统貔貅。人来推杯你就换大斗，",
      "text_length": 51
    },
    {
      "event_id": "01007013_e00034",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00035",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "姬僚"
      ],
      "text": "御弟为何面带愁？",
      "text_length": 8
    },
    {
      "event_id": "01007013_e00036",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "吓，御弟为何这等模样？",
      "text_length": 11
    },
    {
      "event_id": "01007013_e00037",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "小弟不料足尖疼痛难忍。",
      "text_length": 11
    },
    {
      "event_id": "01007013_e00038",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "快快前去太医院调治！",
      "text_length": 10
    },
    {
      "event_id": "01007013_e00039",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "兄长一人在此，弟放心不下。",
      "text_length": 13
    },
    {
      "event_id": "01007013_e00040",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "御弟你来看，孤内穿长猊宝铠，外罩锦袍三层。两旁战将千员，料无妨碍。快快调治去罢！",
      "text_length": 40
    },
    {
      "event_id": "01007013_e00041",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬光"
      ],
      "text": "告辞了！",
      "text_length": 4
    },
    {
      "event_id": "01007013_e00042",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "姬光"
      ],
      "text": "谢过兄王龙恩厚，小弟即来献酒酬。袖内机关怎猜透，管叫鱼儿上了钩！",
      "text_length": 32
    },
    {
      "event_id": "01007013_e00043",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "姬光下。",
      "text_length": 4
    },
    {
      "event_id": "01007013_e00044",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姬僚"
      ],
      "text": "来，传进肴人走上！",
      "text_length": 9
    },
    {
      "event_id": "01007013_e00045",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四将"
      ],
      "text": "传进肴人走上！",
      "text_length": 7
    },
    {
      "event_id": "01007013_e00046",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "专诸"
      ],
      "text": "来也！",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00047",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专诸上。",
      "text_length": 4
    },
    {
      "event_id": "01007013_e00048",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "专诸"
      ],
      "text": "三皇五帝夏商周，盖世英雄不到头。命中有来终须有，命里无来莫强求。鱼中暗藏剑一口，要把王僚一笔勾。手捧鲜鱼朝上走，",
      "text_length": 56
    },
    {
      "event_id": "01007013_e00049",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四校尉"
      ],
      "text": "呔！作什么的？",
      "text_length": 7
    },
    {
      "event_id": "01007013_e00050",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "进肴的。",
      "text_length": 4
    },
    {
      "event_id": "01007013_e00051",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四校尉"
      ],
      "text": "可有夹带？",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00052",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "无有。",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00053",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四校尉"
      ],
      "text": "我等要搜！",
      "text_length": 5
    },
    {
      "event_id": "01007013_e00054",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "站立了！",
      "text_length": 4
    },
    {
      "event_id": "01007013_e00055",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "专诸"
      ],
      "text": "这才是官差不自由。解带脱衣你们请搜透，",
      "text_length": 19
    },
    {
      "event_id": "01007013_e00056",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四校尉同搜。",
      "text_length": 6
    },
    {
      "event_id": "01007013_e00057",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四校尉"
      ],
      "text": "无有。",
      "text_length": 3
    },
    {
      "event_id": "01007013_e00058",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "无有？闪开了！",
      "text_length": 7
    },
    {
      "event_id": "01007013_e00059",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "专诸"
      ],
      "text": "老天爷助我把名留！手捧鲜鱼朝上走，见君不敢强抬头。",
      "text_length": 25
    },
    {
      "event_id": "01007013_e00060",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "姬僚"
      ],
      "text": "霎时一阵寒风透，这见鱼儿在当头。快快拿来孤消受，",
      "text_length": 24
    },
    {
      "event_id": "01007013_e00061",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "管叫王僚一笔勾！",
      "text_length": 8
    },
    {
      "event_id": "01007013_e00062",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专诸刺姬僚，四将同打杀专诸。专诸下。柳展熊上，开打。四将同下。",
      "text_length": 31
    },
    {
      "event_id": "01007013_e00063",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "expression",
      "mode_label": "三笑",
      "speakers": [
        "柳展熊"
      ],
      "text": "哈哈哈！",
      "text_length": 4
    },
    {
      "event_id": "01007013_e00064",
      "play_id": "01007013",
      "scene_id": "01007013_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}