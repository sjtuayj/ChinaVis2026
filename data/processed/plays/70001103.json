  "events": [
    {
      "event_id": "70001103_e00001",
      "play_id": "70001103",
      "scene_id": "70001103_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00002",
      "play_id": "70001103",
      "scene_id": "70001103_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "王宝钏"
      ],
      "text": "相府堂前三击掌，抛却荣华，甘守清贫。",
      "text_length": 18
    },
    {
      "event_id": "70001103_e00003",
      "play_id": "70001103",
      "scene_id": "70001103_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王宝钏"
      ],
      "text": "恼恨爹爹太不仁，嫌贫爱富赖婚姻。宝钏誓死随平贵，愿在寒窑受苦辛。",
      "text_length": 32
    },
    {
      "event_id": "70001103_e00004",
      "play_id": "70001103",
      "scene_id": "70001103_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我，王宝钏。爹爹王允，官居首相。只因二月二日在十字街前高搭彩楼，抛球招婿，打中薛郎，可恨爹爹嫌贫爱富，是我与他三击掌，离却相府，夫妻二人来到寒窑，苦度光阴。如今薛郎立志前去投军，但愿日后能得一官半职，也不枉我受苦一场，啊啊啊……",
      "text_length": 114
    },
    {
      "event_id": "70001103_e00005",
      "play_id": "70001103",
      "scene_id": "70001103_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏拭泪。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00006",
      "play_id": "70001103",
      "scene_id": "70001103_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "王宝钏"
      ],
      "text": "王宝钏坐寒窑珠泪双掉，老爹爹枉为官一品当朝：嫌贫穷爱富贵信义不要，狠心肠把骨肉情一旦丢抛。愿薛郎此一去身得荣耀，也不枉我宝钏受苦一遭。",
      "text_length": 67
    },
    {
      "event_id": "70001103_e00007",
      "play_id": "70001103",
      "scene_id": "70001103_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏下。",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00008",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵上，起霸。",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00009",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "薛平贵"
      ],
      "text": "头戴银盔一点红，身穿铠甲透玲珑；降了红鬃一烈马，扶保唐王立大功。",
      "text_length": 32
    },
    {
      "event_id": "70001103_e00010",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "俺，薛平贵。是我前去投军，降红鬃烈马，圣上见喜，封为后军督府。可恨王允老贼，上得金殿，参奏一本，言道西凉下国，打来连环战表，要夺我主江山，苏龙、魏虎以为正副帅，我后军督府改为马前的先锋。今乃黄道吉日，就要登程。我不免回转寒窑，辞别三姐。天哪，天！恼煞某也！",
      "text_length": 128
    },
    {
      "event_id": "70001103_e00011",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "薛平贵"
      ],
      "text": "可恨王允太不仁，",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00012",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵上马。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00013",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "薛平贵"
      ],
      "text": "害我夫妻们两下离分！催马加鞭往前进，",
      "text_length": 18
    },
    {
      "event_id": "70001103_e00014",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵下马。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00015",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "叫声三姐快开窑门。",
      "text_length": 9
    },
    {
      "event_id": "70001103_e00016",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "王宝钏"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "70001103_e00017",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00018",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "忽听门外一声唤，想必薛郎回窑前。开开窑门用目看，",
      "text_length": 24
    },
    {
      "event_id": "70001103_e00019",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐，为丈夫回来了。",
      "text_length": 10
    },
    {
      "event_id": "70001103_e00020",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵进窑。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00021",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "70001103_e00022",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "来了堂堂将一员。",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00023",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊，薛郎，你回来了！",
      "text_length": 10
    },
    {
      "event_id": "70001103_e00024",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "回来了。",
      "text_length": 4
    },
    {
      "event_id": "70001103_e00025",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "你这身荣耀，莫非作了官了?",
      "text_length": 13
    },
    {
      "event_id": "70001103_e00026",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "为丈夫降了红鬃烈马，圣上见喜，封为后军督府。",
      "text_length": 22
    },
    {
      "event_id": "70001103_e00027",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "哎呀呀，果然作了官了。待我谢天谢地。",
      "text_length": 18
    },
    {
      "event_id": "70001103_e00028",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐慢谢天地，其中有变哪。",
      "text_length": 13
    },
    {
      "event_id": "70001103_e00029",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛郎，此话活从何而起？",
      "text_length": 11
    },
    {
      "event_id": "70001103_e00030",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "啊呀三姐呀！可恨你父与魏虎奸贼，上得金殿，参奏一本，言道西凉下国，打来战表，要夺我主江山，苏龙、魏虎以为正副帅，为丈夫后军督府改为了马前的先锋，即日就要登程。",
      "text_length": 79
    },
    {
      "event_id": "70001103_e00031",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "怎么讲？",
      "text_length": 4
    },
    {
      "event_id": "70001103_e00032",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "我就要走了。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00033",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊呀！",
      "text_length": 3
    },
    {
      "event_id": "70001103_e00034",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏晕倒。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00035",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐，三姐醒来！",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00036",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "王宝钏"
      ],
      "text": "听一言来珠泪洒！",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00037",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐醒来！",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00038",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同叫头",
      "speakers": [
        "王宝钏",
        "薛平贵"
      ],
      "text": "（薛郎）（宝钏）！（我夫）（我妻）！（喂呀）（嗳呀）！",
      "text_length": 27
    },
    {
      "event_id": "70001103_e00039",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王宝钏"
      ],
      "text": "好一似万把刀把我心扎！父好比秦赵高指鹿为马，又好比汉萧何私造律法。",
      "text_length": 33
    },
    {
      "event_id": "70001103_e00040",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "薛平贵"
      ],
      "text": "贼好比秦赵高指鹿为马，贼好比汉萧何私造律法。为丈夫与你父冤仇结下，害得我夫妻俩各奔天涯。",
      "text_length": 44
    },
    {
      "event_id": "70001103_e00041",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王宝钏"
      ],
      "text": "手指相府，",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00042",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "王宝钏"
      ],
      "text": "高声骂，爹爹作事理太差。",
      "text_length": 12
    },
    {
      "event_id": "70001103_e00043",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "夫妻们只哭得泪如雨下，好鸳鸯遭棒打各奔天涯！",
      "text_length": 22
    },
    {
      "event_id": "70001103_e00044",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐！",
      "text_length": 3
    },
    {
      "event_id": "70001103_e00045",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐不必泪双流，丈夫言来听从头：干柴十担米八斗，你在寒窑度春秋；守得住来将我守，三姐呀！守不住来将我丢。",
      "text_length": 52
    },
    {
      "event_id": "70001103_e00046",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛郎说话没来由，为妻言来听从头：干柴十担米八斗，我在寒窑度春秋；守不住来也要守，纵死在寒窑也不回头。",
      "text_length": 50
    },
    {
      "event_id": "70001103_e00047",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐说话世少有，上得青史把美名留。",
      "text_length": 17
    },
    {
      "event_id": "70001103_e00048",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "中军上。",
      "text_length": 4
    },
    {
      "event_id": "70001103_e00049",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "先行听令。",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00050",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "来也。",
      "text_length": 3
    },
    {
      "event_id": "70001103_e00051",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵出窑。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00052",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "70001103_e00053",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "元帅初点大卯，不要误了卯期。",
      "text_length": 14
    },
    {
      "event_id": "70001103_e00054",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "70001103_e00055",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "中军"
      ],
      "text": "将军不下马，",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00056",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "薛平贵"
      ],
      "text": "各自奔前程。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00057",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "中军下。薛平贵进窑。",
      "text_length": 10
    },
    {
      "event_id": "70001103_e00058",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "方才何人到此？",
      "text_length": 7
    },
    {
      "event_id": "70001103_e00059",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "方才中军至此，言道元帅初点大卯，不要误了卯期。三姐你看，天色不早，我要告辞了。",
      "text_length": 39
    },
    {
      "event_id": "70001103_e00060",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛郎，你这就要走了吗？",
      "text_length": 11
    },
    {
      "event_id": "70001103_e00061",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "唉！我这就要走了。",
      "text_length": 9
    },
    {
      "event_id": "70001103_e00062",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "你有什么言语，嘱咐为妻几句。",
      "text_length": 14
    },
    {
      "event_id": "70001103_e00063",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "我的心如刀割，也想不起什么言语来了。",
      "text_length": 18
    },
    {
      "event_id": "70001103_e00064",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "你……嘱咐为妻几句啊！",
      "text_length": 11
    },
    {
      "event_id": "70001103_e00065",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "罢！为丈夫此番从军，不知几时回来，寒窑之中，干柴十担，老米八斗，你苦度春秋；倘若是柴米不够，你……回转相府去吧！",
      "text_length": 56
    },
    {
      "event_id": "70001103_e00066",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛郎啊！我与我爹爹三击掌，纵然是饿死寒窑，我也是不……回去的啊！",
      "text_length": 32
    },
    {
      "event_id": "70001103_e00067",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "好哇！好个三姐，虽是女流，却比男子刚强。为丈夫此番征战西凉，不知三年五载，才得回来；你在这窑前、窑后、窑左、窑右，与人家缝缝连连度日，为丈夫回来，一家一家登门叩谢。话已讲完，我告辞了！",
      "text_length": 92
    },
    {
      "event_id": "70001103_e00068",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛郎，你当真要走了？",
      "text_length": 10
    },
    {
      "event_id": "70001103_e00069",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "我即刻就要走了。唉！",
      "text_length": 10
    },
    {
      "event_id": "70001103_e00070",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "待为妻送你一程。",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00071",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "外面的风大得很哪！",
      "text_length": 9
    },
    {
      "event_id": "70001103_e00072",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我一定要送。",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00073",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "不送也罢。",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00074",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "一定要送啊！",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00075",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "如此有劳了！",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00076",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵欲走，回身为王宝钏拭泪。",
      "text_length": 15
    },
    {
      "event_id": "70001103_e00077",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "啊三姐，为丈夫征战西凉，就要回来了，你……不要哭啊！",
      "text_length": 26
    },
    {
      "event_id": "70001103_e00078",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛郎，你自己珍重，也不……要哭啊！",
      "text_length": 17
    },
    {
      "event_id": "70001103_e00079",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏为薛平贵拭泪。薛平贵出窑，头碰窑门，王宝钏为薛平贵抚痛。",
      "text_length": 31
    },
    {
      "event_id": "70001103_e00080",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "不妨事。",
      "text_length": 4
    },
    {
      "event_id": "70001103_e00081",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵、王宝钏同出窑。",
      "text_length": 11
    },
    {
      "event_id": "70001103_e00082",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王宝钏"
      ],
      "text": "夫妻双双出窑门，",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00083",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "薛平贵"
      ],
      "text": "叫人难舍又难分。",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00084",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王宝钏"
      ],
      "text": "但愿得此一去旗开得胜，",
      "text_length": 11
    },
    {
      "event_id": "70001103_e00085",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "薛平贵"
      ],
      "text": "自有那探马儿来报捷音。",
      "text_length": 11
    },
    {
      "event_id": "70001103_e00086",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王宝钏"
      ],
      "text": "一路上必须要小心谨慎！",
      "text_length": 11
    },
    {
      "event_id": "70001103_e00087",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "薛平贵"
      ],
      "text": "你在那寒窑内切莫要挂心。",
      "text_length": 12
    },
    {
      "event_id": "70001103_e00088",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "王宝钏"
      ],
      "text": "送薛郎送至在三岔路口，喂呀，薛郎啊！",
      "text_length": 18
    },
    {
      "event_id": "70001103_e00089",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐啊！",
      "text_length": 4
    },
    {
      "event_id": "70001103_e00090",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "薛平贵"
      ],
      "text": "刀绞肝肠泪淋淋。",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00091",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "从空降下无情剑，",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00092",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "薛平贵"
      ],
      "text": "斩断夫妻两离分。",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00093",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 93,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "王宝钏难舍薛平贵。",
      "text_length": 9
    },
    {
      "event_id": "70001103_e00094",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 94,
      "seq_in_scene": 87,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "薛平贵"
      ],
      "text": "薛平贵难割结发情。",
      "text_length": 9
    },
    {
      "event_id": "70001103_e00095",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 95,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "流泪眼观流泪眼。",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00096",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 96,
      "seq_in_scene": 89,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "薛平贵"
      ],
      "text": "断肠人送……",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00097",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 97,
      "seq_in_scene": 90,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "薛平贵"
      ],
      "text": "断肠人。",
      "text_length": 4
    },
    {
      "event_id": "70001103_e00098",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 98,
      "seq_in_scene": 91,
      "page_no": 4,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "王宝钏"
      ],
      "text": "夫妻们只哭得珠泪滚滚……喂呀，我的夫啊！",
      "text_length": 20
    },
    {
      "event_id": "70001103_e00099",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 99,
      "seq_in_scene": 92,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "号炮三声。",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00100",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 100,
      "seq_in_scene": 93,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "70001103_e00101",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 101,
      "seq_in_scene": 94,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "薛平贵"
      ],
      "text": "又听大炮响三声。辞别三姐踏金蹬，",
      "text_length": 16
    },
    {
      "event_id": "70001103_e00102",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 102,
      "seq_in_scene": 95,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "拉住薛郎不放开。你要走来将我带！",
      "text_length": 16
    },
    {
      "event_id": "70001103_e00103",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 103,
      "seq_in_scene": 96,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "薛平贵"
      ],
      "text": "你苦苦拉我为何来？",
      "text_length": 9
    },
    {
      "event_id": "70001103_e00104",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 104,
      "seq_in_scene": 97,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "此去不知三五载，你叫为妻怎安排？",
      "text_length": 16
    },
    {
      "event_id": "70001103_e00105",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 105,
      "seq_in_scene": 98,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "薛平贵"
      ],
      "text": "干柴十担米八斗，你在寒窑度春秋。辞别三姐跨马走，",
      "text_length": 24
    },
    {
      "event_id": "70001103_e00106",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 106,
      "seq_in_scene": 99,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵推王宝钏倒地，拉马欲行，见状复回。",
      "text_length": 20
    },
    {
      "event_id": "70001103_e00107",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 107,
      "seq_in_scene": 100,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐醒来！",
      "text_length": 5
    },
    {
      "event_id": "70001103_e00108",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 108,
      "seq_in_scene": 101,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵扶王宝钏起，急上马。王宝钏急追，扯薛平贵衣襟。薛平贵拔剑割断衣襟，王宝钏晕倒。",
      "text_length": 42
    },
    {
      "event_id": "70001103_e00109",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 109,
      "seq_in_scene": 102,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "三姐，你要保重了！",
      "text_length": 9
    },
    {
      "event_id": "70001103_e00110",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 110,
      "seq_in_scene": 103,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵下。王宝钏苏醒起立，远望。",
      "text_length": 16
    },
    {
      "event_id": "70001103_e00111",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 111,
      "seq_in_scene": 104,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛郎！我夫！",
      "text_length": 6
    },
    {
      "event_id": "70001103_e00112",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 112,
      "seq_in_scene": 105,
      "page_no": 4,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊……我的夫啊！",
      "text_length": 8
    },
    {
      "event_id": "70001103_e00113",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
      "scene_no": 2,
      "seq_global": 113,
      "seq_in_scene": 106,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "马走如飞不见影，撇下宝钏苦伶仃。悲悲切切进窑门，但愿薛郎早回程。",
      "text_length": 32
    },
    {
      "event_id": "70001103_e00114",
      "play_id": "70001103",
      "scene_id": "70001103_s02",
