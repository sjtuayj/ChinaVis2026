  "events": [
    {
      "event_id": "14002009_e00001",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大鬼上。",
      "text_length": 4
    },
    {
      "event_id": "14002009_e00002",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "哽吓。",
      "text_length": 3
    },
    {
      "event_id": "14002009_e00003",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "数板",
      "speakers": [
        "大鬼"
      ],
      "text": "阎君命我作鬼头，十鬼见了九鬼愁。行善的金桥走，作恶的打不休来骂不休，哪怕小鬼作对头。",
      "text_length": 42
    },
    {
      "event_id": "14002009_e00004",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "我乃大鬼是也。阎君朝拜佛祖去了，命我看守酆都城，不免在此伺候。",
      "text_length": 31
    },
    {
      "event_id": "14002009_e00005",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "目莲上。",
      "text_length": 4
    },
    {
      "event_id": "14002009_e00006",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "阿弥陀佛。",
      "text_length": 5
    },
    {
      "event_id": "14002009_e00007",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "目莲"
      ],
      "text": "在仙山奉了师父命，来到阴曹探望娘亲。",
      "text_length": 18
    },
    {
      "event_id": "14002009_e00008",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "小生目莲僧。奉了师父之命，来到阴曹探望娘亲。就此走走。",
      "text_length": 27
    },
    {
      "event_id": "14002009_e00009",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "目莲"
      ],
      "text": "西方路上一只鹅，口含仙草念弥陀。扁毛倒有修行意，人不修来待如何？",
      "text_length": 32
    },
    {
      "event_id": "14002009_e00010",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "来此已是酆都城，待我念起咒语。唵嘛呢叭咪吽。",
      "text_length": 22
    },
    {
      "event_id": "14002009_e00011",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "啊。哪里这样惊天动地？待我看来。原来是小师父，姓甚名谁？",
      "text_length": 28
    },
    {
      "event_id": "14002009_e00012",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "小生目莲僧。",
      "text_length": 6
    },
    {
      "event_id": "14002009_e00013",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "到此何事？",
      "text_length": 5
    },
    {
      "event_id": "14002009_e00014",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "掌关听了。",
      "text_length": 5
    },
    {
      "event_id": "14002009_e00015",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "目莲"
      ],
      "text": "在仙山奉了师父命，来到阴曹探望娘亲。",
      "text_length": 18
    },
    {
      "event_id": "14002009_e00016",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "你母亲姓甚名谁？",
      "text_length": 8
    },
    {
      "event_id": "14002009_e00017",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "听了。",
      "text_length": 3
    },
    {
      "event_id": "14002009_e00018",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "目莲"
      ],
      "text": "我的母并非是别的名姓，刘氏清蒂就是我娘亲。",
      "text_length": 21
    },
    {
      "event_id": "14002009_e00019",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "待我与你问来。众鬼卒！",
      "text_length": 11
    },
    {
      "event_id": "14002009_e00020",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众鬼卒内同应。",
      "text_length": 7
    },
    {
      "event_id": "14002009_e00021",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "里面可有个刘氏清蒂，她子目莲僧看望于她，有者即来答话。",
      "text_length": 27
    },
    {
      "event_id": "14002009_e00022",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "刘氏"
      ],
      "text": "有哇！",
      "text_length": 3
    },
    {
      "event_id": "14002009_e00023",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘氏上。",
      "text_length": 4
    },
    {
      "event_id": "14002009_e00024",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "刘氏"
      ],
      "text": "听一言不由我喜之不尽，原来是小娇儿寻找娘亲。刘清蒂本是我老身的名姓，我的儿叫罗卜不叫莲僧。望长官你与我盘查细问，https://scripts.xikao.com/play/140020092024-03-01我母子见一面感你的大恩。",
      "text_length": 117
    },
    {
      "event_id": "14002009_e00025",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "小师父，里面有一个刘氏清蒂，她子不叫目莲僧。",
      "text_length": 22
    },
    {
      "event_id": "14002009_e00026",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "叫什么？",
      "text_length": 4
    },
    {
      "event_id": "14002009_e00027",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大鬼"
      ],
      "text": "叫什么糖萝菔，醋萝菔。",
      "text_length": 11
    },
    {
      "event_id": "14002009_e00028",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "敢是傅罗卜。",
      "text_length": 6
    },
    {
      "event_id": "14002009_e00029",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 29,
