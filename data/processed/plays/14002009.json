      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘氏"
      ],
      "text": "儿啊，这些冤鬼，超度他们罢。",
      "text_length": 14
    },
