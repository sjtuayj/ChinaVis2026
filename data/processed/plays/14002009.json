      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "目莲"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "14002009_e00070",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "目莲"
      ],
      "text": "对准西方身拜定，取来了干饭付与娘亲。",
      "text_length": 18
    },
    {
      "event_id": "14002009_e00071",
      "play_id": "14002009",
      "scene_id": "14002009_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众冤鬼同上。",
      "text_length": 6
    },
