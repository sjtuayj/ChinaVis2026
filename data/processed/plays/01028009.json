    },
    {
      "event_id": "01028009_e00020",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李世民"
      ],
      "text": "绛帻鸡人报晓筹，珮声响倒凤池头。九天阊阖开宫阙，万国衣冠拜冕旒。",
      "text_length": 32
    },
    {
      "event_id": "01028009_e00021",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "孤，大唐天子，贞观在位。自登基以来，风调雨顺，海晏河清。孤有意欲命唐三藏去求西天真经，以崇佛教。但路途遥远，跋涉艰难。不免将御弟三藏宣上殿来，与他商议。内侍！",
      "text_length": 79
    },
    {
      "event_id": "01028009_e00022",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍甲"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01028009_e00023",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "宣唐三藏上殿。",
      "text_length": 7
    },
    {
      "event_id": "01028009_e00024",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍甲"
      ],
      "text": "领旨。万岁爷有旨，宣唐三藏上殿呐。",
      "text_length": 17
    },
    {
      "event_id": "01028009_e00025",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "唐三藏"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01028009_e00026",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐三藏上。",
      "text_length": 5
    },
    {
      "event_id": "01028009_e00027",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "唐三藏"
      ],
      "text": "金钵日食千家饭，破衲穿来万户衣。",
      "text_length": 16
    },
    {
      "event_id": "01028009_e00028",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "贫僧三藏见驾，愿吾主万岁。",
      "text_length": 13
    },
    {
      "event_id": "01028009_e00029",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "御弟平身。",
      "text_length": 5
    },
    {
      "event_id": "01028009_e00030",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "万万岁。",
      "text_length": 4
    },
    {
      "event_id": "01028009_e00031",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "赐座。",
      "text_length": 3
    },
    {
      "event_id": "01028009_e00032",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "谢座。万岁将贫僧宣上殿来，不知有何训谕？",
      "text_length": 20
    },
    {
      "event_id": "01028009_e00033",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "孤意欲悟道修真，只是天朝无有真经，未能尊崇佛教。不知真经，究在何处？",
      "text_length": 34
    },
    {
      "event_id": "01028009_e00034",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "启奏万岁：想那佛教真经，在西域五印度梵王宫内。",
      "text_length": 23
    },
    {
      "event_id": "01028009_e00035",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "寡人意欲命御弟前去求取真经，只是路途遥远，跋涉艰难，恐怕御弟不能受此劳苦。",
      "text_length": 37
    },
    {
      "event_id": "01028009_e00036",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "万岁说那里话来？贫僧久有此心，但是无有天朝玉牒、路引，贫僧定要被各国番王中途阻拦。万岁既有此心，贫僧不胜欣幸。",
      "text_length": 55
    },
    {
      "event_id": "01028009_e00037",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "只是路途遥远，过于辛苦。",
      "text_length": 12
    },
    {
      "event_id": "01028009_e00038",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "万岁呀！",
      "text_length": 4
    },
    {
      "event_id": "01028009_e00039",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "唐三藏"
      ],
      "text": "唐三藏在金殿把本来进，尊一声圣天子细听分明：真经文吾国中无人来问，五印度梵王宫才有真经。但愿得吾主爷赐我路引，哪怕那千山万水道路难行。有贫僧受皇恩当把诚尽，说什么一路上辛苦劳神。",
      "text_length": 89
    },
    {
      "event_id": "01028009_e00040",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "御弟呀！",
      "text_length": 4
    },
    {
      "event_id": "01028009_e00041",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "李世民"
      ],
      "text": "有孤王在金殿把话来论，叫一声唐三藏御弟细听：我天朝真佛教无人过问，孤也曾学空门悟道修真。真经文在印度西域绝境，梵王宫那才是三藏真经。但愿得此一去把经文取定，回朝中孤定要感谢大恩。",
      "text_length": 89
    },
    {
      "event_id": "01028009_e00042",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "唐三藏"
      ],
      "text": "我主爷说什么感恩不尽，取真经到西域是分内所应。",
      "text_length": 23
    },
    {
      "event_id": "01028009_e00043",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "此番御弟去往西天求取真经，一路上要受不尽风霜之苦。孤赐御弟锦绣袈裟一件、禅杖一根、紫金宝钵一个、装金僧衣僧帽一袭，小童四人替御弟牵马随镫。明日其性，孤王率领满朝文武百官，同到长亭饯别。",
      "text_length": 92
    },
    {
      "event_id": "01028009_e00044",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "贫僧有何德能，敢劳万岁圣驾出城。",
      "text_length": 16
    },
    {
      "event_id": "01028009_e00045",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "此事本是御弟代孤远行，何须辞让？内侍，看文房伺候。",
      "text_length": 25
    },
    {
      "event_id": "01028009_e00046",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "李世民"
      ],
      "text": "提龙笔写文牒大唐国号，孤御弟唐三藏替孤代劳。各国内众番王休得阻道，往西天求了经即刻还朝。孤赐你装金镶僧衣僧帽，孤赐你紫金钵禅杖一条；再赐你锦袈裟霞光万道，再赐你四童儿牵马代劳。内侍臣与孤王将宝抬到，",
      "text_length": 99
    },
    {
      "event_id": "01028009_e00047",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监同抬桌摆各件放台中间，四小童同上。",
      "text_length": 20
    },
    {
      "event_id": "01028009_e00048",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "李世民"
      ],
      "text": "金銮殿孤与你改换法袍。",
      "text_length": 11
    },
    {
      "event_id": "01028009_e00049",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖小开门〗。唐三藏换衣帽。",
      "text_length": 13
    },
    {
      "event_id": "01028009_e00050",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "唐三藏"
      ],
      "text": "在金殿谢万岁皇恩深浩，准备着到西天远走一遭。",
      "text_length": 22
    },
    {
      "event_id": "01028009_e00051",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐三藏下。",
      "text_length": 5
    },
    {
      "event_id": "01028009_e00052",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "李世民"
      ],
      "text": "一见三藏下龙廷，不由孤王喜在心。回头来叫众卿听孤话论，明日里文武官俱要出城。十八家督总管皆要恭敬，随同孤到沙桥前去饯行。",
      "text_length": 60
    },
    {
      "event_id": "01028009_e00053",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李世民下。",
      "text_length": 5
    },
    {
      "event_id": "01028009_e00054",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "同二黄正板",
      "speakers": [
        "徐勣",
        "房玄龄",
        "殷开山",
        "尉迟恭"
      ],
      "text": "金殿上领了万岁命，大家一同去送行。",
      "text_length": 17
    },
    {
      "event_id": "01028009_e00055",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "徐勣",
        "房玄龄",
        "殷开山",
        "尉迟恭"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "01028009_e00056",
      "play_id": "01028009",
      "scene_id": "01028009_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐勣、房玄龄、殷开山、尉迟恭同下。",
      "text_length": 17
    },
    {
      "event_id": "01028009_e00057",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四童子持幡引唐三藏同上。",
      "text_length": 12
    },
    {
      "event_id": "01028009_e00058",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "唐三藏"
      ],
      "text": "在金殿受皇恩深如四海，赐僧衣并袈裟出了金街。出家人皈三宝虔持斋戒，此一去好一比直上天台。",
      "text_length": 44
    },
    {
      "event_id": "01028009_e00059",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "贫僧，唐三藏。昨日在金殿之上面奉圣旨，替万岁去至西天五印度清净世界梵王宫中，求取宝藏真经。也曾命满朝文武、众家国公、一十八家督总管，均在长亭沙桥以外，与贫僧饯行。看天色不早，就此前往。童儿，带路。",
      "text_length": 98
    },
    {
      "event_id": "01028009_e00060",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "唐三藏"
      ],
      "text": "叫童儿忙带路荒郊以外，至沙桥等候了圣驾到来。",
      "text_length": 22
    },
    {
      "event_id": "01028009_e00061",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐三藏、四童子同下。",
      "text_length": 10
    },
    {
      "event_id": "01028009_e00062",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "李世民"
      ],
      "text": "出离了龙凤阁荒郊外，",
      "text_length": 10
    },
    {
      "event_id": "01028009_e00063",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四战将、四太监、二内侍、徐勣、房玄龄、殷开山、尉迟恭同上，李世民上。",
      "text_length": 38
    },
    {
      "event_id": "01028009_e00064",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李世民"
      ],
      "text": "有文臣和武将随侍在两排。唐三藏到西天清净世界，求取到宝藏经即便归来。有孤王在宫中也曾斋戒，一路上设香案顶礼安排。一霎时来至在长亭以外，",
      "text_length": 67
    },
    {
      "event_id": "01028009_e00065",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李世民下辇。",
      "text_length": 6
    },
    {
      "event_id": "01028009_e00066",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "李世民"
      ],
      "text": "因何故孤御弟不见到来。",
      "text_length": 11
    },
    {
      "event_id": "01028009_e00067",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四童子持幡引唐三藏同上。",
      "text_length": 12
    },
    {
      "event_id": "01028009_e00068",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "唐三藏"
      ],
      "text": "白龙马随定了长幡宝盖，今日里替圣主权做钦差。",
      "text_length": 22
    },
    {
      "event_id": "01028009_e00069",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐三藏下马。",
      "text_length": 6
    },
    {
      "event_id": "01028009_e00070",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "贫僧有何德能，怎敢劳动万岁圣驾到此相送？",
      "text_length": 20
    },
    {
      "event_id": "01028009_e00071",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "此番求取真经，理应孤王亲往。只因朝中之事无人料理，才命御弟替孤代劳。今日一来为御弟送行，二来尽孤王求经之诚意。孤王有言，御弟听道。",
      "text_length": 65
    },
    {
      "event_id": "01028009_e00072",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "李世民"
      ],
      "text": "孤王在长亭把旨传，尊一声御弟三藏听根源：天朝无有真经卷，怎令人悟道把禅参？你今替孤行方便，披星戴月去往西天。孤念你万里征途道路远，孤念你登山涉水跋涉艰难；孤念你每夜里投宿在庵观寺院，孤念你夏日受暑冬日受严寒。但愿得一路无阻险，御笔牒文你带在身边。道经各国叫他们观看，免得那番王将你阻拦。倘若得了真经卷，务须要急速转回还。孤在朝命人起造寺院，高设下钟鼓筑起法坛。那时节令众僧人齐把真经念，方知道西方佛祖法力无边。那时节御弟方算是功成圆满，孤封你参禅法师万古流传。",
      "text_length": 230
    },
    {
      "event_id": "01028009_e00073",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "唐三藏"
      ],
      "text": "谢过了万岁爷皇恩典，再谢文武臣两班。辞别圣驾把路趱，",
      "text_length": 26
    },
    {
      "event_id": "01028009_e00074",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐三藏"
      ],
      "text": "带马。",
      "text_length": 3
    },
    {
      "event_id": "01028009_e00075",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 19,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "唐三藏"
      ],
      "text": "一并虔诚奔西天。",
      "text_length": 8
    },
    {
      "event_id": "01028009_e00076",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 20,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐三藏下，四童子同下。",
      "text_length": 11
    },
    {
      "event_id": "01028009_e00077",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "李世民"
      ],
      "text": "一见三藏奔阳关，眼望沙桥自详参。但愿取经早回转，",
      "text_length": 24
    },
    {
      "event_id": "01028009_e00078",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 22,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同大转场。",
      "text_length": 7
    },
    {
      "event_id": "01028009_e00079",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 23,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "李世民"
      ],
      "text": "成佛作祖是不老神仙。",
      "text_length": 10
    },
    {
      "event_id": "01028009_e00080",
      "play_id": "01028009",
      "scene_id": "01028009_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、二内侍、徐勣、房玄龄、殷开山、尉迟恭引李世民同下。",
      "text_length": 29
    }
  ],
  "roles_inferred": true
}