  "events": [
    {
      "event_id": "01014015_e00001",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、八挂旗、康茂才同上。",
      "text_length": 14
    },
    {
      "event_id": "01014015_e00002",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "康茂才"
      ],
      "text": "某与军师打赌赛，气得豪杰怒满怀。陈友谅提兵反唐界，要夺我主九龙台。军师锦囊命我解，我命康玉下书来。绿袍遮提黄金镫，凤凰插翅五云排。杏黄旗不住在空中摆，耀武扬威站立土台。",
      "text_length": 84
    },
    {
      "event_id": "01014015_e00003",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "陈友谅"
      ],
      "text": "损兵折将把兵回，",
      "text_length": 8
    },
    {
      "event_id": "01014015_e00004",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈友谅、陈友杰、龙套同上。",
      "text_length": 13
    },
    {
      "event_id": "01014015_e00005",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "陈友谅"
      ],
      "text": "陈友谅在马上恸伤悲。悔不该在唐邑摆大队，又谁知中奸谋难把头回。到如今兵败人马溃，事到头来埋怨谁？",
      "text_length": 48
    },
    {
      "event_id": "01014015_e00006",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈友谅"
      ],
      "text": "贤弟，你我且喜逃出重围，你看前面又有旌旗招展，倘若那贼设有埋伏，你我性命难保！",
      "text_length": 39
    },
    {
      "event_id": "01014015_e00007",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈友杰"
      ],
      "text": "待我向前看过。启禀兄王：前面旗号高打“康”字。",
      "text_length": 23
    },
    {
      "event_id": "01014015_e00008",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈友谅"
      ],
      "text": "旗号之上写的“康”字，想必是康茂才贤弟在此。我与他有八拜之交，他若到此，你我君臣定得活命也！",
      "text_length": 46
    },
    {
      "event_id": "01014015_e00009",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈友谅"
      ],
      "text": "听说来了康茂才，不由孤家喜心怀。叫贤弟与我把路带，停鞭立马在土台。",
      "text_length": 33
    },
    {
      "event_id": "01014015_e00010",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小校"
      ],
      "text": "启爷：陈友谅到！",
      "text_length": 8
    },
    {
      "event_id": "01014015_e00011",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "康茂才"
      ],
      "text": "军师将令把咱委，站立土台抖雄威。刘基不识英雄辈，他道豪杰少计策。站立土台往下觑，那壁厢来了一伙贼：半似人，半似鬼，个个脸上带土灰。好一似佛爷离宝位，罗汉下损土沙坯。损兵败将悔不悔，事到头来埋怨谁？战鼓儿不住的咚咚咚咚，咚咙咚，紧紧地打，追命锣不住的叮当叮当叮当，当得啷当，紧紧地催！吓得他魂灵不附体，好一似阎罗把命追。美不美，湘江水，亲不亲，故乡客。康茂才又把良心昧，问一声土台下来者是谁？",
      "text_length": 195
    },
    {
      "event_id": "01014015_e00012",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "陈友谅"
      ],
      "text": "康贤弟说话言太差，细听孤家说根芽：我与你同窗共长大，一母同胞也不差。今日为何出大话，洋洋得意不识某家？",
      "text_length": 51
    },
    {
      "event_id": "01014015_e00013",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "康茂才"
      ],
      "text": "康茂才站土台高声大骂，",
      "text_length": 11
    },
    {
      "event_id": "01014015_e00014",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "康茂才"
      ],
      "text": "骂一声陈友谅无义的冤家：你与我在原郡同窗长大，你爱我，我爱你，才把香插。又谁知你一时心意太大，一心意只想着吞并中华。你好比秦赵高",
      "text_length": 64
    },
    {
      "event_id": "01014015_e00015",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "康茂才"
      ],
      "text": "指鹿为马，你好比楚霸王败国亡家。你好比曹丕前仲达司马，你好比宋秦桧丧了邦家。你好比王莽贼称孤道寡，你好比汉昭君怀抱琵琶。",
      "text_length": 60
    },
    {
      "event_id": "01014015_e00016",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "陈友谅"
      ],
      "text": "贤弟说话甚蹊跷，孤家言来听根苗：三国有个奸曹操，他与关公结故交。赠他金银和财宝，又赠他美女、战马、锦绣袍。到后来败走华容道，也曾放他把命逃。关公放曹三不死，你今救我这一遭。",
      "text_length": 86
    },
    {
      "event_id": "01014015_e00017",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "康茂才"
      ],
      "text": "这一辈古人比得好，我比关公你比曹。我比关公不敢比，你比曹操不差分毫。我今不放陈友谅，负了当年旧故交；我今放了陈友谅，只怕人头保不牢。叫小校摆一字长蛇道，认得此阵放尔逃。",
      "text_length": 84
    },
    {
      "event_id": "01014015_e00018",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈友谅"
      ],
      "text": "贤弟看看康贤弟摆的什么阵式？",
      "text_length": 14
    },
    {
      "event_id": "01014015_e00019",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈友杰"
      ],
      "text": "乃是一字长蛇大阵。",
      "text_length": 9
    },
    {
      "event_id": "01014015_e00020",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈友谅"
      ],
      "text": "谢天谢地！关公放曹就是此阵。你我君臣逃走了吧！",
      "text_length": 23
    },
    {
      "event_id": "01014015_e00021",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈友谅"
      ],
      "text": "听说一字长蛇道，好叫孤家喜眉梢。贤弟齐催跨下豹，异日相逢再报琼瑶。",
      "text_length": 33
    },
    {
      "event_id": "01014015_e00022",
      "play_id": "01014015",
      "scene_id": "01014015_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈友谅、陈友杰、龙套同下。",
