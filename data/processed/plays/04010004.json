        "陈氏"
      ],
      "text": "（母亲）（宝钏）！（亲娘）（姣儿）（喂呀）（罢）！",
      "text_length": 25
    },
    {
      "event_id": "04010004_e00106",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 106,
      "seq_in_scene": 106,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏下。陈氏上车，家院、丫鬟、陈氏、车夫同下。",
