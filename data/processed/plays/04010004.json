  "events": [
    {
      "event_id": "04010004_e00001",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟、陈氏同上。",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00002",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "陈氏"
      ],
      "text": "两鬓如霜，承诰命，身宿华堂。",
      "text_length": 14
    },
    {
      "event_id": "04010004_e00003",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "陈氏"
      ],
      "text": "可叹相爷不公平，三个女儿两看承。虽然身居在相府，思想姣儿不安宁。",
      "text_length": 32
    },
    {
      "event_id": "04010004_e00004",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "老身陈氏。配夫王允，官居首相，膝下无儿，所生三女。长女金钏许配苏龙；次女银钏许配魏虎；三女宝钏彩楼招赘，打中花郎平贵，我家相爷嫌他贫寒，定要退婚，三女执意不肯，因此父女失和。可叹她性情高傲，搬往城南寒窑居住。如今闻得平贵命丧西凉，我也曾命家院前去探望三女，未见回报。丫鬟！",
      "text_length": 136
    },
    {
      "event_id": "04010004_e00005",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "04010004_e00006",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "伺候了！",
      "text_length": 4
    },
    {
      "event_id": "04010004_e00007",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院上。",
      "text_length": 4
    },
    {
      "event_id": "04010004_e00008",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "家院"
      ],
      "text": "有事来通报，无事不乱言。",
      "text_length": 12
    },
    {
      "event_id": "04010004_e00009",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "参见老夫人。",
      "text_length": 6
    },
    {
      "event_id": "04010004_e00010",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "罢了。命你探望三姑娘怎么样了？",
      "text_length": 15
    },
    {
      "event_id": "04010004_e00011",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "三姑娘在寒窑身染重病。",
      "text_length": 11
    },
    {
      "event_id": "04010004_e00012",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "你待怎讲？",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00013",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "三姑娘身染重病。",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00014",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "唉！儿啊！",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00015",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "忽听家院报一声，宝钏姣儿病缠身。眼望寒窑珠泪滚，",
      "text_length": 24
    },
    {
      "event_id": "04010004_e00016",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "陈氏"
      ],
      "text": "我的儿啊！",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00017",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "怎不叫娘痛伤心。",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00018",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "老夫人不必悲伤，何不去到城南探望三姑娘？",
      "text_length": 20
    },
    {
      "event_id": "04010004_e00019",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "如此家院、丫鬟，",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00020",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "家院",
        "丫鬟"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "04010004_e00021",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "多带银米裙衫，探望你家三姑娘。吩咐车辆伺候。",
      "text_length": 22
    },
    {
      "event_id": "04010004_e00022",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "车辆上来。",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00023",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "车夫上，陈氏上车。",
      "text_length": 9
    },
    {
      "event_id": "04010004_e00024",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "陈氏"
      ],
      "text": "思想起当年事心中悔恨，大不该叫女儿彩楼招亲。闻听得薛平贵西凉丧命，寒窑内抛下了我儿千金。叫家院你与我前把路引，见宝钏母女门叙叙衷情。",
      "text_length": 66
    },
    {
      "event_id": "04010004_e00025",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "来此已是寒窑。",
      "text_length": 7
    },
    {
      "event_id": "04010004_e00026",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "前去叫门。",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00027",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈氏下车，车夫下。",
      "text_length": 9
    },
    {
      "event_id": "04010004_e00028",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "是。三姑娘开门来。",
      "text_length": 9
    },
    {
      "event_id": "04010004_e00029",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "王宝钏"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "04010004_e00030",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00031",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "耳边厢又听得有人声，想必是左右邻来看我身。想薛郎想得我身染重病，这几日未起床思念夫君。",
      "text_length": 43
    },
    {
      "event_id": "04010004_e00032",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "三姑娘开门来，老夫人来了。",
      "text_length": 13
    },
    {
      "event_id": "04010004_e00033",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "04010004_e00034",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "听说是我的母在窑外立等，这光景怎见得儿的老娘亲。",
      "text_length": 24
    },
    {
      "event_id": "04010004_e00035",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏开门，出窑。",
      "text_length": 9
    },
    {
      "event_id": "04010004_e00036",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "母亲在哪里？母亲在……",
      "text_length": 11
    },
    {
      "event_id": "04010004_e00037",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同三叫头",
      "speakers": [
        "王宝钏",
        "陈氏"
      ],
      "text": "（母亲）（宝钏）！（亲娘）（姣儿）！（喂呀母亲哪）（儿啊）！",
      "text_length": 30
    },
    {
      "event_id": "04010004_e00038",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "陈氏"
      ],
      "text": "一见姣儿珠泪滚，",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00039",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同三叫头",
      "speakers": [
        "陈氏",
        "王宝钏"
      ],
      "text": "（宝钏）（母亲）！（姣儿）（亲娘）！（儿啊）（喂呀娘啊）！",
      "text_length": 29
    },
    {
      "event_id": "04010004_e00040",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "陈氏"
      ],
      "text": "手拉三姐站窑门。儿在相府多由性，使女丫鬟陪伴儿的身。闲来绣楼描花锦，闷来花园散散儿的心。儿从前容颜多端正，到如今你头上无钗、身上无衣、面黄肌瘦、脸带病形，千般苦处都受尽，叫娘心疼不心疼！",
      "text_length": 93
    },
    {
      "event_id": "04010004_e00041",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "母亲！",
      "text_length": 3
    },
    {
      "event_id": "04010004_e00042",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲不必两泪淋，女儿言来听分明：老爹爹在朝官一品，生下我姐妹共三人。大姐二姐遵父命，许配居官为宦人；女儿许配花郎汉，平贵虽穷趁儿的心。世人都想为官宦，谁是那耕田种地的人。",
      "text_length": 86
    },
    {
      "event_id": "04010004_e00043",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "陈氏"
      ],
      "text": "背地里只把相国恨，一样女儿两样看承。回头再对宝钏论：为娘常把我儿挂在心。今日母女重相会，好似枯木又逢春。",
      "text_length": 52
    },
    {
      "event_id": "04010004_e00044",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "母亲请上，待女儿拜见。",
      "text_length": 11
    },
    {
      "event_id": "04010004_e00045",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿不必拜了。",
      "text_length": 7
    },
    {
      "event_id": "04010004_e00046",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿久离膝下，少奉甘旨，恕女儿不孝之罪。",
      "text_length": 20
    },
    {
      "event_id": "04010004_e00047",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "不必拜了。家院、丫鬟，见过三姑娘。",
      "text_length": 17
    },
    {
      "event_id": "04010004_e00048",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "家院",
        "丫鬟"
      ],
      "text": "参见三姑娘。",
      "text_length": 6
    },
    {
      "event_id": "04010004_e00049",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "罢了。啊母亲，不在相府，来此寒窑作甚？",
      "text_length": 19
    },
    {
      "event_id": "04010004_e00050",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "适才家院报道：我儿身染重病；但不知你的病症从何而起？",
      "text_length": 26
    },
    {
      "event_id": "04010004_e00051",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "再不要提起。只因那日魏虎回朝，打此寒窑经过，他说薛郎命丧西凉，女儿闻听，痛哭不止。爹爹又命人前来，要接儿回去另行改嫁，因此身得重病。今见母亲，儿的病体，哎呀！好了一半了哇……",
      "text_length": 87
    },
    {
      "event_id": "04010004_e00052",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏哭。",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00053",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "啊，我把你这老天杀的！为何时常逼我女儿改嫁？为娘回的府去，定不与他甘休！",
      "text_length": 36
    },
    {
      "event_id": "04010004_e00054",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊母亲，不要为了女儿之事，伤了你二老的和气才好。",
      "text_length": 24
    },
    {
      "event_id": "04010004_e00055",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "看在我儿面上，为娘不与他吵闹就是。",
      "text_length": 17
    },
    {
      "event_id": "04010004_e00056",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "多谢母亲。",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00057",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿呀，为娘要进得窑去，看看我儿的光景如何？",
      "text_length": 21
    },
    {
      "event_id": "04010004_e00058",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "这个……寒窑窄小，不看也罢。",
      "text_length": 14
    },
    {
      "event_id": "04010004_e00059",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "唉！我儿住得，难道为娘就看也看不得么？",
      "text_length": 19
    },
    {
      "event_id": "04010004_e00060",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "如此女儿打扫打扫。",
      "text_length": 9
    },
    {
      "event_id": "04010004_e00061",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "何必打扫，与为娘带路进窑。",
      "text_length": 13
    },
    {
      "event_id": "04010004_e00062",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈氏、王宝钏同进。",
      "text_length": 9
    },
    {
      "event_id": "04010004_e00063",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿啊！",
      "text_length": 3
    },
    {
      "event_id": "04010004_e00064",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "画阁雕梁儿不住，破瓦寒窑怎把身存？",
      "text_length": 17
    },
    {
      "event_id": "04010004_e00065",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院端饭与陈氏看。",
      "text_length": 9
    },
    {
      "event_id": "04010004_e00066",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "04010004_e00067",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "珍馐美味儿不用，粗茶淡饭怎渡光阴？",
      "text_length": 17
    },
    {
      "event_id": "04010004_e00068",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同三叫头",
      "speakers": [
        "王宝钏",
        "陈氏"
      ],
      "text": "（母亲）（宝钏）！（亲娘）（姣儿）！（喂呀母亲哪）（儿啊）！",
      "text_length": 30
    },
    {
      "event_id": "04010004_e00069",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "陈氏"
      ],
      "text": "我哭，哭一声宝钏我的儿啊！",
      "text_length": 13
    },
    {
      "event_id": "04010004_e00070",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "王宝钏"
      ],
      "text": "我叫，叫一声疼儿的老娘亲！",
      "text_length": 13
    },
    {
      "event_id": "04010004_e00071",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "想当初在相府何等光景，到如今住寒窑娘好心疼！",
      "text_length": 22
    },
    {
      "event_id": "04010004_e00072",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "只当儿今朝丧了命，老娘亲何必你、你、你……挂在心！",
      "text_length": 25
    },
    {
      "event_id": "04010004_e00073",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "我的儿随为娘把相府来进，随娘坐来伴娘行。",
      "text_length": 20
    },
    {
      "event_id": "04010004_e00074",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "二堂与父三击掌，冻饿死在寒窑也不回相府的门！",
      "text_length": 22
    },
    {
      "event_id": "04010004_e00075",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "陈氏"
      ],
      "text": "宝钏儿！",
      "text_length": 4
    },
    {
      "event_id": "04010004_e00076",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲！",
      "text_length": 4
    },
    {
      "event_id": "04010004_e00077",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "expression",
      "mode_label": "同哭头",
      "speakers": [
        "王宝钏",
        "陈氏"
      ],
      "text": "啊……（儿的娘）（我的儿）啊！",
      "text_length": 15
    },
    {
      "event_id": "04010004_e00078",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮小导板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲请上容儿拜禀，",
      "text_length": 10
    },
    {
      "event_id": "04010004_e00079",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "王宝钏"
      ],
      "text": "母女们在寒窑叙一叙苦情。为母病奉汤药三年整，蒙正宫赐绒线抛彩结亲。彩楼前打着薛平贵，老爹爹一见怒气生。前门赶走",
      "text_length": 55
    },
    {
      "event_id": "04010004_e00080",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "王宝钏"
      ],
      "text": "薛平贵，后门又赶女儿身。夫妻双双无投奔，在破瓦寒窑把身存。薛郎投军征西去，儿愿守寒窑等他回程。老娘回府替儿禀，从今后不用父操心。",
      "text_length": 64
    },
    {
      "event_id": "04010004_e00081",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿不必太伤心，为娘言来听分明：休与你父来争论，休要牵挂平贵身。儿随为娘相府进，随娘坐来伴娘行。倘若你父来争论，为娘把性命与他拼。倘若为娘下世去，儿就是披麻带孝的人。",
      "text_length": 83
    },
    {
      "event_id": "04010004_e00082",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘不必痛伤心，女儿言来听分明：倘若老娘百年后，儿就是披麻带孝的人。倘若是爹爹身亡故，女儿不去哭半声。非是女儿不孝顺，他把儿夫不当人。宝钏心志早已定，贫困至死也不回相府的门！",
      "text_length": 87
    },
    {
      "event_id": "04010004_e00083",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿立志心拿稳，但愿不负苦心人。",
      "text_length": 16
    },
    {
      "event_id": "04010004_e00084",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "家院、丫鬟，将银米裙衫交与你三姑娘。",
      "text_length": 18
    },
    {
      "event_id": "04010004_e00085",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊母亲，相府之物，女儿不用，叫他们带了回去吧。",
      "text_length": 23
    },
    {
      "event_id": "04010004_e00086",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿啊，难道你就辜负为娘一片心意么？",
      "text_length": 17
    },
    {
      "event_id": "04010004_e00087",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "女儿收下就是。",
      "text_length": 7
    },
    {
      "event_id": "04010004_e00088",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "这便才是。家院、丫鬟，你们暂且回去，我在寒窑陪伴你三姑娘住上几日。",
      "text_length": 33
    },
    {
      "event_id": "04010004_e00089",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊母亲，寒窑肮脏得很，母亲怎能住得？",
      "text_length": 18
    },
    {
      "event_id": "04010004_e00090",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿住得，难道为娘就住不得么？",
      "text_length": 15
    },
    {
      "event_id": "04010004_e00091",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "哎呀且住！我母亲不回相府，这这这便怎么处？我自有道理。啊母亲，女儿今日也要同母亲回相府去了。",
      "text_length": 46
    },
    {
      "event_id": "04010004_e00092",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿愿回相府了么？这便才是。家院、丫鬟，前面带路。",
      "text_length": 25
    },
    {
      "event_id": "04010004_e00093",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏开门，家院、丫鬟、陈氏同出窑，王宝钏急闭窑门。车夫上。",
      "text_length": 30
    },
    {
      "event_id": "04010004_e00094",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 94,
      "seq_in_scene": 94,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "哎呀儿啊，你怎么将窑门关闭了？",
      "text_length": 15
    },
    {
      "event_id": "04010004_e00095",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 95,
      "seq_in_scene": 95,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "母亲哪！二堂与父三击掌，冻饿死在寒窑，哎呀，也是不回去的了哇……",
      "text_length": 32
    },
    {
      "event_id": "04010004_e00096",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 96,
      "seq_in_scene": 96,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏哭。",
      "text_length": 5
    },
    {
      "event_id": "04010004_e00097",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 97,
      "seq_in_scene": 97,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿啊！",
      "text_length": 3
    },
    {
      "event_id": "04010004_e00098",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 98,
      "seq_in_scene": 98,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "宝钏儿抛为娘心肠太狠，",
      "text_length": 11
    },
    {
      "event_id": "04010004_e00099",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 99,
      "seq_in_scene": 99,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "儿在寒窑送娘亲。",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00100",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 100,
      "seq_in_scene": 100,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "陈氏"
      ],
      "text": "娘哭儿来痛难忍，",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00101",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 101,
      "seq_in_scene": 101,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "王宝钏"
      ],
      "text": "女哭娘来类满襟。",
      "text_length": 8
    },
    {
      "event_id": "04010004_e00102",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 102,
      "seq_in_scene": 102,
      "page_no": 4,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "陈氏"
      ],
      "text": "宝钏儿！",
      "text_length": 4
    },
    {
      "event_id": "04010004_e00103",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 103,
      "seq_in_scene": 103,
      "page_no": 4,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲！",
      "text_length": 4
    },
    {
      "event_id": "04010004_e00104",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 104,
      "seq_in_scene": 104,
      "page_no": 5,
      "type": "expression",
      "mode_label": "同哭头",
      "speakers": [
        "王宝钏",
        "陈氏"
      ],
      "text": "啊……（儿的娘）（我的儿）啊！",
      "text_length": 15
    },
    {
      "event_id": "04010004_e00105",
      "play_id": "04010004",
      "scene_id": "04010004_s01",
      "scene_no": 1,
      "seq_global": 105,
      "seq_in_scene": 105,
      "page_no": 5,
      "type": "recitation",
      "mode_label": "同三叫头",
      "speakers": [
