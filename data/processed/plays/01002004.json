  "events": [
    {
      "event_id": "01002004_e00001",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟引陈氏同上。",
      "text_length": 8
    },
    {
      "event_id": "01002004_e00002",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "陈氏"
      ],
      "text": "鹤发皓首，两鬓如霜。",
      "text_length": 10
    },
    {
      "event_id": "01002004_e00003",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "陈氏"
      ],
      "text": "夫为相国伴皇家，妻沾雨露享荣华。终朝只把娇儿叹，哪得周全喜生花。",
      "text_length": 32
    },
    {
      "event_id": "01002004_e00004",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "老身陈氏，配夫王允。膝下无儿，所生三女：长女金钏，许配苏龙；次女银钏，许配魏虎；三女宝钏，配夫平贵。可恨三女性情高傲，居住城南，老身百般相劝，执意不肯回府。今早也曾命家院去往城南，探望三女度日光景如何。这时候怎么还不见回来？丫鬟伺候了！",
      "text_length": 118
    },
    {
      "event_id": "01002004_e00005",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院上。",
      "text_length": 4
    },
    {
      "event_id": "01002004_e00006",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "家院"
      ],
      "text": "有事即来报，无事不乱言。",
      "text_length": 12
    },
    {
      "event_id": "01002004_e00007",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "参见老夫人。",
      "text_length": 6
    },
    {
      "event_id": "01002004_e00008",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "罢了，起来。命你打听三姑娘，光景如何？",
      "text_length": 19
    },
    {
      "event_id": "01002004_e00009",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "三姑娘在窑中身染重病。",
      "text_length": 11
    },
    {
      "event_id": "01002004_e00010",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "你待怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00011",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "三姑娘身染重病！",
      "text_length": 8
    },
    {
      "event_id": "01002004_e00012",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "哎呀，儿吓！",
      "text_length": 6
    },
    {
      "event_id": "01002004_e00013",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "听得家院一声禀，烈性的三女病缠身。",
      "text_length": 17
    },
    {
      "event_id": "01002004_e00014",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "陈氏"
      ],
      "text": "眼望城南高声叫，我的儿吓……",
      "text_length": 14
    },
    {
      "event_id": "01002004_e00015",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "怎能够到寒窑探望儿身。",
      "text_length": 11
    },
    {
      "event_id": "01002004_e00016",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "老夫人不必啼哭，何不多带银米衣裳，去往寒窑探望三姑娘。",
      "text_length": 27
    },
    {
      "event_id": "01002004_e00017",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "言之有理。家院、丫鬟，多带银米衣裳与你三姑娘。家院，吩咐外面车辆伺候。",
      "text_length": 35
    },
    {
      "event_id": "01002004_e00018",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "车辆走上。",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00019",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00020",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "陈氏"
      ],
      "text": "叫家院你与我前把路引，想从前大不该彩楼结亲。为宝钏把我的精神用尽，为女儿与相国吵闹相争；为宝钏常忧闷神昏不定，为女儿哭得我头闷眼昏。实可叹薛平郎西凉丧命，宝钏儿受凄凉一十七春。",
      "text_length": 88
    },
    {
      "event_id": "01002004_e00021",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "老夫人，此地已是寒窑。",
      "text_length": 11
    },
    {
      "event_id": "01002004_e00022",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "前去叫门。",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00023",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "三姑娘开门来。",
      "text_length": 7
    },
    {
      "event_id": "01002004_e00024",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "王宝钏"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00025",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏上。",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00026",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "忽听窑外有人声，想必是四邻探奴身。薛郎一去无音信，寒窑内哭坏女钗裙。",
      "text_length": 34
    },
    {
      "event_id": "01002004_e00027",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "三姑娘开门来，老夫人来了。",
      "text_length": 13
    },
    {
      "event_id": "01002004_e00028",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00029",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘来到城南郡，好一似钢刀刺在心。儿夫西凉丧了命，这回怎见老娘亲？",
      "text_length": 33
    },
    {
      "event_id": "01002004_e00030",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王宝钏开窑，出窑。",
      "text_length": 9
    },
    {
      "event_id": "01002004_e00031",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "王宝钏"
      ],
      "text": "母亲！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00032",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "陈氏"
      ],
      "text": "宝钏！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00033",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00034",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00035",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲吓！",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00036",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "陈氏"
      ],
      "text": "哎呀，儿吓！",
      "text_length": 6
    },
    {
      "event_id": "01002004_e00037",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "陈氏"
      ],
      "text": "一见娇儿珠泪滚，",
      "text_length": 8
    },
    {
      "event_id": "01002004_e00038",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "陈氏"
      ],
      "text": "三女，宝钏儿吓！",
      "text_length": 8
    },
    {
      "event_id": "01002004_e00039",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "陈氏"
      ],
      "text": "手搀三女说分明：儿在相府多侥幸，乖巧伶俐甚聪明。闲来绣阁挑花朵，闷来花园散精神。多少侍女来陪伴，许多丫鬟随后跟。自从我儿出相府，母女分别十七春。从前娇容如嫩笋，今朝我儿变了形。面黄肌瘦容颜改，忍饥受饱不回心。日见无人来谈论，晚来好似一孤灯。寒风冷凉儿受尽，破窑怎藏儿的身？你本是宰相千金女，叫娘心疼不心疼！",
      "text_length": 153
    },
    {
      "event_id": "01002004_e00040",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘不必两泪淋，女儿言来听分明：大姐、二姐有福分，许配为官做宦人。惟有女儿命内苦，彩球单打花郎身。好的好来歹的歹，富的富来贫的贫。若人多想为官宦，谁做耕田种地人？",
      "text_length": 81
    },
    {
      "event_id": "01002004_e00041",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "陈氏"
      ],
      "text": "背地里只把相国恨，三个女儿两看承。大女、二女我不爱，唯有冤家我心疼。老身今年六十九，瓦上霜来风前灯。今日见了娇儿面，好似枯木又逢春。",
      "text_length": 66
    },
    {
      "event_id": "01002004_e00042",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "母亲请上，待女儿拜见。",
      "text_length": 11
    },
    {
      "event_id": "01002004_e00043",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿不要拜了。",
      "text_length": 6
    },
    {
      "event_id": "01002004_e00044",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "儿久离膝下，少奉甘旨，望母亲恕罪！",
      "text_length": 17
    },
    {
      "event_id": "01002004_e00045",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿起来。家院、丫鬟，见过你三姑娘。",
      "text_length": 18
    },
    {
      "event_id": "01002004_e00046",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "家院",
        "丫鬟"
      ],
      "text": "参见三姑娘！",
      "text_length": 6
    },
    {
      "event_id": "01002004_e00047",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "罢了！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00048",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "母亲不在相府，来至寒窑则甚？",
      "text_length": 14
    },
    {
      "event_id": "01002004_e00049",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "家院回府：报道吾儿身染重病。此病从何而起？",
      "text_length": 21
    },
    {
      "event_id": "01002004_e00050",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "多因魏虎打从寒窑经过，言道儿丈夫命丧西凉，爹爹又差人前来劝奴改嫁，儿闻此言，因此身体十分病重。今日母亲到此，该是儿的病，好了一半了。",
      "text_length": 66
    },
    {
      "event_id": "01002004_e00051",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "哦，我把你这老天杀的，常常逼我儿改嫁，此番回去，又要与他吵闹一场！",
      "text_length": 33
    },
    {
      "event_id": "01002004_e00052",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "吓，母亲，为了女儿，不要伤了你二老的和气。",
      "text_length": 21
    },
    {
      "event_id": "01002004_e00053",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿吓，为娘看在我儿分上，不与你父吵闹就是。",
      "text_length": 21
    },
    {
      "event_id": "01002004_e00054",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "多谢母亲。",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00055",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿吓，为娘要进窑内看看，我儿的度日光景如何？",
      "text_length": 22
    },
    {
      "event_id": "01002004_e00056",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "寒窑窄小，不看也罢了。",
      "text_length": 11
    },
    {
      "event_id": "01002004_e00057",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "咳，我儿住了一十七载，难道为娘就进去不得么？",
      "text_length": 22
    },
    {
      "event_id": "01002004_e00058",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "如此待女儿打扫打扫。",
      "text_length": 10
    },
    {
      "event_id": "01002004_e00059",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "不用打扫，与为娘带路进窑，儿吓！",
      "text_length": 16
    },
    {
      "event_id": "01002004_e00060",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "雕梁画阁儿不住，寒窑怎存我儿身？",
      "text_length": 16
    },
    {
      "event_id": "01002004_e00061",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "哎，母亲请用。",
      "text_length": 7
    },
    {
      "event_id": "01002004_e00062",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01002004_e00063",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "珍馐海味儿不用，罐内稀饭怎度光阴？",
      "text_length": 17
    },
    {
      "event_id": "01002004_e00064",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同三叫头",
      "speakers": [
        "王宝钏",
        "陈氏"
      ],
      "text": "（母亲）（宝钏）！（老娘）（我儿）！哎吓，（老娘亲）（儿吓）！",
      "text_length": 31
    },
    {
      "event_id": "01002004_e00065",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "哭一声王宝钏！",
      "text_length": 7
    },
    {
      "event_id": "01002004_e00066",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "叫一声老娘亲！",
      "text_length": 7
    },
    {
      "event_id": "01002004_e00067",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "想当年在相府何等侥幸，到如今住寒窑娘好心痛。",
      "text_length": 22
    },
    {
      "event_id": "01002004_e00068",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "只当孩儿伤了命，何劳娘亲挂在心？",
      "text_length": 16
    },
    {
      "event_id": "01002004_e00069",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "儿随为娘回相府，只享荣华不愁贫。",
      "text_length": 16
    },
    {
      "event_id": "01002004_e00070",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "儿与爹爹三击掌，饿死寒窑不进相府门。",
      "text_length": 18
    },
    {
      "event_id": "01002004_e00071",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "陈氏"
      ],
      "text": "王宝钏……",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00072",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲……",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00073",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "expression",
      "mode_label": "同哭板",
      "speakers": [
        "陈氏",
        "王宝钏"
      ],
      "text": "呀吓呀吓！",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00074",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "陈氏"
      ],
      "text": "我的儿吓……",
      "text_length": 6
    },
    {
      "event_id": "01002004_e00075",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲吓……",
      "text_length": 6
    },
    {
      "event_id": "01002004_e00076",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲请上容儿拜禀，",
      "text_length": 10
    },
    {
      "event_id": "01002004_e00077",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿不必拜了，一旁坐了。",
      "text_length": 12
    },
    {
      "event_id": "01002004_e00078",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院、丫鬟同暗下。",
      "text_length": 9
    },
    {
      "event_id": "01002004_e00079",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "王宝钏"
      ],
      "text": "母女们在寒窑叙一叙苦情：都只为老娘亲身染重病，女儿在后花园把香来焚。许愿降香三年整，后宫娘娘得知情。恩赐五彩花绒线，绣成了彩球定终身。实指望打中宦门后，谁知单打在花郎身。夫妻二人相府进，老爹爹一见怒气升。前门赶出薛平贵，后门赶出女儿身。夫妻二人无投奔，破瓦寒窑把身存。渠江河内妖魔显，红鬃烈马乱伤人。平贵擒了红鬃马，唐王驾前去讨封。西凉贼子造了反，平贵倒做马先行。一去不觉十七载，儿比孤雁失了群。老娘回府对父论，休把孩儿挂在心。",
      "text_length": 214
    },
    {
      "event_id": "01002004_e00080",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿不必心烦闷，不要啼哭费精神。不要听你父的话，不要牵挂平郎身。儿随为娘回相府，跟娘坐来随娘行。倘若你父有谈论，舍生忘死拼他人。若是为娘归泉路，儿就是披麻戴孝人。",
      "text_length": 81
    },
    {
      "event_id": "01002004_e00081",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "王宝钏"
      ],
      "text": "老娘亲不必两泪淋，女儿言来听分明：倘若老娘身亡故，儿是披麻戴孝人；倘若爹爹身亡故，女儿不去哭半声。宝钏烧香把佛敬，儿要修修来世身。",
      "text_length": 65
    },
    {
      "event_id": "01002004_e00082",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈氏"
      ],
      "text": "立志守节拿得稳，皇天不负你这苦心人。",
      "text_length": 18
    },
    {
      "event_id": "01002004_e00083",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院、丫鬟同暗上。",
      "text_length": 9
    },
    {
      "event_id": "01002004_e00084",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "家院、丫鬟，将银米衣裳，交与你三姑娘。",
      "text_length": 19
    },
    {
      "event_id": "01002004_e00085",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "且慢，相府之物，一概不要。",
      "text_length": 13
    },
    {
      "event_id": "01002004_e00086",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿吓，你不收下，岂不辜负为娘一片好心？儿吓，收下罢！",
      "text_length": 26
    },
    {
      "event_id": "01002004_e00087",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "多谢母亲！",
      "text_length": 5
    },
    {
      "event_id": "01002004_e00088",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "这便才是。家院、丫鬟，你们暂且回去，老身在此陪伴你三姑娘一宵，明日回府。",
      "text_length": 36
    },
    {
      "event_id": "01002004_e00089",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "吓，母亲，寒窑肮脏得紧，母亲焉能得住？",
      "text_length": 19
    },
    {
      "event_id": "01002004_e00090",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "我儿住得，难道为娘就住不得么？",
      "text_length": 15
    },
    {
      "event_id": "01002004_e00091",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "且住，母亲不回相府，这便如何是好？我自有道理。吓，母亲，女儿情愿回转相府去了。",
      "text_length": 39
    },
    {
      "event_id": "01002004_e00092",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "好，我儿情愿回得相府了！家院吩咐车辆搭上。我儿开了窑门。",
      "text_length": 28
    },
    {
      "event_id": "01002004_e00093",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "01002004_e00094",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 94,
      "seq_in_scene": 94,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈氏、家院、丫鬟同出窑，王宝钏关窑门。",
      "text_length": 19
    },
    {
      "event_id": "01002004_e00095",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 95,
      "seq_in_scene": 95,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈氏"
      ],
      "text": "儿吓，为何将窑门紧闭？",
      "text_length": 11
    },
    {
      "event_id": "01002004_e00096",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 96,
      "seq_in_scene": 96,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊吓，母亲哪！儿与爹爹三击掌，饿在寒窑……也是不回去的了！",
      "text_length": 29
    },
    {
      "event_id": "01002004_e00097",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 97,
      "seq_in_scene": 97,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "陈氏"
      ],
      "text": "儿吓，狠心的儿，不把娘来送！",
      "text_length": 14
    },
    {
      "event_id": "01002004_e00098",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 98,
      "seq_in_scene": 98,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "王宝钏"
      ],
      "text": "娘吓，儿跪寒窑送娘亲。",
      "text_length": 11
    },
    {
      "event_id": "01002004_e00099",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 99,
      "seq_in_scene": 99,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "陈氏"
      ],
      "text": "娘哭儿来天地震！",
      "text_length": 8
    },
    {
      "event_id": "01002004_e00100",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 100,
      "seq_in_scene": 100,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "王宝钏"
      ],
      "text": "儿哭娘来泪成冰！",
      "text_length": 8
    },
    {
      "event_id": "01002004_e00101",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 101,
      "seq_in_scene": 101,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "陈氏"
      ],
      "text": "我那狠心的王三姐！",
      "text_length": 9
    },
    {
      "event_id": "01002004_e00102",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 102,
      "seq_in_scene": 102,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "王宝钏"
      ],
      "text": "我那疼儿的老娘亲……吓……",
      "text_length": 13
    },
    {
      "event_id": "01002004_e00103",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 103,
      "seq_in_scene": 103,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "陈氏"
      ],
      "text": "啊……啊……啊……啊……我的儿吓……",
      "text_length": 18
    },
    {
      "event_id": "01002004_e00104",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 104,
      "seq_in_scene": 104,
      "page_no": 5,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊吓……儿的老娘亲吓……吓……吓……吓……",
      "text_length": 21
    },
    {
      "event_id": "01002004_e00105",
      "play_id": "01002004",
      "scene_id": "01002004_s01",
      "scene_no": 1,
      "seq_global": 105,
      "seq_in_scene": 105,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}