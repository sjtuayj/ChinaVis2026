      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "诸葛亮"
      ],
      "text": "我主爷坐山河未享安静，全凭着五虎将保定乾坤。我心中恨的是东吴陆逊，必须要把孙曹一旦扫平。",
      "text_length": 44
    },
    {
      "event_id": "05007005_e00003",
      "play_id": "05007005",
      "scene_id": "05007005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李严上。",
      "text_length": 4
    },
    {
      "event_id": "05007005_e00004",
      "play_id": "05007005",
      "scene_id": "05007005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李严"
      ],
      "text": "启先生：主公兵败白帝城！",
      "text_length": 12
    },
    {
      "event_id": "05007005_e00005",
      "play_id": "05007005",
      "scene_id": "05007005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "命你传文武百官，去至白帝城接驾便了！",
      "text_length": 18
    },
    {
      "event_id": "05007005_e00006",
      "play_id": "05007005",
      "scene_id": "05007005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李严下。",
      "text_length": 4
    },
    {
      "event_id": "05007005_e00007",
      "play_id": "05007005",
      "scene_id": "05007005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "05007005_e00008",
      "play_id": "05007005",
      "scene_id": "05007005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
