      "mode_label": "念",
      "speakers": [
        "诸葛亮"
      ],
      "text": "阴阳八卦早算定，主公兵败白帝城。",
      "text_length": 16
    },
    {
      "event_id": "05007005_e00009",
      "play_id": "05007005",
      "scene_id": "05007005_s01",
      "scene_no": 1,
      "seq_global": 9,
