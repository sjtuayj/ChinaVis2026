      "mode_label": "stage_direction",
      "speakers": [],
      "text": "诸葛亮下。",
      "text_length": 5
    },
    {
      "event_id": "05007005_e00010",
      "play_id": "05007005",
      "scene_id": "05007005_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "刘备"
      ],
      "text": "搀扶。",
      "text_length": 3
    },
    {
      "event_id": "05007005_e00011",
      "play_id": "05007005",
      "scene_id": "05007005_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "关兴、张苞搀刘备同上。",
      "text_length": 11
    },
    {
      "event_id": "05007005_e00012",
      "play_id": "05007005",
      "scene_id": "05007005_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "刘备"
      ],
      "text": "为江山把孤的心血用尽，何日里把孙曹一旦扫平？二皇侄搀孤王龙床养静，活活地把桃园两下离分。",
      "text_length": 44
    },
    {
      "event_id": "05007005_e00013",
      "play_id": "05007005",
      "scene_id": "05007005_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马良、马谡、赵云、邓芝、费祎、二太子、诸葛亮同上。",
      "text_length": 25
    },
    {
      "event_id": "05007005_e00014",
      "play_id": "05007005",
      "scene_id": "05007005_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "诸葛亮"
      ],
      "text": "主公兵败白帝城，急忙进宫问分明。",
      "text_length": 16
    },
    {
      "event_id": "05007005_e00015",
      "play_id": "05007005",
