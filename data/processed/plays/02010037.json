      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "李慧娘"
      ],
      "text": "好一会诉不尽伤情话，",
      "text_length": 10
    },
    {
      "event_id": "02010037_e00031",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内鸡鸣。",
      "text_length": 4
    },
