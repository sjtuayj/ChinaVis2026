  "events": [
    {
      "event_id": "02010037_e00001",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四院子同上，同喝道。贾似道上。",
      "text_length": 15
    },
    {
      "event_id": "02010037_e00002",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "贾似道"
      ],
      "text": "烂醉归来明月下，看万条银烛笼纱。",
      "text_length": 16
    },
    {
      "event_id": "02010037_e00003",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贾似道"
      ],
      "text": "才罢朝餐，又排家宴。",
      "text_length": 10
    },
    {
      "event_id": "02010037_e00004",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起三更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "02010037_e00005",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二院子"
      ],
      "text": "启爷：三鼓了。",
      "text_length": 7
    },
    {
      "event_id": "02010037_e00006",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贾似道"
      ],
      "text": "早不觉三更初下。",
      "text_length": 8
    },
    {
      "event_id": "02010037_e00007",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾似道"
      ],
      "text": "老夫，贾似道。官拜平章之职，与圣上玩月而归，不觉大醉。廖应忠报道：后花园中，放走裴生，也不知是哪个贱婢。院子，",
      "text_length": 55
    },
    {
      "event_id": "02010037_e00008",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二院子"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02010037_e00009",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾似道"
      ],
      "text": "后堂传话：将众姬妾吊在两廊，各打一百。",
      "text_length": 19
    },
    {
      "event_id": "02010037_e00010",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二院子"
      ],
      "text": "啊。后堂传话，老爷吩咐：将众姬妾吊在两廊，各打一百。",
      "text_length": 26
    },
    {
      "event_id": "02010037_e00011",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二院子自两边分下。",
      "text_length": 9
    },
    {
      "event_id": "02010037_e00012",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "众人"
      ],
      "text": "哎哟！",
      "text_length": 3
    },
    {
      "event_id": "02010037_e00013",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "内北一枝花",
      "speakers": [
        "李慧娘"
      ],
      "text": "忽听得中堂人语喧，",
      "text_length": 9
    },
    {
      "event_id": "02010037_e00014",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李慧娘上。",
      "text_length": 5
    },
    {
      "event_id": "02010037_e00015",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "北一枝花",
      "speakers": [
        "李慧娘"
      ],
      "text": "把俺这幽怯里魂灵诈。太师坐当衙。俺这里闪过了，靠边些，我则道为甚唧喳。却原来为花园事发。堂堂宰相坐官衙，一声儿怒发如雷，一声儿怒发如雷，把俺这怯生生小胆儿唬杀。",
      "text_length": 80
    },
    {
      "event_id": "02010037_e00016",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李慧娘"
      ],
      "text": "妾乃生前李慧娘。只因鬼魂放走裴生，贼子不知，拷打众家姐妹。我若不向前厮认呵！",
      "text_length": 38
    },
    {
      "event_id": "02010037_e00017",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "梁州第七",
      "speakers": [
        "李慧娘"
      ],
      "text": "怎忍见，姊妹们受无端拷打，好一部肉骨吹，唧唧喳喳，呀呀呀，仗威风，不唬得阎浮乍。似这等三更签押，五鼓排衙，荆条竹板，玉锁金枷。呀呀呀，这壁厢只少个拨云堆牛头夜叉，那壁厢只少个哨锋尖鸟侩獠牙。呀呀呀，到阴司少不得一桩桩，一件件，把善恶来稽查，少不得明晃晃把业镜查。早料到葫芦提一笔勾，拿一笔勾，拿死不当要，拿死不当要。针尖事儿，谎的有天来大，恁粗豪将神鬼诈。唔，贼呀，只怕相报冤冤定不差，迟早争些，迟早争些。",
      "text_length": 203
    },
    {
      "event_id": "02010037_e00018",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李慧娘"
      ],
      "text": "老爷在上，贱妾叩头。",
      "text_length": 10
    },
    {
      "event_id": "02010037_e00019",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾似道"
      ],
      "text": "我把你这贱婢，一向躲在哪里，今日才来见我？",
      "text_length": 21
    },
    {
      "event_id": "02010037_e00020",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李慧娘"
      ],
      "text": "夜已深了，老爷不在后堂将息贵体，为何在此发怒？",
      "text_length": 23
    },
    {
      "event_id": "02010037_e00021",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾似道"
      ],
      "text": "后花园中放走裴生，敢是你这贱婢？从实招上来，免得我三推六问。",
      "text_length": 30
    },
    {
      "event_id": "02010037_e00022",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李慧娘"
      ],
      "text": "老爷容禀。",
      "text_length": 5
    },
    {
      "event_id": "02010037_e00023",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "牧羊关",
      "speakers": [
        "李慧娘"
      ],
      "text": "一犬声还吠，千牛在那家。似这等重重朱户锁窗纱，怎生得羊肠路，羊肠路，去奔走天涯。动不动钢刀一下，俺可也不害些儿怕。迟和急，一死无加，却原来有亏心的也怕杀。怎不自保身家？小妮子从来心胆大，因此上拚残生，拚残生来调牙。",
      "text_length": 107
    },
    {
      "event_id": "02010037_e00024",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "四块玉",
      "speakers": [
        "李慧娘"
      ],
      "text": "脱牢笼，尽是咱，怎掇陷，在他名下。只恁的，把书生冷禁在官衙。妾听他一句句诉向，都是伤情话。他说道，穷秀才，分无缘，住在相府家。多拜上老平章，且放了先生假。他思家，这其间，是奴方便了他。",
      "text_length": 92
    },
    {
      "event_id": "02010037_e00025",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "骂王郎",
      "speakers": [
        "李慧娘"
      ],
      "text": "俺与他欢会在西廊下，行了些云雨，勾了些风花。这些时一死，一死干休罢。待今宵跟着他呀，呀，呀，厮撞着叫人难停踏。",
      "text_length": 55
    },
    {
      "event_id": "02010037_e00026",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭皇天",
      "speakers": [
        "李慧娘"
      ],
      "text": "休，休，休，这话儿提他，怎么说将来叫奴痛杀。则他在断魂桥，盻上个人情雅。少年郎瞥见了冷嗟呀，又不曾背地里通些情话。又不曾向人前，眼角眉梢去调弄他。恰怎生半生纳纳彩，一剑分花，一剑分花。",
      "text_length": 92
    },
    {
      "event_id": "02010037_e00027",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "鸟夜啼",
      "speakers": [
        "李慧娘"
      ],
      "text": "手提着明晃晃钢刀一把，下场头轮到奴家。把奴的尸骸，仍葬在牡丹花。俺可也作鬼，作鬼风流杀。伴艳艳朝霞，冉冉春华，与他把天姿国色向人夸，怕的是风僝雨僽香魂乍。早些儿发付，有甚么争差，有甚么争差。",
      "text_length": 95
    },
    {
      "event_id": "02010037_e00028",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贾似道"
      ],
      "text": "我自动手，倒便宜你这贱婢，我有宝剑一口，拿去刎下头来见我。",
      "text_length": 29
    },
