      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "李慧娘"
      ],
      "text": "忽听金鸡报晓衙。",
      "text_length": 8
    },
    {
      "event_id": "02010037_e00033",
      "play_id": "02010037",
      "scene_id": "02010037_s01",
