  "events": [
    {
      "event_id": "70902136_e00001",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "江花右"
      ],
      "text": "花披露，月有影，青灯照得我如花容貌，别具精神。",
      "text_length": 23
    },
    {
      "event_id": "70902136_e00002",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海俊"
      ],
      "text": "啊，公公，我是饮不下了。",
      "text_length": 12
    },
    {
      "event_id": "70902136_e00003",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "呔！那一汉子竟敢擅入公主内室，休走，看剑！",
      "text_length": 21
    },
    {
      "event_id": "70902136_e00004",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海俊"
      ],
      "text": "啊！你……你敢是我妹子江花右么？",
      "text_length": 16
    },
    {
      "event_id": "70902136_e00005",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "是啊！兄长因何来到此地呀？",
      "text_length": 13
    },
    {
      "event_id": "70902136_e00006",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海俊"
      ],
      "text": "咳！再也不要提起。只因今日，那内侍叭喇，请我饮酒，不觉大醉，我也不晓得怎么会来到这里的呀。",
      "text_length": 45
    },
    {
      "event_id": "70902136_e00007",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "啊呀，兄长啊！此乃公主内室，倘有擅入者，斩首示众！",
      "text_length": 25
    },
    {
      "event_id": "70902136_e00008",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海俊"
      ],
      "text": "这个……啊呀，妹子啊，想我乃是中了奸人之计，你快快送我出去才好呀。",
      "text_length": 33
    },
    {
      "event_id": "70902136_e00009",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "这……好，随我来。",
      "text_length": 9
    },
    {
      "event_id": "70902136_e00010",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖节节高〗。",
      "text_length": 6
    },
    {
      "event_id": "70902136_e00011",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "啊呀兄长呀！公主她……",
      "text_length": 11
    },
    {
      "event_id": "70902136_e00012",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海俊"
      ],
      "text": "怎么？",
      "text_length": 3
    },
    {
      "event_id": "70902136_e00013",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "她回来了！",
      "text_length": 5
    },
    {
      "event_id": "70902136_e00014",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海俊"
      ],
      "text": "啊呀！",
      "text_length": 3
    },
    {
      "event_id": "70902136_e00015",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "海俊"
      ],
      "text": "我不道这场大祸，恐吉少又凶深。",
      "text_length": 15
    },
    {
      "event_id": "70902136_e00016",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "江花右引海俊藏在桌后。〖起二更鼓〗。",
      "text_length": 18
    },
    {
      "event_id": "70902136_e00017",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "百花公主"
      ],
      "text": "掌灯回亭者！",
      "text_length": 6
    },
    {
      "event_id": "70902136_e00018",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖出队子〗。宫女引百花公主同上。宫女下。〖小开门〗。百花公主坐定。〖乐止〗。",
      "text_length": 38
    },
    {
      "event_id": "70902136_e00019",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "天色不早，公主安睡了罢！",
      "text_length": 12
    },
    {
      "event_id": "70902136_e00020",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "百花公主"
      ],
      "text": "天色尚早。我来问你，昨日教你的兵法十三篇，可曾熟否？",
      "text_length": 26
    },
    {
      "event_id": "70902136_e00021",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "吖，烂熟的了。",
      "text_length": 7
    },
    {
      "event_id": "70902136_e00022",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "百花公主"
      ],
      "text": "好，你且背来。",
      "text_length": 7
    },
    {
      "event_id": "70902136_e00023",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "啊公主，你今日实是乏了，早些安睡罢。",
      "text_length": 18
    },
    {
      "event_id": "70902136_e00024",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "百花公主"
      ],
      "text": "不背么，也好。与我讲来。",
      "text_length": 12
    },
    {
      "event_id": "70902136_e00025",
      "play_id": "70902136",
      "scene_id": "70902136_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "江花右"
      ],
      "text": "是，我讲。",
      "text_length": 5
    },
    {
