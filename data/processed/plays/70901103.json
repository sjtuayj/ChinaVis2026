      "event_id": "70901103_e00060",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "红绣鞋",
      "speakers": [
        "孟良"
      ],
      "text": "一个儿脚尖踏。",
      "text_length": 7
    },
    {
      "event_id": "70901103_e00061",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "噫！",
      "text_length": 2
    },
    {
      "event_id": "70901103_e00062",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "红绣鞋",
      "speakers": [
        "孟良"
      ],
      "text": "好教俺半合儿傒幸杀。",
      "text_length": 10
    },
    {
      "event_id": "70901103_e00063",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "孟贤弟，元帅有件心事命你猜来，猜着用你，猜不着你自回避。",
      "text_length": 28
    },
    {
      "event_id": "70901103_e00064",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "元帅有心事，命俺猜来？",
      "text_length": 11
    },
    {
      "event_id": "70901103_e00065",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "70901103_e00066",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "嗨！待俺猜来，待俺猜来，待俺猜来，俺今番猜着了。",
      "text_length": 24
    },
    {
      "event_id": "70901103_e00067",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "猜着何来？",
      "text_length": 5
    },
    {
      "event_id": "70901103_e00068",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 68,
