      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "叫你回避。",
