  "events": [
    {
      "event_id": "70901103_e00001",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖急急风〗。四龙套、中军引杨延昭同上。",
      "text_length": 19
    },
    {
      "event_id": "70901103_e00002",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杨延昭"
      ],
      "text": "昨夜分明见严亲，休言梦里是非真。我今不把冤仇报，枉为英雄一世人。",
      "text_length": 32
    },
    {
      "event_id": "70901103_e00003",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "岳胜告进。",
      "text_length": 5
    },
    {
      "event_id": "70901103_e00004",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "岳胜上。",
      "text_length": 4
    },
    {
      "event_id": "70901103_e00005",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "元帅在上，岳胜打恭。",
      "text_length": 10
    },
    {
      "event_id": "70901103_e00006",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "贤弟免礼，请坐。",
      "text_length": 8
    },
    {
      "event_id": "70901103_e00007",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "谢坐。元帅，今日为何开门恁早？",
      "text_length": 15
    },
    {
      "event_id": "70901103_e00008",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "贤弟有所不知，昨夜梦见老父托梦于我，对俺说，被番兵困在虎口交牙峪，内无粮草，外无救兵。我父差七郎兄弟前去雄关搬兵求救，不想被潘仁美乱箭射死。那时，我父盼兵不到，盼子不归，万般无奈，碰死在李陵碑下。尸首被番兵盗去，吊在幽州昊天塔上，每日用一百个小番各射一箭，名曰百箭会。那时我父幽魂疼痛难忍，来在三关渡口，托梦于我，叫我盗取爹爹骨殖而归，无计可施，故此伤感。",
      "text_length": 178
    },
    {
      "event_id": "70901103_e00009",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "吓元帅，既如此，何不领兵前去，抢回老元帅骨殖，有何不可？",
      "text_length": 28
    },
    {
      "event_id": "70901103_e00010",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "贤弟，若统大兵，番兵必然有所准备，怎得骨殖到手？此乃悄悄地行动，方能成功。",
      "text_length": 37
    },
    {
      "event_id": "70901103_e00011",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "待小弟同哥哥去。",
      "text_length": 8
    },
    {
      "event_id": "70901103_e00012",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "俱个去不得。惟有孟良兄弟方能成功。",
      "text_length": 17
    },
    {
      "event_id": "70901103_e00013",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "岳胜"
      ],
      "text": "元帅。只是孟良是个倔强性儿，使他去，他倒不去，不使他去，他偏要去。唯有用言语激发于他，方能前去。",
      "text_length": 48
    },
    {
      "event_id": "70901103_e00014",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "既如此，待我吩咐。中军过来。",
      "text_length": 14
    },
    {
      "event_id": "70901103_e00015",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "70901103_e00016",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "辕门把守，待孟良回来，就说元帅与将军议论紧急军情，用他不着，叫他回避。",
      "text_length": 35
    },
    {
      "event_id": "70901103_e00017",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "70901103_e00018",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "掩门。",
      "text_length": 3
    },
    {
      "event_id": "70901103_e00019",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。孟良上。",
      "text_length": 9
    },
    {
      "event_id": "70901103_e00020",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孟良"
      ],
      "text": "伽山太保显英豪，昼夜巡边不惮劳。饶尔番兵千百万，撞着咱，胆战魂魄消。",
      "text_length": 34
    },
    {
      "event_id": "70901103_e00021",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "俺孟良，奉着哥哥将令，巡察界河，一路平安无事，不免回复哥哥将令，须索走遭也。",
      "text_length": 38
    },
    {
      "event_id": "70901103_e00022",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "粉蝶儿",
      "speakers": [
        "孟良"
      ],
      "text": "这些时无处征伐，俺在那界河边，恰才巡罢。撞俺的一个个活捉生拿，涌彪躯舒猿臂，肝横胆乍。也不用将武艺盘咱，回头儿只看咱全身披挂。",
      "text_length": 63
    },
    {
      "event_id": "70901103_e00023",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "来此已是辕门，为何这等静悄悄地？呔！里面哪个小校在？",
      "text_length": 26
    },
    {
      "event_id": "70901103_e00024",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "中军上。",
      "text_length": 4
    },
    {
      "event_id": "70901103_e00025",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "孟将军回来了，巡查界河多有辛苦。",
      "text_length": 16
    },
    {
      "event_id": "70901103_e00026",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "小校，禀知元帅，说俺孟良巡查界河一路平安无事，俺今特来交令。",
      "text_length": 30
    },
    {
      "event_id": "70901103_e00027",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "元帅与岳将军在后帐议论紧急军情，用你不着，叫你回避。",
      "text_length": 26
    },
    {
      "event_id": "70901103_e00028",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "用哪个不着？",
      "text_length": 6
    },
    {
      "event_id": "70901103_e00029",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "用你不着。",
      "text_length": 5
    },
    {
      "event_id": "70901103_e00030",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "叫哪个回避？",
      "text_length": 6
    },
    {
