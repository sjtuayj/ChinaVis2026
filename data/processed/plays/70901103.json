      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "叫你回避。",
      "text_length": 5
    },
    {
      "event_id": "70901103_e00032",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "呔！小校吃我一斧！",
      "text_length": 9
    },
    {
      "event_id": "70901103_e00033",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "请元帅，啊呀杀人！",
      "text_length": 9
    },
    {
      "event_id": "70901103_e00034",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭、岳胜同上。",
      "text_length": 9
    },
    {
      "event_id": "70901103_e00035",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
