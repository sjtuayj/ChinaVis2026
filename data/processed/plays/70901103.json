      "event_id": "70901103_e00055",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "红绣鞋",
      "speakers": [
        "孟良"
      ],
      "text": "有甚么机密事，对孟良也合知么。",
      "text_length": 15
    },
    {
      "event_id": "70901103_e00056",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "岳胜与杨延昭耳语。",
      "text_length": 9
    },
    {
      "event_id": "70901103_e00057",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孟良"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "70901103_e00058",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "红绣鞋",
      "speakers": [
        "孟良"
      ],
      "text": "一个儿眼角觑，",
      "text_length": 7
    },
    {
      "event_id": "70901103_e00059",
      "play_id": "70901103",
      "scene_id": "70901103_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "他哪里知道？",
      "text_length": 6
    },
