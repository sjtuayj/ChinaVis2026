  "events": [
    {
      "event_id": "02001050_e00001",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛蕡、王翦、五雷孕妇同上，同摆阵。孙膑上，打阵，入阵，跪，挂双拐。",
      "text_length": 33
    },
    {
      "event_id": "02001050_e00002",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "孙膑"
      ],
      "text": "眼前一阵红光现，阴风吹得透体寒。醉卧埃尘神魂乱，放却青牛在那边。",
      "text_length": 32
    },
    {
      "event_id": "02001050_e00003",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂上。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00004",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "三哥醒来！",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00005",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "孙膑"
      ],
      "text": "耳边听得人叫喊，",
      "text_length": 8
    },
    {
      "event_id": "02001050_e00006",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "三哥！",
      "text_length": 3
    },
    {
      "event_id": "02001050_e00007",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "孙膑"
      ],
      "text": "又见贤弟在面前。",
      "text_length": 8
    },
    {
      "event_id": "02001050_e00008",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "贤弟到此何事？",
      "text_length": 7
    },
    {
      "event_id": "02001050_e00009",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "小弟前来搭救三哥出阵。",
      "text_length": 11
    },
    {
      "event_id": "02001050_e00010",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "有劳贤弟。",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00011",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "三哥，头上鲜花，往哪里去了？",
      "text_length": 14
    },
    {
      "event_id": "02001050_e00012",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "被那贼道，押在阵内了，三日内就要丧命。",
      "text_length": 19
    },
    {
      "event_id": "02001050_e00013",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "这便如何是好？",
      "text_length": 7
    },
    {
      "event_id": "02001050_e00014",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "要愚兄出阵，这也不难，除非有太上老君九转还魂丹、南极真人的太极图，才能出阵。",
      "text_length": 38
    },
    {
      "event_id": "02001050_e00015",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "三哥，这有何难？小弟前去，盗来法宝，救三哥出阵便了。",
      "text_length": 26
    },
    {
      "event_id": "02001050_e00016",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "孙膑",
        "毛遂"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "02001050_e00017",
      "play_id": "02001050",
      "scene_id": "02001050_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑、毛遂同下。毛蕡、王翦、五雷孕妇同暗下。",
      "text_length": 22
    },
    {
      "event_id": "02001050_e00018",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王禅上。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00019",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "王禅"
      ],
      "text": "久住深山，抛却尘缘。",
      "text_length": 10
    },
    {
      "event_id": "02001050_e00020",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "山人王禅，只因孙膑被打在五雷阵中。今有金眼毛遂，来盗仙丹，不免助他成功。",
      "text_length": 36
    },
    {
      "event_id": "02001050_e00021",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂上。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00022",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "毛遂"
      ],
      "text": "足踏祥云到高山，大胆来盗九转丹。",
      "text_length": 16
    },
    {
      "event_id": "02001050_e00023",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "来此已是云蒙山。我想王禅，炼成仙丹，焉肯送我？不免变作老君模样，诓他丹药便了。变！",
      "text_length": 41
    },
    {
      "event_id": "02001050_e00024",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂下。太上老君上。",
      "text_length": 10
    },
    {
      "event_id": "02001050_e00025",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "徒儿在哪里？",
      "text_length": 6
    },
    {
      "event_id": "02001050_e00026",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王禅跪。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00027",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "弟子王禅，迎接仙师。",
      "text_length": 10
    },
    {
      "event_id": "02001050_e00028",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "起来。",
      "text_length": 3
    },
    {
      "event_id": "02001050_e00029",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "谢仙师。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00030",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "你在洞中作什么来？",
      "text_length": 9
    },
    {
      "event_id": "02001050_e00031",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "弟子炼丹。",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00032",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "炼了多少？",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00033",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "两粒半。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00034",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "拿来我看。",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00035",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "是。仙师请看。",
      "text_length": 7
    },
    {
      "event_id": "02001050_e00036",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "呔！小心着看守洞门，我毛遂去也！",
      "text_length": 16
    },
    {
      "event_id": "02001050_e00037",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太上老君下。",
      "text_length": 6
    },
    {
      "event_id": "02001050_e00038",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "你看这畜牲胆大，戏耍山人。若不是念他为孙膑而来，焉能放他而去。",
      "text_length": 31
    },
    {
      "event_id": "02001050_e00039",
      "play_id": "02001050",
      "scene_id": "02001050_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王禅下。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00040",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太上老君上。",
      "text_length": 6
    },
    {
      "event_id": "02001050_e00041",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "太上老君"
      ],
      "text": "执掌三清，法令施行。",
      "text_length": 10
    },
    {
      "event_id": "02001050_e00042",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "山人，太上老君是也。今有毛遂，前来盗取太极图，救孙膑出阵。不免到洞外打坐，假装睡熟，让他盗去便了。",
      "text_length": 49
    },
    {
      "event_id": "02001050_e00043",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂上。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00044",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "毛遂"
      ],
      "text": "离了水帘洞，又盗八卦图。",
      "text_length": 12
    },
    {
      "event_id": "02001050_e00045",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "且住。你看这老儿睡着，待我盗来。",
      "text_length": 16
    },
    {
      "event_id": "02001050_e00046",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂盗图。",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00047",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "且住。我毛遂一生不作暗事，不免将他唤醒。呔！毛遂盗了你的八卦仙图，救那孙膑，即刻送来。",
      "text_length": 43
    },
    {
      "event_id": "02001050_e00048",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂下。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00049",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "你看这贼仙，将图盗去，不免去到云端，收回此宝便了。",
      "text_length": 25
    },
    {
      "event_id": "02001050_e00050",
      "play_id": "02001050",
      "scene_id": "02001050_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太上老君下。",
      "text_length": 6
    },
    {
      "event_id": "02001050_e00051",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 51,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛蕡、王翦、五雷孕妇同上，同摆阵。孙膑上，入阵。",
      "text_length": 24
    },
    {
      "event_id": "02001050_e00052",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 52,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "孙膑"
      ],
      "text": "盼想家园难得见，寸断肝肠不安然。",
      "text_length": 16
    },
    {
      "event_id": "02001050_e00053",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 53,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂上。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00054",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 54,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "三哥，小弟盗了金丹来了。",
      "text_length": 12
    },
    {
      "event_id": "02001050_e00055",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 55,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "盗了多少？",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00056",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 56,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "两粒半。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00057",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 57,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "与兄一粒，青牛一粒，剩下半粒，贤弟衔在口内。无有太极图，也是枉然。",
      "text_length": 33
    },
    {
      "event_id": "02001050_e00058",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 58,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "三哥请看。",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00059",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 59,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "好哇！",
      "text_length": 3
    },
    {
      "event_id": "02001050_e00060",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 60,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "孙膑"
      ],
      "text": "见图犹如天开眼，贤弟恩情重如山。打开了太极祥光现，（孙膑起，杀。毛蕡、王翦、五雷孕妇同暗下。孙膑用图照。王翦、毛蕡同上，同开打。孙膑打死毛蕡，毛蕡下。孙膑擒王翦。太上老君、王禅同暗上。）",
      "text_length": 93
    },
    {
      "event_id": "02001050_e00061",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 61,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "孙膑"
      ],
      "text": "阵中逃出了大罗神仙。",
      "text_length": 10
    },
    {
      "event_id": "02001050_e00062",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "且慢。他乃奉敕旨之人，不可伤他。",
      "text_length": 16
    },
    {
      "event_id": "02001050_e00063",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "看在师父面上，饶尔去罢。",
      "text_length": 12
    },
    {
      "event_id": "02001050_e00064",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 64,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王翦下。",
      "text_length": 4
    },
    {
      "event_id": "02001050_e00065",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 65,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "参拜师父。",
      "text_length": 5
    },
    {
      "event_id": "02001050_e00066",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 66,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太上老君"
      ],
      "text": "毛遂，我的太极图呢？",
      "text_length": 10
    },
    {
      "event_id": "02001050_e00067",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 67,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "多谢太极图。",
      "text_length": 6
    },
    {
      "event_id": "02001050_e00068",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 68,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王禅"
      ],
      "text": "毛遂，还我金丹。",
      "text_length": 8
    },
    {
      "event_id": "02001050_e00069",
      "play_id": "02001050",
      "scene_id": "02001050_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "金丹，被我三哥吞在肚内了。",
      "text_length": 13
    },
    {
      "event_id": "02001050_e00070",
      "play_id": "02001050",
