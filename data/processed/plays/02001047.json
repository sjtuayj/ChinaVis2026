  "events": [
    {
      "event_id": "02001047_e00001",
      "play_id": "02001047",
      "scene_id": "02001047_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王翦、四卒子同上。",
      "text_length": 9
    },
    {
      "event_id": "02001047_e00002",
      "play_id": "02001047",
      "scene_id": "02001047_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "可恼啊，可恼。本帅王翦。奉了师父之命，下山扶助秦始皇，兵吞六国。一路之上，迎风扫灭数国，只有燕、齐二国未平。本帅兴兵伐燕，瑞陵君孙操他父子，俱丧本帅钢鞭之下。谁知瘸夫孙膑，私下天台高山，与他父兄报仇。本帅被他杀得大败，免战高悬。当初下山之时，师父赐我信香一支：倘有急难之事，焚香叩求，必遣师兄下山。也罢，就此焚香叩拜。众将！",
      "text_length": 162
    },
    {
      "event_id": "02001047_e00003",
      "play_id": "02001047",
      "scene_id": "02001047_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四卒子"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02001047_e00004",
      "play_id": "02001047",
      "scene_id": "02001047_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "看香案伺候。",
      "text_length": 6
    },
    {
      "event_id": "02001047_e00005",
      "play_id": "02001047",
      "scene_id": "02001047_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "王翦"
      ],
      "text": "一柱信香叩天仙，过往力士听我言。香烟捧过垂花洞，等候师兄下高山。",
      "text_length": 32
    },
    {
      "event_id": "02001047_e00006",
      "play_id": "02001047",
      "scene_id": "02001047_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王翦、四卒子同下。",
      "text_length": 9
    },
    {
      "event_id": "02001047_e00007",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "海潮、清风、明月同上。",
      "text_length": 11
    },
    {
      "event_id": "02001047_e00008",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "海潮"
      ],
      "text": "养性参禅，修成大罗神仙。",
      "text_length": 12
    },
    {
      "event_id": "02001047_e00009",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "山人海朝。圣旨因秦始皇登基，他本是黄龙下界，玉帝牒文，兵吞六国。山人打发二徒弟王翦下山，投在秦国。始皇封为天宝元帅，起动大兵，征讨六国，不知何日已完劫数？山人今日，心神不定，不知所为何故？清风、明月童儿，",
      "text_length": 102
    },
    {
      "event_id": "02001047_e00010",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "清风",
        "明月"
      ],
      "text": "伺候师父。",
      "text_length": 5
    },
    {
      "event_id": "02001047_e00011",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "闪开洞门，外面看来。",
      "text_length": 10
    },
    {
      "event_id": "02001047_e00012",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "清风",
        "明月"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001047_e00013",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "力士暗上，走，下。",
      "text_length": 9
    },
    {
      "event_id": "02001047_e00014",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "清风",
        "明月"
      ],
      "text": "启禀师父：香烟吹到洞前。",
      "text_length": 12
    },
    {
      "event_id": "02001047_e00015",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "我山人出洞看来。",
      "text_length": 8
    },
    {
      "event_id": "02001047_e00016",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "力士上，走，下。",
      "text_length": 8
    },
    {
      "event_id": "02001047_e00017",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "02001047_e00018",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "海潮"
      ],
      "text": "睁慧眼在洞前仔细来观，却原来小王翦叩焚香烟。兵行至燕国中身临大难，孙伯龄杀得他免战高悬。叩求我遣能人将他扶助，方能够秦始皇一统江山。观罢了信香烟进洞打坐，叫一声众弟子细听我言。",
      "text_length": 88
    },
    {
      "event_id": "02001047_e00019",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "众徒儿，",
      "text_length": 4
    },
    {
      "event_id": "02001047_e00020",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "清风",
        "明月"
      ],
      "text": "师父。",
      "text_length": 3
    },
    {
      "event_id": "02001047_e00021",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "为师方才观看，香烟过去，却是你师兄王翦，兵至燕国，被天台山孙膑，杀得他免战高悬，叩求山人，遣能人下山，破却孙膑，方能进兵。也罢，唤你师兄上殿。",
      "text_length": 71
    },
    {
      "event_id": "02001047_e00022",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "清风",
        "明月"
      ],
      "text": "有请师兄。",
      "text_length": 5
    },
    {
      "event_id": "02001047_e00023",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛蕡上。",
      "text_length": 4
    },
    {
      "event_id": "02001047_e00024",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "毛蕡"
      ],
      "text": "弃凡学道在深山，八卦炉中看仙丹。",
      "text_length": 16
    },
    {
      "event_id": "02001047_e00025",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "参拜师父。",
      "text_length": 5
    },
    {
      "event_id": "02001047_e00026",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "一旁坐下。",
      "text_length": 5
    },
    {
      "event_id": "02001047_e00027",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "谢座。师父唤弟子上殿，有何法旨？",
      "text_length": 16
    },
    {
      "event_id": "02001047_e00028",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "方才山人，心血来潮，掐指一算，却原来是你师弟王翦，兵至燕国，被孙膑杀得大败，因此唤你出来，命你下山，扶助秦国，大战孙膑。",
      "text_length": 60
    },
    {
      "event_id": "02001047_e00029",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "师父，那孙膑法理高强，徒儿非是瘸夫的对手。",
      "text_length": 21
    },
    {
      "event_id": "02001047_e00030",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "为师赐你镇洞法宝，带下山去。",
      "text_length": 14
    },
    {
      "event_id": "02001047_e00031",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "但不知是何法宝？",
      "text_length": 8
    },
    {
      "event_id": "02001047_e00032",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "混元紫金锤、聚魂盒，外有五雷阴兵宝册，何愁不胜孙膑？",
      "text_length": 26
    },
    {
      "event_id": "02001047_e00033",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "有此法宝，弟子即刻下山。",
      "text_length": 12
    },
    {
      "event_id": "02001047_e00034",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "海潮"
      ],
      "text": "如此，听山人法旨：",
      "text_length": 9
    },
    {
      "event_id": "02001047_e00035",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "海潮"
      ],
      "text": "秦国君他本是黄龙下凡，应天命扫六国一统江山。那孙膑不该把天台山下，杀得你二师弟免战高悬。此一去带法宝将他扶助，劝孙膑弃红尘去归高山。小孙燕本是那青龙一转，交阵时休将他性命伤残。你若是破孙膑早早回转，休得要贪荣华不回高山。",
      "text_length": 110
    },
    {
      "event_id": "02001047_e00036",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "毛蕡"
      ],
      "text": "谨遵定我师命身下高山，带定了这法宝去到阵前。此一去但愿得功劳成定，愚弟子不染尘急转高山。",
      "text_length": 44
    },
    {
      "event_id": "02001047_e00037",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛蕡下。",
      "text_length": 4
    },
    {
      "event_id": "02001047_e00038",
      "play_id": "02001047",
      "scene_id": "02001047_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "海潮"
      ],
      "text": "毛蕡一去到阵前，扶助始皇定江山。",
      "text_length": 16
    },
    {
      "event_id": "02001047_e00039",
      "play_id": "02001047",
