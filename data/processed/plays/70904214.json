  "events": [
    {
      "event_id": "70904214_e00001",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "天使上。〖神仗儿〗。",
      "text_length": 10
    },
    {
      "event_id": "70904214_e00002",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天使"
      ],
      "text": "玉旨下，火灵圣母接旨。",
      "text_length": 11
    },
    {
      "event_id": "70904214_e00003",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众仙童引火灵圣母同上。",
      "text_length": 11
    },
    {
      "event_id": "70904214_e00004",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "迎接天使。",
      "text_length": 5
    },
    {
      "event_id": "70904214_e00005",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天使"
      ],
      "text": "玉帝有旨，大仙听宣。",
      "text_length": 10
    },
    {
      "event_id": "70904214_e00006",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "无量佛。",
      "text_length": 4
    },
    {
      "event_id": "70904214_e00007",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天使"
      ],
      "text": "诏曰，君为民表，民为君依，赤子之亡，惟敬尚在知命。今者晋室皇帝司马邺，逆天不道，乱法滥刑，信任奸邪，专恃狂惑。谗佞谣毒宫廷，义士捐魂狱底。有负民望，天不佑焉。命尔火灵圣母，率火部众神，齐下尘凡。将三宫六院及三司法、刑狱，尽行烧烟，以警将来。只有忠良义所当救。另行议奏。尔其钦哉。",
      "text_length": 139
    },
    {
      "event_id": "70904214_e00008",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "圣寿无疆。",
      "text_length": 5
    },
    {
      "event_id": "70904214_e00009",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天使"
      ],
      "text": "大仙即刻兴师，俺回复上帝去也。",
      "text_length": 15
    },
    {
      "event_id": "70904214_e00010",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "送天使。",
      "text_length": 4
    },
    {
      "event_id": "70904214_e00011",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天使"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "70904214_e00012",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "天使下。",
      "text_length": 4
    },
    {
      "event_id": "70904214_e00013",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "传谕火部诸神，尘凡去者。",
      "text_length": 12
    },
    {
      "event_id": "70904214_e00014",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众仙童"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "70904214_e00015",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "淘金令",
      "speakers": [
        "火灵圣母"
      ],
      "text": "仙舆下尘凡，静闭琼宫岛。云兴雾行，鸾鹤相随绕。离了清琼，投寻烦恼。堪笑君王行暴，子庶飘摇。忠臣义士皆已凋，如今焚也怎逆天条。六院三宫尽教一扫。（火灵圣母下。〖水龙吟〗。宫娥扶晋帝同上，过场，同下。〖水龙吟止〗。风火旗、火鸦军引火炬星君同上。火灵圣母上。）",
      "text_length": 127
    },
    {
      "event_id": "70904214_e00016",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "一枝花",
      "speakers": [
        "火灵圣母"
      ],
      "text": "一轮明月出海陬，万古江山秀。一片价清光兴玉岛，果然是瑞霭之秋，雾净云收。恨那些谗臣权相，搅乱了社稷江山，哪里有为国的把天心转扭。",
      "text_length": 64
    },
    {
      "event_id": "70904214_e00017",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "火灵圣母上高台，入座。",
      "text_length": 11
    },
    {
      "event_id": "70904214_e00018",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "火灵圣母"
      ],
      "text": "一片星辰浸月光，满天风露夜茫茫。谗臣惑主邦家乱，玉帝震怒降灾殃。",
      "text_length": 32
    },
    {
      "event_id": "70904214_e00019",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "俺乃，火灵圣母是也。今有晋室无道，玉帝大怒。命俺下凡焚宫烧狱。火炬星君。https://scripts.xikao.com/play/709042142018-08-24",
      "text_length": 85
    },
    {
      "event_id": "70904214_e00020",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火炬星君"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "70904214_e00021",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "焚宫者。",
      "text_length": 4
    },
    {
      "event_id": "70904214_e00022",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火炬星君"
      ],
      "text": "遵法旨。",
      "text_length": 4
    },
    {
      "event_id": "70904214_e00023",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火灵圣母"
      ],
      "text": "可笑那晋帝呵。",
      "text_length": 7
    },
    {
      "event_id": "70904214_e00024",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "四块玉",
      "speakers": [
        "火灵圣母"
      ],
      "text": "他他他，才罢了楚游，又入了阳台岫。这火打断了鸳鸯锦帐两绸缪，打断了梦入三更候。哪里有粉黛讴，哪里有娇娥宿，哪里管瑞霭之秋。",
      "text_length": 61
    },
    {
      "event_id": "70904214_e00025",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "风火旗、火鸦军引火炬星君同上。宫娥、晋帝同上，过场，同逃下。",
      "text_length": 30
    },
    {
      "event_id": "70904214_e00026",
      "play_id": "70904214",
      "scene_id": "70904214_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "幺篇",
      "speakers": [
        "火灵圣母"
      ],
      "text": "呀呀呀，倾刻间晋国喧如吼，闹嚷嚷乱煞了公与侯，闹嚷嚷乱煞了公与侯。一霎时铁壁铜监成尘垢，一霎时金银玉石都付横流。一霎时广寒宫变作凄凉周，一霎时五方六界四海光收。天崩地裂鬼笑神愁，似斜阳朱殷血透。眼见得人间灰烬，好教那宫廷作了荒丘。",
