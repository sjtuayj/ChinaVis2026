  "events": [
    {
      "event_id": "05004008_e00001",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四军校、旗牌、关羽同上。",
      "text_length": 12
    },
    {
      "event_id": "05004008_e00002",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "关羽"
      ],
      "text": "一片丹心扶炎汉，何日里恢复中原。",
      "text_length": 16
    },
    {
      "event_id": "05004008_e00003",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "关羽"
      ],
      "text": "徐州一战好惨然，相约三事依曹瞒。身在曹营心在汉，兄南弟北各一天。",
      "text_length": 32
    },
    {
      "event_id": "05004008_e00004",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "某，汉室关。徐州一战，被困土山。为保二嫂，暂归曹操。曹操待某，三日一小宴，五日一大宴；上马献金，下马献银。又赠美女十名，侍奉二嫂。这美女之中，有貂婵在内。想当年王司徒定下连环之计，诛了董卓。那貂婵女足智多谋，她可算巾帼丈夫也。军校，",
      "text_length": 116
    },
    {
      "event_id": "05004008_e00005",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四军校"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "05004008_e00006",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "看看可有明月？",
      "text_length": 7
    },
    {
      "event_id": "05004008_e00007",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四军校"
      ],
      "text": "皓月当空。",
      "text_length": 5
    },
    {
      "event_id": "05004008_e00008",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "将纱窗撑起。",
      "text_length": 6
    },
    {
      "event_id": "05004008_e00009",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "真乃是清秋天月色灿烂，广寒宫拥出了玉兔仙颜。照得某美英雄赤心肝胆，",
      "text_length": 33
    },
    {
      "event_id": "05004008_e00010",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "05004008_e00011",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "今夜晚心有事懒把书观。",
      "text_length": 11
    },
    {
      "event_id": "05004008_e00012",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "且住！董卓误国专权，就有貂婵耳！",
      "text_length": 16
    },
    {
      "event_id": "05004008_e00013",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "王司徒他把那连环计献，貂婵女可算得女中魁元。",
      "text_length": 22
    },
    {
      "event_id": "05004008_e00014",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "那貂婵是甚等之人，计谋多端。吾不免将她唤至帐前，问个明白。军校，",
      "text_length": 32
    },
    {
      "event_id": "05004008_e00015",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四军校同允。",
      "text_length": 6
    },
    {
      "event_id": "05004008_e00016",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "传貂婵进见。",
      "text_length": 6
    },
    {
      "event_id": "05004008_e00017",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四军校"
      ],
      "text": "貂婵进见。",
      "text_length": 5
    },
    {
      "event_id": "05004008_e00018",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "貂婵"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "05004008_e00019",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "貂婵上。",
      "text_length": 4
    },
    {
      "event_id": "05004008_e00020",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "貂婵"
      ],
      "text": "恨只恨多薄命苦从心上，白门楼诛良人进退两难。",
      "text_length": 22
    },
    {
      "event_id": "05004008_e00021",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "奴家貂婵。正在后楼侍奉二位主母，忽听君侯呼唤，吾只得捧茶向前便了。",
      "text_length": 33
    },
    {
      "event_id": "05004008_e00022",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "貂婵"
      ],
      "text": "奴好比花开放风再作践，老天爷何生奴苦命貂婵？曹丞相造铜雀打入下贱，貂婵女只落得声名倒悬。站立在宝帐口偷眼观看，见君侯坐虎帐好不威严！无奈何我只得捧茶进见，唬得我战兢兢不敢开言。",
      "text_length": 88
    },
    {
      "event_id": "05004008_e00023",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "下跪何人？",
      "text_length": 5
    },
    {
      "event_id": "05004008_e00024",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "侍女貂婵。",
      "text_length": 5
    },
    {
      "event_id": "05004008_e00025",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "怎不抬头？",
      "text_length": 5
    },
    {
      "event_id": "05004008_e00026",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "有罪不敢抬头。",
      "text_length": 7
    },
    {
      "event_id": "05004008_e00027",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "恕你无罪。",
      "text_length": 5
    },
    {
      "event_id": "05004008_e00028",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "谢君侯。",
      "text_length": 4
    },
    {
      "event_id": "05004008_e00029",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "05004008_e00030",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "关羽"
      ],
      "text": "见貂婵生来的沉鱼落雁，好一似天仙女降下广寒。怪不得凤仪亭父子们迷恋，父杀子子弑父人伦倒颠。",
      "text_length": 45
    },
    {
      "event_id": "05004008_e00031",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "貂婵，那厢有座，你且坐下。",
      "text_length": 13
    },
    {
      "event_id": "05004008_e00032",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "君侯在此，哪有小婢之座？",
      "text_length": 12
    },
    {
      "event_id": "05004008_e00033",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "你乃司徒之女，温侯之妻，焉有不坐之理？",
      "text_length": 19
    },
    {
      "event_id": "05004008_e00034",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "谢君侯。",
      "text_length": 4
    },
    {
      "event_id": "05004008_e00035",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "貂婵，不在虎牢关，来在曹营则甚？",
      "text_length": 16
    },
    {
      "event_id": "05004008_e00036",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "皆因水淹下邳，白门楼诛了良人吕布，曹丞相将奴打入下贱之辈。",
      "text_length": 29
    },
    {
      "event_id": "05004008_e00037",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "这也难说。你父将你先许吕布，后许董卓，是何意也？",
      "text_length": 24
    },
    {
      "event_id": "05004008_e00038",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "君侯若问此事，一言难尽。",
      "text_length": 12
    },
    {
      "event_id": "05004008_e00039",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "貂婵"
      ],
      "text": "未开言不由人泪流满面，",
      "text_length": 11
    },
    {
      "event_id": "05004008_e00040",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "貂婵"
      ],
      "text": "尊君侯在上面细听奴言：献帝爷坐江山信任阉宦，逼反了黄巾贼抖起狼烟。钜鹿村反张角天下大乱，把一个圣天子坐卧不安。吕奉先在丁府螟蛉呼唤，刺死了丁建阳后投董奸。董卓贼得虎子横行作乱，一心要谋汉室锦绣江山。满朝的文武官袖手旁站，因此上奴父女巧献连环。也非是小貂婵生来下贱，为的是献帝爷锦绣江山。到如今顾不得出头露面，",
      "text_length": 154
    },
    {
      "event_id": "05004008_e00041",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "貂婵"
      ],
      "text": "君侯啊！",
      "text_length": 4
    },
    {
      "event_id": "05004008_e00042",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "貂婵"
      ],
      "text": "望君侯施恻隐恕奴貂婵。",
      "text_length": 11
    },
    {
      "event_id": "05004008_e00043",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "05004008_e00044",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "关羽"
      ],
      "text": "听她言不由我心中嗟叹，她乃是有功女流落此间。董卓贼若不是她父女盘算，这江山到如今老贼专权。展愁眉睁凤眼心中转念，汉朝中论英雄谁占魁元？",
      "text_length": 67
    },
    {
      "event_id": "05004008_e00045",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "貂婵"
      ],
      "text": "汉朝中论英雄良人吕……",
      "text_length": 11
    },
    {
      "event_id": "05004008_e00046",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "关羽瞪眼看。",
      "text_length": 6
    },
    {
      "event_id": "05004008_e00047",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "05004008_e00048",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "貂婵"
      ],
      "text": "二君侯听此言怒发威严。吓得我战兢兢汗流粉面，汉朝中论英雄可算桃园。三将军如猛虎威风八面，跨一骑乌骓马似虎吐烟。乌油盔乌油甲天神发现，手使着丈八矛打将钢鞭。两军战吼一声如同电闪，二君侯可算得义气冲天。",
      "text_length": 99
    },
    {
      "event_id": "05004008_e00049",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "关羽"
      ],
      "text": "好一个貂婵女口能舌辩，一句话说的吾毛骨悚然。曾记得虎牢关一场大战，恼怒了某三弟奋勇当先。吼一声吓破了吕布肝胆，鞭打他紫金冠坠落马前。吕奉先他本是英雄好汉，某三弟可算得将中魁元。",
      "text_length": 88
    },
    {
      "event_id": "05004008_e00050",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "貂婵，",
      "text_length": 3
    },
    {
      "event_id": "05004008_e00051",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "关羽"
      ],
      "text": "你本是有功女谁敢轻慢？好比那浣纱婆西施一般。",
      "text_length": 22
    },
    {
      "event_id": "05004008_e00052",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "貂婵，暂且侍奉二位主母。等我大哥得了天下，定有封赠。下帐去罢。",
      "text_length": 31
    },
    {
      "event_id": "05004008_e00053",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂婵"
      ],
      "text": "谢君侯。",
      "text_length": 4
    },
    {
      "event_id": "05004008_e00054",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "貂婵"
      ],
      "text": "貂婵女听一言喜从天降，到如今拨浮云才见青天。但愿得刘皇叔把位来践，也不枉为国家下贱不堪。",
      "text_length": 44
    },
    {
      "event_id": "05004008_e00055",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "貂婵下。",
      "text_length": 4
    },
    {
      "event_id": "05004008_e00056",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "关羽"
      ],
      "text": "曹丞相他把那美色来献，哪知道汉关某义气冲天？我好比柳下惠坐怀不乱，又好比鲁男子闭户不贪。",
      "text_length": 44
    },
    {
      "event_id": "05004008_e00057",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "关羽"
      ],
      "text": "但愿皇叔把位参，重整汉室锦江山。平生正气冲霄汉，关某月下赞貂婵。",
      "text_length": 32
    },
    {
      "event_id": "05004008_e00058",
      "play_id": "05004008",
      "scene_id": "05004008_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}