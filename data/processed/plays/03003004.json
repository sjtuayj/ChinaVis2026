      "event_id": "03003004_e00062",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "就是咱们哥俩好。",
      "text_length": 8
    },
    {
      "event_id": "03003004_e00063",
