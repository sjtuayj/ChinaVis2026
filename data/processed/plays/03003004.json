  "events": [
    {
      "event_id": "03003004_e00001",
      "play_id": "03003004",
      "scene_id": "03003004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同上，同站门。秦琼上。",
      "text_length": 14
    },
    {
      "event_id": "03003004_e00002",
      "play_id": "03003004",
      "scene_id": "03003004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "秦琼"
      ],
      "text": "帐中奉了先生命，押运粮草走一程。",
      "text_length": 16
    },
    {
      "event_id": "03003004_e00003",
      "play_id": "03003004",
      "scene_id": "03003004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦琼"
      ],
      "text": "俺，秦琼。奉了先生将令，催押粮草，军前听用。军士们，趱行者！",
      "text_length": 30
    },
    {
      "event_id": "03003004_e00004",
      "play_id": "03003004",
      "scene_id": "03003004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00005",
      "play_id": "03003004",
      "scene_id": "03003004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "秦琼"
      ],
      "text": "押定车辆朝前进，一路之上要小心。",
      "text_length": 16
    },
    {
      "event_id": "03003004_e00006",
      "play_id": "03003004",
      "scene_id": "03003004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦琼、四龙套同下。",
      "text_length": 9
    },
    {
      "event_id": "03003004_e00007",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "单雄信"
      ],
      "text": "号令一声绑帐外，",
      "text_length": 8
    },
    {
      "event_id": "03003004_e00008",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "二刽子手"
      ],
      "text": "嘿！",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00009",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二刽子手、单雄信同上。",
      "text_length": 11
    },
    {
      "event_id": "03003004_e00010",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "哼……",
      "text_length": 3
    },
    {
      "event_id": "03003004_e00011",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "单雄信"
      ],
      "text": "不由得豪杰笑开怀。单人独骑我把唐营踹，只杀得众儿郎叫苦悲哀。遍野荒郊血成海，尸骨堆山无处葬埋。小唐童被某，",
      "text_length": 53
    },
    {
      "event_id": "03003004_e00012",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "胆吓坏，某二次被擒也应该。他劝某降唐某不爱，一心想坐九龙台。今生不能冤仇解，二十年投胎某再来。",
      "text_length": 47
    },
    {
      "event_id": "03003004_e00013",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同上一字儿，程咬金、罗成、徐茂公、李世民同上。",
      "text_length": 26
    },
    {
      "event_id": "03003004_e00014",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "李世民"
      ],
      "text": "将身来在营门外，只见雄信绑法台。",
      "text_length": 16
    },
    {
      "event_id": "03003004_e00015",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "看酒！",
      "text_length": 3
    },
    {
      "event_id": "03003004_e00016",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00017",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "李世民"
      ],
      "text": "一斗酒儿满满筛，尊声将军听开怀：你今饮了这斗酒，你我冤仇两丢开。",
      "text_length": 32
    },
    {
      "event_id": "03003004_e00018",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "见唐童把我牙咬坏，大骂无耻小奴才。我兄被你箭射坏，兵发洛阳为何来！今生不能够把仇解，你坐江山某再来。",
      "text_length": 50
    },
    {
      "event_id": "03003004_e00019",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "徐茂公"
      ],
      "text": "主公且坐营门外，为臣自有巧安排。",
      "text_length": 16
    },
    {
      "event_id": "03003004_e00020",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐茂公"
      ],
      "text": "看酒！",
      "text_length": 3
    },
    {
      "event_id": "03003004_e00021",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00022",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "徐茂公"
      ],
      "text": "一斗酒儿满满筛，尊声五弟听开怀：三十六人曾结拜，散了瓦岗又分开。非是愚兄将你害，各为其主把兵排。你今饮了这斗酒，切莫埋怨愚兄来。",
      "text_length": 64
    },
    {
      "event_id": "03003004_e00023",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "嘿！",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00024",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "休要提起来结拜，提起结拜怒满怀。你在唐营为元帅，某在洛阳为将才。叔宝、咬金被你拐，点手又唤罗成来。锦绣江山被你卖，你是个人面兽投胎。",
      "text_length": 66
    },
    {
      "event_id": "03003004_e00025",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "罗成"
      ],
      "text": "三哥且站营门外，小弟向前说开怀。",
      "text_length": 16
    },
    {
      "event_id": "03003004_e00026",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "酒来！",
      "text_length": 3
    },
    {
      "event_id": "03003004_e00027",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00028",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "罗成"
      ],
      "text": "一斗酒儿满满筛，我与五哥解愁怀。你今饮了这斗酒，生死之事莫悲哀。",
      "text_length": 32
    },
    {
      "event_id": "03003004_e00029",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "呸！",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00030",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "见罗成怒气冲天界，大骂忘恩负义小奴才。曾记得打散了瓦岗寨，曾记得一家大小洛阳来。我为你三贤府来盖，我为你花费许多财。我为你东床招驸马，我为你造下拜将台。忘恩负义投唐寨，花言巧语哄谁来。雄信一死英名在，",
      "text_length": 100
    },
    {
      "event_id": "03003004_e00031",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "罗成哪！奴才！",
      "text_length": 7
    },
    {
      "event_id": "03003004_e00032",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "单雄信"
      ],
      "text": "怕只怕乱箭攒身你死无葬埋。",
      "text_length": 13
    },
    {
      "event_id": "03003004_e00033",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "呸！着打。",
      "text_length": 5
    },
    {
      "event_id": "03003004_e00034",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00035",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "别打，别打，瞧我喽。别打，别打，瞧我喽。别打，别打，瞧着我啵！",
      "text_length": 31
    },
    {
      "event_id": "03003004_e00036",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "程咬金"
      ],
      "text": "贤弟且站营门外，愚兄上前说开怀。",
      "text_length": 16
    },
    {
      "event_id": "03003004_e00037",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "看酒！",
      "text_length": 3
    },
    {
      "event_id": "03003004_e00038",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00039",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "程咬金"
      ],
      "text": "一斗酒儿满满筛，尊声我的哥细听开怀：你今饮了头斗酒，管你的灵魂赴蓬莱。",
      "text_length": 35
    },
    {
      "event_id": "03003004_e00040",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "怎么，赴蓬莱？",
      "text_length": 7
    },
    {
      "event_id": "03003004_e00041",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "赴蓬莱。",
      "text_length": 4
    },
    {
      "event_id": "03003004_e00042",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "好啊，看酒来！干哪！",
      "text_length": 10
    },
    {
      "event_id": "03003004_e00043",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "看酒！",
      "text_length": 3
    },
    {
      "event_id": "03003004_e00044",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00045",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "程咬金"
      ],
      "text": "二斗酒儿满满筛，点点珠泪洒下来。你今饮了这斗酒，管你的灵魂上天台。",
      "text_length": 33
    },
    {
      "event_id": "03003004_e00046",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "怎么，上天台？",
      "text_length": 7
    },
    {
      "event_id": "03003004_e00047",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "上天台。",
      "text_length": 4
    },
    {
      "event_id": "03003004_e00048",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "好，看酒来！干哪！",
      "text_length": 9
    },
    {
      "event_id": "03003004_e00049",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "好海量，好海量！斟酒！",
      "text_length": 11
    },
    {
      "event_id": "03003004_e00050",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03003004_e00051",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "程咬金"
      ],
      "text": "三斗酒儿满满筛，尊声我的哥细听明白：贾家楼曾结拜，惟有你我同心怀。我的哥一死威名在，且把美酒饮开怀。你今饮了这斗酒，拿住他们一刀一个把刀开，把我丢开。",
      "text_length": 75
    },
    {
      "event_id": "03003004_e00052",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "怎么，把你丢开？",
      "text_length": 8
    },
    {
      "event_id": "03003004_e00053",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "对喽，把我丢开。",
      "text_length": 8
    },
    {
      "event_id": "03003004_e00054",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "好哇！",
      "text_length": 3
    },
    {
      "event_id": "03003004_e00055",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "这句话儿真爽快，",
      "text_length": 8
    },
    {
      "event_id": "03003004_e00056",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "我就好说直话吗！",
      "text_length": 8
    },
    {
      "event_id": "03003004_e00057",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "贤弟把酒斟上来。",
      "text_length": 8
    },
    {
      "event_id": "03003004_e00058",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "好，您喝嗻！",
      "text_length": 6
    },
    {
      "event_id": "03003004_e00059",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "贾家楼曾结拜，",
      "text_length": 7
    },
    {
      "event_id": "03003004_e00060",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "不错，咱们拜过把子。",
      "text_length": 10
    },
    {
      "event_id": "03003004_e00061",
      "play_id": "03003004",
      "scene_id": "03003004_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "单雄信"
      ],
      "text": "惟有你我同心怀。",
