  "events": [
    {
      "event_id": "80000007_e00001",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "杨继业"
      ],
      "text": "金乌坠玉兔升黄昏时候，",
      "text_length": 11
    },
    {
      "event_id": "80000007_e00002",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业上。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00003",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "杨继业"
      ],
      "text": "盼姣儿不由人珠泪双流。",
      "text_length": 11
    },
    {
      "event_id": "80000007_e00004",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄快三眼",
      "speakers": [
        "杨继业"
      ],
      "text": "七郎儿回雁门搬兵求救，为什么此一去不见回头？唯恐那潘仁美记起前扣，怕的是我的儿一命罢休。含悲泪进大营双眉愁皱，腹内饥身寒冷遍体飕飕。",
      "text_length": 66
    },
    {
      "event_id": "80000007_e00005",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业睡。杨延昭上。",
      "text_length": 10
    },
    {
      "event_id": "80000007_e00006",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨延昭"
      ],
      "text": "听谯楼打罢了二更时分，杨延昭倒作了巡夜之人。迈虎步且把那大营来进，又只见老爹爹瞌睡沉沉。我这里用袍服与父遮冷，等候了我七弟搬兵回营。",
      "text_length": 66
    },
    {
      "event_id": "80000007_e00007",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭睡。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00008",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "杨继业"
      ],
      "text": "我方才蒙胧将养静，",
      "text_length": 9
    },
    {
      "event_id": "80000007_e00009",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业醒。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00010",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "又只见六郎儿瞌睡沉沉。",
      "text_length": 11
    },
    {
      "event_id": "80000007_e00011",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "我儿醒来！",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00012",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨延昭"
      ],
      "text": "方才一梦得唤醒，",
      "text_length": 8
    },
    {
      "event_id": "80000007_e00013",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭醒。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00014",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨延昭"
      ],
      "text": "只见爹爹面前存。",
      "text_length": 8
    },
    {
      "event_id": "80000007_e00015",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "哎呀，儿啊！你七弟回转雁门，搬取救应，如今杳无音信。为父放心不下，我儿快快杀出重围，探听你七弟下落，为父的也好放心哪！",
      "text_length": 59
    },
    {
      "event_id": "80000007_e00016",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "孩儿不去！",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00017",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "为何不去？",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00018",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹年迈，无人侍奉。孩儿不去！",
      "text_length": 15
    },
    {
      "event_id": "80000007_e00019",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "为父的么？为父虽老，有道是：虎老雄心在。儿只管前去。",
      "text_length": 26
    },
    {
      "event_id": "80000007_e00020",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "孩儿不去！",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00021",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "当真不去？",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00022",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "当真不去！",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00023",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "儿啊，为父倒有父子之情，难道我儿，就无有手足之义了么？",
      "text_length": 27
    },
    {
      "event_id": "80000007_e00024",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹不必如此，孩儿愿去就是。",
      "text_length": 14
    },
    {
      "event_id": "80000007_e00025",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "好，快快上马去罢！",
      "text_length": 9
    },
    {
      "event_id": "80000007_e00026",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹呀！",
      "text_length": 4
    },
    {
      "event_id": "80000007_e00027",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨延昭"
      ],
      "text": "倘若胡儿来骂阵，紧守大营莫出兵。辞别爹爹足踏蹬，探听七弟走一程。",
      "text_length": 32
    },
    {
      "event_id": "80000007_e00028",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "杨继业",
        "杨延昭"
      ],
      "text": "（六郎）（爹爹），（延昭）（我父）！",
      "text_length": 18
    },
    {
      "event_id": "80000007_e00029",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹呀！罢！",
      "text_length": 6
    },
    {
      "event_id": "80000007_e00030",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭下。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00031",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "杨继业"
      ],
      "text": "啊！我的儿啊！",
      "text_length": 7
    },
    {
      "event_id": "80000007_e00032",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "见姣儿上了马能行，指着潘洪发恨声。我儿若有好和歹，",
      "text_length": 25
    },
    {
      "event_id": "80000007_e00033",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "潘洪啊，贼！",
      "text_length": 6
    },
    {
      "event_id": "80000007_e00034",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "定把老命与尔拚！",
      "text_length": 8
    },
    {
      "event_id": "80000007_e00035",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "儿啊！",
      "text_length": 3
    },
    {
      "event_id": "80000007_e00036",
      "play_id": "80000007",
      "scene_id": "80000007_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业下。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00037",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四番兵引韩延寿同上。",
      "text_length": 10
    },
    {
      "event_id": "80000007_e00038",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "韩延寿"
      ],
      "text": "奉了太后旨，把守在雁门。",
      "text_length": 12
    },
    {
      "event_id": "80000007_e00039",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩延寿"
      ],
      "text": "某，韩延寿。奉了太后旨意，把守雁门关。儿郎的，",
      "text_length": 23
    },
    {
      "event_id": "80000007_e00040",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四番兵"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "80000007_e00041",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩延寿"
      ],
      "text": "雁门关去者。",
      "text_length": 6
    },
    {
      "event_id": "80000007_e00042",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四番兵"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "80000007_e00043",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭上。会阵。",
      "text_length": 8
    },
    {
      "event_id": "80000007_e00044",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "何人挡住俺的去路？",
      "text_length": 9
    },
    {
      "event_id": "80000007_e00045",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩延寿"
      ],
      "text": "韩延寿要尔的狗命！",
      "text_length": 9
    },
    {
      "event_id": "80000007_e00046",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "一派胡言，放马过来。",
      "text_length": 10
    },
    {
      "event_id": "80000007_e00047",
      "play_id": "80000007",
      "scene_id": "80000007_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭、韩延寿同开打，杨延昭下。韩延寿、四番兵同追下。",
      "text_length": 27
    },
    {
      "event_id": "80000007_e00048",
      "play_id": "80000007",
      "scene_id": "80000007_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭上。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00049",
      "play_id": "80000007",
      "scene_id": "80000007_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "杨延昭"
      ],
      "text": "休赶哪，休赶！",
      "text_length": 7
    },
    {
      "event_id": "80000007_e00050",
      "play_id": "80000007",
      "scene_id": "80000007_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨延昭"
      ],
      "text": "打破玉笼飞彩凤，顿断金锁走蛟龙！",
      "text_length": 16
    },
    {
      "event_id": "80000007_e00051",
      "play_id": "80000007",
      "scene_id": "80000007_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭下。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00052",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 52,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四老军扛弓刀引杨继业上。",
      "text_length": 12
    },
    {
      "event_id": "80000007_e00053",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 53,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "杨继业"
      ],
      "text": "叹杨家秉忠心大宋扶保，到如今只落得兵败荒郊。恨北国萧营中打来战表，擅抢夺我主爷的锦绣龙朝。贼潘洪在金殿帅印挂了，我父子倒作了马前的英豪。金沙滩双龙会一阵败了，只杀得血成河鬼哭神嚎。我的大郎儿替宋王把忠尽了，二郎儿短剑下命赴阴曹；杨三郎被马踏尸首不晓，四八郎失番邦无有下梢；杨五郎在五台学禅修道，七郎儿被潘洪箭射花标。只落得杨延昭随营征剿，可怜他尽得忠，又尽孝，血染沙场、马不停蹄，为国辛劳。可怜我八个子把四子丧了，把四子丧了，我的儿啊！",
      "text_length": 218
    },
    {
      "event_id": "80000007_e00054",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 54,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "可怜我一家人无有下梢。魍魉臣与潘洪又生计巧，请我主到五台快乐逍遥。又谁知中了那奸贼笼套，四下里众番儿犹如海潮。多亏了杨延昭一马来到，一杆枪保圣驾闯出笼牢。有老夫二次里又闯贼道，害得我东西杀砍、左冲右突、虎撞羊群，被困在两狼山，里无有粮，外无有草，盼兵不到，眼见得我这老残生就难以还朝！我的儿啊！",
      "text_length": 147
    },
    {
      "event_id": "80000007_e00055",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 55,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四老军"
      ],
      "text": "饿呀！",
      "text_length": 3
    },
    {
      "event_id": "80000007_e00056",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 56,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "饥饿了就该把战马宰了，",
      "text_length": 11
    },
    {
      "event_id": "80000007_e00057",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 57,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四老军"
      ],
      "text": "冷呀！",
      "text_length": 3
    },
    {
      "event_id": "80000007_e00058",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 58,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "身寒冷就该把大营焚烧。",
      "text_length": 11
    },
    {
      "event_id": "80000007_e00059",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 59,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四老军"
      ],
      "text": "雁来了。",
      "text_length": 4
    },
    {
      "event_id": "80000007_e00060",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 60,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "啊？",
      "text_length": 2
    },
    {
      "event_id": "80000007_e00061",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 61,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四老军"
      ],
      "text": "雁来了。",
      "text_length": 4
    },
    {
      "event_id": "80000007_e00062",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业持弓搭箭，弦断。",
      "text_length": 11
    },
    {
      "event_id": "80000007_e00063",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "宝雕弓打不着空中飞鸟，弓炸弦断就为的是哪条？",
      "text_length": 22
    },
    {
      "event_id": "80000007_e00064",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 64,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "探子"
      ],
      "text": "报！",
      "text_length": 2
    },
    {
      "event_id": "80000007_e00065",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 65,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "探子上。",
      "text_length": 4
    },
    {
      "event_id": "80000007_e00066",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 66,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "探子"
      ],
      "text": "石虎将爷战马绞倒。",
      "text_length": 9
    },
    {
      "event_id": "80000007_e00067",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 67,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "不、不、不、不好了！",
      "text_length": 10
    },
    {
      "event_id": "80000007_e00068",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 68,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "探子下。",
      "text_length": 4
    },
    {
      "event_id": "80000007_e00069",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "恨石虎把我的战马绞倒，为大将无良骑怎把战交？抬过了定宋刀爷把路找，",
      "text_length": 33
    },
    {
      "event_id": "80000007_e00070",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四老军同下。",
      "text_length": 6
    },
    {
      "event_id": "80000007_e00071",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 71,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "寻一个避风所再作计较。",
      "text_length": 11
    },
    {
      "event_id": "80000007_e00072",
      "play_id": "80000007",
      "scene_id": "80000007_s04",
      "scene_no": 4,
      "seq_global": 72,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业下。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00073",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 73,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苏隐士上。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00074",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 74,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "苏隐士"
      ],
      "text": "天下荒荒刀兵乱，黎民涂炭不得安。",
      "text_length": 16
    },
    {
      "event_id": "80000007_e00075",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 75,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏隐士"
      ],
      "text": "老汉，苏隐士，乃南朝人也。当年大战北国，流落在此，每日在这海上牧羊度日。闻听南朝差来大将杨继业，被番兵杀得大败，被困在这两狼山下，内无粮草，外无救兵，倘若被番兵擒去，可叹他一世的忠良付与流水。是老汉在苏武庙前、李陵碑下刻下诗句一首，激他之怒，盗去宝刀，成全他一世英名也。",
      "text_length": 135
    },
    {
      "event_id": "80000007_e00076",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 76,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "苏隐士"
      ],
      "text": "可叹忠良遭大难，那旁来了一将官。",
      "text_length": 16
    },
    {
      "event_id": "80000007_e00077",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 77,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业上。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00078",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 78,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "当年保驾五台山，智空长老对我言：他道我后来遭大难，到如今果应那智空言。",
      "text_length": 35
    },
    {
      "event_id": "80000007_e00079",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 79,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "来此不知什么所在？",
      "text_length": 9
    },
    {
      "event_id": "80000007_e00080",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 80,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏隐士"
      ],
      "text": "嗯哼！",
      "text_length": 3
    },
    {
      "event_id": "80000007_e00081",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 81,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "那厢有一老丈，向前问来。啊，老丈请了。",
      "text_length": 19
    },
    {
      "event_id": "80000007_e00082",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 82,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏隐士"
      ],
      "text": "请了。这位将军，敢么失迷路途么？",
      "text_length": 16
    },
    {
      "event_id": "80000007_e00083",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 83,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "请问老丈，此处什么所在？",
      "text_length": 12
    },
    {
      "event_id": "80000007_e00084",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 84,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏隐士"
      ],
      "text": "你来看：",
      "text_length": 4
    },
    {
      "event_id": "80000007_e00085",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 85,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "苏隐士"
      ],
      "text": "此处是两狼，前面摆战场。到此有埋伏，犯者一命亡。",
      "text_length": 24
    },
    {
      "event_id": "80000007_e00086",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 86,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "请问老丈，在此作甚？",
      "text_length": 10
    },
    {
      "event_id": "80000007_e00087",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 87,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏隐士"
      ],
      "text": "在此牧羊。",
      "text_length": 5
    },
    {
      "event_id": "80000007_e00088",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 88,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "这样兵荒马乱，你还牧的什么羊啊？",
      "text_length": 16
    },
    {
      "event_id": "80000007_e00089",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 89,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏隐士"
      ],
      "text": "兵荒不兵荒，与我实无妨。老汉无别干，在此牧老羊。",
      "text_length": 24
    },
    {
      "event_id": "80000007_e00090",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 90,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "难道这老羊还有什么贵处么？",
      "text_length": 13
    },
    {
      "event_id": "80000007_e00091",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 91,
      "seq_in_scene": 19,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "苏隐士"
      ],
      "text": "提起此羊有贵处，他的名儿万古扬。生下几个羊羔子，烈烈轰轰在世上。前者几个死，今日一个亡。逃生是忘想，今日死老羊。",
      "text_length": 56
    },
    {
      "event_id": "80000007_e00092",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 92,
      "seq_in_scene": 20,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏隐士"
      ],
      "text": "老羊与我死！",
      "text_length": 6
    },
    {
      "event_id": "80000007_e00093",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 93,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "老丈说话理不通，分明道我杨令公！定宋宝刀将你砍，",
      "text_length": 24
    },
    {
      "event_id": "80000007_e00094",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 94,
      "seq_in_scene": 22,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苏隐士收刀，下。",
      "text_length": 8
    },
    {
      "event_id": "80000007_e00095",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 95,
      "seq_in_scene": 23,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "杨继业"
      ],
      "text": "霎时不见我的护身龙。",
      "text_length": 10
    },
    {
      "event_id": "80000007_e00096",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 96,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "且住。老丈将我的宝刀收去。为大将者，宁舍千军，不舍寸铁。待我赶上前去。“苏武庙”，进庙走走。",
      "text_length": 46
    },
    {
      "event_id": "80000007_e00097",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 97,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业进庙。",
      "text_length": 6
    },
    {
      "event_id": "80000007_e00098",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 98,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "那厢有一碑碣，向前看来。“李陵碑”，呀呀呸！汉室李陵，乃是大大的奸佞，不知何人与他立的什么碑碣！上面还有几行小字，待我仔细看来：",
      "text_length": 64
    },
    {
      "event_id": "80000007_e00099",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 99,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "杨继业"
      ],
      "text": "庙是苏武庙，碑是李陵碑，令公来到此，卸甲又丢盔！",
      "text_length": 24
    },
    {
      "event_id": "80000007_e00100",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 100,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业丢盔弃甲。",
      "text_length": 8
    },
    {
      "event_id": "80000007_e00101",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 101,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "且住！老夫被困在两狼山，盼兵兵不到，望子子不归，白日受饥饿，夜晚被风吹。也罢，不免拜谢宋王爵禄之恩，我就碰死在李陵碑下！",
      "text_length": 60
    },
    {
      "event_id": "80000007_e00102",
      "play_id": "80000007",
      "scene_id": "80000007_s05",
      "scene_no": 5,
      "seq_global": 102,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业碰碑，死。",
      "text_length": 8
    }
  ],
  "roles_inferred": true
}