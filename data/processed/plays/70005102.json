  "events": [
    {
      "event_id": "70005102_e00001",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "甲岳、乙岳、丙岳、丁岳同上。",
      "text_length": 14
    },
    {
      "event_id": "70005102_e00002",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "甲岳"
      ],
      "text": "比户皆可封，",
      "text_length": 6
    },
    {
      "event_id": "70005102_e00003",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "乙岳"
      ],
      "text": "尤存太古风；",
      "text_length": 6
    },
    {
      "event_id": "70005102_e00004",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "丙岳"
      ],
      "text": "唐尧称盛世，",
      "text_length": 6
    },
    {
      "event_id": "70005102_e00005",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "丁岳"
      ],
      "text": "化育九州同。",
      "text_length": 6
    },
    {
      "event_id": "70005102_e00006",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甲岳",
        "乙岳",
        "丙岳",
        "丁岳"
      ],
      "text": "我等四岳是也。",
      "text_length": 7
    },
    {
      "event_id": "70005102_e00007",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "甲岳"
      ],
      "text": "列位请了！圣上登殿，分班侍立。",
      "text_length": 15
    },
    {
      "event_id": "70005102_e00008",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四侍臣引尧帝同上。",
      "text_length": 9
    },
    {
      "event_id": "70005102_e00009",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "尧帝"
      ],
      "text": "传贤不传子，官天下，大公无私。",
      "text_length": 15
    },
    {
      "event_id": "70005102_e00010",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "尧帝"
      ],
      "text": "土阶茅茨自辛勤，也是国家一庶民。君臣共治安天下，元首股肱本一身。",
      "text_length": 32
    },
    {
      "event_id": "70005102_e00011",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "孤，帝尧在位。自登基以来，励精图国，勤求民隐，数十年来四海义治，万民乐业；无如年迈，难以日理万机，朕若传位与子，怎奈我儿丹朱不肖，必然误尽苍生，酿纷争于天下，终有国破家亡之一日。朕欲传位于贤，上顺天心，下和民意。舍一姓之尊荣，保全国之安乐，岂不美哉。啊，众卿！",
      "text_length": 130
    },
    {
      "event_id": "70005102_e00012",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甲岳",
        "乙岳",
        "丙岳",
        "丁岳"
      ],
      "text": "万岁！",
      "text_length": 3
    },
    {
      "event_id": "70005102_e00013",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "孤想天下乃天下人之天下，非一人之天下，有德者居之，无德者失之。朕之子不肖，不堪为君，意欲传位于贤，以让有德之人，岂不是一国之利，万民之福。朕在宫中不知外事，千里一俊，万里一贤，众卿必有所知。奏与朕躬以便奉请。万不可徒慕其名，不察其实，使朕传位非人，遗害于天下也。",
      "text_length": 131
    },
    {
      "event_id": "70005102_e00014",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甲岳",
        "乙岳",
        "丙岳",
        "丁岳"
      ],
      "text": "万岁以君位公于天下，传贤不传子，足征圣德高深，真万民之福也。臣等夙知布衣许由，乃当今贤者，品行清高，学识深远，敬奉此人以继帝位，天下幸甚，未知圣意如何？",
      "text_length": 76
    },
    {
      "event_id": "70005102_e00015",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "一人之智识有限，万民之舆论无私。既卿等同举此人，必名下不虚，但不知现居何地？",
      "text_length": 38
    },
    {
      "event_id": "70005102_e00016",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甲岳",
        "乙岳",
        "丙岳",
        "丁岳"
      ],
      "text": "就在箕山居住。",
      "text_length": 7
    },
    {
      "event_id": "70005102_e00017",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "好！吩咐武士保驾，众卿随朕一同前去迎接便了。",
      "text_length": 22
    },
    {
      "event_id": "70005102_e00018",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甲岳",
        "乙岳",
        "丙岳",
        "丁岳"
      ],
      "text": "臣等领旨！武士走上！",
      "text_length": 10
    },
    {
      "event_id": "70005102_e00019",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四武士持金瓜钺斧同上。",
      "text_length": 15
    },
    {
      "event_id": "70005102_e00020",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甲岳",
        "乙岳",
        "丙岳",
        "丁岳"
      ],
      "text": "起驾浮云村。",
      "text_length": 6
    },
    {
      "event_id": "70005102_e00021",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "尧帝"
      ],
      "text": "自登基恶民所恶好民所好，国承平民安泰快乐逍遥。朕有心传于子奈儿不肖，为国民谋治安传位于贤豪。可叹那无道君自私自保，全不想与百姓原是同胞。只为你一姓人富贵荣耀，怎忍得天下人鬼哭神嚎。谁能保子与孙人人有道，反不如官天下免动枪刀。有四岳在金殿把贤人荐了，因此上访许由亲到荒郊。但愿得将天下早早让掉，",
      "text_length": 146
    },
    {
      "event_id": "70005102_e00022",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "免得朕担重任国事勤劳。",
      "text_length": 11
    },
    {
      "event_id": "70005102_e00023",
      "play_id": "70005102",
      "scene_id": "70005102_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "70005102_e00024",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许由上。",
      "text_length": 4
    },
    {
      "event_id": "70005102_e00025",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "许由"
      ],
      "text": "笑世人口圣贤心同贼盗，或争权或夺利不让分毫。全不想国若亡家也难保，一霎时冰山倒火灭烟消。位愈尊身愈险你可知道？又何必争天下糜烂同胞？不如我谈风月山林啸傲，终日间无忧虑自在逍遥。",
      "text_length": 88
    },
    {
      "event_id": "70005102_e00026",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四御林军、四内侍、四岳引尧帝同上。",
      "text_length": 17
    },
    {
      "event_id": "70005102_e00027",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "离都城访箕山眼前到了，为访贤朕不辞路远山遥。但愿得让贤人修明政教，从此后一身轻免把心操。向前去叩柴扉急忙通报，",
      "text_length": 55
    },
    {
      "event_id": "70005102_e00028",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "许由"
      ],
      "text": "忽听得柴门外有人喊叫。马蹄乱人声众谁来寻找？",
      "text_length": 22
    },
    {
      "event_id": "70005102_e00029",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "朕亲身迎贤者同驾入朝。",
      "text_length": 11
    },
    {
      "event_id": "70005102_e00030",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "许由"
      ],
      "text": "听此言不由我心惊肉跳，我怎肯自由身坠入笼牢？放民力君无权必然纷扰，重君权民不利烦恼自招。观时势万不能两面见好，这虚名真误人徒惹风潮。不如我脱身走不见为妙，且将这闭门羹款待帝尧。",
      "text_length": 88
    },
    {
      "event_id": "70005102_e00031",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许由暗从后门逃出，下。",
      "text_length": 11
    },
    {
      "event_id": "70005102_e00032",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "半晌时不见人开门来到，转面来问群臣事有蹊跷！",
      "text_length": 22
    },
    {
      "event_id": "70005102_e00033",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "朕立侍许久，因何不开门相见？",
      "text_length": 14
    },
    {
      "event_id": "70005102_e00034",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "甲岳",
        "乙岳",
        "丙岳",
        "丁岳"
      ],
      "text": "那许由品行孤高，从不交结富贵之人，或闻车马声喧，从后门逃走，也未可知！",
      "text_length": 35
    },
    {
      "event_id": "70005102_e00035",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "卫士，看他家可有后门？",
      "text_length": 11
    },
    {
      "event_id": "70005102_e00036",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "卫士"
      ],
      "text": "有后门如今大开。",
      "text_length": 8
    },
    {
      "event_id": "70005102_e00037",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "好好替许先生看守门户。众卿随朕家追赶先生回来便了！",
      "text_length": 25
    },
    {
      "event_id": "70005102_e00038",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "许先生果然是性情高傲，为访贤顾不得跋涉勤劳。",
      "text_length": 22
    },
    {
      "event_id": "70005102_e00039",
      "play_id": "70005102",
      "scene_id": "70005102_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "70005102_e00040",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许由上。",
      "text_length": 4
    },
    {
      "event_id": "70005102_e00041",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "许由"
      ],
      "text": "借羽毛任翱翔出笼飞鸟，笑燕雀怎知道鸿鹄高超。看富贵如浮云不贪荣耀，天子尊百姓卑何必结交？因此上从后门急忙逃跑，",
      "text_length": 55
    },
    {
      "event_id": "70005102_e00042",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四御林军、四内侍、四岳引尧帝同上。",
      "text_length": 17
    },
    {
      "event_id": "70005102_e00043",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "请先生且留步有事相邀。",
      "text_length": 11
    },
    {
      "event_id": "70005102_e00044",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "许先生，慢走！",
      "text_length": 7
    },
    {
      "event_id": "70005102_e00045",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "原来是天子下降，待小民参拜。",
      "text_length": 14
    },
    {
      "event_id": "70005102_e00046",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "先生乃当世名贤，何拘这君臣俗礼？",
      "text_length": 16
    },
    {
      "event_id": "70005102_e00047",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "小民无德无才，何贤之有？不过虚名误人而已。",
      "text_length": 21
    },
    {
      "event_id": "70005102_e00048",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尧帝"
      ],
      "text": "先生不必太谦，朕年已迈，生子不肖，诚恐误国殃民。故别求贤君，以继大位。询于群臣，共举先生，先生当以苍生为重，幸勿固辞，天下幸甚。",
      "text_length": 64
    },
    {
      "event_id": "70005102_e00049",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "万岁此言差矣。",
      "text_length": 7
    },
    {
      "event_id": "70005102_e00050",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "许由"
      ],
      "text": "闻此言不由我微微冷笑，为什么圣天子下询刍荛？万岁你一席话太过谦了，有什么滔天祸如此心焦？你只当皇帝位有如重宝，在我看皇帝位不值分毫：遇荒旱就怨你赈济太少，遭兵旱又恨你无有略韬；逢水灾总怪你治河未好，外国侵便说你不重邦交。哪一个帝王家富贵长保？反惹起普天下乱动枪刀。自古来成者王败者强盗，争权利自相残害死同胞。似这等危险位我不入圈套，居皇宫终日里如坐监牢。出宫门众文武前后围绕，心也惊胆也怕魂魄皆消。以一人压天下原非正道，到后来祸临头公理不饶。不如我隐林泉烟霞啸傲，落一个无忧无虑、无是无非、无权无利、无仇无恨、无灾无祸、终日之间饮酒看花乐陶陶。为君难你让天下我许由不要，请寻那非常人替你代劳。",
      "text_length": 296
    },
    {
      "event_id": "70005102_e00051",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "你休学厌世人山林高蹈，做一个救世者再莫辞劳。",
      "text_length": 22
    },
    {
      "event_id": "70005102_e00052",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "许由"
      ],
      "text": "我平生最恨那英雄自命，有几个圣贤君救济苍生？也不过口头禅骗人信任，似这等污秽话掩耳不听。纵话得天花坠我不担任，从此后风马牛各奔途程。",
      "text_length": 66
    },
    {
      "event_id": "70005102_e00053",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许由下。",
      "text_length": 4
    },
    {
      "event_id": "70005102_e00054",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "尧帝"
      ],
      "text": "我一心让天下他不受任，莫非是无实学徒有虚名？众文武忙摆驾深宫前进，与群臣商议定再访贤人。",
      "text_length": 44
    },
    {
      "event_id": "70005102_e00055",
      "play_id": "70005102",
      "scene_id": "70005102_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "70005102_e00056",
      "play_id": "70005102",
      "scene_id": "70005102_s04",
      "scene_no": 4,
      "seq_global": 56,
      "seq_in_scene": 1,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "巢父牵牛上。",
      "text_length": 6
    },
    {
      "event_id": "70005102_e00057",
      "play_id": "70005102",
      "scene_id": "70005102_s04",
      "scene_no": 4,
      "seq_global": 57,
      "seq_in_scene": 2,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "巢父"
      ],
      "text": "心比寒梅澈骨清，孤芳自赏乐天真。清高绝俗是本性，扑去污人三斗尘。",
      "text_length": 32
    },
    {
      "event_id": "70005102_e00058",
      "play_id": "70005102",
      "scene_id": "70005102_s04",
      "scene_no": 4,
      "seq_global": 58,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "巢父"
      ],
      "text": "老汉，巢父。自幼秉性清高，为人固执，生在如今世界，语言动静俱不合时宜；因此隐居山林，与世人不通往来，自种自食，日出而作，日入而息，任天行乐，却也逍遥自在。村中有一人许由，也是个清洁君子，我与他为友，颇甚相得。看溪边水清，不免牵牛去饮便了！",
      "text_length": 119
    },
    {
      "event_id": "70005102_e00059",
      "play_id": "70005102",
      "scene_id": "70005102_s04",
      "scene_no": 4,
      "seq_global": 59,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "巢父"
      ],
      "text": "牵牛去向溪边饮，高唱一声河水清。",
      "text_length": 16
    },
    {
      "event_id": "70005102_e00060",
      "play_id": "70005102",
      "scene_id": "70005102_s04",
      "scene_no": 4,
      "seq_global": 60,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "巢父下。",
      "text_length": 4
    },
    {
      "event_id": "70005102_e00061",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 61,
      "seq_in_scene": 1,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许由上。",
      "text_length": 4
    },
    {
      "event_id": "70005102_e00062",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 62,
      "seq_in_scene": 2,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "许由"
      ],
      "text": "匆匆掩耳向前走，口出污言不自羞。溪边用水洗污垢，",
      "text_length": 24
    },
    {
      "event_id": "70005102_e00063",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 63,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许由洗耳。巢父牵牛上。",
      "text_length": 11
    },
    {
      "event_id": "70005102_e00064",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 64,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "巢父"
      ],
      "text": "你因何洗耳说原由。",
      "text_length": 9
    },
    {
      "event_id": "70005102_e00065",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 65,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "巢父"
      ],
      "text": "许先生请了！",
      "text_length": 6
    },
    {
      "event_id": "70005102_e00066",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 66,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "原来是巢老先生！",
      "text_length": 8
    },
    {
      "event_id": "70005102_e00067",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 67,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "巢父"
      ],
      "text": "何故在此洗耳？",
      "text_length": 7
    },
    {
      "event_id": "70005102_e00068",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 68,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "再休提起。今日我正在家中，忽听户外人声马嘶，叩门相访。想你我向不与人相交，况高车驷马，富贵之人，忽然造访，岂不是一件大大的怪事！",
      "text_length": 64
    },
    {
      "event_id": "70005102_e00069",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 69,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "巢父"
      ],
      "text": "真是件怪事。但不知是何人来访？",
      "text_length": 15
    },
    {
      "event_id": "70005102_e00070",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 70,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "是我隔门偷觑偷觑，你道是谁？原来是皇帝亲到我家来了。",
      "text_length": 26
    },
    {
      "event_id": "70005102_e00071",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 71,
      "seq_in_scene": 11,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "巢父"
      ],
      "text": "我却不知你几时与皇帝结交？以后我就不敢高攀了！",
      "text_length": 23
    },
    {
      "event_id": "70005102_e00072",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 72,
      "seq_in_scene": 12,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "我哪里与他结交？是他自来寻我，我和他素不相识！况且分隔云泥，还是不见为妙，因此我从后门逃走。",
      "text_length": 46
    },
    {
      "event_id": "70005102_e00073",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 73,
      "seq_in_scene": 13,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "巢父"
      ],
      "text": "好朋友！真与我同心。他乃专制之君，我们是自由之民，薰莸不同器，公私不两立，哪里能说到一处？不见的为妙。",
      "text_length": 51
    },
    {
      "event_id": "70005102_e00074",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 74,
      "seq_in_scene": 14,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许由"
      ],
      "text": "怎奈他赶到荒郊，与我相见，他言道：家天下不如官天下，天下乃人人之天下，非一人之天下，所以不传于子而传于贤。苦苦将天下让与我许由，这等污耳之言，我哪里能听？因此掩耳到此，用溪中清水，洗我耳中污言，老先生你想这件事，岂不是一件大大的怪事？",
      "text_length": 117
    },
    {
      "event_id": "70005102_e00075",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 75,
      "seq_in_scene": 15,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "巢父"
      ],
      "text": "唉！",
      "text_length": 2
    },
    {
      "event_id": "70005102_e00076",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 76,
      "seq_in_scene": 16,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "巢父"
      ],
      "text": "闻言不觉怒心头，顿足捶胸恨许由。只顾耳根清净洗污垢，全不管这浊水污我的牛！不饮此水牵牛走，可惜这清流变浊流。",
      "text_length": 54
    },
    {
      "event_id": "70005102_e00077",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 77,
      "seq_in_scene": 17,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "巢父气愤，牵牛走去，下。",
      "text_length": 12
    },
    {
      "event_id": "70005102_e00078",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 78,
      "seq_in_scene": 18,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "许由"
      ],
      "text": "可笑巢父没来由，何以人而不如牛？这样孤僻性情真少有，更比我清高胜一筹。叫声先生且慢走，你不争上流为何从下流？",
      "text_length": 54
    },
    {
      "event_id": "70005102_e00079",
      "play_id": "70005102",
      "scene_id": "70005102_s05",
      "scene_no": 5,
      "seq_global": 79,
      "seq_in_scene": 19,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "许由下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}