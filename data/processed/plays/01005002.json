  "events": [
    {
      "event_id": "01005002_e00001",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00002",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "且住。行至此间，前面一带长江，后有追兵到此，这便如何是好。呜呼呀！看那旁有一打渔小舟，等他到来，再做道理。",
      "text_length": 53
    },
    {
      "event_id": "01005002_e00003",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "渔父"
      ],
      "text": "打鱼吓。",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00004",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "渔父上。",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00005",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "船家前来，渡我过江。",
      "text_length": 10
    },
    {
      "event_id": "01005002_e00006",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "打渔船不渡人。",
      "text_length": 7
    },
    {
      "event_id": "01005002_e00007",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "多把银两与你。",
      "text_length": 7
    },
    {
      "event_id": "01005002_e00008",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "我们是不爱财的。",
      "text_length": 8
    },
    {
      "event_id": "01005002_e00009",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "我乃是被难之人，老丈行个方便吧。",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00010",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "既是被难之人，待我与你搭了扶手。",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00011",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上船。",
      "text_length": 5
    },
    {
      "event_id": "01005002_e00012",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "老丈快快催舟。",
      "text_length": 7
    },
    {
      "event_id": "01005002_e00013",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "待我扯起蓬来。",
      "text_length": 7
    },
    {
      "event_id": "01005002_e00014",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "渔父"
      ],
      "text": "昨夜晚上得一梦，梦见斗大红星坠落舟中。今日有人来问渡，原来白发老公公。",
      "text_length": 35
    },
    {
      "event_id": "01005002_e00015",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "请问老丈，此话因何而起？",
      "text_length": 12
    },
    {
      "event_id": "01005002_e00016",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "昨夜三更偶得一梦：斗大红星落舱，故尔来做此歌。",
      "text_length": 23
    },
    {
      "event_id": "01005002_e00017",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "原来如此。",
      "text_length": 5
    },
    {
      "event_id": "01005002_e00018",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "请问尊姓大名？",
      "text_length": 7
    },
    {
      "event_id": "01005002_e00019",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "我若说出名姓，恐你走漏我的消息。",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00020",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "你看舟中只有你我二人，但讲何妨。",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00021",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "在下姓伍名员字子胥。",
      "text_length": 10
    },
    {
      "event_id": "01005002_e00022",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "吓，原来是明甫将军。失敬了。舟到江边。",
      "text_length": 19
    },
    {
      "event_id": "01005002_e00023",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "搭了扶手。",
      "text_length": 5
    },
    {
      "event_id": "01005002_e00024",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上岸。",
      "text_length": 5
    },
    {
      "event_id": "01005002_e00025",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "老丈，这有宝剑一口，价值千金，以做渡江之费。",
      "text_length": 22
    },
    {
      "event_id": "01005002_e00026",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "你行路之人，岂能无剑，怎好行路？",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00027",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "既然如此，请问老丈尊姓大名？待我报仇之后，也好答报。",
      "text_length": 26
    },
    {
      "event_id": "01005002_e00028",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "日后你我相会，你称我“渔中人”，我称你“芦中人”就是。",
      "text_length": 27
    },
    {
      "event_id": "01005002_e00029",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "渔中人，告辞了。",
      "text_length": 8
    },
    {
      "event_id": "01005002_e00030",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "01005002_e00031",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "渔父"
      ],
      "text": "他父在朝掌山河，我这里将船忙摇过。",
      "text_length": 17
    },
    {
      "event_id": "01005002_e00032",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "伍员"
      ],
      "text": "多蒙老丈渡江河，千金谢礼不为多。这样恩德怎报却，",
      "text_length": 24
    },
    {
      "event_id": "01005002_e00033",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。伍员上。",
      "text_length": 8
    },
    {
      "event_id": "01005002_e00034",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "伍员"
      ],
      "text": "再与老丈把话说。",
      "text_length": 8
    },
    {
      "event_id": "01005002_e00035",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "将军为何去而复返？",
      "text_length": 9
    },
    {
      "event_id": "01005002_e00036",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "非是我去而复转，倘若后面追兵到来，莫说我打此经过，休要走漏我的消息。",
      "text_length": 34
    },
    {
      "event_id": "01005002_e00037",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "哎呀，且住。我好心倒变了坏意，这便怎么处？待我投江一死。将军，那旁有人来了。",
      "text_length": 38
    },
    {
      "event_id": "01005002_e00038",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "在哪里？",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00039",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔父"
      ],
      "text": "在那里。",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00040",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "渔父投江下。",
      "text_length": 6
    },
    {
      "event_id": "01005002_e00041",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "扑灯蛾",
      "speakers": [
        "伍员"
      ],
      "text": "老丈投江河，老丈投江河，为我投江死，美名万古波，美名万古波。",
      "text_length": 30
    },
    {
      "event_id": "01005002_e00042",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "且住，我不免将绳索砍断，断却行人，我就是这个主意。",
      "text_length": 25
    },
    {
      "event_id": "01005002_e00043",
      "play_id": "01005002",
      "scene_id": "01005002_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员砍绳，下。",
      "text_length": 7
    },
    {
      "event_id": "01005002_e00044",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "浣纱女上。",
      "text_length": 5
    },
    {
      "event_id": "01005002_e00045",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "浣纱女"
      ],
      "text": "光阴似箭日月梭，人生在世奈如何。不求富贵求安乐，母女浣纱度日活。",
      "text_length": 32
    },
    {
      "event_id": "01005002_e00046",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "伍员"
      ],
      "text": "豪杰打马奔吴国，",
      "text_length": 8
    },
    {
      "event_id": "01005002_e00047",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00048",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "伍员"
      ],
      "text": "龙离沧海虎离窝。樊城一呼人百诺，令出山摇不敢挪。力举千斤伍明甫，各国不敢动干戈。天下英雄俱服我，秦诓诸侯求讲和。只是我当初不知过，不该倚强做媒约。可叹我一家无有结果，见一位娘行浣纱罗。行来觉得肚饥饿，篮中有饭又有馍。下得马来把揖做，娘行斋生念弥陀。",
      "text_length": 124
    },
    {
      "event_id": "01005002_e00049",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01005002_e00050",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "浣纱女"
      ],
      "text": "眼观水底人影过，耳旁听得言语多。浣纱溪边谁问我，男女交谈是非多。",
      "text_length": 32
    },
    {
      "event_id": "01005002_e00051",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "将军，听汝之言，敢是迷失路途。",
      "text_length": 15
    },
    {
      "event_id": "01005002_e00052",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "非也。行路之人，肚中饥饿，望求娘行周济一碗半碗充饥。",
      "text_length": 26
    },
    {
      "event_id": "01005002_e00053",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "想我浣纱女三十未嫁，与寡母同居，哪有余食与将军充饥。",
      "text_length": 26
    },
    {
      "event_id": "01005002_e00054",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "吓，娘行！在下乃是落难之人，娘行行个方便吧。",
      "text_length": 22
    },
    {
      "event_id": "01005002_e00055",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "听你之言，亦非平常之人。请道其详。",
      "text_length": 17
    },
    {
      "event_id": "01005002_e00056",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "如此娘行听了。",
      "text_length": 7
    },
    {
      "event_id": "01005002_e00057",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "伍员"
      ],
      "text": "未曾开言我的心难过，两眼不住泪如棱。家住在楚国御皇阁，我的父人称伍相国。伍子胥，就是我，父子三人保山河。我的父谏奏反遭祸，可怜我一家大小三百余口见阎罗。只剩下子胥人一个，穷途落魄受折磨。",
      "text_length": 93
    },
    {
      "event_id": "01005002_e00058",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01005002_e00059",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "浣纱女"
      ],
      "text": "听罢言来珠泪落，忠臣孝子受折磨。篮中有馍你用过，免了奔波受饥饿。",
      "text_length": 32
    },
    {
      "event_id": "01005002_e00060",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "伍员"
      ],
      "text": "多谢娘行周济我，一饭千金不为多。",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00061",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "浣纱女"
      ],
      "text": "将军打马忙走却，男女交谈理不合。",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00062",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "伍员"
      ],
      "text": "娘行一言提醒我，句句言语记心窝。伍员打马忙走却，",
      "text_length": 24
    },
    {
      "event_id": "01005002_e00063",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00064",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "浣纱女"
      ],
      "text": "盖世英雄受折磨。时来双挂明甫印，",
      "text_length": 16
    },
    {
      "event_id": "01005002_e00065",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "01005002_e00066",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "伍员"
      ],
      "text": "还有一事要求托。",
      "text_length": 8
    },
    {
      "event_id": "01005002_e00067",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "将军为何去而复返？",
      "text_length": 9
    },
    {
      "event_id": "01005002_e00068",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "后面倘有追兵赶来，千万莫说我打此经过。",
      "text_length": 19
    },
    {
      "event_id": "01005002_e00069",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "呀！稍站。且住，想我浣纱女子，三十未嫁，今与男子交言，倘被旁人知晓，岂不失却我的贞洁之名？也罢，我不免投江一死，免却他人的疑心便了。",
      "text_length": 66
    },
    {
      "event_id": "01005002_e00070",
      "play_id": "01005002",
      "scene_id": "01005002_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "浣纱女"
      ],
