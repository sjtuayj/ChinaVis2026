  "events": [
    {
      "event_id": "05011001_e00001",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘基上。",
      "text_length": 4
    },
    {
      "event_id": "05011001_e00002",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "刘基"
      ],
      "text": "执掌朝纲，伴君王，位列三台。",
      "text_length": 14
    },
    {
      "event_id": "05011001_e00003",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘基"
      ],
      "text": "春来杨柳正发芽，万物俱在土中发。朝中多少骏马客，一心只想帝王家。",
      "text_length": 32
    },
    {
      "event_id": "05011001_e00004",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘基"
      ],
      "text": "下官刘基。昨日圣上传旨，今日驾游武庙拈香。看香烟缭绕，圣驾登殿，在此伺候。",
      "text_length": 37
    },
    {
      "event_id": "05011001_e00005",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。四太监引洪武帝同上。",
      "text_length": 15
    },
    {
      "event_id": "05011001_e00006",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "洪武帝"
      ],
      "text": "海晏河清，齐奏升平。",
      "text_length": 10
    },
    {
      "event_id": "05011001_e00007",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "洪武帝"
      ],
      "text": "大明一统乐无忧，至尊天子坐龙楼。太平天下朝元日，万国衣冠拜冕旒。",
      "text_length": 32
    },
    {
      "event_id": "05011001_e00008",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "洪武帝"
      ],
      "text": "寡人大明天子洪武在位。自从登基以来，风调雨顺，国泰民安，刀枪入库，马放南山，真乃寡人福泽无疆。昨日传旨，今日武庙拈香。刘先生，",
      "text_length": 63
    },
    {
      "event_id": "05011001_e00009",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘基"
      ],
      "text": "臣。",
      "text_length": 2
    },
    {
      "event_id": "05011001_e00010",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "洪武帝"
      ],
      "text": "銮驾可齐？",
      "text_length": 5
    },
    {
      "event_id": "05011001_e00011",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘基"
      ],
      "text": "俱已齐备。",
      "text_length": 5
    },
    {
      "event_id": "05011001_e00012",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "洪武帝"
      ],
      "text": "起驾武庙。",
      "text_length": 5
    },
    {
      "event_id": "05011001_e00013",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘基"
      ],
      "text": "御林军走上，起驾武庙。",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00014",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "05011001_e00015",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "龙行虎步把殿下，",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00016",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "大明朝归一统锦绣中华。",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00017",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "有孤王在马上得来天下，",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00018",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "文有谋武有勇保定皇家。",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00019",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "文站西武列东扶保王驾，",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00020",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "两旁边摆的是斧钺金瓜。",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00021",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "内侍臣与孤王急忙起驾，",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00022",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "君与臣到武庙去把香插。",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00023",
      "play_id": "05011001",
      "scene_id": "05011001_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "05011001_e00024",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老道上。",
      "text_length": 4
    },
    {
      "event_id": "05011001_e00025",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老道"
      ],
      "text": "扫地恐丧蝼蚁命，爱惜飞蛾罩纱灯。",
      "text_length": 16
    },
    {
      "event_id": "05011001_e00026",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "贫道武庙住持。圣驾游幸，不免打扫清洁。",
      "text_length": 19
    },
    {
      "event_id": "05011001_e00027",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "左摆赵云、伍员，中设姜尚、张良，右摆王勇、韩信。",
      "text_length": 24
    },
    {
      "event_id": "05011001_e00028",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "远远望见圣驾来也。",
      "text_length": 9
    },
    {
      "event_id": "05011001_e00029",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。四太监、大太监、四大铠、刘基、洪武帝同上。",
      "text_length": 26
    },
    {
      "event_id": "05011001_e00030",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大铠"
      ],
      "text": "来此武庙。",
      "text_length": 5
    },
    {
      "event_id": "05011001_e00031",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "洪武帝"
      ],
      "text": "驻辇。",
      "text_length": 3
    },
    {
      "event_id": "05011001_e00032",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "洪武帝"
      ],
      "text": "武庙驻辇马停蹄，",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00033",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "保驾的将军是刘基。孤登基未曾游此地，看一看前朝古今奇。",
      "text_length": 27
    },
    {
      "event_id": "05011001_e00034",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "金梁玉柱瓦琉璃，玉石栏杆摆列在丹墀。",
      "text_length": 18
    },
    {
      "event_id": "05011001_e00035",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "站立庙外用目觑，一位将军庙外立。头戴白盔双凤翅，身穿白甲似雪飞。跨下一骑白龙马，方天画戟手中提。左手弯弓秋月样，右桶狼牙箭几枝。马前威风高万丈，马后威风八百余。脸面笑容真可喜，好像哪里得胜回。回头便把先生问，那位将军他是谁？",
      "text_length": 112
    },
    {
      "event_id": "05011001_e00036",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "刘基拱手忙奏启，启奏我主圣驾知：他家住常山真定地，赵云名儿天下知。长坂坡前救后主，杀得那曹兵无对敌。皆因糜妃自跳井，反说忠良把君欺。宋室王爷修武庙，反将神像立丹墀。",
      "text_length": 82
    },
    {
      "event_id": "05011001_e00037",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "太祖闻言心中气，史官错把忠良欺。万马营中救后主，单人独骑逞雄威。曹兵暗放无情箭，可叹糜妃投井死。这等臣子不入庙，还有何人保华夷？孤王传旨往内请，一阵清风往内吹。回头又见一员将，面如枣红五绺须。跨下一骑红鬃马，斩将的大刀手内提。这是哪朝安邦将，他的功劳在哪里？回言便把先生问，这位将军他是谁？",
      "text_length": 145
    },
    {
      "event_id": "05011001_e00038",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "姓王名勇字伯党，文武全才世间稀。唐兵暗放无情箭，左遮右挡护主体。不幸李密带箭死，断密涧下命归西。",
      "text_length": 48
    },
    {
      "event_id": "05011001_e00039",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "听奏言来皱双眉，史官竟把忠良欺。唐兵暗放无情箭，保主尽忠命归西。金牛压死娄金狗，反说忠良把主欺。这等臣子不入庙，还有何人保华夷？孤王传旨请进庙，一阵清风往内吹。叫内臣与孤摆下祭奠礼，",
      "text_length": 91
    },
    {
      "event_id": "05011001_e00040",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "焚香祭奠酒三杯。",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00041",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。",
      "text_length": 5
    },
    {
      "event_id": "05011001_e00042",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "洪武帝"
      ],
      "text": "上坐斩将封神姜吕望，",
      "text_length": 10
    },
    {
      "event_id": "05011001_e00043",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "下坐着箕子、微子、闻太师。",
      "text_length": 13
    },
    {
      "event_id": "05011001_e00044",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "兵吞六国名王翦，",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00045",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "呼风唤雨燕孙膑。",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00046",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "英布、彭越与韩信，",
      "text_length": 9
    },
    {
      "event_id": "05011001_e00047",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "岑彭、马武和姚期。",
      "text_length": 9
    },
    {
      "event_id": "05011001_e00048",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "独行千里关圣帝，",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00049",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "喝断坝桥是张飞。",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00050",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "跨海征东薛仁贵，",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00051",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "李存孝倒有托天力。",
      "text_length": 9
    },
    {
      "event_id": "05011001_e00052",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "威镇三关杨家将，",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00053",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "这都是前朝忠良将尽人皆知。",
      "text_length": 13
    },
    {
      "event_id": "05011001_e00054",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "见几个头戴双凤翅，",
      "text_length": 9
    },
    {
      "event_id": "05011001_e00055",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "见几个身穿紫罗衣。",
      "text_length": 9
    },
    {
      "event_id": "05011001_e00056",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "见几个横须赛太岁，",
      "text_length": 9
    },
    {
      "event_id": "05011001_e00057",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "见几个怀抱令箭和令旗。",
      "text_length": 11
    },
    {
      "event_id": "05011001_e00058",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "观前观后观仔细，问左问右问刘基。",
      "text_length": 16
    },
    {
      "event_id": "05011001_e00059",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "刘基拱手忙奏启，不敢隐瞒惹是非。",
      "text_length": 16
    },
    {
      "event_id": "05011001_e00060",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "回头又见一员将，白盔白甲五绺须。回头便把先生问，这一位将军他是谁？",
      "text_length": 33
    },
    {
      "event_id": "05011001_e00061",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "刘基拱手忙奏启，启奏我主听端的：姓伍名员字子胥，平王驾前算第一。临潼会上曾斗宝，他与秦楚做过媒。",
      "text_length": 48
    },
    {
      "event_id": "05011001_e00062",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "听奏言来怒冲起，骂声伍员不忠的。平王虽然纳儿妇，错斩你父命归西。吴国借兵将仇报，为臣反上把君欺。自古人死仇不记，不该鞭打主的尸。喝骂一声赶出庙去，",
      "text_length": 73
    },
    {
      "event_id": "05011001_e00063",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 40,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "洪武帝转头。",
      "text_length": 6
    },
    {
      "event_id": "05011001_e00064",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 41,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "将身又到二殿里。回头又见一员将，身穿一件大红衣。回言便把先生问，这位神像他是谁？",
      "text_length": 40
    },
    {
      "event_id": "05011001_e00065",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 42,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "他是汉朝的韩信，暗度陈仓少人知。九里山摆下埋伏阵，逼死霸王一管笛。",
      "text_length": 33
    },
    {
      "event_id": "05011001_e00066",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 43,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "听奏言来怒火起，骂一声不忠不孝贼。你不该受那汉王拜，不该埋母在秦西；你不该问路把樵夫斩，你不该乌江把主逼。你不该杀那陈仓女，你不该想夺主社稷。报应丧在阴人手，未央宫中命归西。仔细思量难容你，武庙难容你这不忠贼。喝骂一声赶出庙去，将身来在后殿里。上面坐的一员将，身穿一件八卦衣。左边儿童捧宝剑，右边插面令字旗。行兵布阵如反掌，威风凛凛透九霄。回言便把先生问，这位道长他是谁？",
      "text_length": 186
    },
    {
      "event_id": "05011001_e00067",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 44,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "姓张名良字子房，出在春秋战国时。勒逼项羽乌江丧，才封他天祭地祭与神祭。",
      "text_length": 35
    },
    {
      "event_id": "05011001_e00068",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 45,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "听说张良皱双眉，反复不定把君欺。汉王有道你就保，汉王无道你就离。眼前若有张良在，割肉熬油剥他皮。骂罢张良回头看……",
      "text_length": 57
    },
    {
      "event_id": "05011001_e00069",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘基"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "05011001_e00070",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "洪武帝"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "05011001_e00071",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "错出一言悔不及。",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00072",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "万岁骂臣不妨骂，指骂张良臣是谁。自古道伴君如伴虎，一点不到有是非。在头上除下了乌纱帽，",
      "text_length": 43
    },
    {
      "event_id": "05011001_e00073",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘基转头。",
      "text_length": 5
    },
    {
      "event_id": "05011001_e00074",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "身上脱下紫罗衣。把武庙当做了金銮殿，望万岁赦臣归故里。",
      "text_length": 27
    },
    {
      "event_id": "05011001_e00075",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 52,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "说什么告老归故里，你不言来朕心知。孤不该今日到此地，错出一言你心疑。先生与孤把江山定，同行半步也难离。先生去了又有谁，可与孤王保华夷。",
      "text_length": 67
    },
    {
      "event_id": "05011001_e00076",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 53,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "老牛老马中何用，年迈之人枉费力。耳聋了，听不见，眼花难把兵来提。望万岁将臣赦了罢！",
      "text_length": 41
    },
    {
      "event_id": "05011001_e00077",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 54,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘基"
      ],
      "text": "哎呀万岁吓！",
      "text_length": 6
    },
    {
      "event_id": "05011001_e00078",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 55,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "臣到深山修道去。",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00079",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 56,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "先生要去真要去，留你不住枉费心机。朕封你云游真人去访道，逢州过府把粮支。赐卿一把白玉扇，先生牢牢记在心里：哪里一旦烟尘起，那时要与孤做主意。",
      "text_length": 70
    },
    {
      "event_id": "05011001_e00080",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 57,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘基"
      ],
      "text": "谢万岁。",
      "text_length": 4
    },
    {
      "event_id": "05011001_e00081",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 58,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘基"
      ],
      "text": "叩头谢恩辞万岁，对着相府泪悲啼。说什么一品三公位，说什么朝中挂紫衣。说什么黄金带北斗，说什么训教子与媳。夫妻本是同林鸟，大限来时各自飞。将身跳出牢笼地，朝中大事再不提。",
      "text_length": 84
    },
    {
      "event_id": "05011001_e00082",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 59,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘基下。",
      "text_length": 4
    },
    {
      "event_id": "05011001_e00083",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 60,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "自古出言要谨慎，今日武庙走刘基。护国军师辞朝去，",
      "text_length": 24
    },
    {
      "event_id": "05011001_e00084",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 61,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "洪武帝"
      ],
      "text": "内侍，摆驾回宫。",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00085",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 62,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "洪武帝"
      ],
      "text": "去了擎天一军师。",
      "text_length": 8
    },
    {
      "event_id": "05011001_e00086",
      "play_id": "05011001",
      "scene_id": "05011001_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 63,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}