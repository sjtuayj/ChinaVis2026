      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "贺后"
      ],
      "text": "享荣华受富贵要它何用？倒不如带皇儿务农耕种，我受的什么荣封？",
      "text_length": 30
    },
    {
      "event_id": "80000024_e00029",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 29,
