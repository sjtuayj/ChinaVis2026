  "events": [
    {
      "event_id": "80000024_e00001",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵德芳扶贺后同上。",
      "text_length": 9
    },
    {
      "event_id": "80000024_e00002",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "贺后"
      ],
      "text": "老王不幸把命丧，二主篡位谋家邦。大皇儿忙把金殿上，要回社稷自为王。",
      "text_length": 33
    },
    {
      "event_id": "80000024_e00003",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺后、赵德芳同下。",
      "text_length": 9
    },
    {
      "event_id": "80000024_e00004",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵德昭"
      ],
      "text": "迈步且把金殿上，快快还我锦家邦。",
      "text_length": 16
    },
    {
      "event_id": "80000024_e00005",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵光义"
      ],
      "text": "大皇儿哭得甚惨伤，口口声声要家邦，本当下位把国让！",
      "text_length": 25
    },
    {
      "event_id": "80000024_e00006",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "潘洪"
      ],
      "text": "万岁，江山只有争斗，哪有禅让之理？",
      "text_length": 17
    },
    {
      "event_id": "80000024_e00007",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵光义"
      ],
      "text": "难学尧舜和商汤。回头便把皇儿讲，孤不封你自为王。",
      "text_length": 24
    },
    {
      "event_id": "80000024_e00008",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德昭"
      ],
      "text": "住口！",
      "text_length": 3
    },
    {
      "event_id": "80000024_e00009",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵德昭"
      ],
      "text": "江山本是小王掌，何人要你封我王！",
      "text_length": 16
    },
    {
      "event_id": "80000024_e00010",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵光义"
      ],
      "text": "奴才说话太张狂，开言就把孤王伤。殿前潘豹与潘疆，推出午门一命亡。",
      "text_length": 32
    },
    {
      "event_id": "80000024_e00011",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵德昭"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "80000024_e00012",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵德昭"
      ],
      "text": "辩贼不过已赐死，不如一死丧无常。",
      "text_length": 16
    },
    {
      "event_id": "80000024_e00013",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵德昭碰死。贺后、赵德芳同上。",
      "text_length": 15
    },
    {
      "event_id": "80000024_e00014",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "贺后"
      ],
      "text": "一见皇儿把命丧，怎不叫娘我痛断了肠。把尸首搭至在白虎堂停放，随娘到金殿骂昏王。",
      "text_length": 39
    },
    {
      "event_id": "80000024_e00015",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "贺后"
      ],
      "text": "昏王！篡位王！",
      "text_length": 7
    },
    {
      "event_id": "80000024_e00016",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "贺后"
      ],
      "text": "有贺后在金殿一声高骂，",
      "text_length": 11
    },
    {
      "event_id": "80000024_e00017",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "贺后"
      ],
      "text": "昏王！篡位王！",
      "text_length": 7
    },
    {
      "event_id": "80000024_e00018",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "贺后"
      ],
      "text": "骂一声无道君细听根芽：",
      "text_length": 11
    },
    {
      "event_id": "80000024_e00019",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "贺后"
      ],
      "text": "老王爷为江山足踢拳打，老王爷为山河奔走天涯。",
      "text_length": 22
    },
    {
      "event_id": "80000024_e00020",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄快三眼",
      "speakers": [
        "贺后"
      ],
      "text": "遭不幸老王爷晏了御驾，⑴贼昏王篡了位谋乱邦家。把一个皇太子逼死殿下，反道说为嫂我拦阻有差。贼好比王莽贼称孤道寡，贼好比曹阿瞒奸雄不差；贼好比秦赵高指鹿为马，贼好比司马师搅乱中华。只骂得贼昏王装聋作哑，只骂得贼昏王扭转身躯、闭目合睛、羞羞惭惭一语不发；只骂得贼昏王无言对答，两旁的文武臣珠泪如麻。搬一把金交椅娘且坐下，你叔王不让位我再去骂他。",
      "text_length": 170
    },
    {
      "event_id": "80000024_e00021",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "赵光义"
      ],
      "text": "自盘古立帝邦天子为重，老皇嫂骂孤王情理难容。论国法就将你残生断送！",
      "text_length": 33
    },
    {
      "event_id": "80000024_e00022",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺后"
      ],
      "text": "谁敢？",
      "text_length": 3
    },
    {
      "event_id": "80000024_e00023",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵光义"
      ],
      "text": "退班！",
      "text_length": 3
    },
    {
      "event_id": "80000024_e00024",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵光义下位，曹彬、赵普、潘洪、苗宗善同下。",
      "text_length": 21
    },
    {
      "event_id": "80000024_e00025",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵光义"
      ],
      "text": "皇嫂！",
      "text_length": 3
    },
    {
      "event_id": "80000024_e00026",
      "play_id": "80000024",
