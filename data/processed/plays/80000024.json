      "type": "aria",
      "mode_label": "二黄快三眼",
      "speakers": [
        "赵光义"
      ],
      "text": "还看在与兄王掌印东宫。兄王爷晏了驾钟鼓齐动，满朝中文武臣齐保孤穹。孤这里施一礼把皇嫂尊重，崇上徽号容是不容？",
      "text_length": 54
    },
    {
      "event_id": "80000024_e00027",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵光义付剑。",
      "text_length": 6
    },
    {
      "event_id": "80000024_e00028",
      "play_id": "80000024",
      "scene_id": "80000024_s01",
      "scene_no": 1,
