    },
    {
      "event_id": "80000011_e00027",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "唉，悔不听先生之言，有此大败，损兵折将，乃孤王之罪矣！",
      "text_length": 27
    },
    {
      "event_id": "80000011_e00028",
