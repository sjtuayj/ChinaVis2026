      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "军家胜败，古之常理，主公保重要紧！",
      "text_length": 17
    },
    {
      "event_id": "80000011_e00029",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
