      ],
      "text": "不在人世了！",
      "text_length": 6
    },
    {
      "event_id": "80000011_e00016",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "刘备"
      ],
      "text": "唉，二弟呀……",
      "text_length": 7
    },
    {
      "event_id": "80000011_e00017",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "刘备"
      ],
      "text": "兄弟们要相逢万也不能。内侍臣勿喧声各归肃静，扶孤王龙床上我养一养精神。",
      "text_length": 35
    },
    {
      "event_id": "80000011_e00018",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘备睡。诸葛亮、刘永、刘理、马谡同上。",
      "text_length": 19
    },
    {
      "event_id": "80000011_e00019",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "诸葛亮"
      ],
      "text": "带领殿下宫院进，问声主公可安宁？",
      "text_length": 16
    },
    {
      "event_id": "80000011_e00020",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "主公醒来！",
      "text_length": 5
    },
    {
      "event_id": "80000011_e00021",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "刘备"
      ],
      "text": "耳边厢又听得人声一阵，",
      "text_length": 11
    },
    {
      "event_id": "80000011_e00022",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "主公！",
      "text_length": 3
    },
    {
      "event_id": "80000011_e00023",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "刘备"
      ],
      "text": "见先生在一边珠泪淋淋。",
      "text_length": 11
    },
    {
      "event_id": "80000011_e00024",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
