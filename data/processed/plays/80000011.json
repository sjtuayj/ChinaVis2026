      "type": "expression",
      "mode_label": "同哭",
      "speakers": [
        "刘永",
        "刘理"
      ],
      "text": "父皇……",
      "text_length": 4
    },
    {
      "event_id": "80000011_e00025",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "刘备"
      ],
      "text": "二皇儿含悲泪一旁站定，孤又惭孤又悔孤又伤心。",
      "text_length": 22
    },
    {
      "event_id": "80000011_e00026",
      "play_id": "80000011",
      "scene_id": "80000011_s01",
