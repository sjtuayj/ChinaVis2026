      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李益"
      ],
      "text": "知道了！",
      "text_length": 4
    },
    {
      "event_id": "70902115_e00035",
      "play_id": "70902115",
      "scene_id": "70902115_s01",
