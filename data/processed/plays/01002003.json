  "events": [
    {
      "event_id": "01002003_e00001",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "孙尚香"
      ],
      "text": "摆驾。",
      "text_length": 3
    },
    {
      "event_id": "01002003_e00002",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、四御林军、二宫女、孙尚香同上。",
      "text_length": 19
    },
    {
      "event_id": "01002003_e00003",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "曾记得当年来辞君，棒打鸳鸯两离分。叹皇叔遭不幸龙归海境，不由奴日夜里珠泪淋淋。内侍臣摆驾江边来进，清风一去未亡人。",
      "text_length": 57
    },
    {
      "event_id": "01002003_e00004",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "祭礼摆下，着衣更换，两厢退下。",
      "text_length": 15
    },
    {
      "event_id": "01002003_e00005",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、四御林军同下。",
      "text_length": 11
    },
    {
      "event_id": "01002003_e00006",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙尚香"
      ],
      "text": "设祭长江岸，举目望西川。梦魂何日见，",
      "text_length": 18
    },
    {
      "event_id": "01002003_e00007",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "夫君，先主！",
      "text_length": 6
    },
    {
      "event_id": "01002003_e00008",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙尚香"
      ],
      "text": "空自珠泪涟。",
      "text_length": 6
    },
    {
      "event_id": "01002003_e00009",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "孙尚香"
      ],
      "text": "孙尚香在江边心中酸疼，",
      "text_length": 11
    },
    {
      "event_id": "01002003_e00010",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "夫君，先主！啊呀！",
      "text_length": 9
    },
    {
      "event_id": "01002003_e00011",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "孙尚香"
      ],
      "text": "尊一声汉皇叔细听分明：",
      "text_length": 11
    },
    {
      "event_id": "01002003_e00012",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "好夫妻恶姻缘悲哀告禀，凭空中便见听一点心诚。可叹你大英雄出身被困，可叹你结桃园义共死生；可叹你破黄巾声名未重，可叹你虎牢关方显成名；可叹你舍徐庶卧龙三请，可叹你水镜庄得一贤伦；可叹你当阳道夏口夜奔，可叹你全仗着诸葛先生；可叹你跳檀溪险些丧命，我的夫吓！",
      "text_length": 126
    },
    {
      "event_id": "01002003_e00013",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "下锣。",
      "text_length": 3
    },
    {
      "event_id": "01002003_e00014",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "可叹你入虎穴东吴招亲。为报仇在猇亭遇见陆逊，又谁知那小贼果有才能。你不该七百里连营扎定，烧死了众儿郎百万雄兵。人报道你在白帝城丧命，那时节得凶信魂魄离身。实指望破奸曹狼烟扫尽，又谁知天不助命归天庭。我本当得此信寻个自尽，又恐怕我母亲不放离分。叹人生在世间如同照镜，夫已死我岂肯独自贪生。因此上备祭礼江边来进，但愿你魂灵儿早归天庭。",
      "text_length": 165
    },
    {
      "event_id": "01002003_e00015",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "且住。想皇叔一死，我在东吴苦守无益。不免拜谢母后养育之恩，投江自尽了吧。",
      "text_length": 36
    },
    {
      "event_id": "01002003_e00016",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "反二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "江水滔滔波浪滚，",
      "text_length": 8
    },
    {
      "event_id": "01002003_e00017",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四水旗同上。",
      "text_length": 6
    },
    {
      "event_id": "01002003_e00018",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "反二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "尚香拜别养育恩。辞别了老母后寻自尽，不如一死见夫君。",
      "text_length": 26
    },
    {
      "event_id": "01002003_e00019",
      "play_id": "01002003",
      "scene_id": "01002003_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香、四水旗同下。",
      "text_length": 10
    },
    {
      "event_id": "01002003_e00020",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香上，四水旗引龙王同上。",
      "text_length": 14
    },
    {
      "event_id": "01002003_e00021",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "龙王"
      ],
      "text": "玉旨下，跪。",
      "text_length": 6
    },
    {
      "event_id": "01002003_e00022",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "01002003_e00023",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "龙王"
      ],
      "text": "听宣读。诏曰：孙尚香为夫投江，尽节一死，玉帝垂怜，封为枭姬娘娘。旨意读罢，望诏谢恩。",
      "text_length": 42
    },
    {
      "event_id": "01002003_e00024",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "圣寿无疆。",
      "text_length": 5
    },
    {
      "event_id": "01002003_e00025",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "龙王下。孙尚香换衣。",
      "text_length": 10
    },
    {
      "event_id": "01002003_e00026",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "众神将，保我朝见玉帝去者。",
      "text_length": 13
    },
    {
      "event_id": "01002003_e00027",
      "play_id": "01002003",
      "scene_id": "01002003_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香、四水旗同下。",
      "text_length": 10
    }
  ],
