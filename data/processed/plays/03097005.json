  "events": [
    {
      "event_id": "03097005_e00001",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00002",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "哎呀且住！前有长江，后有追兵，无舟可渡，如何是好！",
      "text_length": 25
    },
    {
      "event_id": "03097005_e00003",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "渔丈人"
      ],
      "text": "打鱼哟！",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00004",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "呜呼呀，那厢有一渔船，待我将他唤来。船家过来。",
      "text_length": 23
    },
    {
      "event_id": "03097005_e00005",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "渔丈人上。",
      "text_length": 5
    },
    {
      "event_id": "03097005_e00006",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "渔丈人"
      ],
      "text": "耳听岸上人唤我，壮士呼唤却为何？",
      "text_length": 16
    },
    {
      "event_id": "03097005_e00007",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "壮士唤我何事？",
      "text_length": 7
    },
    {
      "event_id": "03097005_e00008",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "烦劳老丈将我渡过江去。",
      "text_length": 11
    },
    {
      "event_id": "03097005_e00009",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "老汉这打鱼小舟从不渡人。",
      "text_length": 12
    },
    {
      "event_id": "03097005_e00010",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "多把银钱与你。",
      "text_length": 7
    },
    {
      "event_id": "03097005_e00011",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "我是不爱钱的。",
      "text_length": 7
    },
    {
      "event_id": "03097005_e00012",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "老丈，我乃被难之人，你行个方便吧！",
      "text_length": 17
    },
    {
      "event_id": "03097005_e00013",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "既然如此，待我渡你过江。请上船来。",
      "text_length": 17
    },
    {
      "event_id": "03097005_e00014",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "就请老丈快快开船！",
      "text_length": 9
    },
    {
      "event_id": "03097005_e00015",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "好，待我扯起篷来。",
      "text_length": 9
    },
    {
      "event_id": "03097005_e00016",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "山歌",
      "speakers": [
        "渔丈人"
      ],
      "text": "万里孤篷一叶舟，萧萧芦荻满江秋。看君不是寻常客，何事忧愁白了头？蹊跷啊，蹊跷啊！",
      "text_length": 40
    },
    {
      "event_id": "03097005_e00017",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "请问老丈，此歌从何而起？",
      "text_length": 12
    },
    {
      "event_id": "03097005_e00018",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "我见你乃是一个壮年，为何忧愁满面，须发皓然？其中必有隐情，故而歌唱。",
      "text_length": 34
    },
    {
      "event_id": "03097005_e00019",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "哦，原来如此。唉！",
      "text_length": 9
    },
    {
      "event_id": "03097005_e00020",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "请问壮士，尊姓大名？",
      "text_length": 10
    },
    {
      "event_id": "03097005_e00021",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "这个——",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00022",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "为何不讲？",
      "text_length": 5
    },
    {
      "event_id": "03097005_e00023",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "我若说出真名实姓，恐怕走漏风声。",
      "text_length": 16
    },
    {
      "event_id": "03097005_e00024",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "你看舟中并无别人，但讲何妨。",
      "text_length": 14
    },
    {
      "event_id": "03097005_e00025",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "在下姓伍名员字子胥，楚国监利人也。",
      "text_length": 17
    },
    {
      "event_id": "03097005_e00026",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "原来是明辅将军。失敬了！",
      "text_length": 12
    },
    {
      "event_id": "03097005_e00027",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "岂敢。",
      "text_length": 3
    },
    {
      "event_id": "03097005_e00028",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "船已抵岸，待我与你搭了扶手。",
      "text_length": 14
    },
    {
      "event_id": "03097005_e00029",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "多蒙老丈将我渡过江来，无物可谢。我这里有宝剑一口，上有七星，价值连城，赠与老丈，以为渡江之费。",
      "text_length": 47
    },
    {
      "event_id": "03097005_e00030",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "慢来，慢来。老汉听说楚平王欲得将军，悬有万金之赏，我不图赏，岂图你的酬谢！况这山路险要，将军岂可无剑！老汉打鱼江中，要它何用！请你速速去吧。",
      "text_length": 70
    },
    {
      "event_id": "03097005_e00031",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "老丈既不受剑，请问尊姓大名，日后相逢，也好答报。",
      "text_length": 24
    },
    {
      "event_id": "03097005_e00032",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "这个——日后你我相逢之时，你唤我渔丈人，我唤你芦中人也就是了。",
      "text_length": 31
    },
    {
      "event_id": "03097005_e00033",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "如此，渔丈人。",
      "text_length": 7
    },
    {
      "event_id": "03097005_e00034",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "芦中人。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00035",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "expression",
      "mode_label": "同笑",
      "speakers": [
        "伍员",
        "渔丈人"
      ],
      "text": "啊哈哈哈……",
      "text_length": 6
    },
    {
      "event_id": "03097005_e00036",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "告辞了！",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00037",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "伍员"
      ],
      "text": "多蒙渡我把江过，日后当报这恩德。临行与你拱拱手，",
      "text_length": 24
    },
    {
      "event_id": "03097005_e00038",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00039",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "渔丈人"
      ],
      "text": "可叹将军涉风波。我把船儿忙摇过，",
      "text_length": 16
    },
    {
      "event_id": "03097005_e00040",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00041",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "伍员"
      ],
      "text": "再与老丈把话说。",
      "text_length": 8
    },
    {
      "event_id": "03097005_e00042",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "将军，为何去而复转？",
      "text_length": 10
    },
    {
      "event_id": "03097005_e00043",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "老丈，非是我去而复转，后面倘有追兵，莫说伍员打此经过。",
      "text_length": 27
    },
    {
      "event_id": "03097005_e00044",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "哎呀且住！老汉偌大年纪，冒着风险将他渡过江来，不料他反而疑我。万一后面追兵将他拿住，必说是我泄漏，岂不以德为怨！也罢，我不免投到江中，也好叫他安心而去。啊将军，那边追兵来了！",
      "text_length": 87
    },
    {
      "event_id": "03097005_e00045",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "在哪里？",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00046",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "渔丈人"
      ],
      "text": "在那里！",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00047",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "渔丈人投江，下。",
      "text_length": 8
    },
    {
      "event_id": "03097005_e00048",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "扑灯蛾牌",
      "speakers": [
        "伍员"
      ],
      "text": "老丈丧江河、丧江河，不由人珠泪落！得展凌云志，一定报恩德、报恩德！",
      "text_length": 33
    },
    {
      "event_id": "03097005_e00049",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "老丈投江一死，不免将篷索砍断，以防不测。",
      "text_length": 20
    },
    {
      "event_id": "03097005_e00050",
      "play_id": "03097005",
      "scene_id": "03097005_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00051",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "浣纱女上。",
      "text_length": 5
    },
    {
      "event_id": "03097005_e00052",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢三眼板",
      "speakers": [
        "浣纱女"
      ],
      "text": "光阴一去快如梭，人生在世能几何？不求富贵求安乐，每日溪边浣纱罗。",
      "text_length": 32
    },
    {
      "event_id": "03097005_e00053",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "溧阳史氏女。与寡母同居。年已三十，尚未嫁人。每日浣纱织罗，奉母度日。看天气晴和，不免去到溪旁浣纱便了！",
      "text_length": 51
    },
    {
      "event_id": "03097005_e00054",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢三眼板",
      "speakers": [
        "浣纱女"
      ],
      "text": "村边桃花——",
      "text_length": 6
    },
    {
      "event_id": "03097005_e00055",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "浣纱女"
      ],
      "text": "红灼灼，垂柳绿叶映清波。景色虽好刹那过，辜负春光可奈何。缓步从容溪边过，临流倚石浣纱罗。",
      "text_length": 44
    },
    {
      "event_id": "03097005_e00056",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "伍员"
      ],
      "text": "豪杰打马奔吴国，",
      "text_length": 8
    },
    {
      "event_id": "03097005_e00057",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00058",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "伍员"
      ],
      "text": "龙离沧海虎离窝。力举千斤伍明辅，压定了各国不敢动干戈。天下英雄皆服我，各路诸侯来求和。盖世功勋无过错，又谁知一旦起风波。可叹我一家人无有结果，",
      "text_length": 71
    },
    {
      "event_id": "03097005_e00059",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员看。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00060",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "伍员"
      ],
      "text": "见一娘行浣纱罗。行至此间腹内饿，见她篮中饭与馍。本当向前求济饿，",
      "text_length": 32
    },
    {
      "event_id": "03097005_e00061",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下马。",
      "text_length": 5
    },
    {
      "event_id": "03097005_e00062",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "伍员"
      ],
      "text": "含羞带愧无奈何！",
      "text_length": 8
    },
    {
      "event_id": "03097005_e00063",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员投石。",
      "text_length": 5
    },
    {
      "event_id": "03097005_e00064",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03097005_e00065",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "浣纱女"
      ],
      "text": "忽见水底人影过，落石击水却为何？想是壮士呼唤我，只得低头把话说。",
      "text_length": 32
    },
    {
      "event_id": "03097005_e00066",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "娘行请了！",
      "text_length": 5
    },
    {
      "event_id": "03097005_e00067",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "请了！客官敢是失迷路途？",
      "text_length": 12
    },
    {
      "event_id": "03097005_e00068",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "并非失迷路途，我乃避难之人，行至此间，腹中饥饿，见娘行篮中有饭食馍馍，可否周济于我？",
      "text_length": 42
    },
    {
      "event_id": "03097005_e00069",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "听客官之言，不像此地人氏，家住哪里，尊姓大名？请道其详。",
      "text_length": 28
    },
    {
      "event_id": "03097005_e00070",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "唉，娘行听了！",
      "text_length": 7
    },
    {
      "event_id": "03097005_e00071",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "伍员"
      ],
      "text": "未曾开言心难过，两眼不住泪如梭。家住监利在楚国，我的父就是伍相国。伍子胥就是我，临潼斗宝压服了各国。恨平王无道贪酒色，父纳子妻理不合。我的父谏奏反得祸，可怜我的一家满门三百余口见阎罗。只剩下伍员人一个，插翅不能逃出网罗。幸遇东皋公周全我，混出了昭关逃奔吴国。行至在江边不能过，多蒙渔丈渡江河。一路行来腹饥饿，但只见你的篮中有饭又有馍。娘行若肯周济我，没齿不忘大恩德。",
      "text_length": 183
    },
    {
      "event_id": "03097005_e00072",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03097005_e00073",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "浣纱女"
      ],
      "text": "听罢言来珠泪落，可叹将军受折磨。请君饱餐免饥饿，篮内取出饭与馍。",
      "text_length": 32
    },
    {
      "event_id": "03097005_e00074",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "伍员"
      ],
      "text": "多谢娘行周济我，用手拿起饭与馍。一饭未足充饥饿，千金相谢不为多。",
      "text_length": 32
    },
    {
      "event_id": "03097005_e00075",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "浣纱女"
      ],
      "text": "将军不必言谢我，区区小事值几何！阳关路上是非多，请君快快离此河。",
      "text_length": 32
    },
    {
      "event_id": "03097005_e00076",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "伍员"
      ],
      "text": "娘行一言提醒我，男女交谈是非多。辞别娘行奔吴国，",
      "text_length": 24
    },
    {
      "event_id": "03097005_e00077",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00078",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "浣纱女"
      ],
      "text": "盖世英雄受折磨。浣纱未毕溪边坐，",
      "text_length": 16
    },
    {
      "event_id": "03097005_e00079",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员上。",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00080",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "伍员"
      ],
      "text": "再与娘行把话说。",
      "text_length": 8
    },
    {
      "event_id": "03097005_e00081",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 31,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "将军为何去而复转？",
      "text_length": 9
    },
    {
      "event_id": "03097005_e00082",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 32,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "非是我去而复转，倘有追兵到此，莫说我伍员打此经过！",
      "text_length": 25
    },
    {
      "event_id": "03097005_e00083",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 33,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "这——将军少待。",
      "text_length": 8
    },
    {
      "event_id": "03097005_e00084",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 34,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "娘行请便。",
      "text_length": 5
    },
    {
      "event_id": "03097005_e00085",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 35,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "且住，我好心周济于他，反而疑心于我。也罢，不免投江一死，免他疑心便了。将军，那旁有人来了！",
      "text_length": 45
    },
    {
      "event_id": "03097005_e00086",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 36,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "在哪里？",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00087",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 37,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "浣纱女"
      ],
      "text": "在那里！",
      "text_length": 4
    },
    {
      "event_id": "03097005_e00088",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 38,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "浣纱女投江，下。",
      "text_length": 8
    },
    {
      "event_id": "03097005_e00089",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 39,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "03097005_e00090",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 40,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "伍员"
      ],
      "text": "娘行身投河，两眼泪如梭。你死皆因我，可叹女娇娥。日后若得仇报却，建碑立旌报恩德。",
      "text_length": 40
    },
    {
      "event_id": "03097005_e00091",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 41,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "伍员"
      ],
      "text": "且住！娘行投江一死，是非之地，不可久停，速速拉马走去。",
      "text_length": 27
    },
    {
      "event_id": "03097005_e00092",
      "play_id": "03097005",
      "scene_id": "03097005_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 42,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "伍员下。",
      "text_length": 4
    }
  ],
