  "events": [
    {
      "event_id": "01005009_e00001",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四红龙套同上，共叔段、魏氏同上。",
      "text_length": 16
    },
    {
      "event_id": "01005009_e00002",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "共叔段"
      ],
      "text": "丹心天地惨，黄泉路途远。",
      "text_length": 12
    },
    {
      "event_id": "01005009_e00003",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "魏氏"
      ],
      "text": "溺爱反遭害，恩情一线牵。",
      "text_length": 12
    },
    {
      "event_id": "01005009_e00004",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "共叔段",
        "魏氏"
      ],
      "text": "我乃（共叔段）（魏氏）鬼魂是也。",
      "text_length": 16
    },
    {
      "event_id": "01005009_e00005",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "共叔段"
      ],
      "text": "只为母后姜夫人，爱子爱媳；不想你我夫妻，反遭毒害。可叹母后在颍燕城中，思儿心切，啼哭悲声。你我夫妻，不免去至梦中，劝解一番。如此夫人请。",
      "text_length": 68
    },
    {
      "event_id": "01005009_e00006",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "魏氏"
      ],
      "text": "夫君请。",
      "text_length": 4
    },
    {
      "event_id": "01005009_e00007",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "共叔段"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "01005009_e00008",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "共叔段"
      ],
      "text": "说破啼惨三月雨，",
      "text_length": 8
    },
    {
      "event_id": "01005009_e00009",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "魏氏"
      ],
      "text": "梦魂惊断五更风。",
      "text_length": 8
    },
    {
      "event_id": "01005009_e00010",
      "play_id": "01005009",
      "scene_id": "01005009_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四红龙套、共叔段、魏氏同下。",
      "text_length": 14
    },
    {
      "event_id": "01005009_e00011",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武姜上，二宫女同上。",
      "text_length": 10
    },
    {
      "event_id": "01005009_e00012",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "武姜"
      ],
      "text": "离别宫闱，空使我，老眼含泪。",
      "text_length": 14
    },
    {
      "event_id": "01005009_e00013",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "武姜"
      ],
      "text": "生离最是苦，死别何伤乎！试看姜国母，有子不如无。",
      "text_length": 24
    },
    {
      "event_id": "01005009_e00014",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武姜"
      ],
      "text": "老身姜氏。只因溺爱次子共叔段，反致他夫妇身亡。可恨寤生不孝，将老身迁居颍地居住。思想起来，好不凄凉人也。",
      "text_length": 52
    },
    {
      "event_id": "01005009_e00015",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "武姜"
      ],
      "text": "凄风苦雨多悲惨，冷落离居泪不干。有子如无发长叹，老死此地几时还？",
      "text_length": 32
    },
    {
      "event_id": "01005009_e00016",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小过门。武姜进帐子，脱帔。",
      "text_length": 13
    },
    {
      "event_id": "01005009_e00017",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武姜"
      ],
      "text": "你们退下。",
      "text_length": 5
    },
    {
      "event_id": "01005009_e00018",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女同下。",
      "text_length": 6
    },
    {
      "event_id": "01005009_e00019",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "武姜"
      ],
      "text": "居异乡恨寂寞红日易晚，思娇儿不觉得月上栏杆。对银灯眼昏花自悲自惨，有何人定晨昏心腹细谈。",
      "text_length": 44
    },
    {
      "event_id": "01005009_e00020",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "共叔段、魏氏同上。",
      "text_length": 9
    },
    {
      "event_id": "01005009_e00021",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "共叔段"
      ],
      "text": "风飘飘冷飕飕黄昏惨淡，曾记得在生前荣带正冠。",
      "text_length": 22
    },
    {
      "event_id": "01005009_e00022",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "魏氏"
      ],
      "text": "此时间也难说分诉情由，进寝门见国母心内痛酸。",
      "text_length": 22
    },
    {
      "event_id": "01005009_e00023",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "共叔段",
        "魏氏"
      ],
      "text": "母后醒来！",
      "text_length": 5
    },
    {
      "event_id": "01005009_e00024",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "武姜"
      ],
      "text": "梦儿里只听得有人呼唤，",
      "text_length": 11
    },
    {
      "event_id": "01005009_e00025",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "共叔段",
        "魏氏"
      ],
      "text": "母后醒来！",
      "text_length": 5
    },
    {
      "event_id": "01005009_e00026",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "武姜"
      ],
      "text": "又只见灯光下双影闪连。看不明擦一擦昏花老眼，你是我次子段儿媳元环。曾记得寿筵前金杯酒满，母子们共聚首一处同欢。忆自你封京邑便不回转，",
      "text_length": 66
    },
    {
      "event_id": "01005009_e00027",
      "play_id": "01005009",
      "scene_id": "01005009_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同回龙",
      "speakers": [
        "共叔段",
        "魏氏"
      ],
      "text": "虽是儿丧黄泉难以心甘。",
      "text_length": 11
    },
    {
      "event_id": "01005009_e00028",
