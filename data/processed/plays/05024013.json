      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "关平"
      ],
      "text": "蒙师爷饯行酒我不敢饮，",
      "text_length": 11
    },
    {
      "event_id": "05024013_e00078",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
