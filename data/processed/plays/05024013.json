  "events": [
    {
      "event_id": "05024013_e00001",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手、太监、刘备同上。",
      "text_length": 12
    },
    {
      "event_id": "05024013_e00002",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "刘备"
      ],
      "text": "昨日长亭作荐时，只为西川日夜思。",
      "text_length": 16
    },
    {
      "event_id": "05024013_e00003",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘备"
      ],
      "text": "尧背汤肩柳叶眉，胸藏韬略任我为。老天赐我三分力，要把中原一扫归。",
      "text_length": 32
    },
    {
      "event_id": "05024013_e00004",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "孤刘备。昨日长亭与张松祖饯，蒙他将西川图献与孤家，要孤兴兵取川，我想西川山路险峻，焉能取之。本当不去，又恐别人取之，不免请上二位先生商议发兵之策。来！",
      "text_length": 75
    },
    {
      "event_id": "05024013_e00005",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "05024013_e00006",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "有请二位先生。",
      "text_length": 7
    },
    {
      "event_id": "05024013_e00007",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监"
      ],
      "text": "领旨。主公有旨，有请二位先生。",
      "text_length": 15
    },
    {
      "event_id": "05024013_e00008",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "诸葛亮",
        "庞统"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "05024013_e00009",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "诸葛亮、庞统同上。",
      "text_length": 9
    },
    {
      "event_id": "05024013_e00010",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "诸葛亮"
      ],
      "text": "习就梅花数，",
      "text_length": 6
    },
    {
      "event_id": "05024013_e00011",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "庞统"
      ],
      "text": "阴阳定鬼神。",
      "text_length": 6
    },
    {
      "event_id": "05024013_e00012",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "诸葛亮",
        "庞统"
      ],
      "text": "参见主公。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00013",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "二位先生少礼，请坐。",
      "text_length": 10
    },
    {
      "event_id": "05024013_e00014",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "诸葛亮",
        "庞统"
      ],
      "text": "谢坐。宣臣等进帐，有何国事商议？",
      "text_length": 16
    },
    {
      "event_id": "05024013_e00015",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "二位先生哪里知道，只因张松将地理图献与孤家，要孤兴兵取川，我想西川山路险峻，焉能取之。本当不去，又恐别人取之，请上二位先生，商议发兵之策。",
      "text_length": 69
    },
    {
      "event_id": "05024013_e00016",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "主公趁此机会兴兵前去。",
      "text_length": 11
    },
    {
      "event_id": "05024013_e00017",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庞统"
      ],
      "text": "我想西川，山路虽险，但有张松以为内应。又恐别人取之，那时悔之晚矣！",
      "text_length": 33
    },
    {
      "event_id": "05024013_e00018",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "二位先生，阴阳有准，查明吉凶如何？",
      "text_length": 17
    },
    {
      "event_id": "05024013_e00019",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "诸葛亮",
        "庞统"
      ],
      "text": "臣领旨。",
      "text_length": 4
    },
    {
      "event_id": "05024013_e00020",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "凤雏先生请。",
      "text_length": 6
    },
    {
      "event_id": "05024013_e00021",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庞统"
      ],
      "text": "先生请。",
      "text_length": 4
    },
    {
      "event_id": "05024013_e00022",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "有占了！",
      "text_length": 4
    },
    {
      "event_id": "05024013_e00023",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "诸葛亮"
      ],
      "text": "刘主公取西川龙心已定，算一算此一去可有功成。周文王造八卦阴阳有准，算一算吉凶事不差毫分。刘主爷他本是帝王根本，众将官一个个俱是将星。此一去阳平关山路险峻，怕只怕落凤坡必损能人。",
      "text_length": 88
    },
    {
      "event_id": "05024013_e00024",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "倒不知应在何人身上，待山人再算。",
      "text_length": 16
    },
    {
      "event_id": "05024013_e00025",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "诸葛亮"
      ],
      "text": "查将来算将去阴阳有准，中乱箭应在那庞统先生。我本当进帐去把话来禀，又恐怕泄天机其罪非轻。我这里将此事权且按定，此一去取西川马到功成。",
      "text_length": 66
    },
    {
      "event_id": "05024013_e00026",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "先生推算，吉凶如何？",
      "text_length": 10
    },
    {
      "event_id": "05024013_e00027",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "主公，山人推算，料然无事。",
      "text_length": 13
    },
    {
      "event_id": "05024013_e00028",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "凤雏先生算来。",
      "text_length": 7
    },
    {
      "event_id": "05024013_e00029",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庞统"
      ],
      "text": "遵命！",
      "text_length": 3
    },
    {
      "event_id": "05024013_e00030",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "庞统"
      ],
      "text": "在帐前领过了主公严命，算一算取西川吉凶事情。算一天和二地三才四命，算五行和六爻八卦七星。刘主爷他本是帝王根本，众将官一个个俱是将星。此一去取西川必然得胜，怕只怕落凤坡必损能人。",
      "text_length": 88
    },
    {
      "event_id": "05024013_e00031",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庞统"
      ],
      "text": "且住，方才推算，落凤坡必损能人，但不知应在何人身上，待我再算。",
      "text_length": 31
    },
    {
      "event_id": "05024013_e00032",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "庞统"
      ],
      "text": "此一去阳平关山路险峻，怕只怕张任贼埋伏刀兵。安排了弓箭手坡前扎定，中乱箭却原来应在我身。我本当不取川荆州看定，怕只怕误刘主大事难成。没奈何统人马去把贼征，此一去取西川马到功成。",
      "text_length": 88
    },
    {
      "event_id": "05024013_e00033",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "先生推算如何？",
      "text_length": 7
    },
    {
      "event_id": "05024013_e00034",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庞统"
      ],
      "text": "吉多凶少。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00035",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "妙计安在？",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00036",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庞统"
      ],
      "text": "主公命刘封、关平为先行，贫道挂帅，料然无事。",
      "text_length": 22
    },
    {
      "event_id": "05024013_e00037",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "主公命山人挂帅，料然无事。",
      "text_length": 13
    },
    {
      "event_id": "05024013_e00038",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庞统"
      ],
      "text": "先生休得要抢夺某的功劳。",
      "text_length": 12
    },
    {
      "event_id": "05024013_e00039",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "先生呵！",
      "text_length": 4
    },
    {
      "event_id": "05024013_e00040",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "诸葛亮"
      ],
      "text": "非是我在帐前把功争定，诸葛亮有一言先生细听：此一去阳平关山路险峻，怕只怕张任贼埋伏刀兵。安排了弓箭手坡前扎定，怕的是此一去一命归阴。",
      "text_length": 66
    },
    {
      "event_id": "05024013_e00041",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "庞统"
      ],
      "text": "我先生说此话欺人太甚，难道我庞凤雏八卦不灵？徐先生在长亭将我荐定，在此地受我主莫大之恩。因此上领人马去把贼征，大丈夫死沙场瞑目甘心。",
      "text_length": 66
    },
    {
      "event_id": "05024013_e00042",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "05024013_e00043",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "诸葛亮"
      ],
      "text": "好一个庞凤雏令人可敬，看将来可算得古圣能人。没奈何进帐去把话来禀，尊一声我主爷细听分明：此一去阳平关山路险峻，君臣们切不可换马分兵。",
      "text_length": 66
    },
    {
      "event_id": "05024013_e00044",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "呵！",
      "text_length": 2
    },
    {
      "event_id": "05024013_e00045",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘备"
      ],
      "text": "他二人在帐前相争相论，好叫我刘玄德大不放心。我本当不取川荆州看定，怕东吴和北魏暗地兴兵。没奈何与先生去把贼征，君臣们取西川走上一程。",
      "text_length": 66
    },
    {
      "event_id": "05024013_e00046",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "主公既要兴兵，山人不敢阻拦，来日命四将军长亭备宴，与主公、先生饯行。",
      "text_length": 34
    },
    {
      "event_id": "05024013_e00047",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "刘备",
        "庞统"
      ],
      "text": "有劳先生。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00048",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "来。",
      "text_length": 2
    },
    {
      "event_id": "05024013_e00049",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "下手甲"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "05024013_e00050",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "命四将军长亭备宴，与主公、先生饯行。",
      "text_length": 18
    },
    {
      "event_id": "05024013_e00051",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "下手甲"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "05024013_e00052",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "下手甲下。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00053",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘备"
      ],
      "text": "辞别先生往西川，",
      "text_length": 8
    },
    {
      "event_id": "05024013_e00054",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "诸葛亮",
        "庞统"
      ],
      "text": "但愿此去扫狼烟。",
      "text_length": 8
    },
    {
      "event_id": "05024013_e00055",
      "play_id": "05024013",
      "scene_id": "05024013_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00056",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手、赵云同上。",
      "text_length": 9
    },
    {
      "event_id": "05024013_e00057",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵云"
      ],
      "text": "奉了师爷命，长亭去饯行。",
      "text_length": 12
    },
    {
      "event_id": "05024013_e00058",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵云"
      ],
      "text": "俺赵云。奉了师爷将令，与大哥、先生饯行。来，",
      "text_length": 22
    },
    {
      "event_id": "05024013_e00059",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四下手"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "05024013_e00060",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵云"
      ],
      "text": "打道长亭。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00061",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00062",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四下手"
      ],
      "text": "来此长亭。",
      "text_length": 5
    },
    {
      "event_id": "05024013_e00063",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵云"
      ],
      "text": "远远观见大哥、先生来也。",
      "text_length": 12
    },
    {
      "event_id": "05024013_e00064",
      "play_id": "05024013",
      "scene_id": "05024013_s02",
