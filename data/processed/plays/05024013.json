      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "诸葛亮"
      ],
      "text": "随皇伯取西川处处留心，休离却庞先生任他独行。",
      "text_length": 22
    },
    {
      "event_id": "05024013_e00077",
