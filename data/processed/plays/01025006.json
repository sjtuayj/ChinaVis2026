  "events": [
    {
      "event_id": "01025006_e00001",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐上。",
      "text_length": 5
    },
    {
      "event_id": "01025006_e00002",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "吴小姐"
      ],
      "text": "清晨起来对菱花，蝴蝶双双闹窗纱。",
      "text_length": 16
    },
    {
      "event_id": "01025006_e00003",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟上。",
      "text_length": 4
    },
    {
      "event_id": "01025006_e00004",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "启禀小姑娘：花轿到门了。",
      "text_length": 12
    },
    {
      "event_id": "01025006_e00005",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "可说是花轿到门了么？",
      "text_length": 10
    },
    {
      "event_id": "01025006_e00006",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "01025006_e00007",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "如此就将新人，搀进房来。",
      "text_length": 12
    },
    {
      "event_id": "01025006_e00008",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是！",
      "text_length": 2
    },
    {
      "event_id": "01025006_e00009",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟下。",
      "text_length": 4
    },
    {
      "event_id": "01025006_e00010",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "看丫鬟报道：花轿到门，已将我家新嫂嫂娶来了。我不免在绣阁等候便了。",
      "text_length": 33
    },
    {
      "event_id": "01025006_e00011",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "梆子正板",
      "speakers": [
        "吴小姐"
      ],
      "text": "时才间小丫鬟报了一声，她说道我新嫂嫂娶到家门。我只得在绣阁慢慢来等，等候着她来时我看看新人。",
      "text_length": 46
    },
    {
      "event_id": "01025006_e00012",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吹牌子。丫鬟扶刘公子扮女装同上。",
      "text_length": 16
    },
    {
      "event_id": "01025006_e00013",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "丫鬟退下。",
      "text_length": 5
    },
    {
      "event_id": "01025006_e00014",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是！",
      "text_length": 2
    },
    {
      "event_id": "01025006_e00015",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟下。",
      "text_length": 4
    },
    {
      "event_id": "01025006_e00016",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "待我将绣阁房门闭上。",
      "text_length": 10
    },
    {
      "event_id": "01025006_e00017",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐关门。",
      "text_length": 6
    },
    {
      "event_id": "01025006_e00018",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "梆子正板",
      "speakers": [
        "吴小姐"
      ],
      "text": "我这里且把房门来掩，陪伴着新嫂嫂坐在床前。用手儿掀盖头仔细详看，",
      "text_length": 32
    },
    {
      "event_id": "01025006_e00019",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐去盖头红巾。",
      "text_length": 9
    },
    {
      "event_id": "01025006_e00020",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "妙吓！",
      "text_length": 3
    },
    {
      "event_id": "01025006_e00021",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "aria",
      "mode_label": "梆子正板",
      "speakers": [
        "吴小姐"
      ],
      "text": "看她那美容颜亚赛天仙。似这等美容颜人间罕见，好一似月里嫦娥降下了凡。",
      "text_length": 34
    },
    {
      "event_id": "01025006_e00022",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "aria",
      "mode_label": "梆子流水板",
      "speakers": [
        "刘公子"
      ],
      "text": "来至在绣阁中偷眼观看，这女子生的是赛过天仙。",
      "text_length": 22
    },
    {
      "event_id": "01025006_e00023",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐看刘公子足背，以手比划，笑。",
      "text_length": 17
    },
    {
      "event_id": "01025006_e00024",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "aria",
      "mode_label": "梆子流水板",
      "speakers": [
        "吴小姐"
      ],
      "text": "她那里不住的将我来看，一时间看得我面带羞惭。",
      "text_length": 22
    },
    {
      "event_id": "01025006_e00025",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "新嫂嫂，请来见礼。",
      "text_length": 9
    },
    {
      "event_id": "01025006_e00026",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "奴家还礼。",
      "text_length": 5
    },
    {
      "event_id": "01025006_e00027",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "好说。请问新嫂嫂，今年多大岁数了？",
      "text_length": 17
    },
    {
      "event_id": "01025006_e00028",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "奴家二八一十六岁了。",
      "text_length": 10
    },
    {
      "event_id": "01025006_e00029",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "怎说是嫂嫂，今年二八一十六岁了？",
      "text_length": 16
    },
    {
      "event_id": "01025006_e00030",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "01025006_e00031",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "如此说来，你倒比我家哥哥小上两岁。",
      "text_length": 17
    },
    {
      "event_id": "01025006_e00032",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "哦，我还比你家哥哥，小上两岁么？",
      "text_length": 16
    },
    {
      "event_id": "01025006_e00033",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "小上两岁。",
      "text_length": 5
    },
    {
      "event_id": "01025006_e00034",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘公子两旁看。",
      "text_length": 7
    },
    {
      "event_id": "01025006_e00035",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "请问嫂嫂，看些什么？",
      "text_length": 10
    },
    {
      "event_id": "01025006_e00036",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "奴家到此半日，为何不见你家哥哥，他往哪里去了？",
      "text_length": 23
    },
    {
      "event_id": "01025006_e00037",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "嫂嫂，是你非知：只因朝中徐老千岁出京放粮，在此下马，我家哥哥奉了我家爹爹之命，去往城中，办差去了。",
      "text_length": 49
    },
    {
      "event_id": "01025006_e00038",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "原来如此，但不知今晚回来不回来？",
      "text_length": 16
    },
    {
      "event_id": "01025006_e00039",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "大概今晚是不回来的分儿多。",
      "text_length": 13
    },
    {
      "event_id": "01025006_e00040",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "你哥哥今晚若不回来，岂不耽误了奴家的好事么？",
      "text_length": 22
    },
    {
      "event_id": "01025006_e00041",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "新嫂嫂不必忧烦，现有我家哥哥的靴帽蓝衫在此，待小妹扮做我家哥哥的模样，陪伴嫂嫂，你看如何呀？",
      "text_length": 46
    },
    {
      "event_id": "01025006_e00042",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "你住了罢！世界之上，只有男子配女郎，哪有女郎配女郎的道理？想你我二人，俱是女流，此事是如何使得？",
      "text_length": 48
    },
    {
      "event_id": "01025006_e00043",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "我说使得，就是使得。待我装扮起来。",
      "text_length": 17
    },
    {
      "event_id": "01025006_e00044",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "aria",
      "mode_label": "梆子流水板",
      "speakers": [
        "吴小姐"
      ],
      "text": "我这里忙取下头上钗环，装作了我哥哥成就良缘。",
      "text_length": 22
    },
    {
      "event_id": "01025006_e00045",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐入帐内换衣。",
      "text_length": 9
    },
    {
      "event_id": "01025006_e00046",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "妙吓！",
      "text_length": 3
    },
    {
      "event_id": "01025006_e00047",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "aria",
      "mode_label": "梆子流水板",
      "speakers": [
        "刘公子"
      ],
      "text": "小姑娘她生得真真好看，她本是女儿家也要装男。怕的是难逃今夜晚，我只得假意儿来学痴颟。将身儿且坐在绣阁里面，等候了小姑娘再把话言。",
      "text_length": 64
    },
    {
      "event_id": "01025006_e00048",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐扮男子出。",
      "text_length": 8
    },
    {
      "event_id": "01025006_e00049",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "吴小姐"
      ],
      "text": "在头上戴定了方巾便帽，在身上穿蓝衫腰系丝绦。走上前便把那嫂嫂来叫，我二人拜华堂凤友鸾交。",
      "text_length": 44
    },
    {
      "event_id": "01025006_e00050",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "嫂嫂，我二人同来拜天地呀！",
      "text_length": 13
    },
    {
      "event_id": "01025006_e00051",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "此事是使不得的。",
      "text_length": 8
    },
    {
      "event_id": "01025006_e00052",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "我说使得，就是使得，你要来呀！",
      "text_length": 15
    },
    {
      "event_id": "01025006_e00053",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "吴小姐"
      ],
      "text": "在绣阁打扮得男子一样，有郎才合女貌果是一双。走向前来把堂拜——",
      "text_length": 31
    },
    {
      "event_id": "01025006_e00054",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐作揖，刘公子作揖。",
      "text_length": 12
    },
    {
      "event_id": "01025006_e00055",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "嫂嫂，你那里怎样吓？",
      "text_length": 10
    },
    {
      "event_id": "01025006_e00056",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "小姑娘，你是怎样吓？",
      "text_length": 10
    },
    {
      "event_id": "01025006_e00057",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "我这里，是作揖呀！",
      "text_length": 9
    },
    {
      "event_id": "01025006_e00058",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "我也是作揖。",
      "text_length": 6
    },
    {
      "event_id": "01025006_e00059",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "嗳，你要拜拜。",
      "text_length": 7
    },
    {
      "event_id": "01025006_e00060",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "我不会拜。",
      "text_length": 5
    },
    {
      "event_id": "01025006_e00061",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "难道你上轿的时节，你家母亲也不曾教导与你么？",
      "text_length": 22
    },
    {
      "event_id": "01025006_e00062",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "我家母亲，并不曾教导与我。",
      "text_length": 13
    },
    {
      "event_id": "01025006_e00063",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "如此，待妹妹教导与你。这女儿家，要用手将鬓角一摸，再这么一摸，将袖儿就是这样一摆，再用手这样一舞，这就是拜了。",
      "text_length": 55
    },
    {
      "event_id": "01025006_e00064",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "我倒学会了，用手一摸鬓角，再一摸，又这样一摆、两摆，一舞，这就是拜了。",
      "text_length": 35
    },
    {
      "event_id": "01025006_e00065",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "着吓，对了！",
      "text_length": 6
    },
    {
      "event_id": "01025006_e00066",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "吴小姐"
      ],
      "text": "夫妻们同交拜成就鸳鸯。",
      "text_length": 11
    },
    {
      "event_id": "01025006_e00067",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "嫂嫂，你我一同安眠了罢！",
      "text_length": 12
    },
    {
      "event_id": "01025006_e00068",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "这个……小姑娘先请，我随后就来了。",
      "text_length": 17
    },
    {
      "event_id": "01025006_e00069",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "你就要来呀！",
      "text_length": 6
    },
    {
      "event_id": "01025006_e00070",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐走浪头，三次入帐。",
      "text_length": 12
    },
    {
      "event_id": "01025006_e00071",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "嫂嫂你来！",
      "text_length": 5
    },
    {
      "event_id": "01025006_e00072",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "来了！",
      "text_length": 3
    },
    {
      "event_id": "01025006_e00073",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "刘公子"
      ],
      "text": "小姑娘她扮作男子模样，她叫我随同她共上牙床。我若是在床上成了勾当——",
      "text_length": 34
    },
    {
      "event_id": "01025006_e00074",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "嫂嫂你快快地来呀！",
      "text_length": 9
    },
    {
      "event_id": "01025006_e00075",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "来了！",
      "text_length": 3
    },
    {
      "event_id": "01025006_e00076",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "刘公子"
      ],
      "text": "还须要暂消停细作商量。",
      "text_length": 11
    },
    {
      "event_id": "01025006_e00077",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐出帐。",
      "text_length": 6
    },
    {
      "event_id": "01025006_e00078",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "吴小姐"
      ],
      "text": "我这里出罗帏把话来讲，叫一声新嫂嫂细听端详：你与我同入那罗帏帐，咱二人在牙床成就鸳鸯。",
      "text_length": 43
    },
    {
      "event_id": "01025006_e00079",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴小姐扯刘公子，比划手势，刘公子遮掩三番，吴小姐入帐。",
      "text_length": 27
    },
    {
      "event_id": "01025006_e00080",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "刘公子"
      ],
      "text": "无奈何我且把牙床来上，我看她今夜晚是怎样下场。",
      "text_length": 23
    },
    {
      "event_id": "01025006_e00081",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘公子入帐。拉牌子。吴小姐出帐子拔宝剑欲杀刘公子，刘公子急跪。",
      "text_length": 31
    },
    {
      "event_id": "01025006_e00082",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "刘公子"
      ],
      "text": "我叫一声小姑娘，哭一声吴小姐，哎呀呀，我的小姑娘吓！",
      "text_length": 26
    },
    {
      "event_id": "01025006_e00083",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "吴小姐"
      ],
      "text": "时才把奴胆吓坏，你为何假扮女裙钗？手执宝剑朝下砍——",
      "text_length": 26
    },
    {
      "event_id": "01025006_e00084",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "小姑娘饶命吓！",
      "text_length": 7
    },
    {
      "event_id": "01025006_e00085",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "吴小姐"
      ],
      "text": "你快快与我说明白。",
      "text_length": 9
    },
    {
      "event_id": "01025006_e00086",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "刘公子"
      ],
      "text": "我本是前巷刘公子，假扮裙钗到此来。望求小姑娘将我放，日后定要报恩来。",
      "text_length": 34
    },
    {
      "event_id": "01025006_e00087",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "吴小姐"
      ],
      "text": "既然你是那刘公子，为何改扮女裙钗？",
      "text_length": 17
    },
    {
      "event_id": "01025006_e00088",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 3,
      "type": "aria",
      "mode_label": "梆子原板",
      "speakers": [
        "刘公子"
      ],
      "text": "你哥哥要娶我的姐，因此上替她扮裙钗。",
      "text_length": 18
    },
    {
      "event_id": "01025006_e00089",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "你且起来。",
      "text_length": 5
    },
    {
      "event_id": "01025006_e00090",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "多谢小姑娘。",
      "text_length": 6
    },
    {
      "event_id": "01025006_e00091",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "此事本来是我家哥哥的不是，你今既到此地，已与奴家同床睡过，你叫我是怎样见人？奴欲与你就此定下姻缘，不知你意下如何？",
      "text_length": 57
    },
    {
      "event_id": "01025006_e00092",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "既蒙小姑娘搭救之恩，敢不遵命？",
      "text_length": 15
    },
    {
      "event_id": "01025006_e00093",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴小姐"
      ],
      "text": "好！就在奴绣阁住下。明日命人送你回家，你要急速叫媒人前来提亲，才是正理。",
      "text_length": 36
    },
    {
      "event_id": "01025006_e00094",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 94,
      "seq_in_scene": 94,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "小生件件依从。正是：",
      "text_length": 10
    },
    {
      "event_id": "01025006_e00095",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 95,
      "seq_in_scene": 95,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘公子"
      ],
      "text": "男扮女来女扮男，",
      "text_length": 8
    },
    {
      "event_id": "01025006_e00096",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 96,
      "seq_in_scene": 96,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "吴小姐"
      ],
      "text": "千里良缘一线牵。",
      "text_length": 8
    },
    {
      "event_id": "01025006_e00097",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 97,
      "seq_in_scene": 97,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘公子"
      ],
      "text": "待等明朝回家转，",
      "text_length": 8
    },
    {
      "event_id": "01025006_e00098",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 98,
      "seq_in_scene": 98,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "吴小姐"
      ],
      "text": "女貌郎才果一般！",
      "text_length": 8
    },
    {
      "event_id": "01025006_e00099",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 99,
      "seq_in_scene": 99,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘公子"
      ],
      "text": "好一个“女貌郎才果一般”！请。",
      "text_length": 15
    },
    {
      "event_id": "01025006_e00100",
      "play_id": "01025006",
      "scene_id": "01025006_s01",
      "scene_no": 1,
      "seq_global": 100,
      "seq_in_scene": 100,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吹牌子。吴小姐、刘公子同下。",
      "text_length": 14
    }
  ],
