  "events": [
    {
      "event_id": "01024003_e00001",
      "play_id": "01024003",
      "scene_id": "01024003_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二书童执酒壶引李白同上。",
      "text_length": 12
    },
    {
      "event_id": "01024003_e00002",
      "play_id": "01024003",
      "scene_id": "01024003_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "满腹文章才高八斗，不愿在朝作王侯。怕的是世上无美酒，那时我愁上反加愁。",
      "text_length": 35
    },
    {
      "event_id": "01024003_e00003",
      "play_id": "01024003",
      "scene_id": "01024003_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "学生，姓李名白字谪仙，巴西人氏。生性清高，做事狂放，经纶满腹。十五学剑术，遍干公侯；二十成文章，力敌卿相。前者曾到贡院赴考，不料杨国忠、高力士二人巡场，因我性喜饮酒，言语放浪，他二人竟将我赶出贡院。因此我也无志功名，视富贵如浮云，观利禄同草芥。只因黑水国国王不肯纳贡，遣使进来蛮表一道，满朝文武俱不能解，圣上甚为忧虑。因有侍臣保奏，举荐我李白。圣上将我宣上金殿，未见龙颜，先封我翰林学士之职。是我解开蛮表，龙颜大悦，命我修文答复蛮邦。那时我命杨国忠与我磨墨捧砚，高力士与我脱靴站班。圣上今日在沉香亭上同贵妃杨娘娘饮酒，宣我侍宴，赋清平调数章。蒙圣恩，赐我御宴琼浆，只吃得醺醺带醉。看今日天气晴和，不免去到接金马门走走。书童，",
      "text_length": 312
    },
    {
      "event_id": "01024003_e00004",
      "play_id": "01024003",
      "scene_id": "01024003_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二书童"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01024003_e00005",
      "play_id": "01024003",
      "scene_id": "01024003_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "带路金马门去者。",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00006",
      "play_id": "01024003",
      "scene_id": "01024003_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "李白"
      ],
      "text": "唐天子有道君英明神圣，普天下众黎民快乐欢欣。满朝中文武臣赓歌称颂，天宝年岁丰熟共享太平。各国中遵王化同把贡进，四下里靖干戈甲胄离身。叫童儿与爷把路引，你一同去到那金马门。",
      "text_length": 85
    },
    {
      "event_id": "01024003_e00007",
      "play_id": "01024003",
      "scene_id": "01024003_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李白、二书童同下。",
      "text_length": 9
    },
    {
      "event_id": "01024003_e00008",
      "play_id": "01024003",
      "scene_id": "01024003_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四校尉、二将、安禄山同上。",
      "text_length": 17
    },
    {
      "event_id": "01024003_e00009",
      "play_id": "01024003",
      "scene_id": "01024003_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "安禄山"
      ],
      "text": "位列朝臣，龙恩宠，出入宫廷。",
      "text_length": 14
    },
    {
      "event_id": "01024003_e00010",
      "play_id": "01024003",
      "scene_id": "01024003_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "安禄山"
      ],
      "text": "某本胡人到天朝，幼习弓马与枪刀。多蒙国忠将某保，因此得宠在当朝。",
      "text_length": 32
    },
    {
      "event_id": "01024003_e00011",
      "play_id": "01024003",
      "scene_id": "01024003_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "某，安禄山，北胡人氏。来到天朝，得遇杨国忠。是我与他结交甚厚，蒙他将吾保奏朝廷，颇蒙圣上恩宠，召吾进宫。是吾又拜杨贵妃为义母，出入宫廷，无人拦阻。万岁因吾征战有功，封吾为锦衣都尉之职，兼管天下人马，统握兵权。满朝文武，人人尊敬。顺吾者昌，逆吾者亡。看今日天气清和，不免到宫中走走。呔，校尉的，打道宫闱。",
      "text_length": 151
    },
    {
      "event_id": "01024003_e00012",
      "play_id": "01024003",
      "scene_id": "01024003_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "安禄山上马。〖牌子〗。众人同下。",
      "text_length": 16
    },
    {
      "event_id": "01024003_e00013",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 13,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二书童引李白同上。",
      "text_length": 9
    },
    {
      "event_id": "01024003_e00014",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 14,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "李白饮酒沧海量，酒后赋诗百十章。醉眼朦胧抬头望，那边厢好似贺知章。",
      "text_length": 33
    },
    {
      "event_id": "01024003_e00015",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 15,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺知章上。",
      "text_length": 5
    },
    {
      "event_id": "01024003_e00016",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 16,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "贺知章"
      ],
      "text": "适才修本出朝房，见学士酒醉甚徜徉。",
      "text_length": 17
    },
    {
      "event_id": "01024003_e00017",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 17,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "原来是学士公。",
      "text_length": 7
    },
    {
      "event_id": "01024003_e00018",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 18,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "原来是贺年兄，请了。",
      "text_length": 10
    },
    {
      "event_id": "01024003_e00019",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 19,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "你今日又在哪里吃得这般大醉？",
      "text_length": 14
    },
    {
      "event_id": "01024003_e00020",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 20,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "我并不曾吃酒，何言大醉？",
      "text_length": 12
    },
    {
      "event_id": "01024003_e00021",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "哎呀哎呀，你看你满面春光，尚说不曾吃酒！",
      "text_length": 20
    },
    {
      "event_id": "01024003_e00022",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "年兄有所不知，只因圣上命我和答蛮诗，退得朝去，在沉香亭同杨贵妃饮宴，命我陪侍，又命我赋清平调数章。龙颜大喜，赐我御酒数觥。因此微微带醉。",
      "text_length": 68
    },
    {
      "event_id": "01024003_e00023",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "原来如此。不知学士公意欲何往？",
      "text_length": 15
    },
    {
      "event_id": "01024003_e00024",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "只因今日闲暇无事，要到金马门走走。",
      "text_length": 17
    },
    {
      "event_id": "01024003_e00025",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "好，老朽亦要到金马门。",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00026",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "如此一同前往。",
      "text_length": 7
    },
    {
      "event_id": "01024003_e00027",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "01024003_e00028",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贺知章"
      ],
      "text": "文心雕龙才非浅，",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00029",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "锦心绣口日试万言。",
      "text_length": 9
    },
    {
      "event_id": "01024003_e00030",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贺知章"
      ],
      "text": "圣天子爱文才官爵显，",
      "text_length": 10
    },
    {
      "event_id": "01024003_e00031",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "怎奈我李太白不愿为官。",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00032",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贺知章"
      ],
      "text": "学士公好风流山水游玩，",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00033",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "游青山玩绿水须把酒担。",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00034",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贺知章"
      ],
      "text": "虽然是好饮酒也须检点，",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00035",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "我李白也本是酒中仙。",
      "text_length": 10
    },
    {
      "event_id": "01024003_e00036",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贺知章"
      ],
      "text": "饮美酒可消愁古人常见，",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00037",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "一斗酒即能咏诗百篇。",
      "text_length": 10
    },
    {
      "event_id": "01024003_e00038",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "贺知章"
      ],
      "text": "耳边厢又听得人马呐喊，",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00039",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "是何人在御街这等威严？",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00040",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "吓，年兄，看前面有许多人役，拥护一人，马嘶人喊。但不知他是何人？",
      "text_length": 32
    },
    {
      "event_id": "01024003_e00041",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "此乃是安禄山入朝，从此经过，故而人马呐喊。",
      "text_length": 21
    },
    {
      "event_id": "01024003_e00042",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "我道是谁，原来是安禄山！等他到来，我定要羞辱他一番！",
      "text_length": 26
    },
    {
      "event_id": "01024003_e00043",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "吓，学士公，他乃是当今万岁宠爱之人，况且又是贵妃杨娘娘之义子。势焰熏天。你惹他恐有不便。",
      "text_length": 44
    },
    {
      "event_id": "01024003_e00044",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "年兄此言差矣，",
      "text_length": 7
    },
    {
      "event_id": "01024003_e00045",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "李白"
      ],
      "text": "说什么万岁爷将他宠眷，说什么他又是贵妃的义男。他虽然是一个男儿汉，却与那妇女们一样般。你道他在朝中颇有势焰，我看他竟不值半文钱！",
      "text_length": 64
    },
    {
      "event_id": "01024003_e00046",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "贺知章"
      ],
      "text": "学士莫把他小看，惹他惟恐起祸端。",
      "text_length": 16
    },
    {
      "event_id": "01024003_e00047",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四校尉、二将、安禄山同上。",
      "text_length": 17
    },
    {
      "event_id": "01024003_e00048",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "安禄山"
      ],
      "text": "绒缰玉辔八宝鞍，金环翠铠珊瑚鞭。催动骏马往走趱，不觉来到金马门前。",
      "text_length": 33
    },
    {
      "event_id": "01024003_e00049",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "来到这金马门，有二人当道而坐，不知他是何人？左右，你等可识此二人？",
      "text_length": 33
    },
    {
      "event_id": "01024003_e00050",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四校尉"
      ],
      "text": "此乃是新翰林学士李白并贺知章。",
      "text_length": 15
    },
    {
      "event_id": "01024003_e00051",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "且住，想那李白乃是新赐翰林学士。此人吃酒癫狂，又是圣上亲信之臣，倘若冲撞于他，有些不便。待吾拨马而回。嗳耶！大丈夫只有向前，哪有退后之理？待吾向前，与他见上一礼也就完了。",
      "text_length": 85
    },
    {
      "event_id": "01024003_e00052",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "安禄山下马。",
      "text_length": 6
    },
    {
      "event_id": "01024003_e00053",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "吓，学士公，本都尉这厢有礼了。",
      "text_length": 15
    },
    {
      "event_id": "01024003_e00054",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李白背面不睬安禄山。",
      "text_length": 10
    },
    {
      "event_id": "01024003_e00055",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "吓，都尉千岁，老朽这里赔礼了。",
      "text_length": 15
    },
    {
      "event_id": "01024003_e00056",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "安禄山背面不睬贺知章。",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00057",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "吓，年兄，你与哪个赔礼呀？",
      "text_length": 13
    },
    {
      "event_id": "01024003_e00058",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "老朽替学士公与安都尉赔礼。",
      "text_length": 13
    },
    {
      "event_id": "01024003_e00059",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "如此，待我向前见礼。吓，都尉，学生有礼了！",
      "text_length": 21
    },
    {
      "event_id": "01024003_e00060",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "还礼！",
      "text_length": 3
    },
    {
      "event_id": "01024003_e00061",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李白伸小指。",
      "text_length": 6
    },
    {
      "event_id": "01024003_e00062",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "李白"
      ],
      "text": "哧，哈哈哈哈！",
      "text_length": 7
    },
    {
      "event_id": "01024003_e00063",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "吓，都尉，你是何等样人，竟敢打从我这金马门而过！",
      "text_length": 24
    },
    {
      "event_id": "01024003_e00064",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "慢说是金马门，就是金銮宝殿，六院三宫，本都威也要走走！",
      "text_length": 27
    },
    {
      "event_id": "01024003_e00065",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "你待怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01024003_e00066",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "也要走走！",
      "text_length": 5
    },
    {
      "event_id": "01024003_e00067",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "住了！",
      "text_length": 3
    },
    {
      "event_id": "01024003_e00068",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "李白"
      ],
      "text": "一言怒了翰林院，",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00069",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 69,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "李白"
      ],
      "text": "叫声禄山听根源：黑水国不曾把贡献，进来蛮邦诗一篇。满朝文武不能辨，惹得万岁怒冲冠。那时文臣把我荐，未曾见君先封官。杨国忠磨墨来捧砚，高力士脱靴来站班。你并无三弓和两箭，怎敢在此出大言？",
      "text_length": 92
    },
    {
      "event_id": "01024003_e00070",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 70,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "想我安禄山，统领雄兵征剿各处，也有汗马功劳，怎说是无有？",
      "text_length": 28
    },
    {
      "event_id": "01024003_e00071",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 71,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "吓，都尉千岁的功劳实实不小！",
      "text_length": 14
    },
    {
      "event_id": "01024003_e00072",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 72,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "安禄山"
      ],
      "text": "嘿，我看这朝中大事，定要坏在你们文官之手！",
      "text_length": 21
    },
    {
      "event_id": "01024003_e00073",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 73,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "吓，年兄，他讲说什么？",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00074",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 74,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "都尉道：朝中之事要坏在我等文官之手。",
      "text_length": 18
    },
    {
      "event_id": "01024003_e00075",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 75,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "你且听了：",
      "text_length": 5
    },
    {
      "event_id": "01024003_e00076",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 76,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "李白"
      ],
      "text": "叫声禄山好大胆，竟敢藐视我文官！昔日弥子把桃啖，他把余桃媚龙颜。到后来色衰反遭斩，我看他与你似一般！回头便把书童唤，你与我辱骂安禄山！",
      "text_length": 67
    },
    {
      "event_id": "01024003_e00077",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 77,
      "seq_in_scene": 65,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "书童，你等向前与我叫骂这厮！",
      "text_length": 14
    },
    {
      "event_id": "01024003_e00078",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 78,
      "seq_in_scene": 66,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "书童甲"
      ],
      "text": "安禄山，你不要自大！自大乃是一个“臭”字！你真是臭而不可闻也！",
      "text_length": 31
    },
    {
      "event_id": "01024003_e00079",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 79,
      "seq_in_scene": 67,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "你也去骂呀！",
      "text_length": 6
    },
    {
      "event_id": "01024003_e00080",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 80,
      "seq_in_scene": 68,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "书童乙"
      ],
      "text": "安禄山，你听了：",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00081",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 81,
      "seq_in_scene": 69,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "书童乙"
      ],
      "text": "金马门前一声喊，大骂无知安禄山！看你鹰鼻又鹞眼，兔头龟背骆驼肩。每日在朝把媚献，好似妇女弄容颜。“尸”字底下加“比”字，你竟做的是屁股官！",
      "text_length": 69
    },
    {
      "event_id": "01024003_e00082",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 82,
      "seq_in_scene": 70,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "骂得好！年兄，这“尸”字加一“比”字，你可知道？",
      "text_length": 24
    },
    {
      "event_id": "01024003_e00083",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 83,
      "seq_in_scene": 71,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "我倒不知。",
      "text_length": 5
    },
    {
      "event_id": "01024003_e00084",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 84,
      "seq_in_scene": 72,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "此乃是一个“屁”字呀！",
      "text_length": 11
    },
    {
      "event_id": "01024003_e00085",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 85,
      "seq_in_scene": 73,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "取笑了！",
      "text_length": 4
    },
    {
      "event_id": "01024003_e00086",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 86,
      "seq_in_scene": 74,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "安禄山"
      ],
      "text": "恼恨李白太不端，主仆竟敢出恶言。人来与爷把路转，",
      "text_length": 24
    },
    {
      "event_id": "01024003_e00087",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 87,
      "seq_in_scene": 75,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四校尉、二将同下。",
      "text_length": 13
    },
    {
      "event_id": "01024003_e00088",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 88,
      "seq_in_scene": 76,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "安禄山"
      ],
      "text": "见了贵妃把本参。",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00089",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 89,
      "seq_in_scene": 77,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "安禄山下。",
      "text_length": 5
    },
    {
      "event_id": "01024003_e00090",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 90,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二书童"
      ],
      "text": "启爷，安禄山回去了！",
      "text_length": 10
    },
    {
      "event_id": "01024003_e00091",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 91,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "看他此番前去定要上殿奏本。",
      "text_length": 13
    },
    {
      "event_id": "01024003_e00092",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 92,
      "seq_in_scene": 80,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李白"
      ],
      "text": "他纵然奏本，他又岂奈我何？",
      "text_length": 13
    },
    {
      "event_id": "01024003_e00093",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 93,
      "seq_in_scene": 81,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "01024003_e00094",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 94,
      "seq_in_scene": 82,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贺知章"
      ],
      "text": "学士出言太癫狂，",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00095",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 95,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李白"
      ],
      "text": "有意痛骂安禄山。",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00096",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 96,
      "seq_in_scene": 84,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贺知章"
      ],
      "text": "倘若进宫把本献，",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00097",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 97,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李白"
      ],
      "text": "摘去乌纱反清闲！",
      "text_length": 8
    },
    {
      "event_id": "01024003_e00098",
      "play_id": "01024003",
      "scene_id": "01024003_s03",
      "scene_no": 3,
      "seq_global": 98,
      "seq_in_scene": 86,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李白、贺知章、二书童同下。",
      "text_length": 13
    }
  ],
  "roles_inferred": true
}