  "events": [
    {
      "event_id": "02005002_e00001",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金氏上。",
      "text_length": 4
    },
    {
      "event_id": "02005002_e00002",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "金氏"
      ],
      "text": "寂寞香闺，为夫君，终朝泪垂。",
      "text_length": 14
    },
    {
      "event_id": "02005002_e00003",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "金氏"
      ],
      "text": "自叹奴命蹇，夫君丧黄泉。遗容无处觅，托赖笔毫端。",
      "text_length": 24
    },
    {
      "event_id": "02005002_e00004",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "奴家金氏，伯伯邓伯道，姆姆李氏，丈夫邓伯俭。遗下一子，名唤寿山。且喜伯伯、姆姆，十分爱惜。奴家自幼略晓丹青，不免将丈夫遗容，描画出来，早晚供奉，以尽夫妇之情。",
      "text_length": 79
    },
    {
      "event_id": "02005002_e00005",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "金氏"
      ],
      "text": "度日如年漫沉吟，终日思君不见君，描画丹青借笔力，叫奴辗转暗伤情。",
      "text_length": 32
    },
    {
      "event_id": "02005002_e00006",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金氏描。",
      "text_length": 4
    },
    {
      "event_id": "02005002_e00007",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "四朝元",
      "speakers": [
        "金氏"
      ],
      "text": "伤情举笔，未描泪先垂。画得他，温柔体态，儒雅风姿。全凭着，全凭着纸共笔，慢寻思就里就里。画得他，锦绣襟怀，气质聪慧。再画他衣冠威仪，堂堂貌美堂堂貌美。我的夫，也只是少口气。喳，再画他俊庞儿庞儿，秋水凝眸，春山秀丽。吾画他，骨格清奇，语句儿语句儿多伶俐。只落得闲居静室，静室幽幽雅雅，好比作在生之日之日。",
      "text_length": 151
    },
    {
      "event_id": "02005002_e00008",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "遗容画完，不免供奉中堂，取些凉浆水饭，祭奠便了。啊，我那夫哇！只说不得与你重相见，谁知纸上又重逢。不免请伯伯、姆姆出来观看。伯伯、姆姆有请。",
      "text_length": 70
    },
    {
      "event_id": "02005002_e00009",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "邓伯道、李氏同上。",
      "text_length": 9
    },
    {
      "event_id": "02005002_e00010",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同薄幸引",
      "speakers": [
        "邓伯道",
        "李氏"
      ],
      "text": "奈何奈何为兄弟，终朝泪落终朝泪落。",
      "text_length": 17
    },
    {
      "event_id": "02005002_e00011",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "伯伯、姆姆万福。",
      "text_length": 8
    },
    {
      "event_id": "02005002_e00012",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "邓伯道",
        "金氏"
      ],
      "text": "罢了。",
      "text_length": 3
    },
    {
      "event_id": "02005002_e00013",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邓伯道"
      ],
      "text": "弟媳妇，请我二人出来，有何话讲？",
      "text_length": 16
    },
    {
      "event_id": "02005002_e00014",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "自从丈夫丧后，朝思暮想。方才描画出来，请伯伯、姆姆观看！",
      "text_length": 28
    },
    {
      "event_id": "02005002_e00015",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "邓伯道",
        "李氏"
      ],
      "text": "在哪里？",
      "text_length": 4
    },
    {
      "event_id": "02005002_e00016",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "在中堂。",
      "text_length": 4
    },
    {
      "event_id": "02005002_e00017",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "邓伯道",
        "李氏"
      ],
      "text": "大家前去。",
      "text_length": 5
    },
    {
      "event_id": "02005002_e00018",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金氏、邓伯道、李氏同走圆场。",
      "text_length": 14
    },
    {
      "event_id": "02005002_e00019",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "邓伯道",
        "李氏"
      ],
      "text": "在哪里？",
      "text_length": 4
    },
    {
      "event_id": "02005002_e00020",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "在上面。",
      "text_length": 4
    },
    {
      "event_id": "02005002_e00021",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "邓伯道",
        "李氏"
      ],
      "text": "啊，我那（兄弟）（叔叔）哇！",
      "text_length": 14
    },
    {
      "event_id": "02005002_e00022",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "邓伯道"
      ],
      "text": "一见图画始惊讶，老眼端详恰是他。指望兄弟常厮守，",
      "text_length": 24
    },
    {
      "event_id": "02005002_e00023",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李氏"
      ],
      "text": "谁知一命染黄沙。",
      "text_length": 8
    },
    {
      "event_id": "02005002_e00024",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "邓伯道"
      ],
      "text": "画得好，果无差。",
      "text_length": 8
    },
    {
      "event_id": "02005002_e00025",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "金氏"
      ],
      "text": "姣妻幼子靠谁家？",
      "text_length": 8
    },
    {
      "event_id": "02005002_e00026",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "邓伯道"
      ],
      "text": "早知落在丹青手，觑定遗容泪如麻。",
      "text_length": 16
    },
    {
      "event_id": "02005002_e00027",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "邓伯道"
      ],
      "text": "觑真容，恰便似共同胞。觑着他模样儿，一般容貌。",
      "text_length": 23
    },
    {
      "event_id": "02005002_e00028",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邓伯道"
      ],
      "text": "画便画得好，只是太丑陋了些。",
      "text_length": 14
    },
    {
      "event_id": "02005002_e00029",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "丈夫在日遗容，一时追想不来。",
      "text_length": 14
    },
    {
      "event_id": "02005002_e00030",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "金氏"
      ],
      "text": "曾记得，临危遗容呵，因此上，画得他病恹恹，这般黄瘦焦。",
      "text_length": 27
    },
    {
      "event_id": "02005002_e00031",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "邓伯道"
      ],
      "text": "若是他，临危遗容呵，全不差半分毫，分毫。兄弟呵，你死后为神道，",
      "text_length": 31
    },
    {
      "event_id": "02005002_e00032",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "邓伯道"
      ],
      "text": "闪得她母子，母子单抛。",
      "text_length": 11
    },
    {
      "event_id": "02005002_e00033",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "哼。",
      "text_length": 2
    },
    {
      "event_id": "02005002_e00034",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "金氏"
      ],
      "text": "夫，想奴家，幼年丧父，中年丧夫。此乃是大不幸了么？夫，你若是阴灵有感，有感阴灵，保佑我母子们灾祸自然消！不由人哭嚎啕，夫你今闪，闪得我也无归落。",
      "text_length": 72
    },
    {
      "event_id": "02005002_e00035",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "步步娇",
      "speakers": [
        "李氏"
      ],
      "text": "劝婶婶不必仍恁心焦，少带些烦恼。不幸叔叔归阴早，从今后叔伯姆，只当作姐妹相交。把侄儿爱惜他，如珍似宝，我丈夫的衣衫鞋帽，任侄儿随意穿着，他随意儿穿着。",
      "text_length": 75
    },
    {
      "event_id": "02005002_e00036",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邓伯道"
      ],
      "text": "哼。",
      "text_length": 2
    },
    {
      "event_id": "02005002_e00037",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "步步娇",
      "speakers": [
        "邓伯道"
      ],
      "text": "老妻你讲便是这等讲。自古道，男儿无妻家无倚，妇人无夫身无主。我那兄弟，生前不愧于天，死后瞑目于地了么？老妻，你叫她，不必焦，少待烦恼，休哭损她两眼秋波，免耽搁她玉体，玉体千姣。",
      "text_length": 88
    },
    {
      "event_id": "02005002_e00038",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "请伯伯、姆姆上香！",
      "text_length": 9
    },
    {
      "event_id": "02005002_e00039",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "邓伯道、李氏同上香。",
      "text_length": 10
    },
    {
      "event_id": "02005002_e00040",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同沉醉东风",
      "speakers": [
        "邓伯道",
        "李氏"
      ],
      "text": "手捧着金凤瓯，设灵魂，在中堂供着，望灵魂容哀告。",
      "text_length": 24
    },
    {
      "event_id": "02005002_e00041",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "沉醉东风",
      "speakers": [
        "邓伯道"
      ],
      "text": "觑着他幽雅俊容貌，飘飘冉冉丰姿好；伴清风，也无消耗，",
      "text_length": 26
    },
    {
      "event_id": "02005002_e00042",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邓伯道"
      ],
      "text": "我邓伯道好生命苦。",
      "text_length": 9
    },
    {
      "event_id": "02005002_e00043",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "沉醉东风",
      "speakers": [
        "邓伯道"
      ],
      "text": "若留得我兄弟在日，他有满腹经纶，盖世奇才。指望与你，共乐余年，又谁知，留你不住了。兄弟，实指望，枝长梅花归故郊，又谁知七弦琴，被风吹别调。衰草秋，可怜姣花老。实指望，兄弟相守到白头，白头，又谁知你死，你死先抛。",
      "text_length": 105
    },
    {
      "event_id": "02005002_e00044",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金氏"
      ],
      "text": "哼。",
      "text_length": 2
    },
    {
      "event_id": "02005002_e00045",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "沉醉东风",
      "speakers": [
        "金氏"
      ],
      "text": "夫，再不来领姣儿，携妻子，与你同偕到老。",
      "text_length": 20
    },
    {
      "event_id": "02005002_e00046",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "沉醉东风",
      "speakers": [
        "邓伯道"
      ],
      "text": "他那里说着，俺这里泪落，这里泪落。猛然间，想起我那兄弟情，不由人默腹中，如刀似搅。",
      "text_length": 41
    },
    {
      "event_id": "02005002_e00047",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内叫“哇哇哇”。",
      "text_length": 8
    },
    {
      "event_id": "02005002_e00048",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邓伯道"
      ],
      "text": "什么叫？",
      "text_length": 4
    },
    {
      "event_id": "02005002_e00049",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "金氏",
        "李氏"
      ],
      "text": "杜鹃。",
      "text_length": 3
    },
    {
      "event_id": "02005002_e00050",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邓伯道"
      ],
      "text": "哪里是杜鹃，分明是我兄弟灵魂，见我一家，在此设祭，故托此鸟来叫。杜鹃哪杜鹃，你若是我兄弟灵魂，大叫三声。",
      "text_length": 52
    },
    {
      "event_id": "02005002_e00051",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内叫“哇哇哇”。",
      "text_length": 8
    },
    {
      "event_id": "02005002_e00052",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邓伯道"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "02005002_e00053",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "雁儿落",
      "speakers": [
        "邓伯道"
      ],
      "text": "你虽一死丧幽冥，幽冥，幽冥难舍姣妻幼子情。见我一家人来设祭，你的阴灵化作杜鹃声。又听得，杜鹃枝头声声叫，他叫他子幼妻姣，我又年老。若还保佑我一家坚牢，多多照管你的根苗，我多多照管你的根苗。",
      "text_length": 94
    },
    {
      "event_id": "02005002_e00054",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "雁儿落",
      "speakers": [
        "金氏"
      ],
      "text": "伯伯、姆姆容哀告，不幸丈夫归阴早。看承寿山儿，长大成人，母子们，衔环结草。",
      "text_length": 37
    },
    {
      "event_id": "02005002_e00055",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "清江引",
      "speakers": [
        "邓伯道"
      ],
      "text": "言三语四絮叨叨，叨叨，家园家计我自承着。杖神保佑，有我身体牢，好扶养寿山你的儿曹，好扶养寿山你的儿曹。",
      "text_length": 51
    },
    {
      "event_id": "02005002_e00056",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "邓伯道"
      ],
      "text": "弃子留侄孤儿保，都只为所系宗祧。",
      "text_length": 16
    },
    {
      "event_id": "02005002_e00057",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "金氏"
      ],
      "text": "教子成名，你的恩不小。",
      "text_length": 11
    },
    {
      "event_id": "02005002_e00058",
      "play_id": "02005002",
      "scene_id": "02005002_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}