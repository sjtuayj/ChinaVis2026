  "events": [
    {
      "event_id": "01017010_e00001",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监同上，刘邦上。",
      "text_length": 10
    },
    {
      "event_id": "01017010_e00002",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘邦"
      ],
      "text": "金殿当头紫阁重，仙人掌上玉芙蓉。太平天子朝元日，五色云车驾六龙。",
      "text_length": 32
    },
    {
      "event_id": "01017010_e00003",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "寡人，汉高祖。今当早朝时分，优势出班早奏，无事卷帘散朝。",
      "text_length": 28
    },
    {
      "event_id": "01017010_e00004",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张良上。",
      "text_length": 4
    },
    {
      "event_id": "01017010_e00005",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张良"
      ],
      "text": "念蒙圣上降旨宣，微臣慌忙到金銮。幞头象简往下跪，万岁三呼把主参。",
      "text_length": 32
    },
    {
      "event_id": "01017010_e00006",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "阶下俯伏何人？有事奏来，无事退班。",
      "text_length": 17
    },
    {
      "event_id": "01017010_e00007",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张良"
      ],
      "text": "臣留侯张良。",
      "text_length": 6
    },
    {
      "event_id": "01017010_e00008",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "朕不曾宣召，因何见朕？",
      "text_length": 11
    },
    {
      "event_id": "01017010_e00009",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张良"
      ],
      "text": "臣游玩花园，见了几派好景，特来启奏。",
      "text_length": 18
    },
    {
      "event_id": "01017010_e00010",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "有什么好景，对朕奏来。",
      "text_length": 11
    },
    {
      "event_id": "01017010_e00011",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "张良"
      ],
      "text": "三月里来好春光，又见万花齐开放。燕子衔泥林内去，百鸟枝头弄笙簧。微臣情愿辞朝回乡去，学一个不老长生自在仙。",
      "text_length": 53
    },
    {
      "event_id": "01017010_e00012",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "刘邦"
      ],
      "text": "朕赐你远也是山近是山，万寿山前盖下庵。",
      "text_length": 19
    },
    {
      "event_id": "01017010_e00013",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "张良"
      ],
      "text": "说什么远是山，近是山，万寿山前盖下庵。荣华富贵臣不恋，何用浮名伴此间？一心要脱红尘境，求吾主放微臣早去归山。",
      "text_length": 54
    },
    {
      "event_id": "01017010_e00014",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "朕赐你上朝不参主，下朝不辞王。你意下如何？",
      "text_length": 21
    },
    {
      "event_id": "01017010_e00015",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "张良"
      ],
      "text": "自古官大必有险，臣伴君如同伴虎眠。吃了些慌慌忙忙的茶和饭，穿了些坐卧不安锦罗衫。忽听金鸡一声叫，吓得微臣胆战寒。急急忙忙上金殿，参王见驾礼当先。掌朝纲，惹祸殃，君王一怒命难全。有朝一日龙颜恼，难脱韩侯剑下亡。及早辞朝归山去，方免韩侯死未央。",
      "text_length": 120
    },
    {
      "event_id": "01017010_e00016",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "朕与你盖下金丝八卦草团瓢，再令那五百文武官，先参见你，然后见朕。你意下如何？",
      "text_length": 38
    },
    {
      "event_id": "01017010_e00017",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "张良"
      ],
      "text": "怕只怕君王带酒龙颜怒，谗臣谋害奏金銮。那时节临崖勒马收缰晚，船到江心补漏难。微臣一心奔山路，旷野深山把身安。白日里奉诵黄经卷，到晚来养性坐蒲团。饿了吃些松柏子，渴了涧下饮清泉。逍遥自在观山景，不戴乌纱心也安。快放微臣归山去，归山去，做一个长生不老仙。",
      "text_length": 125
    },
    {
      "event_id": "01017010_e00018",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "放你归山，你有三件大事，千万不可前去。",
      "text_length": 19
    },
    {
      "event_id": "01017010_e00019",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张良"
      ],
      "text": "哪三件大事？",
      "text_length": 6
    },
    {
      "event_id": "01017010_e00020",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "第一件，你家园好；第二件，妻又姣；第三件，儿女成双。有此三件也归不得山，也学不得道，可以不必归山。",
      "text_length": 49
    },
    {
      "event_id": "01017010_e00021",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "张良"
      ],
      "text": "万岁爷坐金殿龙耳听道，一桩桩一件件奏与当朝：说什么微臣的家园好，家园好比惹祸苗。什么妻来什么妾，妻妾好比斩人刀。未央宫里韩信死，哪有儿女替他死这遭？文官拍手哈哈笑，武将捶胸泪滔滔。纷纷议论不一定，就是微臣心也焦。",
      "text_length": 106
    },
    {
      "event_id": "01017010_e00022",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘邦"
      ],
      "text": "爱卿所奏何事，朕不依从？冷淡卿心，也是有的，朕也知道。再陪孤家几载，寡人难舍干国忠臣。",
      "text_length": 43
    },
    {
      "event_id": "01017010_e00023",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张良"
      ],
      "text": "微臣情愿留下幞头象简，归山去了！",
      "text_length": 16
    },
    {
      "event_id": "01017010_e00024",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张良"
      ],
      "text": "双手破开生死路，翻身跳出是非门。",
      "text_length": 16
    },
    {
      "event_id": "01017010_e00025",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张良下。",
      "text_length": 4
    },
    {
      "event_id": "01017010_e00026",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘邦"
      ],
      "text": "张良归山辞高皇，范蠡游湖别越王。他人不是嫌官小，见斩韩信三齐王。",
      "text_length": 32
    },
    {
      "event_id": "01017010_e00027",
      "play_id": "01017010",
      "scene_id": "01017010_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘邦下。",
      "text_length": 4
    }
  ],
