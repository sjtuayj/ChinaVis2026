  "events": [
    {
      "event_id": "01010013_e00001",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "白素贞"
      ],
      "text": "哎哎呀！",
      "text_length": 4
    },
    {
      "event_id": "01010013_e00002",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "白素贞"
      ],
      "text": "被天兵杀得我无处逃走，",
      "text_length": 11
    },
    {
      "event_id": "01010013_e00003",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "白素贞上，前扑后捽。小青上。",
      "text_length": 14
    },
    {
      "event_id": "01010013_e00004",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "白素贞"
      ],
      "text": "止不住泪珠儿点点血流。这才是虎难描反成为狗，主仆们倒做了泼水难收。",
      "text_length": 33
    },
    {
      "event_id": "01010013_e00005",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "三锤。白素贞坐下。",
      "text_length": 9
    },
    {
      "event_id": "01010013_e00006",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "白素贞"
      ],
      "text": "金山寺与法海一处争斗，只杀得主仆们头破血流。好容易出罗网方得逃走，",
      "text_length": 33
    },
    {
      "event_id": "01010013_e00007",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "罢了，青儿姐吓！",
      "text_length": 8
    },
    {
      "event_id": "01010013_e00008",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "白素贞"
      ],
      "text": "恨许仙骂法海无义贼囚！",
      "text_length": 11
    },
    {
      "event_id": "01010013_e00009",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "小青"
      ],
      "text": "端阳节你不该多贪药酒，纱罗帐谁叫你自逞风流。尊娘娘得撒手且自撒手，许官人他本是惹祸根由。",
      "text_length": 44
    },
    {
      "event_id": "01010013_e00010",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "白素贞"
      ],
      "text": "青儿姐你不要羞言出口，",
      "text_length": 11
    },
    {
      "event_id": "01010013_e00011",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "白素贞"
      ],
      "text": "纱罗帐是图他一时风流。到如今怀揣着许门之后，十个月要产生何处收留？",
      "text_length": 33
    },
    {
      "event_id": "01010013_e00012",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "哎唷哎唷！",
      "text_length": 5
    },
    {
      "event_id": "01010013_e00013",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "娘娘怎么样了？",
      "text_length": 7
    },
    {
      "event_id": "01010013_e00014",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "青儿，一霎时腹内疼痛起来，想必是娃儿分娩。你我主仆，该在哪里存身？",
      "text_length": 33
    },
    {
      "event_id": "01010013_e00015",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "你我回上灵王府去罢。",
      "text_length": 10
    },
    {
      "event_id": "01010013_e00016",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "前面带路。",
      "text_length": 5
    },
    {
      "event_id": "01010013_e00017",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "晓得。哎呀，娘娘大事不好了。",
      "text_length": 14
    },
    {
      "event_id": "01010013_e00018",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "慌张为何？",
      "text_length": 5
    },
    {
      "event_id": "01010013_e00019",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "灵王府为天兵火化。",
      "text_length": 9
    },
    {
      "event_id": "01010013_e00020",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "怎么说？",
      "text_length": 4
    },
    {
      "event_id": "01010013_e00021",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮滚板",
      "speakers": [
        "白素贞"
      ],
      "text": "薄命的女姣娥，点点珠泪落。王府被火化，何处藏身躲？偶遇天兵将，杀得我魂魄落。官人不见面，恩爱如刀割。仰面把天叫，可说是天吓天吓，我的老天爷吓！",
      "text_length": 71
    },
    {
      "event_id": "01010013_e00022",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "白素贞"
      ],
      "text": "自幼儿百草山从来修炼，修炼了千百年带路神仙。在高山我不听兄长相劝，我一心到西湖去把景观。灵王府与青儿一处交战，用法宝收来了使女丫鬟。她与我到西湖许郎见面，也是我与许郎前世姻缘。多亏了许官人搭船借伞，小青儿为媒证正配良缘。端阳节用药酒原形出现，吓死了许官人命染黄泉。长寿山盗灵芝白鹤交战，雄黄阵险些儿一命难全。多亏了观音母救苦救难，南极星赠灵芝放我回还。许官人病体好许下香愿，金山寺去降香惹下祸端。那法海留官人不放回转，那法海他不该拆散姻缘。也是我到金山法海变脸，也是我气烦恼水漫金山。",
      "text_length": 242
    },
    {
      "event_id": "01010013_e00023",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "娘娘，前面就是断桥亭，你我主仆二人，到着那里，再作道理。",
      "text_length": 28
    },
    {
      "event_id": "01010013_e00024",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "青儿姐，是你挽我来吓。",
      "text_length": 11
    },
    {
      "event_id": "01010013_e00025",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮紧板",
      "speakers": [
        "白素贞"
      ],
      "text": "举来了天兵将与我交战，韦陀爷降魔杵切断眉肩。行来在断桥亭用目观看，",
      "text_length": 33
    },
    {
      "event_id": "01010013_e00026",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "白素贞"
      ],
      "text": "主仆们倒做了千难万难。",
      "text_length": 11
    },
    {
      "event_id": "01010013_e00027",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小锣。许仙上。",
      "text_length": 7
    },
    {
      "event_id": "01010013_e00028",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "许仙"
      ],
      "text": "老和尚他赐我金钵一口，断桥亭见我妻必做对头。行一步来至在断桥路口，",
      "text_length": 33
    },
    {
      "event_id": "01010013_e00029",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "许仙"
      ],
      "text": "见青儿吓得我两鬓汗流。见娘子我只得哀哀叩首，",
      "text_length": 22
    },
    {
      "event_id": "01010013_e00030",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仙"
      ],
      "text": "娘子，嗳呀，嗳呀娘子吓！",
      "text_length": 12
    },
    {
      "event_id": "01010013_e00031",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "许仙"
      ],
      "text": "尊娘子放开怀莫结冤仇。",
      "text_length": 11
    },
    {
      "event_id": "01010013_e00032",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "01010013_e00033",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "小青"
      ],
      "text": "见许仙不由人气冲牛斗，细思想你本是惹祸根由。我在这断桥亭招你头首，",
      "text_length": 33
    },
    {
      "event_id": "01010013_e00034",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "expression",
      "mode_label": "西皮哭板",
      "speakers": [
        "白素贞"
      ],
      "text": "说是你、你、你慢、慢、慢、慢着。",
      "text_length": 16
    },
    {
      "event_id": "01010013_e00035",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "白素贞"
      ],
      "text": "拦住了青儿姐莫要动手，许官人做此事你、你、你、你好无来由。我本当断桥亭招你头首，",
      "text_length": 40
    },
    {
      "event_id": "01010013_e00036",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "看剑！",
      "text_length": 3
    },
    {
      "event_id": "01010013_e00037",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "你慢来！",
      "text_length": 4
    },
    {
      "event_id": "01010013_e00038",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "白素贞"
      ],
      "text": "念起了夫妻情一笔勾销。",
      "text_length": 11
    },
    {
      "event_id": "01010013_e00039",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮滚板",
      "speakers": [
        "白素贞"
      ],
      "text": "白氏泪如梭，官人听我说：听了法海言，说妻是妖魔。无心害你，你反害我。",
      "text_length": 34
    },
    {
      "event_id": "01010013_e00040",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "看剑！",
      "text_length": 3
    },
    {
      "event_id": "01010013_e00041",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "01010013_e00042",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "白素贞"
      ],
      "text": "断桥亭把官人怀中抱搂，似你这无义人何处收留！自从你金山寺降香去后，老和尚他把你锁在后楼。奴愁你茶和饭不随你口，哪一夜不等你鼓打更楼。和青儿到金山山门等候，那法海与为妻做下了对头。他举来了天兵将与妻争斗，韦陀爷降魔杵打断了眉头。尊官人手摸胸思前想后，谁的是谁的非天在上头。",
      "text_length": 135
    },
    {
      "event_id": "01010013_e00043",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "许仙"
      ],
      "text": "自那日到金山降香之后，老和尚他将我锁在后楼。想娘子见一面不能得够，每日里在后楼加上忧愁。尊娘子得撒手且自撒手，好夫妻哪有个结下的冤仇？",
      "text_length": 67
    },
    {
      "event_id": "01010013_e00044",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "娘娘，休要听贼子之言，待我将他杀了罢！",
      "text_length": 19
    },
    {
      "event_id": "01010013_e00045",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "白素贞"
      ],
      "text": "许官人你看到什么时候，那青儿她与你做下对头。来来来随为妻连连叩首，念起了娘子面将他收留。",
      "text_length": 44
    },
    {
      "event_id": "01010013_e00046",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "青儿姐，看在娘娘跪前跪后，你将官人他、他、他饶了罢！",
      "text_length": 26
    },
    {
      "event_id": "01010013_e00047",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "看在娘娘，我不杀他就是。",
      "text_length": 12
    },
    {
      "event_id": "01010013_e00048",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "青儿请起。",
      "text_length": 5
    },
    {
      "event_id": "01010013_e00049",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "娘娘请起。",
      "text_length": 5
    },
    {
      "event_id": "01010013_e00050",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "大家同起。嗳唷嗳唷！",
      "text_length": 10
    },
    {
      "event_id": "01010013_e00051",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "白素贞坐下。",
      "text_length": 6
    },
    {
      "event_id": "01010013_e00052",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仙"
      ],
      "text": "娘娘怎么样了？",
      "text_length": 7
    },
    {
      "event_id": "01010013_e00053",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "官人，一霎时我腹内疼痛，想是娃儿分娩。你我夫妻，该在哪里安身了？",
      "text_length": 32
    },
    {
      "event_id": "01010013_e00054",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仙"
      ],
      "text": "前面就是姐丈家中，你我夫妻，到在那里，再作道理。",
      "text_length": 24
    },
    {
      "event_id": "01010013_e00055",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "挽我来。嗳唷嗳唷！",
      "text_length": 9
    },
    {
      "event_id": "01010013_e00056",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "许仙"
      ],
      "text": "娘子怎么样了？",
      "text_length": 7
    },
    {
      "event_id": "01010013_e00057",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "这个么……",
      "text_length": 5
    },
    {
      "event_id": "01010013_e00058",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "白素贞"
      ],
      "text": "可说是许官人、许郎夫，你、你、你害得我好苦也！",
      "text_length": 23
    },
    {
      "event_id": "01010013_e00059",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "白素贞"
      ],
      "text": "这就是倒叫我难以出口，纱罗帐自图你一时风流。到如今怀揣着许门之后，此一去见姐丈未必收留。",
      "text_length": 44
    },
    {
      "event_id": "01010013_e00060",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "官人挽我来。",
      "text_length": 6
    },
    {
      "event_id": "01010013_e00061",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小青"
      ],
      "text": "看剑！",
      "text_length": 3
    },
    {
      "event_id": "01010013_e00062",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "白素贞"
      ],
      "text": "你还了得！",
      "text_length": 5
    },
    {
      "event_id": "01010013_e00063",
      "play_id": "01010013",
      "scene_id": "01010013_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}