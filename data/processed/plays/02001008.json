      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "五路天官"
      ],
      "text": "速诏催旺众神来者。",
      "text_length": 9
    },
    {
      "event_id": "02001008_e00025",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "五路财神"
      ],
      "text": "领法旨。催旺众神何在？",
      "text_length": 11
    },
    {
      "event_id": "02001008_e00026",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "催旺",
        "时运",
        "金神",
        "银神",
        "催财"
      ],
      "text": "来也。",
      "text_length": 3
    },
    {
      "event_id": "02001008_e00027",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "催旺、时运、金神、银神、催财看吉祥如意同跳上。",
      "text_length": 23
    },
    {
      "event_id": "02001008_e00028",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
