      "page_no": 2,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "催旺",
        "时运",
        "金神",
        "银神",
        "催财"
      ],
      "text": "大财源百川会海，愿人间六合同春。",
      "text_length": 16
    },
    {
      "event_id": "02001008_e00029",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "催旺",
        "时运",
        "金神",
        "银神",
        "催财"
      ],
      "text": "吾乃——",
      "text_length": 4
    },
