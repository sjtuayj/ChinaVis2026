  "events": [
    {
      "event_id": "02001008_e00001",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四文堂、招财、利市同上，同站门。黑虎玄坛上。",
      "text_length": 22
    },
    {
      "event_id": "02001008_e00002",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "粉蝶儿",
      "speakers": [
        "黑虎玄坛"
      ],
      "text": "百福盈庭，喜的是百福盈庭，更有那千祥吉庆。俺职掌天藏金银，今日个聚财源骈辏，有的是生生隆顺，凭着那积玉堆金，乐善的必生余庆。",
      "text_length": 62
    },
    {
      "event_id": "02001008_e00003",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黑虎玄坛坐。",
      "text_length": 6
    },
    {
      "event_id": "02001008_e00004",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "黑虎玄坛"
      ],
      "text": "鸾鹤纷纷下九天，财源滚滚庆丰年。享受千载皇家禄，皆是阴功绩德全。",
      "text_length": 32
    },
    {
      "event_id": "02001008_e00005",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黑虎玄坛"
      ],
      "text": "吾乃龙虎玄坛是也。手执金轮如意，默起千祥吉庆。跨着黑虎，行着大有之年，所到之处，无不雨顺风调，国泰民安。正是：",
      "text_length": 55
    },
    {
      "event_id": "02001008_e00006",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "黑虎玄坛"
      ],
      "text": "五谷丰登天下乐，民安物阜贺升平。",
      "text_length": 16
    },
    {
      "event_id": "02001008_e00007",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。四云童、五天官同上，同挖门，同归坐。",
      "text_length": 23
    },
    {
      "event_id": "02001008_e00008",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "五天官"
      ],
      "text": "民安物阜风光好，五谷丰登兆。舜日与尧天，圣德齐天乐。祝遐龄爵位高，祝丰年长生不老。",
      "text_length": 41
    },
    {
      "event_id": "02001008_e00009",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "五天官"
      ],
      "text": "吾等乃天官是也。今有下界福主，阴功浩大，积德累功。奉上帝敕旨，命吾招聚财源，献与福地。正是：",
      "text_length": 46
    },
    {
      "event_id": "02001008_e00010",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "五天官"
      ],
      "text": "积善人家当德报，存心自有上苍知。",
      "text_length": 16
    },
    {
      "event_id": "02001008_e00011",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黑虎玄坛"
      ],
      "text": "奉命招集财源，俱已聚齐，请天官赐福。",
      "text_length": 18
    },
    {
      "event_id": "02001008_e00012",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "五天官"
      ],
      "text": "速诏五路财神来者。",
      "text_length": 9
    },
    {
      "event_id": "02001008_e00013",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黑虎玄坛"
      ],
      "text": "领钧旨。招财、利市。",
      "text_length": 10
    },
    {
      "event_id": "02001008_e00014",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "招财",
        "利市"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "02001008_e00015",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黑虎玄坛"
      ],
      "text": "速请五路财神来者。",
      "text_length": 9
    },
    {
      "event_id": "02001008_e00016",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "招财",
        "利市"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001008_e00017",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "招财、利市同同。",
      "text_length": 8
    },
    {
      "event_id": "02001008_e00018",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同石榴花",
      "speakers": [
        "黑虎玄坛",
        "五天官"
      ],
      "text": "只见那香风阵阵献氤氲，簇簇的子气满阶庭。聚金银腰缠十万，跨鹤登程，勤读的加官进爵，宠锡君恩。俺如今先把那金银赠，管教夫妻父子富贵康宁。得个绵绵不绝，荫袭儿孙，方显得，管金银掌天库的财神。",
      "text_length": 93
    },
    {
      "event_id": "02001008_e00019",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "招财、利市引五路财神同上。",
      "text_length": 13
    },
    {
      "event_id": "02001008_e00020",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "五路财神"
      ],
      "text": "执掌皇家国宝，耑管帑藏金银。经商客旅奉吾神，满载金银堪趁。分明四方通达，荣封五路将军。乘鸾跨鹤下凡尘，降福添财本分。",
      "text_length": 58
    },
    {
      "event_id": "02001008_e00021",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "五路财神"
      ],
      "text": "吾等乃五路财神是也。天官相诏，一同进见。天官在上，我等参见。",
      "text_length": 30
    },
    {
      "event_id": "02001008_e00022",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "五路天官"
      ],
      "text": "命你等招集财源，可曾齐备？",
      "text_length": 13
    },
    {
      "event_id": "02001008_e00023",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "五路财神"
      ],
      "text": "俱已齐备。候天官赐福。",
      "text_length": 11
    },
    {
      "event_id": "02001008_e00024",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
      "scene_no": 1,
      "seq_global": 24,
