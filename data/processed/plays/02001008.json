        "金神",
        "银神",
        "催财"
      ],
      "text": "请。天官在上，我等参见。",
      "text_length": 12
    },
    {
      "event_id": "02001008_e00037",
      "play_id": "02001008",
      "scene_id": "02001008_s01",
