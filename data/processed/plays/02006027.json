  "events": [
    {
      "event_id": "02006027_e00001",
      "play_id": "02006027",
      "scene_id": "02006027_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "熊精上。",
      "text_length": 4
    },
    {
      "event_id": "02006027_e00002",
      "play_id": "02006027",
      "scene_id": "02006027_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "熊精"
      ],
      "text": "黑风山下惯藏妖，相貌狰狞胆气豪。一片雄心收未得，且施小计恣贪饕。",
      "text_length": 32
    },
    {
      "event_id": "02006027_e00003",
      "play_id": "02006027",
      "scene_id": "02006027_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "熊精"
      ],
      "text": "吾乃黑风山、黑风洞黑熊大王是也。今有唐三藏借宿在观音禅院。那寺僧了然，意欲谋取他的袈裟。叫徒弟们三更时分放起火来，将他师徒烧死。我不免借他的火力，将他得袈裟摄来，作一个佛衣圣会，有何不可。",
      "text_length": 94
    },
    {
      "event_id": "02006027_e00004",
      "play_id": "02006027",
      "scene_id": "02006027_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "熊精"
      ],
      "text": "良善称君子，山中号大王。",
      "text_length": 12
    },
    {
      "event_id": "02006027_e00005",
      "play_id": "02006027",
      "scene_id": "02006027_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "熊精下。",
      "text_length": 4
    },
    {
      "event_id": "02006027_e00006",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然、众僧同上。",
      "text_length": 8
    },
    {
      "event_id": "02006027_e00007",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "放火去咧。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00008",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "啊，放火也是嚷得的？",
      "text_length": 10
    },
    {
      "event_id": "02006027_e00009",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众僧同嘘。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00010",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "啊，徒弟们。听听几更了。",
      "text_length": 12
    },
    {
      "event_id": "02006027_e00011",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "六更了。",
      "text_length": 4
    },
    {
      "event_id": "02006027_e00012",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "哪里来的六更？",
      "text_length": 7
    },
    {
      "event_id": "02006027_e00013",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "钟三下，鼓三下，可不是六更？",
      "text_length": 14
    },
    {
      "event_id": "02006027_e00014",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "那还是三更。啊，徒弟们。今晚放火好有一比。",
      "text_length": 21
    },
    {
      "event_id": "02006027_e00015",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "众僧"
      ],
      "text": "比作何来？",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00016",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "扑灯蛾",
      "speakers": [
        "了然"
      ],
      "text": "好一似周郎破赤壁，赤壁东风一阵起。田单恢齐地，连人带马一齐烧死也。",
      "text_length": 33
    },
    {
      "event_id": "02006027_e00017",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "火部同上，出烟彩。熊精上，拿袈裟下。",
      "text_length": 18
    },
    {
      "event_id": "02006027_e00018",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "不好了。",
      "text_length": 4
    },
    {
      "event_id": "02006027_e00019",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "扑灯蛾",
      "speakers": [
        "了然"
      ],
      "text": "连天火拥四下里，烟雾腾空，真个是好叫人奔走，魂散与魂飞，魂散与魂飞。",
      "text_length": 34
    },
    {
      "event_id": "02006027_e00020",
      "play_id": "02006027",
      "scene_id": "02006027_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然烧死，众人同下。",
      "text_length": 10
    },
    {
      "event_id": "02006027_e00021",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐僧上。",
      "text_length": 4
    },
    {
      "event_id": "02006027_e00022",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "唐僧"
      ],
      "text": "安心睡，梦正酣。安心睡，梦正酣。窗前燕燕语呢喃。梦破鼠窥灯，懒起将他撼。",
      "text_length": 36
    },
    {
      "event_id": "02006027_e00023",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "呀，天明了。",
      "text_length": 6
    },
    {
      "event_id": "02006027_e00024",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "唐僧"
      ],
      "text": "因何不听钟声沸，不见僧了然，不见僧了然？且到圣像前，礼一回千佛忏，礼一回千佛忏。",
      "text_length": 40
    },
    {
      "event_id": "02006027_e00025",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "呀。夜来失火烧得这等光景。阿弥陀佛。悟空哪里？",
      "text_length": 23
    },
    {
      "event_id": "02006027_e00026",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙悟空上。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00027",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙悟空"
      ],
      "text": "善有善报，恶有恶报。若还不报，时辰未到。",
      "text_length": 20
    },
    {
      "event_id": "02006027_e00028",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "悟空，昨夜失火，你可晓得么？",
      "text_length": 14
    },
    {
      "event_id": "02006027_e00029",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "弟子怎么不晓得？",
      "text_length": 8
    },
    {
      "event_id": "02006027_e00030",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "我睡熟了，竟不晓得。可曾烧坏了人么？",
      "text_length": 18
    },
    {
      "event_id": "02006027_e00031",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "师父，你不问袈裟，问人怎么？",
      "text_length": 14
    },
    {
      "event_id": "02006027_e00032",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "岂不闻孔子云：厩焚问人不问马。火是怎么起的？",
      "text_length": 22
    },
    {
      "event_id": "02006027_e00033",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "师父，你问起火的缘故么，真个可恼。那了然呵！",
      "text_length": 22
    },
    {
      "event_id": "02006027_e00034",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "孙悟空"
      ],
      "text": "他的心不善，起恶端，心不善，起恶端。袈裟一见蓄意安。他面上起春风，腹内三昧暗。",
      "text_length": 39
    },
    {
      "event_id": "02006027_e00035",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "师父。不但了然见了袈裟意欲谋求，还吩咐众和尚放火，要把你我烧死。",
      "text_length": 32
    },
    {
      "event_id": "02006027_e00036",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "阿弥陀佛。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00037",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "那时弟子听得，将火神召来，用火罩将师父的睡处罩住，故此师父无恙。",
      "text_length": 32
    },
    {
      "event_id": "02006027_e00038",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "阿弥陀佛。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00039",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "孙悟空"
      ],
      "text": "喜得天有耳，火反弹。喜得天有耳，火反弹，烧得秃光头，一个个额头烂，一个个额头烂。",
      "text_length": 40
    },
    {
      "event_id": "02006027_e00040",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "如此，唤了然来。",
      "text_length": 8
    },
    {
      "event_id": "02006027_e00041",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "呔，了然哪里？",
      "text_length": 7
    },
    {
      "event_id": "02006027_e00042",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众僧同上。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00043",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "众僧"
      ],
      "text": "暗地损人伦，放火烧自身。",
      "text_length": 12
    },
    {
      "event_id": "02006027_e00044",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "爷爷饶命啊。",
      "text_length": 6
    },
    {
      "event_id": "02006027_e00045",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "了然哪里去了？",
      "text_length": 7
    },
    {
      "event_id": "02006027_e00046",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "我那老和尚呵！",
      "text_length": 7
    },
    {
      "event_id": "02006027_e00047",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同锁南枝",
      "speakers": [
        "众僧"
      ],
      "text": "他的年华迈，两鬓黲，年华迈，两鬓黲。",
      "text_length": 18
    },
    {
      "event_id": "02006027_e00048",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "见了袈裟呵！",
      "text_length": 6
    },
    {
      "event_id": "02006027_e00049",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同锁南枝",
      "speakers": [
        "众僧"
      ],
      "text": "金光夺目锦又灿。",
      "text_length": 8
    },
    {
      "event_id": "02006027_e00050",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "要谋袈裟是实。故此叫我们放火。害得二位师父呵！",
      "text_length": 23
    },
    {
      "event_id": "02006027_e00051",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同锁南枝",
      "speakers": [
        "众僧"
      ],
      "text": "谁料自烧身，送死全无怨。",
      "text_length": 12
    },
    {
      "event_id": "02006027_e00052",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "袈裟放在哪里？",
      "text_length": 7
    },
    {
      "event_id": "02006027_e00053",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "那袈裟呵！",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00054",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同锁南枝",
      "speakers": [
        "众僧"
      ],
      "text": "藏在观音院，韦陀龛。观音院，韦陀龛。",
      "text_length": 18
    },
    {
      "event_id": "02006027_e00055",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "方才取去，又不见了。",
      "text_length": 10
    },
    {
      "event_id": "02006027_e00056",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同锁南枝",
      "speakers": [
        "众僧"
      ],
      "text": "伏乞念同衣，饶恕头颅汉。饶恕头颅汉。",
      "text_length": 18
    },
    {
      "event_id": "02006027_e00057",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "胡说。料你们这些秃厮，也不肯实说。吃老孙一棒！",
      "text_length": 23
    },
    {
      "event_id": "02006027_e00058",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "爷爷饶命。我们常闻听老和尚说，这院南有个黑风山，黑风洞，有个黑熊大王。想是他见火光起处，被他摄去，也未见得。",
      "text_length": 54
    },
    {
      "event_id": "02006027_e00059",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "这等说，自然是他摄去了。老和尚既死，与你们无干。去罢。",
      "text_length": 27
    },
    {
      "event_id": "02006027_e00060",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧"
      ],
      "text": "多谢爷爷。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00061",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众僧同下。",
      "text_length": 5
    },
    {
      "event_id": "02006027_e00062",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "想起来，都是你这猴头，卖弄我的宝贝，惹出这场祸来。不管。只问你要袈裟。",
      "text_length": 35
    },
    {
      "event_id": "02006027_e00063",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "师父！",
      "text_length": 3
    },
    {
      "event_id": "02006027_e00064",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "孙悟空"
      ],
      "text": "你休埋怨，骂再三。追取袈裟全在俺。料相如赴秦庭，赵璧依无憾。",
      "text_length": 30
    },
    {
      "event_id": "02006027_e00065",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "那妖怪凶狠，你如何是他的对手？",
      "text_length": 15
    },
    {
      "event_id": "02006027_e00066",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "孙悟空"
      ],
      "text": "任他狰狞貌，恶势憨。狰狞貌，恶势憨。",
      "text_length": 18
    },
    {
      "event_id": "02006027_e00067",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙悟空"
      ],
      "text": "若还说出老孙名，",
      "text_length": 8
    },
    {
      "event_id": "02006027_e00068",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "锁南枝",
      "speakers": [
        "孙悟空"
      ],
      "text": "管叫吓破他的胆，吓破他的胆。",
      "text_length": 14
    },
    {
      "event_id": "02006027_e00069",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 69,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "不管。只问你要。",
      "text_length": 8
    },
    {
      "event_id": "02006027_e00070",
      "play_id": "02006027",
      "scene_id": "02006027_s03",
      "scene_no": 3,
      "seq_global": 70,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙悟空"
      ],
      "text": "师父莫再生嗔。",
      "text_length": 7
