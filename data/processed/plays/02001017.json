  "events": [
    {
      "event_id": "02001017_e00001",
      "play_id": "02001017",
      "scene_id": "02001017_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四上手拿云牌、四鬼卒拿风旗、马童甲拉马、马童乙背鞭、闻仲同上。",
      "text_length": 31
    },
    {
      "event_id": "02001017_e00002",
      "play_id": "02001017",
      "scene_id": "02001017_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "闻仲"
      ],
      "text": "忠魂未散，回朝歌，面见龙颜。",
      "text_length": 14
    },
    {
      "event_id": "02001017_e00003",
      "play_id": "02001017",
      "scene_id": "02001017_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "闻仲"
      ],
      "text": "商汤创业立帝基，各路诸侯保华夷。六百余年气数尽，可叹忠良丧西歧。",
      "text_length": 32
    },
    {
      "event_id": "02001017_e00004",
      "play_id": "02001017",
      "scene_id": "02001017_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "老夫，太宰闻仲魂灵是也。奉命征剿西歧，不幸命丧绝龙岭。本当封神台下听候法旨。奈因商汤江山，不久将终，为此回至朝歌，与昏王托一梦兆。鬼卒们驾起阴风，往朝歌去者。",
      "text_length": 79
    },
    {
      "event_id": "02001017_e00005",
      "play_id": "02001017",
      "scene_id": "02001017_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "闻仲"
      ],
      "text": "在生时保我主东征西战，小昏王宠妲己残害百官。姜国母炮烙死十分伤惨，比干相剖心亡令人可怜。此一番进宫帷将主来劝，但愿得天下转恢复江山。",
      "text_length": 66
    },
    {
      "event_id": "02001017_e00006",
      "play_id": "02001017",
      "scene_id": "02001017_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "02001017_e00007",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖小开门〗，〖吹打〗。四小太监、二大太监引纣王同上。",
      "text_length": 26
    },
    {
      "event_id": "02001017_e00008",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "纣王"
      ],
      "text": "皇宫内院，喜爱妃，常伴龙眠。",
      "text_length": 14
    },
    {
      "event_id": "02001017_e00009",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "纣王"
      ],
      "text": "红旦一轮照四方，人君有道自当阳。姜后欺孤炮烙丧，飞虎西歧反朝堂。",
      "text_length": 32
    },
    {
      "event_id": "02001017_e00010",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "孤，大商天子受辛在位。恼恨西歧，听信黄飞虎之言，口称吊民罚罪。孤命太宰闻仲，前去征剿，不见回朝。为此十分忧虑，不免宣苏妃上殿，共论大事。内臣！",
      "text_length": 71
    },
    {
      "event_id": "02001017_e00011",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监甲"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02001017_e00012",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "宣苏国母上殿。",
      "text_length": 7
    },
    {
      "event_id": "02001017_e00013",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监甲"
      ],
      "text": "领旨。万岁有旨：宣苏国母上殿",
      "text_length": 14
    },
    {
      "event_id": "02001017_e00014",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "妲己"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02001017_e00015",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女、妲己同上。",
      "text_length": 9
    },
    {
      "event_id": "02001017_e00016",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "妲己"
      ],
      "text": "忽听万岁宣，急忙上金銮。",
      "text_length": 12
    },
    {
      "event_id": "02001017_e00017",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "妾妃见驾，吾皇万岁！",
      "text_length": 10
    },
    {
      "event_id": "02001017_e00018",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "梓童平身。",
      "text_length": 5
    },
    {
      "event_id": "02001017_e00019",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "万万岁！",
      "text_length": 4
    },
    {
      "event_id": "02001017_e00020",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "赐座。",
      "text_length": 3
    },
    {
      "event_id": "02001017_e00021",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "谢万岁。启奏万岁：将妾妃宣上殿来，不知有何谕诏？",
      "text_length": 24
    },
    {
      "event_id": "02001017_e00022",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "梓童有所不知：只因太宰征剿西歧，未见回音。因此宣上爱妃，商议此事，以免寡人忧虑。",
      "text_length": 40
    },
    {
      "event_id": "02001017_e00023",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "我主但放宽心，太宰乃是安邦之将，国家栋梁。自然扫灭西贼，不久得胜而归。万岁何必忧虑？",
      "text_length": 42
    },
    {
      "event_id": "02001017_e00024",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "梓童言之有理。内臣看酒，孤与梓童共饮一番。",
      "text_length": 21
    },
    {
      "event_id": "02001017_e00025",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "妾妃把盏。",
      "text_length": 5
    },
    {
      "event_id": "02001017_e00026",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖小吹打〗。妲己敬酒。牌子完。",
      "text_length": 15
    },
    {
      "event_id": "02001017_e00027",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "万岁再饮几杯。",
      "text_length": 7
    },
    {
      "event_id": "02001017_e00028",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "寡人酒已够了。内臣撤去酒宴",
      "text_length": 13
    },
    {
      "event_id": "02001017_e00029",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吹打完。",
      "text_length": 4
    },
    {
      "event_id": "02001017_e00030",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "启奏我主：不知今晚宿在哪一宫？",
      "text_length": 15
    },
    {
      "event_id": "02001017_e00031",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "宿在寿仙宫。",
      "text_length": 6
    },
    {
      "event_id": "02001017_e00032",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "内臣打扫寿仙宫",
      "text_length": 7
    },
    {
      "event_id": "02001017_e00033",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二大太监"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02001017_e00034",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二大太监同下。",
      "text_length": 7
    },
    {
      "event_id": "02001017_e00035",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "02001017_e00036",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "纣王"
      ],
      "text": "朝欢暮乐在宫帷，哪管朝中是与非。",
      "text_length": 16
    },
    {
      "event_id": "02001017_e00037",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "妲己"
      ],
      "text": "蒙恩万岁将妃宠，陪王伴驾更有谁？",
      "text_length": 16
    },
    {
      "event_id": "02001017_e00038",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "摆驾寿仙宫。",
      "text_length": 6
    },
    {
      "event_id": "02001017_e00039",
      "play_id": "02001017",
      "scene_id": "02001017_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "纣王、妲己同下。",
      "text_length": 8
    },
    {
      "event_id": "02001017_e00040",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二大太监同上，同打扫。〖小吹打〗。",
      "text_length": 17
    },
    {
      "event_id": "02001017_e00041",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二大太监"
      ],
      "text": "有请万岁！",
      "text_length": 5
    },
    {
      "event_id": "02001017_e00042",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小太监、二宫娥、纣王、妲己同上。吹打完。",
      "text_length": 21
    },
    {
      "event_id": "02001017_e00043",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "梓童随孤来呀，哈哈哈！",
      "text_length": 11
    },
    {
      "event_id": "02001017_e00044",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "纣王入帐子。",
      "text_length": 6
    },
    {
      "event_id": "02001017_e00045",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "妲己"
      ],
      "text": "回避了。",
      "text_length": 4
    },
    {
      "event_id": "02001017_e00046",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二大太监、四小太监、二宫娥自两边分下。起更鼓。",
      "text_length": 23
    },
    {
      "event_id": "02001017_e00047",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "闻仲"
      ],
      "text": "最可叹为国家身遭大难，",
      "text_length": 11
    },
    {
      "event_id": "02001017_e00048",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖急急风〗。四上手、四鬼卒、二马童、闻仲同上，同斜椅。",
      "text_length": 27
    },
    {
      "event_id": "02001017_e00049",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "闻仲"
      ],
      "text": "我的命丧至在绝龙岭前。",
      "text_length": 11
    },
    {
      "event_id": "02001017_e00050",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "闻仲上椅子，归正。",
      "text_length": 9
    },
    {
      "event_id": "02001017_e00051",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄正板",
      "speakers": [
        "闻仲"
      ],
      "text": "半空中云磨响霹雳闪电，一口气吹散了云雾归天。奉圣命伐西歧威风八面，到如今只落得孤身回还。身穿着连环甲腥腥血染，恶狠狠三只眼杀气冲天。跨下的墨麒麟疆场游遍，我背后身插着打将神鞭。阴惨惨来至在皇宫内院，",
      "text_length": 99
    },
    {
      "event_id": "02001017_e00052",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二冲头，打堂鼓。",
      "text_length": 8
    },
    {
      "event_id": "02001017_e00053",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "闻仲"
      ],
      "text": "站至在金阶上且把话言：我本是老闻仲西歧回转，寿仙宫请我主驾出金銮。",
      "text_length": 33
    },
    {
      "event_id": "02001017_e00054",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "万岁醒来！",
      "text_length": 5
    },
    {
      "event_id": "02001017_e00055",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "纣王"
      ],
      "text": "龙床上只听得有人呼唤，",
      "text_length": 11
    },
    {
      "event_id": "02001017_e00056",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "纣王"
      ],
      "text": "梦见了朝歌城塌了半边。有孤王睁龙目抬头观看，",
      "text_length": 22
    },
    {
      "event_id": "02001017_e00057",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "02001017_e00058",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "纣王"
      ],
      "text": "只觉得阴风吹体似冰寒。你是妖你是怪细说一遍，",
      "text_length": 22
    },
    {
      "event_id": "02001017_e00059",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "闻仲"
      ],
      "text": "我的主休惊怕细听根源：",
      "text_length": 11
    },
    {
      "event_id": "02001017_e00060",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄正板",
      "speakers": [
        "闻仲"
      ],
      "text": "臣本是老闻仲西歧回转，魂灵儿进朝歌面见龙颜。臣奉命到西歧与他交战，怒恼了众弟子会战阵前：头一阵杨二郎七十二变，李哪吒手使相乾坤神圈；土行孙会地遁甚是灵便，邓蝉玉五色石无人敢拦；雷震子在空中苦苦鏖战，龙须虎发飞石重如泰山。臣调来赵公明前去交战，全仗着定海珠蛟龙神鞭。只杀得周营中东逃西散，他请来燃灯道下了高山。与公明在阵前一场交战，惹恼了三教主下了凡间。摆下了阵一座十分凶险，将为臣围至在绝龙岭前。有杨戬与哪吒法宝来献，九龙罩罩为臣化为灰烟。我本当封神台听候旨选，怎能舍我主爷锦绣江山？劝我主与妲己休得怜恋，最可叹锦江山六百余年。臣本当与我主——",
      "text_length": 272
    },
    {
      "event_id": "02001017_e00061",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "闻仲"
      ],
      "text": "再诉一遍，怕只怕五更尽难去归天。叫鬼卒驾云雾封神台转，",
      "text_length": 27
    },
    {
      "event_id": "02001017_e00062",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四上手、四鬼卒、二马童同下。",
      "text_length": 14
    },
    {
      "event_id": "02001017_e00063",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "闻仲"
      ],
      "text": "周室兴商汤灭就在眼前。",
      "text_length": 11
    },
    {
      "event_id": "02001017_e00064",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "02001017_e00065",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "闻仲下。天亮。",
      "text_length": 7
    },
    {
      "event_id": "02001017_e00066",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监甲"
      ],
      "text": "万岁醒来！",
      "text_length": 5
    },
    {
      "event_id": "02001017_e00067",
      "play_id": "02001017",
      "scene_id": "02001017_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 28,
      "page_no": 3,
