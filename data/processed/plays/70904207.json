  "events": [
    {
      "event_id": "70904207_e00001",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "殷氏上。",
      "text_length": 4
    },
    {
      "event_id": "70904207_e00002",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "殷氏"
      ],
      "text": "世人似我几多愁，忆念儿夫化石头。心如快鹞拖着线，身似浮鱼吞了钩。",
      "text_length": 32
    },
    {
      "event_id": "70904207_e00003",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "妾身殷氏。自从抛弃丈夫、孩儿，早又是十八年矣。这几日，耳热心跳，神思不安。嗳，多因思想丈夫、孩儿，恹恹成病。啊呀！不知几时，才有个出头日子吓。啊呀，我那江流儿吓！",
      "text_length": 81
    },
    {
      "event_id": "70904207_e00004",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "北集贤宾",
      "speakers": [
        "殷氏"
      ],
      "text": "恁趁着这碧澄澄大江东去得紧，如失却宝和珍。白日里鱼行也那虾队，到晚来与鹭友鸥群。黑漫漫翠雾连山，白茫茫雪浪堆银。只俺这跳龙门的丈夫，畅好是千转的稳，便重生十八岁为人。目穷明月渡，肠断碧天云。",
      "text_length": 95
    },
    {
      "event_id": "70904207_e00005",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "殷氏下。玄奘上。",
      "text_length": 8
    },
    {
      "event_id": "70904207_e00006",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "玄奘"
      ],
      "text": "迢迢路途休嫌远，但能早见慈亲面。",
      "text_length": 16
    },
    {
      "event_id": "70904207_e00007",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "我玄奘。奉师父之命，来到此间，寻访母亲。一路问来，说此间黑楼子内就是。不知我母亲可在里面？待我打坐在此，只做化斋访问便了。阿弥陀佛！",
      "text_length": 66
    },
    {
      "event_id": "70904207_e00008",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "殷氏上。",
      "text_length": 4
    },
    {
      "event_id": "70904207_e00009",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "不免登楼一望。",
      "text_length": 7
    },
    {
      "event_id": "70904207_e00010",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "逍遥乐",
      "speakers": [
        "殷氏"
      ],
      "text": "倚危楼高峻，瞑眩药难痊，志诚心较谨。我见一个小沙弥来往踅门，念一声阿弥陀佛心意真，策杖移踪似有因，恰便似塑来的诸佛世尊。",
      "text_length": 60
    },
    {
      "event_id": "70904207_e00011",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "师父做什么的？",
      "text_length": 7
    },
    {
      "event_id": "70904207_e00012",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "是化斋的。",
      "text_length": 5
    },
    {
      "event_id": "70904207_e00013",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "如此俺家斋你哩。",
      "text_length": 8
    },
    {
      "event_id": "70904207_e00014",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "逍遥乐",
      "speakers": [
        "殷氏"
      ],
      "text": "我有那做袈裟的绸绢，供佛像的斋粮，御严寒的衲裙。",
      "text_length": 24
    },
    {
      "event_id": "70904207_e00015",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "师父从哪里来？",
      "text_length": 7
    },
    {
      "event_id": "70904207_e00016",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "金山寺来。",
      "text_length": 5
    },
    {
      "event_id": "70904207_e00017",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "哦，金山寺来，几时可到？",
      "text_length": 12
    },
    {
      "event_id": "70904207_e00018",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "风顺二十日可到，风不顺要行一月才到。",
      "text_length": 18
    },
    {
      "event_id": "70904207_e00019",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "金山寺可是大刹之所？",
      "text_length": 10
    },
    {
      "event_id": "70904207_e00020",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "是大刹之所，万众可容。",
      "text_length": 11
    },
    {
      "event_id": "70904207_e00021",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "金菊香",
      "speakers": [
        "玄奘"
      ],
      "text": "金山寺至此有二三旬，https://scripts.xikao.com/play/709042072021-07-30宝殿能容千万人。",
      "text_length": 67
    },
    {
      "event_id": "70904207_e00022",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "师父请。",
      "text_length": 4
    },
    {
      "event_id": "70904207_e00023",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "女菩萨请。",
      "text_length": 5
    },
    {
      "event_id": "70904207_e00024",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "金菊香",
      "speakers": [
        "玄奘"
      ],
      "text": "问询向前施礼勤。",
      "text_length": 8
    },
    {
      "event_id": "70904207_e00025",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "师父请里面用斋。",
      "text_length": 8
    },
    {
      "event_id": "70904207_e00026",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "多谢女菩萨，贫僧告斋了。",
      "text_length": 12
    },
    {
      "event_id": "70904207_e00027",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "70904207_e00028",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "金菊香",
      "speakers": [
        "殷氏"
      ],
      "text": "觑着他清气逼人，恰便似一溪流水澈云根。",
      "text_length": 19
    },
    {
      "event_id": "70904207_e00029",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "好奇怪！这和尚的面庞，好似我丈夫陈光蕊模样。",
      "text_length": 22
    },
    {
      "event_id": "70904207_e00030",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "梧叶儿",
      "speakers": [
        "殷氏"
      ],
      "text": "他眉眼全相似，身材忒煞真，霞脸绛丹唇。莫不是石上三生梦，天台一化身。我心下自如亲，我心下自如亲。",
      "text_length": 48
    },
    {
      "event_id": "70904207_e00031",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "请问师父法算多少？",
      "text_length": 9
    },
    {
      "event_id": "70904207_e00032",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "贫僧今年十八岁了。",
      "text_length": 9
    },
    {
      "event_id": "70904207_e00033",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "俺孩儿若在，也是十八岁了。",
      "text_length": 13
    },
    {
      "event_id": "70904207_e00034",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "梧叶儿",
      "speakers": [
        "殷氏"
      ],
      "text": "啊呀儿呵！恁十八岁在波翻得这浪滚！",
      "text_length": 17
    },
    {
      "event_id": "70904207_e00035",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "师父！（醋葫芦）我问恁何处是家？哪个是亲？几年上落发做僧人？",
      "text_length": 30
    },
    {
      "event_id": "70904207_e00036",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "玄奘"
      ],
      "text": "贫僧出胞胎就做僧人的。",
      "text_length": 11
    },
    {
      "event_id": "70904207_e00037",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "醋葫芦",
      "speakers": [
        "殷氏"
      ],
      "text": "出胞胎怎生便离了世尘？也是恁那前生有分？与俺从头一一说个原因。",
      "text_length": 31
    },
    {
      "event_id": "70904207_e00038",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "我父姓陈，母姓殷，曾任洪州太守。",
      "text_length": 16
    },
    {
      "event_id": "70904207_e00039",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "呀！（醋葫芦）他道是父姓陈，母姓殷，为官为吏是当军，几年上此间来治民？",
      "text_length": 35
    },
    {
      "event_id": "70904207_e00040",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "贞观三年八月间，被水贼刘洪推入江中的。",
      "text_length": 19
    },
    {
      "event_id": "70904207_e00041",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "啊呀！",
      "text_length": 3
    },
    {
      "event_id": "70904207_e00042",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "醋葫芦",
      "speakers": [
        "殷氏"
      ],
      "text": "这一句道得咱心迷眼晕！他道是江上遇着强人。那时你怎生得活？",
      "text_length": 29
    },
    {
      "event_id": "70904207_e00043",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "贫僧在母腹中才得八个月。",
      "text_length": 12
    },
    {
      "event_id": "70904207_e00044",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "你怎知许多备细？",
      "text_length": 8
    },
    {
      "event_id": "70904207_e00045",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "师父丹霞禅师，在金山下拾得一个漆匣，内有金钗两股，血书一封，送至寺中，蒙长老收留。七岁能文，十五岁通经，今年一十八岁，师父着我来到洪州，寻访母亲的。",
      "text_length": 74
    },
    {
      "event_id": "70904207_e00046",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "70904207_e00047",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "醋葫芦",
      "speakers": [
        "殷氏"
      ],
      "text": "听说罢口内词，扫除了心上尘。悠悠的顶门上失了三魂！原来是江流儿远方来认亲。",
      "text_length": 37
    },
    {
      "event_id": "70904207_e00048",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "师父！",
      "text_length": 3
    },
    {
      "event_id": "70904207_e00049",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "醋葫芦",
      "speakers": [
        "殷氏"
      ],
      "text": "非是俺言多语峻，告吾师心下莫生嗔。",
      "text_length": 17
    },
    {
      "event_id": "70904207_e00050",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "你既来寻亲，有何为证。",
      "text_length": 11
    },
    {
      "event_id": "70904207_e00051",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "有血书为证。",
      "text_length": 6
    },
    {
      "event_id": "70904207_e00052",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "你那血书，可曾带来？https://scripts.xikao.com/play/709042072021-07-30",
      "text_length": 59
    },
    {
      "event_id": "70904207_e00053",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "既来寻亲，怎生不带？",
      "text_length": 10
    },
    {
      "event_id": "70904207_e00054",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "如此，我有钞写的墨书在此，你可念来，看可是一样的。",
      "text_length": 25
    },
    {
      "event_id": "70904207_e00055",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "待贫僧跪读。殷氏血书：此子之父，乃海州弘农人也，姓陈名萼，字光蕊，官拜洪州太守。携家小至任，买舟江上，遇贼刘洪，将夫推入江中，那贼冒认洪州太守。殷氏有遗腹之子，才得满月，被贼人逼勒投入江中，身系金钗两股，血书一封，望仁者怜而救之。此子乃贞观三年十一月十五日子时建生。",
      "text_length": 133
    },
    {
      "event_id": "70904207_e00056",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "殷氏"
      ],
      "text": "一些也不差！",
      "text_length": 6
    },
    {
      "event_id": "70904207_e00057",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "别无名字，唤做江流儿。",
      "text_length": 11
    },
    {
      "event_id": "70904207_e00058",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "嗳，江流儿！是我孩儿了！",
      "text_length": 12
    },
    {
      "event_id": "70904207_e00059",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "是我母亲了！玄奘（同白）啊呀（儿）（娘）呀！",
      "text_length": 22
    },
    {
      "event_id": "70904207_e00060",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "醋葫芦",
      "speakers": [
        "殷氏",
        "殷氏"
      ],
      "text": "尘昏了老绢白，惊荒了旧血痕。这的是一翻提起一翻亲。与俺那十八年的泪珠儿都挣了本，善和恶在乎方寸。恰便似花开枯树再逢春！",
      "text_length": 59
    },
    {
      "event_id": "70904207_e00061",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "母亲，师父说寻见母亲，即便回山，商量报仇要紧。",
      "text_length": 23
    },
    {
      "event_id": "70904207_e00062",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "噤声！儿吓，那贼手足较多，须要小心。待我收拾些盘缠与你，星夜回山，请师父到来，商量报仇便了。",
      "text_length": 46
    },
    {
      "event_id": "70904207_e00063",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "谨依母亲慈命。",
      "text_length": 7
    },
    {
      "event_id": "70904207_e00064",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "70904207_e00065",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "后庭花",
      "speakers": [
        "殷氏"
      ],
      "text": "我这里便收拾下金共银，哎呀！只要恁早分一个冤与恩。俺孩儿经卷能成事，陈光蕊呵！恁说什么文章可立身。莫因循，疾忙前进，下水船风力稳，报仇心似火焚，去程忙如箭紧。",
      "text_length": 79
    },
    {
      "event_id": "70904207_e00066",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "后庭花",
      "speakers": [
        "玄奘"
      ],
      "text": "去程忙如箭紧。",
      "text_length": 7
    },
    {
      "event_id": "70904207_e00067",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "柳叶儿",
      "speakers": [
        "殷氏"
      ],
      "text": "啊呀儿呵！又想起当年，当年时分，哭啼啼送你到江滨，今日个蒲帆百尺西风顺，休辞困，暂劳神。天吓！谁承望血修书弄假成真。",
      "text_length": 58
    },
    {
      "event_id": "70904207_e00068",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "来此已是江边，孩儿就此拜别。",
      "text_length": 14
    },
    {
      "event_id": "70904207_e00069",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "罢了！",
      "text_length": 3
    },
    {
      "event_id": "70904207_e00070",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "浪里来煞",
      "speakers": [
        "殷氏"
      ],
      "text": "才得个掌上珍，又提起心头闷。",
      "text_length": 14
    },
    {
      "event_id": "70904207_e00071",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "玄奘"
      ],
      "text": "母亲！",
      "text_length": 3
    },
    {
      "event_id": "70904207_e00072",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "浪里来煞",
      "speakers": [
        "玄奘"
      ],
      "text": "今宵何处去安身？",
      "text_length": 8
    },
    {
      "event_id": "70904207_e00073",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "殷氏"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "70904207_e00074",
      "play_id": "70904207",
      "scene_id": "70904207_s01",
      "scene_no": 1,
      "seq_global": 74,
