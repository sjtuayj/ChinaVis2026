      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "03080005_e00093",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 93,
