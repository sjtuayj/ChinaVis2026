  "events": [
    {
      "event_id": "03080005_e00001",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四月华旗、四飞虎旗同上，大马童引关羽同上。",
      "text_length": 21
    },
    {
      "event_id": "03080005_e00002",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "关羽"
      ],
      "text": "忠心赤胆，扶汉室，锦绣江山。",
      "text_length": 14
    },
    {
      "event_id": "03080005_e00003",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "关羽"
      ],
      "text": "青龙偃月武艺高，万马营中逞英豪。温酒未寒华雄斩，桃园美名万古标。",
      "text_length": 32
    },
    {
      "event_id": "03080005_e00004",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "某，关羽。弟兄三人桃园结义，白马祭天，乌牛祭地，一在三在，一亡三亡。只因水淹下邳，吕布被擒；吕布之家属，均落于相府。那曹操将貂蝉送与某家，以侍枕席。不过欲使某迷恋美色，消磨英雄志气。某想貂蝉牺牲一身，匡扶社稷，使董卓父子自相残害，有功于汉朝。当此离乱之时，只有一死，方能保其名节。马童！",
      "text_length": 143
    },
    {
      "event_id": "03080005_e00005",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大马童"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "03080005_e00006",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "看看今晚有月无月？",
      "text_length": 9
    },
    {
      "event_id": "03080005_e00007",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大马童"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03080005_e00008",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大马童看。",
      "text_length": 5
    },
    {
      "event_id": "03080005_e00009",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大马童"
      ],
      "text": "启爷：明月当空，",
      "text_length": 8
    },
    {
      "event_id": "03080005_e00010",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "将窗儿挂起。两厢退下！",
      "text_length": 11
    },
    {
      "event_id": "03080005_e00011",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四月华旗",
        "四飞虎旗"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03080005_e00012",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四月华旗、四飞虎旗同下。大马童支窗。",
      "text_length": 18
    },
    {
      "event_id": "03080005_e00013",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03080005_e00014",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "明月当空照窗前，风吹云散星斗全。对孤灯我把春秋看，看春秋想起了事一端。",
      "text_length": 35
    },
    {
      "event_id": "03080005_e00015",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "想那董卓专权，蓄意谋篡，吕布小儿助纣为虐，若不是那貂蝉呵！",
      "text_length": 29
    },
    {
      "event_id": "03080005_e00016",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "若不是貂蝉女连环计献，怎能够使奸佞父子相残。",
      "text_length": 22
    },
    {
      "event_id": "03080005_e00017",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "马童！",
      "text_length": 3
    },
    {
      "event_id": "03080005_e00018",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大马童"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "03080005_e00019",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "传貂蝉进帐！",
      "text_length": 6
    },
    {
      "event_id": "03080005_e00020",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大马童"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03080005_e00021",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大马童向外。",
      "text_length": 6
    },
    {
      "event_id": "03080005_e00022",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 22,
