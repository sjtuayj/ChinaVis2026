      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大马童"
      ],
      "text": "貂蝉进帐！",
      "text_length": 5
    },
    {
      "event_id": "03080005_e00023",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 23,
