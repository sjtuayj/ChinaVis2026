      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "貂蝉引头就刃。",
      "text_length": 7
    },
    {
      "event_id": "03080005_e00090",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "关云长月下斩貂蝉！",
      "text_length": 9
    },
    {
      "event_id": "03080005_e00091",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "关羽斩貂蝉死。",
      "text_length": 7
    },
    {
      "event_id": "03080005_e00092",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
