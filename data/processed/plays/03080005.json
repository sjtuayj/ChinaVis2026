      "event_id": "03080005_e00084",
      "play_id": "03080005",
      "scene_id": "03080005_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
