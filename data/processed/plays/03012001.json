  "events": [
    {
      "event_id": "03012001_e00001",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四宫娥各掌灯引窦太真同上。",
      "text_length": 13
    },
    {
      "event_id": "03012001_e00002",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "窦太真"
      ],
      "text": "闷坐昭阳，思皇儿，泪洒胸膛。",
      "text_length": 14
    },
    {
      "event_id": "03012001_e00003",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "窦太真"
      ],
      "text": "世民领兵伐洛阳，一去数载未还乡。但愿姣儿早回转，也免为娘挂心肠！",
      "text_length": 32
    },
    {
      "event_id": "03012001_e00004",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "窦太真"
      ],
      "text": "本后窦氏太真。可恨洛阳兴兵犯界，圣上命世民儿带兵前去征剿，一去数载，杳无音信。是哀家放心不下，在五凤楼前，起造望儿楼一座，每日黄昏时候，登楼盼望。今当黄昏时候，正好遥望姣儿一番。宫娥们掌灯！",
      "text_length": 95
    },
    {
      "event_id": "03012001_e00005",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "窦太真"
      ],
      "text": "窦太真在昭阳前思后想，想起了隋炀帝无道昏王。欺了兄灭了母以小犯上，将胞妹立正宫败坏纲常。陆地里行龙舟万民怨望，怒恼了塞北地众家番王。同兴师问罪行把昏王扫荡，逼死了狗奸王命丧无常。我的夫成大业把江山执掌，可恨那洛阳贼兴兵反唐。宫娥女掌银灯望儿楼上，到楼台望姣儿早回朝堂。",
      "text_length": 134
    },
    {
      "event_id": "03012001_e00006",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "窦太真、四宫娥同下。",
      "text_length": 10
    },
    {
      "event_id": "03012001_e00007",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "内唱",
      "speakers": [
        "李渊"
      ],
      "text": "思皇儿不由孤龙心裂碎，",
      "text_length": 11
    },
    {
      "event_id": "03012001_e00008",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内侍掌红灯引李渊同上。",
      "text_length": 11
    },
    {
      "event_id": "03012001_e00009",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李渊"
      ],
      "text": "下江南十余载得胜回归。恨只恨小杨广与孤作对，修下了辞王本告职回归。实指望转家园平安度岁，行在那临潼山又遇贼围；多亏了秦叔宝将贼杀退，原来是贼杨广奸计未遂。内侍臣掌红灯望儿楼内，",
      "text_length": 88
    },
    {
      "event_id": "03012001_e00010",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "窦太真"
      ],
      "text": "儿啊！",
      "text_length": 3
    },
    {
      "event_id": "03012001_e00011",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李渊"
      ],
      "text": "又听得后宫院哭咽声悲！",
      "text_length": 11
    },
    {
      "event_id": "03012001_e00012",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "内唱",
      "speakers": [
        "窦太真"
      ],
      "text": "凄凉凄凉真凄凉，不见我儿转回乡。叫声世民回来吧，免得为娘挂心肠。",
      "text_length": 32
    },
    {
      "event_id": "03012001_e00013",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "窦太真"
      ],
      "text": "啊，我的儿啊！",
      "text_length": 7
    },
    {
      "event_id": "03012001_e00014",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李渊"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "03012001_e00015",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李渊"
      ],
      "text": "我道是宫娥女宫中悲泪，却原来窦太真哭出宫闱。内侍臣熄红灯望儿楼退，",
      "text_length": 33
    },
    {
      "event_id": "03012001_e00016",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内侍熄灯，下。",
      "text_length": 7
    },
    {
      "event_id": "03012001_e00017",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李渊"
      ],
      "text": "君臣们躲一旁且免伤悲。",
      "text_length": 11
    },
    {
      "event_id": "03012001_e00018",
      "play_id": "03012001",
      "scene_id": "03012001_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李渊下。",
      "text_length": 4
    },
    {
      "event_id": "03012001_e00019",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起初更鼓〗。四宫娥各掌灯引窦太真同上。",
      "text_length": 20
    },
    {
      "event_id": "03012001_e00020",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "窦太真"
      ],
      "text": "深宫院打罢了初更时分，楼台下又来了窦氏太真。恨只恨洛阳贼兴兵犯境，他要夺我主爷锦绣龙庭。宫娥女掌银灯望儿楼进，",
      "text_length": 55
    },
    {
      "event_id": "03012001_e00021",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "窦太真上楼。",
      "text_length": 6
    },
    {
      "event_id": "03012001_e00022",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "窦太真"
      ],
      "text": "上楼来望姣儿早回朝廷。",
      "text_length": 11
    },
    {
      "event_id": "03012001_e00023",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "窦太真远望听。〖起二更鼓〗。",
      "text_length": 14
    },
    {
      "event_id": "03012001_e00024",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "窦太真"
      ],
      "text": "深宫院打罢了二更时分，想起了孝道儿李世民。建成、元吉缺孝顺，惟有那世民有孝心。",
      "text_length": 39
    },
    {
      "event_id": "03012001_e00025",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "起三鼓更。窦太真望、听、落泪。",
      "text_length": 15
    },
    {
      "event_id": "03012001_e00026",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "窦太真"
      ],
      "text": "深宫院打罢了三更时分，",
      "text_length": 11
    },
    {
      "event_id": "03012001_e00027",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内侍执灯暗上，巡查宫院。",
      "text_length": 12
    },
    {
      "event_id": "03012001_e00028",
      "play_id": "03012001",
      "scene_id": "03012001_s02",
      "scene_no": 2,
