  "events": [
    {
      "event_id": "01018004_e00001",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女引窦太真同上。",
      "text_length": 10
    },
    {
      "event_id": "01018004_e00002",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "窦太真"
      ],
      "text": "闷坐宫闱，想娇儿，好不伤悲。",
      "text_length": 14
    },
    {
      "event_id": "01018004_e00003",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "窦太真"
      ],
      "text": "恼恨单于似豺狼，兴兵扰乱锦家邦。吾儿领兵把贼挡，不知何日转回乡。哀家窦后。杨广无道，败坏纲常，天怒人怨，群雄蜂起。只为单于兴兵犯境，建成、元吉两个奴才，上殿奏本，言道吾儿世民武艺高强，定能平灭贼寇。就命吾儿带领三千人马前去平贼，至今三载有余，竟无音信，也不知生死存亡，倒叫哀家时时挂念。思想起来，好不悲伤人也。",
      "text_length": 155
    },
    {
      "event_id": "01018004_e00004",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "窦太真"
      ],
      "text": "窦太真坐昭阳自思自忿，想起了我的儿好不伤情。恨杨广无道君不修德政，每日里贪酒色残害黎民。后花园奸胞妹羞愤自尽，弟弑兄霸孀嫂败坏人伦。气死了他的母一旦丧命，戏父妃丧天良日夜荒淫。天降下五花棒昏君丧命，这江山归一统才得太平。恨建成和元吉上殿奏本，我的儿领人马去把贼平。到如今已三载不见音信，叫哀家终日里常挂在心。想娇儿把我的心血用尽，想娇儿止不住双泪淋淋。将身儿且把那望儿楼进，",
      "text_length": 187
    },
    {
      "event_id": "01018004_e00005",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "窦太真上楼。",
      "text_length": 6
    },
    {
      "event_id": "01018004_e00006",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "窦太真"
      ],
      "text": "但不知我的儿何日回京？",
      "text_length": 11
    },
    {
      "event_id": "01018004_e00007",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太监提灯引李渊同上。",
      "text_length": 10
    },
    {
      "event_id": "01018004_e00008",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "李渊"
      ],
      "text": "适才间在朝中来标本，各路兵马乱纷纷。人来掌灯后宫进，",
      "text_length": 26
    },
    {
      "event_id": "01018004_e00009",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李渊转场。",
      "text_length": 5
    },
    {
      "event_id": "01018004_e00010",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "李渊"
      ],
      "text": "又闻楼上有人声。站立楼下把身隐，看是何人把话云。",
      "text_length": 24
    },
    {
      "event_id": "01018004_e00011",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "窦太真"
      ],
      "text": "手扶定楼栏杆用目观定，开言叫声李世民：吾儿带兵去临阵，为何不见信回音？眼睁睁我的儿不能相见，",
      "text_length": 46
    },
    {
      "event_id": "01018004_e00012",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "窦太真"
      ],
      "text": "我的儿吓！",
      "text_length": 5
    },
    {
      "event_id": "01018004_e00013",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "窦太真"
      ],
      "text": "不知何日转回京。",
      "text_length": 8
    },
    {
      "event_id": "01018004_e00014",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "李渊"
      ],
      "text": "站立楼前仔细听，却原来是窦后想念世民。明日殿前将旨降，即调我儿转回程。叫人来带路后宫进，又听谯楼起了更。",
      "text_length": 52
    },
    {
      "event_id": "01018004_e00015",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李渊下。〖起初更鼓〗。",
      "text_length": 11
    },
    {
      "event_id": "01018004_e00016",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "窦太真"
      ],
      "text": "听谯楼打罢了初更时分，又只见一轮月映照楼门。有哀家在楼前用目观定，深宫院静悄悄无有人声。半空中烟雾沉山川罩定，也不知我的儿何处存身？看不见我的儿何处临阵？也不知我的儿何处交兵？此时间观不见半点踪影，好一似万把刀刺在我心。",
      "text_length": 110
    },
    {
      "event_id": "01018004_e00017",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起二更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "01018004_e00018",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "窦太真"
      ],
      "text": "又听得谯楼上二更鼓震，一字儿长空雁不住哀鸣。你可能与哀家寄上一信，带至在边关外交付儿身。",
      "text_length": 44
    },
    {
      "event_id": "01018004_e00019",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起三更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "01018004_e00020",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "窦太真"
      ],
      "text": "听谯楼又打罢三更尽，眼望着边关地大放悲声。吾的儿领人马番贼会阵，每日里与番兵对垒相争。但愿得此一去旗开得胜，但愿得此一去马到功成。我的儿若将那贼寇灭尽，那时节奏凯回庆贺功勋。",
      "text_length": 87
    },
    {
      "event_id": "01018004_e00021",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起四更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "01018004_e00022",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "窦太真"
      ],
      "text": "又听得谯楼上四更鼓震，忍不住泪珠儿湿透衣巾。有哀家望娇儿无人来问，他怎知我母子难舍难分。我的儿他为人十分孝顺，事父母尽孝道定省晨昏。但愿得众朝臣启奏一本，唤吾儿早日里转回朝门。",
      "text_length": 88
    },
    {
      "event_id": "01018004_e00023",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起五更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "01018004_e00024",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "窦太真"
      ],
      "text": "五鼓打罢天将明，月暗星稀冷露侵。盼望娇儿不能见，好叫哀家恸在心。悲切切无奈何出楼门，",
      "text_length": 42
    },
    {
      "event_id": "01018004_e00025",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "窦太真下楼。",
      "text_length": 6
    },
    {
      "event_id": "01018004_e00026",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "窦太真"
      ],
      "text": "但不知何日里重叙天伦。",
      "text_length": 11
    },
    {
      "event_id": "01018004_e00027",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "窦太真"
      ],
      "text": "儿吓，儿吓！",
      "text_length": 6
    },
    {
      "event_id": "01018004_e00028",
      "play_id": "01018004",
      "scene_id": "01018004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "窦太真下。",
      "text_length": 5
    }
  ],
