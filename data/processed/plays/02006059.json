      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺知章"
      ],
      "text": "来日领教。",
      "text_length": 5
    },
    {
      "event_id": "02006059_e00070",
      "play_id": "02006059",
      "scene_id": "02006059_s02",
      "scene_no": 2,
      "seq_global": 70,
