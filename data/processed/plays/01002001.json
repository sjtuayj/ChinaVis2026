  "events": [
    {
      "event_id": "01002001_e00001",
      "play_id": "01002001",
      "scene_id": "01002001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延嗣上。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00002",
      "play_id": "01002001",
      "scene_id": "01002001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "杨延嗣"
      ],
      "text": "赤胆忠心，只落得，青史名标。",
      "text_length": 14
    },
    {
      "event_id": "01002001_e00003",
      "play_id": "01002001",
      "scene_id": "01002001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延嗣"
      ],
      "text": "我乃七郎阴魂是也。只因那日回朝颁兵，可恨潘洪将我射死芭蕉树上。不免前去与我父托兆。众鬼卒，宋营去者！",
      "text_length": 50
    },
    {
      "event_id": "01002001_e00004",
      "play_id": "01002001",
      "scene_id": "01002001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "杨延嗣"
      ],
      "text": "我杨家保宋主忠心秉正，",
      "text_length": 11
    },
    {
      "event_id": "01002001_e00005",
      "play_id": "01002001",
      "scene_id": "01002001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨延嗣"
      ],
      "text": "东西征南北剿哪得安宁。金沙滩打一仗父子被困，老爹爹他命我回朝颁兵。潘洪贼想起了打子仇恨，他将我绑芭蕉乱箭穿身。叫鬼卒驾阴风宋营来进，见了那老爹爹细说分明。",
      "text_length": 77
    },
    {
      "event_id": "01002001_e00006",
      "play_id": "01002001",
      "scene_id": "01002001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延嗣下。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00007",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业上。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00008",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "杨继业"
      ],
      "text": "金乌坠玉免升黄昏时候，",
      "text_length": 11
    },
    {
      "event_id": "01002001_e00009",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "杨继业"
      ],
      "text": "盼姣儿不由人珠泪双流，我的儿吓！",
      "text_length": 16
    },
    {
      "event_id": "01002001_e00010",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "命七郎回大营颁兵求救，为什么此一去不见回头？莫不是潘仁美又下毒手，怕的是我的儿性命难留。含悲泪进宝帐双眉愁皱，西北风吹的我遍体飕飕。",
      "text_length": 66
    },
    {
      "event_id": "01002001_e00011",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭上。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00012",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "杨延昭"
      ],
      "text": "听谯楼打罢了二更时分，杨延昭倒做了巡营之人。迈步儿且把那宝帐来进，又只见老爹爹瞌睡沉沉。",
      "text_length": 44
    },
    {
      "event_id": "01002001_e00013",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延嗣上。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00014",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨延嗣"
      ],
      "text": "听谯楼打罢了三更时分，半空中来了我七郎阴魂。叫鬼卒驾阴风宝帐来进，又只见老爹爹瞌睡沉沉。我这里将他的忠魂惊醒，",
      "text_length": 55
    },
    {
      "event_id": "01002001_e00015",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "猛抬头又只见七郎姣生。我命你回大营颁兵求救，为什么哭啼啼头带雕翎？恨不得下位去将儿抱定，",
      "text_length": 44
    },
    {
      "event_id": "01002001_e00016",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨延嗣"
      ],
      "text": "老爹爹休贪睡细听分明：金沙滩打一仗父子被困，老爹爹命孩儿回朝颁兵。潘洪贼想起了打子仇恨，他将我绑芭蕉乱箭穿身。回头来又对六兄论，小弟言来听分明：高堂老母要你孝敬，莫学小弟不孝顺。我本当与六兄多谈多论，又恐怕天明亮难回天庭。",
      "text_length": 111
    },
    {
      "event_id": "01002001_e00017",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延嗣下。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00018",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "杨继业"
      ],
      "text": "适才间梦见了七郎来临，",
      "text_length": 11
    },
    {
      "event_id": "01002001_e00019",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01002001_e00020",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "又只见六郎儿瞌睡沉沉。",
      "text_length": 11
    },
    {
      "event_id": "01002001_e00021",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "六郎儿醒来！",
      "text_length": 6
    },
    {
      "event_id": "01002001_e00022",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "杨延昭"
      ],
      "text": "适才间梦见了七弟来临，",
      "text_length": 11
    },
    {
      "event_id": "01002001_e00023",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "杨延昭"
      ],
      "text": "又只见老爹爹面前存。",
      "text_length": 10
    },
    {
      "event_id": "01002001_e00024",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹，适才睡梦之中，观见七弟浑身是血，头带雕翎。不知是何缘故？",
      "text_length": 31
    },
    {
      "event_id": "01002001_e00025",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "为父亦得此兆。这才是“梦梦相同，必有凶险”。我亦有意，命你回朝探听七弟下落。不知我儿意下如何？",
      "text_length": 47
    },
    {
      "event_id": "01002001_e00026",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹年迈，孩儿放心不下。",
      "text_length": 12
    },
    {
      "event_id": "01002001_e00027",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "为父虽然年迈，倒也康健，只管前去。",
      "text_length": 17
    },
    {
      "event_id": "01002001_e00028",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "孩儿不去！",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00029",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "儿吓，为父倒有父子之情，难道你无手足之义么？",
      "text_length": 22
    },
    {
      "event_id": "01002001_e00030",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹不必如此，孩儿去就是了。",
      "text_length": 14
    },
    {
      "event_id": "01002001_e00031",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "杨延昭"
      ],
      "text": "辞别爹爹跨金蹬，不分昼夜去颁兵。",
      "text_length": 16
    },
    {
      "event_id": "01002001_e00032",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "杨延昭"
      ],
      "text": "爹爹，我父，啊呀！",
      "text_length": 9
    },
    {
      "event_id": "01002001_e00033",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭下。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00034",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "杨继业"
      ],
      "text": "六郎上了马能行，好不叫人痛伤心。悲悲切切大营进，父子相会再等来生。",
      "text_length": 33
    },
    {
      "event_id": "01002001_e00035",
      "play_id": "01002001",
      "scene_id": "01002001_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业下。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00036",
      "play_id": "01002001",
      "scene_id": "01002001_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "耶律休上。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00037",
      "play_id": "01002001",
      "scene_id": "01002001_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "耶律休"
      ],
      "text": "俺奉太后之命，巡营了哨。就此前往。呔！",
      "text_length": 19
    },
    {
      "event_id": "01002001_e00038",
      "play_id": "01002001",
      "scene_id": "01002001_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭上。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00039",
      "play_id": "01002001",
      "scene_id": "01002001_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "何人挡住某家去路？",
      "text_length": 9
    },
    {
      "event_id": "01002001_e00040",
      "play_id": "01002001",
      "scene_id": "01002001_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "耶律休"
      ],
      "text": "俺乃耶律休，要你的狗命！",
      "text_length": 12
    },
    {
      "event_id": "01002001_e00041",
      "play_id": "01002001",
      "scene_id": "01002001_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "一派胡言！",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00042",
      "play_id": "01002001",
      "scene_id": "01002001_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭、耶律休同开打，耶律休败下，杨延昭下。",
      "text_length": 22
    },
    {
      "event_id": "01002001_e00043",
      "play_id": "01002001",
      "scene_id": "01002001_s04",
      "scene_no": 4,
      "seq_global": 43,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭上。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00044",
      "play_id": "01002001",
      "scene_id": "01002001_s04",
      "scene_no": 4,
      "seq_global": 44,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨延昭"
      ],
      "text": "且住，且喜逃出虎口，不免回朝便了！",
      "text_length": 17
    },
    {
      "event_id": "01002001_e00045",
      "play_id": "01002001",
      "scene_id": "01002001_s04",
      "scene_no": 4,
      "seq_global": 45,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨延昭下。",
      "text_length": 5
    },
    {
      "event_id": "01002001_e00046",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 46,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业、四老军同上。",
      "text_length": 10
    },
    {
      "event_id": "01002001_e00047",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 47,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "杨继业"
      ],
      "text": "叹杨家秉忠心大宋扶保，到如今只落得瓦解冰消。恨胡儿打来了连环战表，他要夺我主爷锦绣龙朝。贼潘洪在金殿挂了招讨，我父子倒做了马前英豪。",
      "text_length": 66
    },
    {
      "event_id": "01002001_e00048",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 48,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "金沙滩双龙会一战败了，只杀得血成河鬼哭神号。我的大郎儿吓，替宋王把忠尽了，二郎儿短剑下命赴阴曹。杨三郎被马踏尸骨难找，四、八郎在番邦无有下梢。五郎儿在五台修真学道，七郎儿被潘洪箭射芭蕉。只剩下六郎儿东征西剿，可怜他又尽忠，又尽孝，身披盔甲、马不停蹄，东荡西剿，昼夜杀砍，为国勤劳。可怜我八个子把四子丧了，我把四子丧了，我的儿吓！一家人只落得死无下梢。恨萧营报前仇又打战表，请我主赴两狼摆一摆枪刀。这潘洪二次里挂了招讨，我父子做先行逢山开路，遇水安桥。黄道日不发兵不把贼剿，黑道日命父子去把兵交。为国家哪顾得黄道黑道，我父子一马当先杀进了贼巢。头一阵得了胜回营禀报，狗奸贼将人马扎定了城濠。传一令将胡儿斩杀尽了，斩不尽杀不绝不许回朝。二次里闯贼巢入了圈套，我父子困焦牙入了笼牢。我也曾命六郎回营去了，可怜我为国家，秉忠心，年迈苍苍，困两狼，里无粮，外无草，盼兵不到、盼子不归，我这老残生，就不能还朝！我的儿吓！",
      "text_length": 404
    },
    {
      "event_id": "01002001_e00049",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 49,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四老军"
      ],
      "text": "饿吓！",
      "text_length": 3
    },
    {
      "event_id": "01002001_e00050",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 50,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "饥饿了你就该战马斩倒，",
      "text_length": 11
    },
    {
      "event_id": "01002001_e00051",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 51,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四老军"
      ],
      "text": "冷吓！",
      "text_length": 3
    },
    {
      "event_id": "01002001_e00052",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 52,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "身冷了拆帐篷用布裹包。",
      "text_length": 11
    },
    {
      "event_id": "01002001_e00053",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 53,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四老军"
      ],
      "text": "雁来了。",
      "text_length": 4
    },
    {
      "event_id": "01002001_e00054",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 54,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业射雁。",
      "text_length": 6
    },
    {
      "event_id": "01002001_e00055",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 55,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "啊呀！",
      "text_length": 3
    },
    {
      "event_id": "01002001_e00056",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 56,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "杨继业"
      ],
      "text": "宝雕弓打不着空中飞鸟，弓折弦断为的是哪条？",
      "text_length": 21
    },
    {
      "event_id": "01002001_e00057",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 57,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "探子上。",
      "text_length": 4
    },
    {
      "event_id": "01002001_e00058",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 58,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "探子"
      ],
      "text": "胡儿把战马绞倒！",
      "text_length": 8
    },
    {
      "event_id": "01002001_e00059",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 59,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨继业"
      ],
      "text": "再探！",
      "text_length": 3
    },
    {
      "event_id": "01002001_e00060",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 60,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "探子下。",
      "text_length": 4
    },
    {
      "event_id": "01002001_e00061",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 61,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反二黄摇板",
      "speakers": [
        "杨继业"
      ],
      "text": "恨胡儿把我的战马绞倒，下由我年迈人怒上眉梢。叫老军抬过了定宋刀，忙把路找。寻一个避风所再作计较。",
      "text_length": 48
    },
    {
      "event_id": "01002001_e00062",
      "play_id": "01002001",
      "scene_id": "01002001_s05",
      "scene_no": 5,
      "seq_global": 62,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨继业、四老军同下。",
      "text_length": 10
    }
  ],
  "roles_inferred": true
}