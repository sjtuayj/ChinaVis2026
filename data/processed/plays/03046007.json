  "events": [
    {
      "event_id": "03046007_e00001",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖发点〗。四大铠、四太监、大太监引赵匡胤同上。",
      "text_length": 23
    },
    {
      "event_id": "03046007_e00002",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "赵匡胤"
      ],
      "text": "龙争虎斗，这干戈，何日罢休！",
      "text_length": 14
    },
    {
      "event_id": "03046007_e00003",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵匡胤"
      ],
      "text": "蛟龙无水困沙滩，失却明珠寻觅难。中了奸贼牢笼计，汴梁何日得回还。",
      "text_length": 32
    },
    {
      "event_id": "03046007_e00004",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "孤、乾德王赵。可恨欧阳方，将孤诓下河东七载，内无粮草，外无救兵。也曾命黄信四路打探，未见回报。",
      "text_length": 47
    },
    {
      "event_id": "03046007_e00005",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "黄信"
      ],
      "text": "马来！",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00006",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄信上。",
      "text_length": 4
    },
    {
      "event_id": "03046007_e00007",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "黄信"
      ],
      "text": "探听军事情，奏与万岁知。",
      "text_length": 12
    },
    {
      "event_id": "03046007_e00008",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄信"
      ],
      "text": "报！黄信告进！",
      "text_length": 7
    },
    {
      "event_id": "03046007_e00009",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄信进门。",
      "text_length": 5
    },
    {
      "event_id": "03046007_e00010",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄信"
      ],
      "text": "臣、黄信见驾，吾皇万岁！",
      "text_length": 12
    },
    {
      "event_id": "03046007_e00011",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00012",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄信"
      ],
      "text": "万万岁！",
      "text_length": 4
    },
    {
      "event_id": "03046007_e00013",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "命你打探军情，一一奏来！",
      "text_length": 12
    },
    {
      "event_id": "03046007_e00014",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄信"
      ],
      "text": "臣打探罗家山发来一哨人马，昨日鞭坠白龙，今日马踏御营。特来报知！",
      "text_length": 32
    },
    {
      "event_id": "03046007_e00015",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "再探再报！",
      "text_length": 5
    },
    {
      "event_id": "03046007_e00016",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄信"
      ],
      "text": "得令！",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00017",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄信下。",
      "text_length": 4
    },
    {
      "event_id": "03046007_e00018",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "且住！适才黄信报道：罗家山发来一哨人马，昨日鞭坠白龙，今日马踏御营。若是我国人马，就不该马踏御营；若是他国人马，就不该鞭坠白龙。此事叫孤好难解也！",
      "text_length": 73
    },
    {
      "event_id": "03046007_e00019",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "探马儿不住的飞来报，他报道罗家山兵发一标。杏黄旗不住在空中飘绕，吓坏了御营中大小英豪。恨河东刘崇贼打来战表，他要夺孤王的锦绣龙朝。欧阳方在金殿帅印挂了，呼寿亭倒作了先行英豪。一文一武把孤保，白龙关前枪对刀。下河东困七载把孤的胡须白了，为社稷昼夜里哪顾辛劳？在头上取下了飞龙帽，身上——在身上脱下了衮龙袍。https://scripts.xikao.com/play/030460072022-04-11孤的玲珑——玲珑铠甲落丝绦，杀人的妙策计一条。御林军与孤巡营了哨，把守御营要勤劳。",
      "text_length": 242
    },
    {
      "event_id": "03046007_e00020",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大铠"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00021",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四太监、大太监同下。马夫暗上。",
      "text_length": 19
    },
    {
      "event_id": "03046007_e00022",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "叫曹头将孤的龙驹鞍辔备好！",
      "text_length": 13
    },
    {
      "event_id": "03046007_e00023",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤下。马夫洗马。赵匡胤上。",
      "text_length": 15
    },
    {
      "event_id": "03046007_e00024",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "这是孤无良将自把兵交。",
      "text_length": 11
    },
    {
      "event_id": "03046007_e00025",
      "play_id": "03046007",
      "scene_id": "03046007_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、马夫同下。",
      "text_length": 9
    },
    {
      "event_id": "03046007_e00026",
      "play_id": "03046007",
      "scene_id": "03046007_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖急急风〗。四龙套引呼延赞同上。",
      "text_length": 16
    },
    {
      "event_id": "03046007_e00027",
      "play_id": "03046007",
      "scene_id": "03046007_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "expression",
      "mode_label": "三笑",
      "speakers": [
        "呼延赞"
      ],
      "text": "哈哈！哈哈！啊哈哈哈……",
      "text_length": 12
    },
    {
      "event_id": "03046007_e00028",
      "play_id": "03046007",
      "scene_id": "03046007_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖四击头〗。呼延赞、四龙套同下。",
      "text_length": 16
    },
    {
      "event_id": "03046007_e00029",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤上。",
      "text_length": 5
    },
    {
      "event_id": "03046007_e00030",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "催马来在战场道，看一看来的是哪家儿曹。",
      "text_length": 19
    },
    {
      "event_id": "03046007_e00031",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内唢呐二黄导板",
      "speakers": [
        "呼延赞"
      ],
      "text": "乌骓马不住的连声吼，",
      "text_length": 10
    },
    {
      "event_id": "03046007_e00032",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "呼延赞上。",
      "text_length": 5
    },
    {
      "event_id": "03046007_e00033",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "呼延赞"
      ],
      "text": "打将鞭一举鬼神愁。催马儿来至在御营口，",
      "text_length": 19
    },
    {
      "event_id": "03046007_e00034",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "哦喝，呔！",
      "text_length": 5
    },
    {
      "event_id": "03046007_e00035",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "呼延赞"
      ],
      "text": "叫一声乾德王早出龙楼！",
      "text_length": 11
    },
    {
      "event_id": "03046007_e00036",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "只见他乌油盔来乌油甲，皂罗袍上绣团花。跨下了一骑乌骓马，打将钢鞭手中拿。问一声小将名和姓，通上名来尔是哪家？",
      "text_length": 54
    },
    {
      "event_id": "03046007_e00037",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "听者！",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00038",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "呼延赞"
      ],
      "text": "家住在河南胡迈境，我的父名叫呼延寿亭。若问少爷的名和姓，",
      "text_length": 28
    },
    {
      "event_id": "03046007_e00039",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "讲！",
      "text_length": 2
    },
    {
      "event_id": "03046007_e00040",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "呼延赞"
      ],
      "text": "呼延赞就是少爷的名。",
      "text_length": 10
    },
    {
      "event_id": "03046007_e00041",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "只说呼延绝了后，谁知还有这条根！不通名姓打马走——",
      "text_length": 25
    },
    {
      "event_id": "03046007_e00042",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "呼延赞"
      ],
      "text": "钢鞭不打无名少姓人。",
      "text_length": 10
    },
    {
      "event_id": "03046007_e00043",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "乾德王驾坐黄罗帐，我是他驾前一小军。",
      "text_length": 18
    },
    {
      "event_id": "03046007_e00044",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "住了！",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00045",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "呼延赞"
      ],
      "text": "丹凤眼来卧蚕眉，五柳胡须飘胸膛。看你不像小军样，定是御营乾德王。拳打五虎把名扬，https://scripts.xikao.com/play/030460072022-04-11岂肯失信小儿郎！",
      "text_length": 97
    },
    {
      "event_id": "03046007_e00046",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "若问孤王名和姓，少打关西赵玄郎。",
      "text_length": 16
    },
    {
      "event_id": "03046007_e00047",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "看鞭！",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00048",
      "play_id": "03046007",
      "scene_id": "03046007_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、呼延赞同起打，赵匡胤、呼延赞双收下。",
      "text_length": 22
    },
    {
      "event_id": "03046007_e00049",
      "play_id": "03046007",
      "scene_id": "03046007_s04",
      "scene_no": 4,
      "seq_global": 49,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "龙形、虎形同上，过场，同下。",
      "text_length": 14
    },
    {
      "event_id": "03046007_e00050",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 50,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤上。",
      "text_length": 5
    },
    {
      "event_id": "03046007_e00051",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 51,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "小将生来武艺大，手使钢鞭似铁塔。一鞭打下千斤重，",
      "text_length": 24
    },
    {
      "event_id": "03046007_e00052",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 52,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "唔呼呀！",
      "text_length": 4
    },
    {
      "event_id": "03046007_e00053",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 53,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "震得孤王虎口麻。催马来在战场下，小将到此顺说他。",
      "text_length": 24
    },
    {
      "event_id": "03046007_e00054",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 54,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "呼延赞上。",
      "text_length": 5
    },
    {
      "event_id": "03046007_e00055",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 55,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "呼延赞"
      ],
      "text": "我的父犯了何条罪，为何斩首在御营？",
      "text_length": 17
    },
    {
      "event_id": "03046007_e00056",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 56,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄导板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "小将军暂且珠泪停，",
      "text_length": 9
    },
    {
      "event_id": "03046007_e00057",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 57,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "细听孤王说分明：恨河东刘崇贼打来战本，他要夺孤王的锦绣龙廷。欧阳方在金殿挂了帅印，尔的父倒做下了马前先行。三更时贼胡儿前来偷营，只说是反了个呼延寿亭。孤王斩字未出唇，欧阳方拔宝剑斩尔的天伦。",
      "text_length": 95
    },
    {
      "event_id": "03046007_e00058",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 58,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "呼延赞"
      ],
      "text": "住口！",
      "text_length": 3
    },
    {
      "event_id": "03046007_e00059",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 59,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "呼延赞"
      ],
      "text": "君不开口谁敢斩，哪有臣子乱杀人？",
      "text_length": 16
    },
    {
      "event_id": "03046007_e00060",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 60,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "兵权落在奸贼手，为王也要听令行。",
      "text_length": 16
    },
    {
      "event_id": "03046007_e00061",
      "play_id": "03046007",
      "scene_id": "03046007_s05",
      "scene_no": 5,
      "seq_global": 61,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "aria",
      "mode_label": "唢呐二黄散板",
      "speakers": [
        "呼延赞"
      ],
      "text": "不会为君死了罢，天宫再降紫微星。",
      "text_length": 16
    },
    {
