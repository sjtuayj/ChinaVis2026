  "events": [
    {
      "event_id": "02006026_e00001",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐僧上。",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00002",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "唐僧"
      ],
      "text": "奉明君九重恩诏，往西天敢惮勋劳。",
      "text_length": 16
    },
    {
      "event_id": "02006026_e00003",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙悟空上。",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00004",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "唐僧"
      ],
      "text": "望云山，满目无幽道。回首望，远皇朝。潇潇秋水分清瘴，寂寞他乡访故交。",
      "text_length": 34
    },
    {
      "event_id": "02006026_e00005",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "贫僧唐三藏。奉大唐天子之命，往西天悮云渡，求取三藏金经。天色已晚。悟空！",
      "text_length": 36
    },
    {
      "event_id": "02006026_e00006",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02006026_e00007",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "哪里借宿一宵，明日早行。",
      "text_length": 12
    },
    {
      "event_id": "02006026_e00008",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "啊师父，你看前面有所禅林，那里就好。",
      "text_length": 18
    },
    {
      "event_id": "02006026_e00009",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "须速趱行。",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00010",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "孙悟空"
      ],
      "text": "形相吊，早穿林渡涧，又过溪桥，又过溪桥。",
      "text_length": 20
    },
    {
      "event_id": "02006026_e00011",
      "play_id": "02006026",
      "scene_id": "02006026_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐僧、孙悟空同下。",
      "text_length": 9
    },
    {
      "event_id": "02006026_e00012",
      "play_id": "02006026",
      "scene_id": "02006026_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然上。",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00013",
      "play_id": "02006026",
      "scene_id": "02006026_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "了然"
      ],
      "text": "绝顶茅庵老此生，寒云枯木伴经行。世人哪得知幽径，遥闻青峰礼磬声。",
      "text_length": 32
    },
    {
      "event_id": "02006026_e00014",
      "play_id": "02006026",
      "scene_id": "02006026_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "贫僧，乃观音禅院住持了然是也。痴长一百二十余岁，我在此院修行八十余年。懒去敲梆募化，现成送来欢喜，人人道我贪财，我说孔子有云：及其老也也，戒之在得。闲话少说，今日天气清明，恐有四方施主到来。徒弟们，打扫洁净，烹茶伺候了。",
      "text_length": 110
    },
    {
      "event_id": "02006026_e00015",
      "play_id": "02006026",
      "scene_id": "02006026_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然下。",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00016",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 16,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐僧、孙悟空同上。",
      "text_length": 9
    },
    {
      "event_id": "02006026_e00017",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 17,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "唐僧"
      ],
      "text": "巍石参通乌道，空山竟有僧家。禅林定在深处，涧水流来落花。",
      "text_length": 28
    },
    {
      "event_id": "02006026_e00018",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 18,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "来此已是观音禅院。悟空！",
      "text_length": 12
    },
    {
      "event_id": "02006026_e00019",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 19,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02006026_e00020",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 20,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "前去叩门。",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00021",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 21,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "吸，里面有人么？",
      "text_length": 8
    },
    {
      "event_id": "02006026_e00022",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 22,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然上。",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00023",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "02006026_e00024",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "了然"
      ],
      "text": "僧院香烟结彩，施主往来如云。",
      "text_length": 14
    },
    {
      "event_id": "02006026_e00025",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "是哪个呀？原来是二位师父。师父是哪里来的？",
      "text_length": 21
    },
    {
      "event_id": "02006026_e00026",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "贫僧是东都大唐，奉圣天子之命，往西天拜求真经，经过宝刹。天色已晚，借宿一宵，望乞慈悲。",
      "text_length": 43
    },
    {
      "event_id": "02006026_e00027",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "说哪里话来，既是同衣，何言借宿。请到里面坐。",
      "text_length": 22
    },
    {
      "event_id": "02006026_e00028",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "02006026_e00029",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐僧进，参。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00030",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "参过菩萨，徒弟们，撞钟擂鼓。",
      "text_length": 14
    },
    {
      "event_id": "02006026_e00031",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然参，坐。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00032",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "徒弟们看茶。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00033",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然上茶。",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00034",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "啊，师父方才说从东都来的，不知东都至此有多少路程，大唐朝内，可有多少文武，在路行程，不知过了多少府县，光景如何？望师父试说一遍，贫僧洗耳恭听。",
      "text_length": 71
    },
    {
      "event_id": "02006026_e00035",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "老师父听禀。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00036",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "唐僧"
      ],
      "text": "四海同风，圣主英明敏又聪。黎民鱼变，满朝臣宰，尽都是薆龙。太平盛世乐时雍，文修武备把升平诵。万国来同，万国来同。宝呈玉帛，车书一统，车书一统。",
      "text_length": 71
    },
    {
      "event_id": "02006026_e00037",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "领教了。",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00038",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "请问师父，宝刹建造多少年了？",
      "text_length": 14
    },
    {
      "event_id": "02006026_e00039",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "这观音院呵！",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00040",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "了然"
      ],
      "text": "许久颓崩，祸宇荒凉，圣像朦，香残火冷。蜗涎鼠糞，断鼓迷钟。",
      "text_length": 29
    },
    {
      "event_id": "02006026_e00041",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "那时老僧呵！",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00042",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "了然"
      ],
      "text": "敲梆募化十檀经，重修殿宇把诸神供。褊小庵笼，褊小庵笼，怎比你名山大刹，雕刻鲜明，雕刻鲜明。",
      "text_length": 45
    },
    {
      "event_id": "02006026_e00043",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "好说，多有领教了。",
      "text_length": 9
    },
    {
      "event_id": "02006026_e00044",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "请问师父，从天朝来，可带了什么宝贝？求借一看。",
      "text_length": 23
    },
    {
      "event_id": "02006026_e00045",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "宝贝虽有，只是贫僧远行，不曾带来。",
      "text_length": 17
    },
    {
      "event_id": "02006026_e00046",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "啊，老师父要看宝贝么，待我取来你看。这件锦襕袈裟，可不是宝贝？",
      "text_length": 31
    },
    {
      "event_id": "02006026_e00047",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然看袈裟。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00048",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "呀，好宝贝。果然的好宝贝。啊师父，老僧痴长一百二十余岁，不曾见此宝贝。欲求借与老僧细观一宵，明早奉还，不知师父意下如何？",
      "text_length": 60
    },
    {
      "event_id": "02006026_e00049",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "老师父要细看看不妨拿去，明早还我就是了。",
      "text_length": 20
    },
    {
      "event_id": "02006026_e00050",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "请到禅堂用斋。",
      "text_length": 7
    },
    {
      "event_id": "02006026_e00051",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "唐僧"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "02006026_e00052",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "啊，老师父，我那马呀。",
      "text_length": 11
    },
    {
      "event_id": "02006026_e00053",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "呕，是了。",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00054",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "要你好生喂养。",
      "text_length": 7
    },
    {
      "event_id": "02006026_e00055",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "这个自然。",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00056",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "唐僧、孙悟空同下。",
      "text_length": 9
    },
    {
      "event_id": "02006026_e00057",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "呀呀，好宝贝。真个人生罕有。怎么设个法儿，谋了他的才好。有了，不免唤出徒弟们来，大家想个计策。徒弟们哪里？",
      "text_length": 53
    },
    {
      "event_id": "02006026_e00058",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众僧人同上。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00059",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧人"
      ],
      "text": "来咧，来咧。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00060",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "众僧人"
      ],
      "text": "忽听师父叫，慌忙就来到。",
      "text_length": 12
    },
    {
      "event_id": "02006026_e00061",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧人"
      ],
      "text": "师父，有何吩咐？",
      "text_length": 8
    },
    {
      "event_id": "02006026_e00062",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "啊，徒弟们，今有大唐来了两个和尚，带来一件锦襕袈裟，真乃人间罕有的宝贝！你们大家看看。",
      "text_length": 43
    },
    {
      "event_id": "02006026_e00063",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众僧人同看，同夸。",
      "text_length": 9
    },
    {
      "event_id": "02006026_e00064",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "啊，徒弟们，我如今要谋下此宝留在本院，作一个传家之宝，咱们大家想个计策。",
      "text_length": 36
    },
    {
      "event_id": "02006026_e00065",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧人"
      ],
      "text": "大家想来。有咧，有咧，又碰回去咧。",
      "text_length": 17
    },
    {
      "event_id": "02006026_e00066",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "哦，有了，我把袈裟藏在韦陀龛内，你们到了三更时分，四面上放起火来，将他们师徒烧死，得了袈裟重修庙宇，再塑金身。有何不可？",
      "text_length": 60
    },
    {
      "event_id": "02006026_e00067",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众僧人"
      ],
      "text": "好计策，好计策。",
      "text_length": 8
    },
    {
      "event_id": "02006026_e00068",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "了然"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "02006026_e00069",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 69,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "了然"
      ],
      "text": "放下一星火，",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00070",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 70,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "众僧人"
      ],
      "text": "能烧万层山。",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00071",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 71,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "了然、众僧人同下。孙悟空上，听。",
      "text_length": 16
    },
    {
      "event_id": "02006026_e00072",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 72,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "哎呀好贼秃！这等凶狠，你要将俺师徒烧死，怎得能够。俺不免将火神召来。呔！火神速降。",
      "text_length": 41
    },
    {
      "event_id": "02006026_e00073",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 73,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "火神上。",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00074",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 74,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "火神"
      ],
      "text": "三眼狰狞相轩昂，金鞭举处鬼神寒。火轮展破红莲地，勅命南方火德权。",
      "text_length": 32
    },
    {
      "event_id": "02006026_e00075",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 75,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火神"
      ],
      "text": "吾乃火德星君是也。今有大圣相召，须速前往。呔！火部众神，就此驾云前往。",
      "text_length": 35
    },
    {
      "event_id": "02006026_e00076",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 76,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众神"
      ],
      "text": "领法旨！",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00077",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 77,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "火神"
      ],
      "text": "忙忙的——",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00078",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 78,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "斗鹌鹑",
      "speakers": [
        "火神"
      ],
      "text": "驾云乘风，须度了云山几重。莫不是复起狠心，驾风云重开天宫，叫咱去相从。俺本是天上莲花，怎肯向污地栽种，污地栽种。",
      "text_length": 56
    },
    {
      "event_id": "02006026_e00079",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 79,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火神"
      ],
      "text": "大圣请了。相召吾神，有何见谕？",
      "text_length": 15
    },
    {
      "event_id": "02006026_e00080",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 80,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "嗳，无事也不劳动于你，只为那寺的了然秃廝，今夜三更时分，要将我师徒烧死咧。",
      "text_length": 37
    },
    {
      "event_id": "02006026_e00081",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 81,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火神"
      ],
      "text": "哇呀，哇呀呀呀呀！",
      "text_length": 9
    },
    {
      "event_id": "02006026_e00082",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 82,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "金蕉叶",
      "speakers": [
        "火神"
      ],
      "text": "听说罢，不由人心中气涌，狠秃廝，狠秃廝，把释戒，贪心顿萌，顷刻间，一个个头焦额红。真个是，杀人可恕，情理难容。",
      "text_length": 55
    },
    {
      "event_id": "02006026_e00083",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 83,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "还要借你的火罩，将俺师父的睡处罩住，不要惊动于他。",
      "text_length": 25
    },
    {
      "event_id": "02006026_e00084",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 84,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火神"
      ],
      "text": "大圣放心。",
      "text_length": 5
    },
    {
      "event_id": "02006026_e00085",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 85,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "火神"
      ],
      "text": "俺、俺、俺，",
      "text_length": 6
    },
    {
      "event_id": "02006026_e00086",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 86,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "秃廝儿",
      "speakers": [
        "火神"
      ],
      "text": "俺将这神罩起空，罩罩罩，罩禅房不透其风，管叫你师徒安眠，稳睡到日东升。",
      "text_length": 35
    },
    {
      "event_id": "02006026_e00087",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 87,
      "seq_in_scene": 72,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "不是当耍的呀，你也要小心着。",
      "text_length": 14
    },
    {
      "event_id": "02006026_e00088",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 88,
      "seq_in_scene": 73,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "秃廝儿",
      "speakers": [
        "火神"
      ],
      "text": "大圣你休谆谆嘱重重，无惊少恐，无惊少恐。",
      "text_length": 20
    },
    {
      "event_id": "02006026_e00089",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 89,
      "seq_in_scene": 74,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙悟空"
      ],
      "text": "他将袈裟藏在韦陀龛内，这殿也不要烧毁了哇！去吧。",
      "text_length": 24
    },
    {
      "event_id": "02006026_e00090",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 90,
      "seq_in_scene": 75,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火神"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02006026_e00091",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 91,
      "seq_in_scene": 76,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "圣药王",
      "speakers": [
        "火神"
      ],
      "text": "西天界如来用，如来用，腾空烈焰不让些儿缝。海中曾救龙神众，笑秃廝，痴心妄想，今成何用，把残生断送。",
      "text_length": 49
    },
    {
      "event_id": "02006026_e00092",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 92,
      "seq_in_scene": 77,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "火神"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "02006026_e00093",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 93,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "火神"
      ],
      "text": "万事到头总成空，齐付南柯一梦中，一梦中。",
      "text_length": 20
    },
    {
      "event_id": "02006026_e00094",
      "play_id": "02006026",
      "scene_id": "02006026_s03",
      "scene_no": 3,
      "seq_global": 94,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人自两边分下。",
      "text_length": 8
    }
  ],
  "roles_inferred": true
}