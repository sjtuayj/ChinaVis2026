        "马芳"
      ],
      "text": "再探。",
      "text_length": 3
    },
    {
      "event_id": "01013005_e00013",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "探子"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "01013005_e00014",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "探子下。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00015",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "转堂。",
      "text_length": 3
    },
    {
      "event_id": "01013005_e00016",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "夫人上。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00017",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "可恼吓可恼。",
      "text_length": 6
    },
    {
      "event_id": "01013005_e00018",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "夫人"
      ],
      "text": "老爷，今日为何这等烦恼？",
      "text_length": 12
    },
    {
      "event_id": "01013005_e00019",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "夫人有所不知，时才探马报到，只因我父杨波，在朝中与奸贼徐赞顶本，可恨昏王，将我父削去官职，囚禁南牢，你道恼是不恼！",
      "text_length": 57
    },
    {
      "event_id": "01013005_e00020",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "夫人"
      ],
      "text": "既有此事，老爷就该点动人马，搭救我父才是。",
      "text_length": 21
    },
    {
      "event_id": "01013005_e00021",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "本帅也有此意，就请夫人点动雄兵，校场伺候。本帅后面披挂。正是：",
      "text_length": 31
    },
    {
      "event_id": "01013005_e00022",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "马芳"
      ],
      "text": "恼恨昏王与徐赞，",
      "text_length": 8
    },
    {
      "event_id": "01013005_e00023",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "夫人"
      ],
      "text": "点兵救父报仇冤。",
      "text_length": 8
    },
    {
      "event_id": "01013005_e00024",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马芳下。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00025",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "夫人"
      ],
      "text": "我这里在二堂忙传将令，",
      "text_length": 11
    },
    {
      "event_id": "01013005_e00026",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "夫人"
      ],
      "text": "叫一声众将官细听分明：此一番发大兵皇城来进，个个争先莫消停。",
      "text_length": 30
    },
    {
      "event_id": "01013005_e00027",
      "play_id": "01013005",
      "scene_id": "01013005_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "夫人下。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00028",
      "play_id": "01013005",
      "scene_id": "01013005_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四上手、马昆、马玉、马芳同上。",
      "text_length": 19
    },
    {
      "event_id": "01013005_e00029",
      "play_id": "01013005",
      "scene_id": "01013005_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "马芳"
      ],
      "text": "点动人和马，兵发紫禁城。",
      "text_length": 12
    },
    {
      "event_id": "01013005_e00030",
      "play_id": "01013005",
      "scene_id": "01013005_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "马昆、马玉，人马可曾齐备？",
      "text_length": 13
    },
    {
      "event_id": "01013005_e00031",
      "play_id": "01013005",
      "scene_id": "01013005_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马昆",
        "马玉"
      ],
      "text": "俱巳齐备。",
      "text_length": 5
    },
    {
      "event_id": "01013005_e00032",
      "play_id": "01013005",
      "scene_id": "01013005_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "起兵前往。",
      "text_length": 5
    },
    {
      "event_id": "01013005_e00033",
      "play_id": "01013005",
      "scene_id": "01013005_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    },
    {
      "event_id": "01013005_e00034",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "万历上。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00035",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "万历"
      ],
      "text": "时才内侍报连声，午门外反了马文成。恭身且把国太请，一同定计退雄兵。",
      "text_length": 33
    },
    {
      "event_id": "01013005_e00036",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "国太上。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00037",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "国太"
      ],
      "text": "马芳领兵到朝门，好叫老身心内惊。",
      "text_length": 16
    },
    {
      "event_id": "01013005_e00038",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "万历"
      ],
      "text": "参见母后。",
      "text_length": 5
    },
    {
      "event_id": "01013005_e00039",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "我儿少礼，一旁坐下。",
      "text_length": 10
    },
    {
      "event_id": "01013005_e00040",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "万历"
      ],
      "text": "谢坐。启禀母后：今有马芳带领人马，反到皇城，如何是好？",
      "text_length": 27
    },
    {
      "event_id": "01013005_e00041",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "我把你这奴才。先前为娘怎样嘱咐于你，执意不听，至有今日，事已至此，快快宣亚父杨波上殿，一同定计便了。",
      "text_length": 50
    },
    {
      "event_id": "01013005_e00042",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "万历"
      ],
      "text": "宣亚父杨波上殿。",
      "text_length": 8
    },
    {
      "event_id": "01013005_e00043",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍"
      ],
      "text": "万岁有旨：亚父杨波上殿。",
      "text_length": 12
    },
    {
      "event_id": "01013005_e00044",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨波上。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00045",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "杨波"
      ],
      "text": "忽听内侍宣一声，午门外来了保国臣。迈步且把金殿进，国太宣臣为何情？",
      "text_length": 33
    },
    {
      "event_id": "01013005_e00046",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "臣杨波见驾，国太千岁。",
      "text_length": 11
    },
    {
      "event_id": "01013005_e00047",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "亚父平身，赐坐。",
      "text_length": 8
    },
    {
      "event_id": "01013005_e00048",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "谢坐。将臣宣上殿来，有何国事议论？",
      "text_length": 17
    },
    {
      "event_id": "01013005_e00049",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "今有你义子马芳，带领人马，反到皇城，要想一退兵之计。",
      "text_length": 26
    },
    {
      "event_id": "01013005_e00050",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "臣子马芳，性情高傲，武艺超群，老臣实无良计。",
      "text_length": 22
    },
    {
      "event_id": "01013005_e00051",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "国太"
      ],
      "text": "不好了。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00052",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "万历"
      ],
      "text": "听一言来心内惊，背转身来自思忖。走向前来礼恭敬，",
      "text_length": 24
    },
    {
      "event_id": "01013005_e00053",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "万历跪。",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00054",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "万历"
      ],
      "text": "还求亚父定计行。",
      "text_length": 8
    },
    {
      "event_id": "01013005_e00055",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "杨波"
      ],
      "text": "自从盘古到如今，哪有君王来跪臣。",
      "text_length": 16
    },
    {
      "event_id": "01013005_e00056",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨波"
      ],
      "text": "臣启万岁：事到如今，并无别计，请将臣捆绑城楼，项带剑枷，倘若马芳不肯退兵，即刻就将为臣斩首城楼，那马芳念在父子之情，或可收兵。",
      "text_length": 63
    },
    {
      "event_id": "01013005_e00057",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "万历",
        "国太"
      ],
      "text": "好，内侍带马敌楼。",
      "text_length": 9
    },
    {
      "event_id": "01013005_e00058",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "国太"
      ],
      "text": "内侍臣摆驾敌楼进，观看马芳发来的兵。",
      "text_length": 18
    },
    {
      "event_id": "01013005_e00059",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "马芳"
      ],
      "text": "探马儿不住待飞来报，",
      "text_length": 10
    },
    {
      "event_id": "01013005_e00060",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四大铠、马昆、马玉、二夫人、马芳同上。",
      "text_length": 23
    },
    {
      "event_id": "01013005_e00061",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "马芳"
      ],
      "text": "海岱门前撤吊桥。",
      "text_length": 8
    },
    {
      "event_id": "01013005_e00062",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四大铠、马昆、马玉、二夫人、马芳同大转场。",
      "text_length": 25
    },
    {
      "event_id": "01013005_e00063",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "马芳"
      ],
      "text": "未兴兵先放三声炮，",
      "text_length": 9
    },
    {
      "event_id": "01013005_e00064",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马芳转场。",
      "text_length": 5
    },
    {
      "event_id": "01013005_e00065",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "马芳"
      ],
      "text": "保驾的夫人赛凤摇。左右的前锋官把帅保，四杆彩旗脑后飘。马文成顾不得全忠孝，",
      "text_length": 37
    },
    {
      "event_id": "01013005_e00066",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "马芳"
      ],
      "text": "都只为我父坐监牢。此一去好比华容道，某学关公来挡曹。",
      "text_length": 26
    },
    {
      "event_id": "01013005_e00067",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "万历"
      ],
      "text": "旌旗不住城下飘，倒叫孤皇心内焦。低头便把将军叫，为何兴兵犯九朝？",
      "text_length": 32
    },
    {
      "event_id": "01013005_e00068",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "马芳"
      ],
      "text": "老王晏驾龙归沧，我朝出了奸贼李良。封条锁在宫门上，太后无故禁昭阳。多亏贾妃搬兵将，人马一齐到朝堂。到如今太平江山你安享，如何无故斩忠良？问得昏王无话讲，再与太后说端详：昏王信用贼奸党，你不念当年保国忠良。",
      "text_length": 102
    },
    {
      "event_id": "01013005_e00069",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 69,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "国太"
      ],
      "text": "亚父快把城楼上，速与哀家作主张。",
      "text_length": 16
    },
    {
      "event_id": "01013005_e00070",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 70,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "马芳"
      ],
      "text": "勒住丝缰来观定，城楼上只见老爹尊。项带剑枷身边捆，倒叫豪杰痛伤情。若叫我退兵不甚要紧，三件大事要应承。",
      "text_length": 51
    },
    {
      "event_id": "01013005_e00071",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 71,
      "seq_in_scene": 38,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "若叫我退兵，却也不难，必须要依我三件大事。",
      "text_length": 21
    },
    {
      "event_id": "01013005_e00072",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 72,
      "seq_in_scene": 39,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "万历"
      ],
      "text": "但不知哪三件？",
      "text_length": 7
    },
    {
      "event_id": "01013005_e00073",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 73,
      "seq_in_scene": 40,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "第一件，要将我父头上剑枷摘去，官复原职。",
      "text_length": 20
    },
    {
      "event_id": "01013005_e00074",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 74,
      "seq_in_scene": 41,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "万历"
      ],
      "text": "第二件？",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00075",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 75,
      "seq_in_scene": 42,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "第二件，榆林郡人马，听调不听宣。",
      "text_length": 16
    },
    {
      "event_id": "01013005_e00076",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 76,
      "seq_in_scene": 43,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "万历"
      ],
      "text": "这第三件？",
      "text_length": 5
    },
    {
      "event_id": "01013005_e00077",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 77,
      "seq_in_scene": 44,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "第三件，要将徐赞放出城来，任凭我父子发落。",
      "text_length": 21
    },
    {
      "event_id": "01013005_e00078",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 78,
      "seq_in_scene": 45,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "万历"
      ],
      "text": "三件大事件件依从，快快收兵。",
      "text_length": 14
    },
    {
      "event_id": "01013005_e00079",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 79,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马芳"
      ],
      "text": "谢万岁！",
      "text_length": 4
    },
    {
      "event_id": "01013005_e00080",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 80,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "马芳"
      ],
      "text": "三件大事皆应允，倒叫豪杰喜在心。人马莫回榆林郡，就在此地札大营。万岁准了臣的本，他是君来我是臣。万岁不准臣的本，人马杀上午朝门。三军与爷往前进，",
      "text_length": 72
    },
    {
      "event_id": "01013005_e00081",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 81,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四大铠、马昆、马玉、二夫人同下。",
      "text_length": 20
    },
    {
      "event_id": "01013005_e00082",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 82,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "马芳"
      ],
      "text": "且看那万岁爷怎样施行。",
      "text_length": 11
    },
    {
      "event_id": "01013005_e00083",
      "play_id": "01013005",
      "scene_id": "01013005_s03",
      "scene_no": 3,
      "seq_global": 83,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马芳下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}