  "events": [
    {
      "event_id": "70902126_e00001",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "程济"
      ],
      "text": "大师趱路！",
      "text_length": 5
    },
    {
      "event_id": "70902126_e00002",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "程济随建文帝同上。",
      "text_length": 9
    },
    {
      "event_id": "70902126_e00003",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "倾杯玉芙蓉",
      "speakers": [
        "建文帝"
      ],
      "text": "收拾起大地山河一担装，四大皆空相。历尽了渺渺程途，漠漠平林，垒垒高山，滚滚长江。",
      "text_length": 40
    },
    {
      "event_id": "70902126_e00004",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "我自吴江别了诸徒出门，师弟两人，一路登山涉水，夜宿晓行。一天心事，都付浮云，七尺形骸，甘为行脚。身似闲云野鹤，心同槁木死灰。",
      "text_length": 62
    },
    {
      "event_id": "70902126_e00005",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "倾杯玉芙蓉",
      "speakers": [
        "建文帝"
      ],
      "text": "但见那寒云惨雾和愁织，受不尽苦雨凄风带怨长。",
      "text_length": 22
    },
    {
      "event_id": "70902126_e00006",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "程徒。",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00007",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "大师。",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00008",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "前面是哪里了？",
      "text_length": 7
    },
    {
      "event_id": "70902126_e00009",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "是襄阳城了。",
      "text_length": 6
    },
    {
      "event_id": "70902126_e00010",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "嗄？喔唷！",
      "text_length": 5
    },
    {
      "event_id": "70902126_e00011",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "倾杯玉芙蓉",
      "speakers": [
        "建文帝"
      ],
      "text": "雄城壮，看江山无恙，谁识我一瓢一笠到襄阳。",
      "text_length": 21
    },
    {
      "event_id": "70902126_e00012",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "二旗牌"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00013",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "大师那边有许多车辆来了，我们且躲过一边。",
      "text_length": 20
    },
    {
      "event_id": "70902126_e00014",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "是，是，是，躲过一边。",
      "text_length": 11
    },
    {
      "event_id": "70902126_e00015",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "建文帝、程济同下。",
      "text_length": 9
    },
    {
      "event_id": "70902126_e00016",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "二旗牌"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00017",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二旗牌、二车夫同上。",
      "text_length": 10
    },
    {
      "event_id": "70902126_e00018",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同刷子芙蓉",
      "speakers": [
        "二旗牌",
        "二车夫"
      ],
      "text": "颈血溅干将，尸骸零落，暴露堪伤。又首级纷纷，驱驰枭示他方。",
      "text_length": 29
    },
    {
      "event_id": "70902126_e00019",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "旗牌甲"
      ],
      "text": "咳！想皇上杀了许多大臣，就在京城号令罢了，又听陈御史之言，凡系哪处人犯，发往本处号令，把头儿装了数十车辆，着咱们各处分解。这样苦差，好不耐烦！",
      "text_length": 71
    },
    {
      "event_id": "70902126_e00020",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二车夫"
      ],
      "text": "其实苦差！",
      "text_length": 5
    },
    {
      "event_id": "70902126_e00021",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "旗牌乙"
      ],
      "text": "嗳！不要说了，起来趱路。",
      "text_length": 12
    },
    {
      "event_id": "70902126_e00022",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同刷子芙蓉",
      "speakers": [
        "二旗牌",
        "二车夫"
      ],
      "text": "凄凉，叹魂魄空飘天际，叹骸骨谁埋土壤？",
      "text_length": 19
    },
    {
      "event_id": "70902126_e00023",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二旗牌"
      ],
      "text": "车夫们，把车辆打伙而行，不要催前落后。",
      "text_length": 19
    },
    {
      "event_id": "70902126_e00024",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二车夫"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "70902126_e00025",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二旗牌"
      ],
      "text": "咳！俺想那些众公卿，到今日里呵！",
      "text_length": 16
    },
    {
      "event_id": "70902126_e00026",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同刷子芙蓉",
      "speakers": [
        "二旗牌",
        "二车夫"
      ],
      "text": "堆车辆，看忠臣榜样，枉铮铮自夸鸣凤在朝阳。",
      "text_length": 21
    },
    {
      "event_id": "70902126_e00027",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二旗牌"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00028",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二旗牌、二车夫同下。建文帝、程济同上。",
      "text_length": 19
    },
    {
      "event_id": "70902126_e00029",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "吓！看车儿上都是我臣子的首级，好痛心也！",
      "text_length": 20
    },
    {
      "event_id": "70902126_e00030",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锦芙蓉",
      "speakers": [
        "建文帝"
      ],
      "text": "裂肝肠！痛诛夷盈朝丧亡，郊野血汤汤。好头颅如山，车载奔忙。又不是逆朱温清流被祸，早做了暴嬴秦儒类遭殃！",
      "text_length": 51
    },
    {
      "event_id": "70902126_e00031",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "大师，此乃臣子分内之事，不必悲伤，我们趱路要紧。",
      "text_length": 24
    },
    {
      "event_id": "70902126_e00032",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "咳！为我一人，连累万人性命，是我累及他们了！",
      "text_length": 22
    },
    {
      "event_id": "70902126_e00033",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "锦芙蓉",
      "speakers": [
        "建文帝"
      ],
      "text": "添悲怆，叹忠魂飘飏，羞杀我独存一息泣斜阳。",
      "text_length": 21
    },
    {
      "event_id": "70902126_e00034",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "女差"
      ],
      "text": "趱路！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00035",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "大师，那边许多犯妇来了，且闪过一边。",
      "text_length": 18
    },
    {
      "event_id": "70902126_e00036",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "是，是，是，闪过一边。",
      "text_length": 11
    },
    {
      "event_id": "70902126_e00037",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "程济、建文帝同下。女差上。",
      "text_length": 13
    },
    {
      "event_id": "70902126_e00038",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "女差"
      ],
      "text": "趱路！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00039",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众犯妇同上。",
      "text_length": 6
    },
    {
      "event_id": "70902126_e00040",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯妇"
      ],
      "text": "苦吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00041",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同雁芙蓉",
      "speakers": [
        "众犯妇"
      ],
      "text": "苍苍呼冤震响，流血泪千行万行。家抄命丧资倾荡，害妻孥徙他乡。",
      "text_length": 30
    },
    {
      "event_id": "70902126_e00042",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "女差徙"
      ],
      "text": "他乡，徙他乡，你们不曾看见那些夫人小姐？砍的砍，剐的剐，还要发教坊，赏象奴，不知死去了千千万万，哪在你们这几百个么？",
      "text_length": 58
    },
    {
      "event_id": "70902126_e00043",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同雁芙蓉",
      "speakers": [
        "众犯妇"
      ],
      "text": "啊呀苦吓！叹匹妇沟渠抛丧。",
      "text_length": 13
    },
    {
      "event_id": "70902126_e00044",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "expression",
      "mode_label": "同哭",
      "speakers": [
        "众犯妇"
      ],
      "text": "啊呀！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00045",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "女差"
      ],
      "text": "吓？怎么你们都睡倒了？",
      "text_length": 11
    },
    {
      "event_id": "70902126_e00046",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯妇"
      ],
      "text": "我们鞋弓袜小，走不动了。",
      "text_length": 12
    },
    {
      "event_id": "70902126_e00047",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "女差"
      ],
      "text": "鞋弓袜小走不动？嘿！谁教你们当初，把这个脚，裹得这样一兜兜的，要讨老公的喜欢！你瞧老娘的脚多大，要走一百，就是一百，要走二百，就是二百，好不爽快。快跟我起来走！",
      "text_length": 80
    },
    {
      "event_id": "70902126_e00048",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯妇"
      ],
      "text": "我们实是走不动了。",
      "text_length": 9
    },
    {
      "event_id": "70902126_e00049",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "女差"
      ],
      "text": "啊？你们不走，招老娘的打！",
      "text_length": 13
    },
    {
      "event_id": "70902126_e00050",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯妇"
      ],
      "text": "啊呀！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00051",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同雁芙蓉",
      "speakers": [
        "众犯妇"
      ],
      "text": "啊呀天吓！真悲怆，纵偷生肮脏，倒不如钢刀骈首丧云阳。",
      "text_length": 26
    },
    {
      "event_id": "70902126_e00052",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "女差"
      ],
      "text": "趱路！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00053",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯妇"
      ],
      "text": "苦吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00054",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "女差、众犯妇同下。建文帝、程济同上。",
      "text_length": 18
    },
    {
      "event_id": "70902126_e00055",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "好恼吓，好恼！纵然杀戮忠臣，与这些妇女们何干？",
      "text_length": 23
    },
    {
      "event_id": "70902126_e00056",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "小桃映芙蓉",
      "speakers": [
        "建文帝"
      ],
      "text": "惨听著哀号莽，惨睹著俘囚状。裙钗何罪遭一网？连抄十族新刑创。",
      "text_length": 30
    },
    {
      "event_id": "70902126_e00057",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "这也是人间浩劫，天降灾殃了。",
      "text_length": 14
    },
    {
      "event_id": "70902126_e00058",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "嗳！（小桃映芙蓉）纵然是天灾降，",
      "text_length": 16
    },
    {
      "event_id": "70902126_e00059",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "白消不得诛屠恁广。𠲔！（小桃映芙蓉）恨少个裸衣挝鼓骂渔阳。",
      "text_length": 29
    },
    {
      "event_id": "70902126_e00060",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "男差"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00061",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "大师，后面又有许多犯官来了，我们再躲过一边。",
      "text_length": 22
    },
    {
      "event_id": "70902126_e00062",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "是，是，是，再躲。",
      "text_length": 9
    },
    {
      "event_id": "70902126_e00063",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "建文帝、程济同下。男差、众犯官同上。",
      "text_length": 18
    },
    {
      "event_id": "70902126_e00064",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "男差"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00065",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同普天芙蓉",
      "speakers": [
        "众犯官"
      ],
      "text": "为邦家输忠谠，尽臣职忤强项。",
      "text_length": 14
    },
    {
      "event_id": "70902126_e00066",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "男差"
      ],
      "text": "只因你们要做忠臣，故此圣上特来奉请。",
      "text_length": 18
    },
    {
      "event_id": "70902126_e00067",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯官"
      ],
      "text": "我们久不为官，又来拿解，岂不冤枉？（同普天芙蓉）山林隐甘学佯狂，俘囚往誓死翱翔。",
      "text_length": 40
    },
    {
      "event_id": "70902126_e00068",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "男差"
      ],
      "text": "你们有话，到圣上面前去讲。",
      "text_length": 13
    },
    {
      "event_id": "70902126_e00069",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯官"
      ],
      "text": "呀呸！讲什么？要砍就砍罢了！",
      "text_length": 14
    },
    {
      "event_id": "70902126_e00070",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "犯官甲"
      ],
      "text": "吓，列位老先生。",
      "text_length": 8
    },
    {
      "event_id": "70902126_e00071",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯官"
      ],
      "text": "老先生。",
      "text_length": 4
    },
    {
      "event_id": "70902126_e00072",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "犯官甲"
      ],
      "text": "总是我们不是，当初无能御敌，直至纵虎归山，悔之晚矣！",
      "text_length": 26
    },
    {
      "event_id": "70902126_e00073",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众犯官"
      ],
      "text": "是吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00074",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "男差"
      ],
      "text": "好一班不知死活的囚徒！",
      "text_length": 11
    },
    {
      "event_id": "70902126_e00075",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "同普天芙蓉",
      "speakers": [
        "众犯官"
      ],
      "text": "空悲壮，负君恩浩荡，拼得个死为厉鬼学睢阳！",
      "text_length": 21
    },
    {
      "event_id": "70902126_e00076",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "男差"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00077",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "男差、众犯官同下。建文帝、程济同上。",
      "text_length": 18
    },
    {
      "event_id": "70902126_e00078",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "罢了吓罢了。我只道独诛戮朝中臣宰，不想又捕捉那些弃职官员。正人君子吓，定无噍类矣！（朱奴插芙蓉）眼见得普天受枉，眼见得忠良尽丧。弥天怨气冲千丈，张毒焰古来无两。程济",
      "text_length": 82
    },
    {
      "event_id": "70902126_e00079",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "大师，天色已晚，趱路要紧。",
      "text_length": 13
    },
    {
      "event_id": "70902126_e00080",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "咳！我想做忠臣的到这个地位，那些读书的，还要做什么官？",
      "text_length": 27
    },
    {
      "event_id": "70902126_e00081",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "朱奴插芙蓉我言非戆劝冠裳罢想，倒不如躬耕陇亩卧南阳。程济",
      "text_length": 28
    },
    {
      "event_id": "70902126_e00082",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "此处湖广要道，京中来往公干甚多，倘有识认，祸生不测。",
      "text_length": 26
    },
    {
      "event_id": "70902126_e00083",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "阿呀！这便怎么处？",
      "text_length": 9
    },
    {
      "event_id": "70902126_e00084",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "不妨。我们且赶到武冈州，速往贵州，直至云南，深山居住，方可安身。",
      "text_length": 32
    },
    {
      "event_id": "70902126_e00085",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "如此快走。",
      "text_length": 5
    },
    {
      "event_id": "70902126_e00086",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "大师请。",
      "text_length": 4
    },
    {
      "event_id": "70902126_e00087",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "建文帝"
      ],
      "text": "路迢迢，心怏怏。",
      "text_length": 8
    },
    {
      "event_id": "70902126_e00088",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "程济"
      ],
      "text": "何处得稳宿梧枝上？",
      "text_length": 9
    },
    {
      "event_id": "70902126_e00089",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "钟声。",
      "text_length": 3
    },
    {
      "event_id": "70902126_e00090",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "咦？程徒，景阳钟鸣了！",
      "text_length": 11
    },
    {
      "event_id": "70902126_e00091",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "吓，大师，此乃野寺晚钟，非景阳钟也。",
      "text_length": 18
    },
    {
      "event_id": "70902126_e00092",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "嗄！咳！（尾声）错听了野寺钟鸣误景阳。",
      "text_length": 19
    },
    {
      "event_id": "70902126_e00093",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程济"
      ],
      "text": "大师趱路。",
      "text_length": 5
    },
    {
      "event_id": "70902126_e00094",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
      "scene_no": 1,
      "seq_global": 94,
      "seq_in_scene": 94,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "建文帝"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "70902126_e00095",
      "play_id": "70902126",
      "scene_id": "70902126_s01",
