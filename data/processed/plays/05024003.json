  "events": [
    {
      "event_id": "05024003_e00001",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手、董卓同上。",
      "text_length": 9
    },
    {
      "event_id": "05024003_e00002",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "董卓"
      ],
      "text": "可恨那黄巾贼无故反上，老夫我兴人马抵却四方。今才得太平世君民同享，挟天子迁长安执掌朝纲。",
      "text_length": 44
    },
    {
      "event_id": "05024003_e00003",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "老夫董卓，汉室为臣。自幼生长羌胡，身居前将军之职。因宦官专权，混乱朝政，何进召俺入朝，废了少主，奉陈留王为帝，迁入长安，恐人心不服，在这长安城外，高筑郿坞，囤粮静观天下事，老夫坐待其变，只是美中不足语难言。咳！",
      "text_length": 105
    },
    {
      "event_id": "05024003_e00004",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李儒上。",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00005",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "太师这几日闷闷不乐，必是想个绝妙女子，陪老太师。",
      "text_length": 24
    },
    {
      "event_id": "05024003_e00006",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "你何以知道老夫心事。哼哼哼！哪里？",
      "text_length": 17
    },
    {
      "event_id": "05024003_e00007",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "三下锣。",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00008",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "在哪里？",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00009",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "就是前将军皇甫规的夫人。",
      "text_length": 12
    },
    {
      "event_id": "05024003_e00010",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "咳，她是朝廷命妇，岂肯嫁我？",
      "text_length": 14
    },
    {
      "event_id": "05024003_e00011",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "这，小官凭三寸不烂之舌，劝说与她，她若不从，我以利害动之。",
      "text_length": 29
    },
    {
      "event_id": "05024003_e00012",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "金银与你。若能成就，必有重赏。名车一乘，彩锦百端，黄金千两，权作聘礼。",
      "text_length": 35
    },
    {
      "event_id": "05024003_e00013",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "明日就去。",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00014",
      "play_id": "05024003",
      "scene_id": "05024003_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "董卓、李儒同下。",
      "text_length": 8
    },
    {
      "event_id": "05024003_e00015",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "皇甫夫人上。",
      "text_length": 6
    },
    {
      "event_id": "05024003_e00016",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "国破家亡，恨奸雄，混乱朝纲。",
      "text_length": 14
    },
    {
      "event_id": "05024003_e00017",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "奴家，小字季贞。先夫皇甫规，汉室为臣，文武兼备，封侯拜爵，坚辞不受。出征西域，不幸忧劳病故，因此董卓扶幼主迁长安。先夫若在，岂容豺狼满志。咳！未亡人乃一柔弱女子，无尺寸之权。忧国忧家，好不愁闷人也！",
      "text_length": 99
    },
    {
      "event_id": "05024003_e00018",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "痛先夫征西域中途命丧，丢下了未亡人国破家亡。长安城遭兵乱终日掠抢，开门户难躲乱何日安康？",
      "text_length": 44
    },
    {
      "event_id": "05024003_e00019",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子上。",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00020",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "启夫人：大事不好了！",
      "text_length": 10
    },
    {
      "event_id": "05024003_e00021",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00022",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "外面来一位官儿，带领家童、聘礼、小轿，说董卓太师差来娶夫人。请躲避躲避。",
      "text_length": 36
    },
    {
      "event_id": "05024003_e00023",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "怎么讲？",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00024",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "躲避躲避。",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00025",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "05024003_e00026",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "听一言不由我动魄惊心，",
      "text_length": 11
    },
    {
      "event_id": "05024003_e00027",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "05024003_e00028",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "这奸雄无故地欺压良民。痛先夫去世早留下遗恨，如不然寻一个玉碎金身。",
      "text_length": 33
    },
    {
      "event_id": "05024003_e00029",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子下，院子拦李儒同上。",
      "text_length": 12
    },
    {
      "event_id": "05024003_e00030",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "来此已是。站住，门上哪位听事？",
      "text_length": 15
    },
    {
      "event_id": "05024003_e00031",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "有人到此，夫人回避。",
      "text_length": 10
    },
    {
      "event_id": "05024003_e00032",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "不必回避，看是何人，叫他进来。",
      "text_length": 15
    },
    {
      "event_id": "05024003_e00033",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "是。呵，李老爷。",
      "text_length": 8
    },
    {
      "event_id": "05024003_e00034",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "不错，说我要见。",
      "text_length": 8
    },
    {
      "event_id": "05024003_e00035",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "夫人知道了，请你进去。",
      "text_length": 11
    },
    {
      "event_id": "05024003_e00036",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "哦，请我进去。哦，此事有个八九。夫人哪里？夫人哪里？咳，小官有礼。",
      "text_length": 33
    },
    {
      "event_id": "05024003_e00037",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "少礼请坐。",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00038",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "夫人恭喜。",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00039",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "呵，先夫尸骨未寒，喜从何来？",
      "text_length": 14
    },
    {
      "event_id": "05024003_e00040",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "这，董太师久闻夫人才德，命小官请夫人同享荣华。",
      "text_length": 23
    },
    {
      "event_id": "05024003_e00041",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "住口。你可知夫人甚等样人？岂肯受老贼凌辱。快快出去，免讨没趣。",
      "text_length": 31
    },
    {
      "event_id": "05024003_e00042",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子推李儒。",
      "text_length": 6
    },
    {
      "event_id": "05024003_e00043",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "不用忙，不用忙，还有话说。你可知太师威严厉害么？",
      "text_length": 24
    },
    {
      "event_id": "05024003_e00044",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "这个？好好好，我随你前去呵。",
      "text_length": 14
    },
    {
      "event_id": "05024003_e00045",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "夫人呵！",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00046",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "不必如此，我此去凶多吉少，你们逃往洛阳去罢！",
      "text_length": 22
    },
    {
      "event_id": "05024003_e00047",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "这家呢？",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00048",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "这个，我也顾不得了！",
      "text_length": 10
    },
    {
      "event_id": "05024003_e00049",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "闭门坐不想祸从天降，",
      "text_length": 10
    },
    {
      "event_id": "05024003_e00050",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "皇甫夫人上轿，下。",
      "text_length": 9
    },
    {
      "event_id": "05024003_e00051",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李儒"
      ],
      "text": "这件事功劳簿又多一样。",
      "text_length": 11
    },
    {
      "event_id": "05024003_e00052",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "哎呵！",
      "text_length": 3
    },
    {
      "event_id": "05024003_e00053",
      "play_id": "05024003",
      "scene_id": "05024003_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00054",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手、董卓同上。",
      "text_length": 9
    },
    {
      "event_id": "05024003_e00055",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "董卓"
      ],
      "text": "闭眼杀人睁眼笑，全凭机谋压群豪。",
      "text_length": 16
    },
    {
      "event_id": "05024003_e00056",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李儒、皇甫夫人同上。",
      "text_length": 10
    },
    {
      "event_id": "05024003_e00057",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "太师花轿到。",
      "text_length": 6
    },
    {
      "event_id": "05024003_e00058",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "好好，真会办事。抬上堂来，后面歇息。",
      "text_length": 18
    },
    {
      "event_id": "05024003_e00059",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李儒"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "05024003_e00060",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李儒下。皇甫夫人下轿。",
      "text_length": 11
    },
    {
      "event_id": "05024003_e00061",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "是呵夫人。",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00062",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "呵啥。",
      "text_length": 3
    },
    {
      "event_id": "05024003_e00063",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "夫人请坐。",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00064",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "呵，老太师将未亡人传来何事？",
      "text_length": 14
    },
    {
      "event_id": "05024003_e00065",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "呵夫人，老夫久闻夫人才貌，老夫不才，要烦夫人安领诸姬，夫人谅无推辞了？",
      "text_length": 35
    },
    {
      "event_id": "05024003_e00066",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "太师之言差了，先夫坟土未干，未亡人焉能丧节？天下美女甚多，何要我这不祥之妇，毁人名节，太师岂不被天下人耻笑。",
      "text_length": 54
    },
    {
      "event_id": "05024003_e00067",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "这，老夫位高极品，何人敢笑。夫人说下才是。",
      "text_length": 21
    },
    {
      "event_id": "05024003_e00068",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "这，老太师，老太师与先夫也是汉家臣子，功在社稷，曾与太师并肩事主，有先夫情份，怜念孤苦，何忍夺故臣之妻！老太师开恩释放，恩高莫大！",
      "text_length": 65
    },
    {
      "event_id": "05024003_e00069",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 69,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "老夫威令四方，难道不能行于一妇人么？",
      "text_length": 18
    },
    {
      "event_id": "05024003_e00070",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 70,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "皇甫夫人立。",
      "text_length": 6
    },
    {
      "event_id": "05024003_e00071",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 71,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "老贼老贼，尔乃羌胡之继，侥幸立功，朝廷待尔不薄，不思感恩图报，狐假狼虎之威，竟谋篡大位，劫杀人民。恨不得将你碎尸万段，为天下人报仇。我是甚等样人，你敢行非礼！",
      "text_length": 79
    },
    {
      "event_id": "05024003_e00072",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 72,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "你好比是我笼中之鸟，怎敢违抗。",
      "text_length": 15
    },
    {
      "event_id": "05024003_e00073",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 73,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "哼哼哼！",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00074",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 74,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "你为何发笑？",
      "text_length": 6
    },
    {
      "event_id": "05024003_e00075",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 75,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "你道我不能违抗与你，可叹可叹！",
      "text_length": 15
    },
    {
      "event_id": "05024003_e00076",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 76,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "叹者何来？",
      "text_length": 5
    },
    {
      "event_id": "05024003_e00077",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 77,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "想汉高祖灭秦破楚，创业艰难，传二十四帝，传至桓灵，桓灵无道，宠信宦官。咳！这也是天意为然，非人所为。可恨何进无谋，以诏引你这老贼进京，你就该力图报效，秉正忠心，匡扶汉室，才是你为人臣之正道。怎么你废幼帝挟少主，焚宫阙，迁百姓，荼毒生灵。咳！你这老贼，自作由你将来自受。心怀篡位，何以为忠？挟迁百姓，何以为信？夺人妻女，何以为仁？劫杀百姓，何以为义？似你这样不忠、不信、不仁、不义，真正是人面兽心，衣冠禽兽！何以今日又来夺故旧之寡妇？我乃女流，还有一点烈性，今日之死，图一个节烈流传！惜乎惜乎！",
      "text_length": 246
    },
    {
      "event_id": "05024003_e00078",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 78,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "未看到你这老贼怎样结果，生不能吃你肉，死后也要追你之魂。汉桓灵任宦官弄权国丧，容何进让袁绍私招豺狼。",
      "text_length": 50
    },
    {
      "event_id": "05024003_e00079",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 79,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "住口！",
      "text_length": 3
    },
    {
      "event_id": "05024003_e00080",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 80,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "董卓"
      ],
      "text": "若非我除宦官汉室早丧，从了我不久要身为皇娘。",
      "text_length": 22
    },
    {
      "event_id": "05024003_e00081",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 81,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "弘农皇何太后无辜命丧，挟天子迁百姓心如豺狼。",
      "text_length": 22
    },
    {
      "event_id": "05024003_e00082",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 82,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "董卓"
      ],
      "text": "你哪知汉宦灭董氏兴旺，出此言你不怕去见阎王？",
      "text_length": 22
    },
    {
      "event_id": "05024003_e00083",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 83,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "我纵死也图个后人敬仰，",
      "text_length": 11
    },
    {
      "event_id": "05024003_e00084",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 84,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "董卓"
      ],
      "text": "我劝你顺我者生逆我者亡。",
      "text_length": 12
    },
    {
      "event_id": "05024003_e00085",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 85,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "家凤凰怎入你乌鸦群党，",
      "text_length": 11
    },
    {
      "event_id": "05024003_e00086",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 86,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "董卓"
      ],
      "text": "你好比笼中鸟虎落平阳。",
      "text_length": 11
    },
    {
      "event_id": "05024003_e00087",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 87,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "喂呀！",
      "text_length": 3
    },
    {
      "event_id": "05024003_e00088",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 88,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "贼不念旧言恩禽兽一样，放声哭日月无光。我此刻拚一死向前去闯，",
      "text_length": 30
    },
    {
      "event_id": "05024003_e00089",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 89,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "先夫呵！",
      "text_length": 4
    },
    {
      "event_id": "05024003_e00090",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 90,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "你就不惜命么？",
      "text_length": 7
    },
    {
      "event_id": "05024003_e00091",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 91,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "皇甫夫人"
      ],
      "text": "纵死在九泉之下姓名皆香。",
      "text_length": 12
    },
    {
      "event_id": "05024003_e00092",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 92,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "这贱人说此言泼口狂妄，把性命当儿戏付与汪洋。叫人来你与我齐动杆棒，打死她我心中才能欢畅。",
      "text_length": 44
    },
    {
      "event_id": "05024003_e00093",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 93,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手同打皇甫夫人。",
      "text_length": 10
    },
    {
      "event_id": "05024003_e00094",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 94,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董卓"
      ],
      "text": "咳咳！拖过去！",
      "text_length": 7
    },
    {
      "event_id": "05024003_e00095",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 95,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "董卓"
      ],
      "text": "贱人作事忒猖狂，哪有福分做昭阳。明天差人去寻访，访得英凰伴爷王。",
      "text_length": 32
    },
    {
      "event_id": "05024003_e00096",
      "play_id": "05024003",
      "scene_id": "05024003_s03",
      "scene_no": 3,
      "seq_global": 96,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "董卓、四下手同下。",
      "text_length": 9
    }
  ],
  "roles_inferred": true
}