      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨戬"
      ],
      "text": "众位师兄请了！",
      "text_length": 7
    },
    {
      "event_id": "02001019_e00012",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 12,
