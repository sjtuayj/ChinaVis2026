    },
    {
      "event_id": "02001019_e00048",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "姜子牙"
      ],
      "text": "周室兴成汤败刀兵不让，吾主爷行仁义兵伐商汤。但愿得干戈静万民欢畅，享尧天乐舜日天下安康。",
      "text_length": 44
    },
    {
      "event_id": "02001019_e00049",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "龙须虎"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001019_e00050",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姜子牙"
      ],
      "text": "雷震子。",
      "text_length": 4
    },
    {
      "event_id": "02001019_e00051",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "雷震子"
      ],
      "text": "在。",
      "text_length": 2
    },
    {
      "event_id": "02001019_e00052",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "姜子牙"
      ],
      "text": "黄金棍重如山奥妙多广，费辛劳兴周室保定家邦。兄与弟弟和兄富贵安享，功劳薄名不朽高载清香。众弟子传吾令回归营帐，",
      "text_length": 55
    },
    {
      "event_id": "02001019_e00053",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "杨戬",
        "韦陀",
        "杨任",
        "龙须虎",
        "金吒",
        "木吒",
        "哪吒",
        "雷震子"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001019_e00054",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "姜子牙"
      ],
      "text": "这一阵使商纣国破家亡。",
      "text_length": 11
    },
    {
      "event_id": "02001019_e00055",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姜子牙"
      ],
      "text": "众将官起兵前往。",
      "text_length": 8
    },
    {
      "event_id": "02001019_e00056",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    },
    {
      "event_id": "02001019_e00057",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 1,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四蓝文堂、四大铠、余达、余兆、余光、余先、余德同上，同站门。〖牌子〗。旗夫、余化龙同上。",
      "text_length": 44
    },
    {
      "event_id": "02001019_e00058",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 2,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "余化龙"
      ],
      "text": "某，余化龙。前者用瘟药将姜子牙人马迷倒，数日不见动静，适才探马报道，姜尚复又兴兵前来，岂肯容他猖狂。众儿郎！城楼去者！（〖牌子〗。余化龙上城。姜子牙、杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子、四文堂、四大铠、四上手同上，同斜一字。）",
      "text_length": 121
    },
    {
      "event_id": "02001019_e00059",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "杨戬",
        "韦陀",
        "杨任",
        "龙须虎",
        "金吒",
        "木吒",
        "哪吒",
        "雷震子"
      ],
      "text": "来此已是临潼关。",
      "text_length": 8
    },
    {
      "event_id": "02001019_e00060",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姜子牙"
      ],
      "text": "安营下寨。",
      "text_length": 5
    },
    {
      "event_id": "02001019_e00061",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "杨戬",
        "韦陀",
        "杨任",
        "龙须虎",
        "金吒",
        "木吒",
        "哪吒",
        "雷震子"
      ],
      "text": "安营下寨。哦。",
      "text_length": 7
    },
    {
      "event_id": "02001019_e00062",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "姜子牙、杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子、四文堂、四大铠、四上手同下。",
      "text_length": 44
    },
    {
      "event_id": "02001019_e00063",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "余化龙"
      ],
      "text": "啊，儿啊，看姜尚人马犹如潮水一般，如何是好？",
      "text_length": 22
    },
    {
      "event_id": "02001019_e00064",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "余达"
      ],
      "text": "啊，爹爹，想是他国出了能人，解开瘟药也是有的。你我父子领兵出城与他决一死战。",
      "text_length": 38
    },
    {
      "event_id": "02001019_e00065",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "余化龙"
      ],
      "text": "好啊！众将官，开城迎敌者。（四蓝文堂、四大铠、余达、余兆、余光、余先、余德、余化龙同出城。姜子牙、杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子、四文堂、四大铠、四上手同上，会阵。）",
      "text_length": 93
    },
    {
      "event_id": "02001019_e00066",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "余化龙"
      ],
      "text": "呔！马前来的敢是姜尚？",
      "text_length": 11
    },
    {
      "event_id": "02001019_e00067",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姜子牙"
      ],
      "text": "唗！胆大余化龙，前者暗用瘟药将我军迷倒，今日整齐兵将与你分个胜负。",
      "text_length": 33
    },
    {
      "event_id": "02001019_e00068",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "余化龙"
      ],
      "text": "姜尚，劝尔等早些下马投降，少时被擒，悔之晚矣！",
      "text_length": 23
    },
    {
      "event_id": "02001019_e00069",
      "play_id": "02001019",
      "scene_id": "02001019_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姜子牙"
      ],
      "text": "众弟子与我杀！（四蓝文堂、四大铠、余达、余兆、余光、余先、余德、姜子牙、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子、四文堂、四大铠、四上手自两边分下，余化龙、杨戬对刀双下。）（金吒、木吒、哪吒、雷震子与余兆、余光、余先、余德打单对，同下。余化龙上，打败杨戬下，杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同败下。）",
      "text_length": 161
    },
    {
      "event_id": "02001019_e00070",
      "play_id": "02001019",
      "scene_id": "02001019_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 1,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨戬、韦陀、杨任、龙须虎、金吒、木吒、哪吒、雷震子同上，同挖门。",
      "text_length": 32
    },
