      "speakers": [
        "哪吒"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001019_e00046",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姜子牙"
      ],
      "text": "龙须虎。",
