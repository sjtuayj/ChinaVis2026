        "木吒"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001019_e00042",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 42,
