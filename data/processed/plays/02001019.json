      "text_length": 2
    },
    {
      "event_id": "02001019_e00040",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "姜子牙"
      ],
      "text": "兄刚强弟好汉血气勇壮，遇见那余化龙谨慎提防。与周室建奇功谁人不仰，方显你将门子非比寻常。",
      "text_length": 44
    },
    {
      "event_id": "02001019_e00041",
      "play_id": "02001019",
      "scene_id": "02001019_s01",
      "scene_no": 1,
      "seq_global": 41,
