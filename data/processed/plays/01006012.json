      ],
      "text": "妈儿娘后面吃饭。",
      "text_length": 8
    },
    {
      "event_id": "01006012_e00020",
      "play_id": "01006012",
      "scene_id": "01006012_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
