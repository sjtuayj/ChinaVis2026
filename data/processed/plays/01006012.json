      "mode_label": "stage_direction",
      "speakers": [],
      "text": "华云、花妈妈、嫂子、刘杭燕同上。华云哭。",
      "text_length": 20
    },
    {
      "event_id": "01006012_e00017",
      "play_id": "01006012",
      "scene_id": "01006012_s02",
      "scene_no": 2,
