  "events": [
    {
      "event_id": "90000004_e00001",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "崔莺莺上。",
      "text_length": 5
    },
    {
      "event_id": "90000004_e00002",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "崔莺莺"
      ],
      "text": "无端的月不圆好事难成，为什么老娘亲言而无信？虽然是亲生母决无歹心，全不想女儿家怎样为人。",
      "text_length": 44
    },
    {
      "event_id": "90000004_e00003",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "奴家崔莺莺。只因爹爹亡故，同母亲扶柩回乡，路过河中府，就在这普救寺内担搁。昨日在经堂超度爹爹，不想强徒孙飞虎要强抢于我，多亏了张相公搭救。是我母亲有言在先：谁能解围，就将我的终身许配于他，事后母亲忽然反悔。啊母亲啊母亲，你如此行事叫女儿如何为人？天已不早，待我梳妆。红娘去了半天，为什么未见到来？",
      "text_length": 148
    },
    {
      "event_id": "90000004_e00004",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "红娘上。",
      "text_length": 4
    },
    {
      "event_id": "90000004_e00005",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "红娘"
      ],
      "text": "为了抱不平，替人送书信。",
      "text_length": 12
    },
    {
      "event_id": "90000004_e00006",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "啊小姐！",
      "text_length": 4
    },
    {
      "event_id": "90000004_e00007",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "你为何去了半天呀？",
      "text_length": 9
    },
    {
      "event_id": "90000004_e00008",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "小姐，这两天我忙得很呢！",
      "text_length": 12
    },
    {
      "event_id": "90000004_e00009",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "啊？你忙些什么？",
      "text_length": 8
    },
    {
      "event_id": "90000004_e00010",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "没有什么。啊小姐，你可记得老夫人请客的那一天？",
      "text_length": 23
    },
    {
      "event_id": "90000004_e00011",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "记得便怎样？",
      "text_length": 6
    },
    {
      "event_id": "90000004_e00012",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "老夫人说：儿啊！",
      "text_length": 8
    },
    {
      "event_id": "90000004_e00013",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "唉！怎样讲话？",
      "text_length": 7
    },
    {
      "event_id": "90000004_e00014",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "我是学老夫人说。老夫人说：儿啊，你上前斟上一杯酒。未了又说一声：儿呀！上前呼一声哥哥！小姐，你晓得那个哥哥有多么难受啊！",
      "text_length": 60
    },
    {
      "event_id": "90000004_e00015",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "这样的胡说我就要打！",
      "text_length": 10
    },
    {
      "event_id": "90000004_e00016",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "小姐，你可怜可怜哥哥吧！",
      "text_length": 12
    },
    {
      "event_id": "90000004_e00017",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "起来替我梳妆。",
      "text_length": 7
    },
    {
      "event_id": "90000004_e00018",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "来了！",
      "text_length": 3
    },
    {
      "event_id": "90000004_e00019",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "崔莺莺"
      ],
      "text": "我母亲为私心悔却婚姻，全不想女儿家难以为人。若不是那张生一封书信，我一命为贞节早赴幽冥。思起了终身事珠泪滚滚，",
      "text_length": 55
    },
    {
      "event_id": "90000004_e00020",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "崔莺莺"
      ],
      "text": "好似那云中月难见光明。",
      "text_length": 11
    },
    {
      "event_id": "90000004_e00021",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "啊红娘，你手拿何物？",
      "text_length": 10
    },
    {
      "event_id": "90000004_e00022",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "没有什么。",
      "text_length": 5
    },
    {
      "event_id": "90000004_e00023",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "哪个叫你拿来？",
      "text_length": 7
    },
    {
      "event_id": "90000004_e00024",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "就是“二十三岁未曾娶妻”的那个人叫我送来的，小姐请看。",
      "text_length": 27
    },
    {
      "event_id": "90000004_e00025",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "啊红娘，我乃是相国千金，虽然我母亲亏对于他，也不能拿这样的书信戏弄于我，你对他言讲：倘若禀告老夫人定责不饶，还要打死你这小贱人！",
      "text_length": 64
    },
    {
      "event_id": "90000004_e00026",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "那么待我去禀告老夫人，打死这小奴才。",
      "text_length": 18
    },
    {
      "event_id": "90000004_e00027",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "红娘我饶了你，你也饶了他吧。",
      "text_length": 14
    },
    {
      "event_id": "90000004_e00028",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "小姐“他”是谁啊？谁又是“他”啊？小姐你快些写回信吧。",
      "text_length": 27
    },
    {
      "event_id": "90000004_e00029",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "与我溶墨。你对张生言讲：我与他写信也不过是问候而已，下次再来书信禀告老夫人，定要重责不饶！就是你也要责打！",
      "text_length": 53
    },
    {
      "event_id": "90000004_e00030",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "小姐，想人家张先生乃是一片好心，你要是不愿意的话就罢了，你干嘛写这样的信给他，这不是害了他张先生吧！这封信啊，我可不给您送去。",
      "text_length": 63
    },
    {
      "event_id": "90000004_e00031",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崔莺莺"
      ],
      "text": "小贱子好不知分晓！",
      "text_length": 9
    },
    {
      "event_id": "90000004_e00032",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "崔莺莺丢信，下。",
      "text_length": 8
    },
    {
      "event_id": "90000004_e00033",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "四平调",
      "speakers": [
        "红娘"
      ],
      "text": "看小姐做出来许多破绽，对红娘偏用着要巧语花言。本来是千金体大家风范，最可怜背人处红泪偷弹。盼佳期数不清黄昏清旦，还有个痴情种忘废寝餐。非是我愿意儿传书递简，有情人成眷属不羡神仙。",
      "text_length": 89
    },
    {
      "event_id": "90000004_e00034",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "张相公开门。",
      "text_length": 6
    },
    {
      "event_id": "90000004_e00035",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "张珙"
      ],
      "text": "来了！",
      "text_length": 3
    },
    {
      "event_id": "90000004_e00036",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张珙上。",
      "text_length": 4
    },
    {
      "event_id": "90000004_e00037",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "张珙"
      ],
      "text": "听叫门想必是红娘来临，但愿得结鸾俦良缘早定。",
      "text_length": 22
    },
    {
      "event_id": "90000004_e00038",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "红娘姐你来了，小姐怎样言讲？可有书信到来？",
      "text_length": 21
    },
    {
      "event_id": "90000004_e00039",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "小姐看了那封书信就要将我责打，我苦苦地哀求才饶恕了我，叫你妈妈的用功念书，下次再要将书信戏弄于她，禀告老夫人，打死你这小奴才！",
      "text_length": 63
    },
    {
      "event_id": "90000004_e00040",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "红娘姐你要救我一救啊！",
      "text_length": 11
    },
    {
      "event_id": "90000004_e00041",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "我救不了你。",
      "text_length": 6
    },
    {
      "event_id": "90000004_e00042",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "噫！这是小姐的书信，待我三跪九叩香案迎接。哈哈哈……",
      "text_length": 26
    },
    {
      "event_id": "90000004_e00043",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "你打了半天的哈哈，怎么回事啊？",
      "text_length": 15
    },
    {
      "event_id": "90000004_e00044",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "红娘姐，这是小姐做的一首好诗啊！",
      "text_length": 16
    },
    {
      "event_id": "90000004_e00045",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "什么好诗啊？",
      "text_length": 6
    },
    {
      "event_id": "90000004_e00046",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "待我念于你听：",
      "text_length": 7
    },
    {
      "event_id": "90000004_e00047",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张珙"
      ],
      "text": "“待月西厢下，迎风户半开。佛墙花影动，疑是玉人来。”",
      "text_length": 26
    },
    {
      "event_id": "90000004_e00048",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "啊好好好！这首诗做得真不错。",
      "text_length": 14
    },
    {
      "event_id": "90000004_e00049",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "啊红娘姐，你也明白么？",
      "text_length": 11
    },
    {
      "event_id": "90000004_e00050",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "文诌诌的，从头到尾我一句都不懂的，你讲给我听听吧。",
      "text_length": 25
    },
    {
      "event_id": "90000004_e00051",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "怎么你要我讲与你听？好！“待月西厢下”就是待月儿上升的时候。",
      "text_length": 30
    },
    {
      "event_id": "90000004_e00052",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "噢，就是月亮上天的时候。张先生，要是阴天没月亮呢？",
      "text_length": 25
    },
    {
      "event_id": "90000004_e00053",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "唉，此乃是一句比喻呀。",
      "text_length": 11
    },
    {
      "event_id": "90000004_e00054",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "哦，是比喻，那么你往下讲。",
      "text_length": 13
    },
    {
      "event_id": "90000004_e00055",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "“迎风户半开”就是门儿被风这么一吹么，开了半扇。",
      "text_length": 24
    },
    {
      "event_id": "90000004_e00056",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "噢，门儿被风这么一吹，开了半扇儿。张先生，那么它另外半扇怎么不开啊？",
      "text_length": 34
    },
    {
      "event_id": "90000004_e00057",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "这又是一句比喻呀。",
      "text_length": 9
    },
    {
      "event_id": "90000004_e00058",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "又是一句比喻，你往下讲。",
      "text_length": 12
    },
    {
      "event_id": "90000004_e00059",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "“佛墙花影动”就是要跳墙进去与你们小姐相会啊！",
      "text_length": 23
    },
    {
      "event_id": "90000004_e00060",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "怎么？我们小姐叫你跳墙相会吗？你说我们小姐多坏啊，表面上庄庄重重的，私底下约人家花园相会。",
      "text_length": 45
    },
    {
      "event_id": "90000004_e00061",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "“疑是玉人来”哦哦！！",
      "text_length": 11
    },
    {
      "event_id": "90000004_e00062",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "张先生，谁是玉人啊？玉人又是谁呢？",
      "text_length": 17
    },
    {
      "event_id": "90000004_e00063",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "就是小生我嘛！",
      "text_length": 7
    },
    {
      "event_id": "90000004_e00064",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "啊哟，敢情你是个玉人啊，我们小姐不是叫你跳墙进去吗？要是把你这个玉人摔碎了，可怎么好啊？啊，张先生，既然我们小姐约你今晚跳墙相会，那么你就跳吧。",
      "text_length": 72
    },
    {
      "event_id": "90000004_e00065",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "好便好，只是花园院墙甚高，叫我怎么跳得过去啊？",
      "text_length": 23
    },
    {
      "event_id": "90000004_e00066",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "你这个人哪连狗都不如！",
      "text_length": 11
    },
    {
      "event_id": "90000004_e00067",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "不要骂人哪！",
      "text_length": 6
    },
    {
      "event_id": "90000004_e00068",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "红娘"
      ],
      "text": "你可晓得狗急跳墙，何况人乎？",
      "text_length": 14
    },
    {
      "event_id": "90000004_e00069",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "红娘下。",
      "text_length": 4
    },
    {
      "event_id": "90000004_e00070",
      "play_id": "90000004",
      "scene_id": "90000004_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张珙"
      ],
      "text": "啊呀，这个丫头厉害得很哪！",
      "text_length": 13
    },
    {
      "event_id": "90000004_e00071",
      "play_id": "90000004",
