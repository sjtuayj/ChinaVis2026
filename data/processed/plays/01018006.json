  "events": [
    {
      "event_id": "01018006_e00001",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "崇祯、王承恩同上。",
      "text_length": 9
    },
    {
      "event_id": "01018006_e00002",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "崇祯"
      ],
      "text": "朝王殿看罢了排王赞，眼含龙泪走进宫。",
      "text_length": 18
    },
    {
      "event_id": "01018006_e00003",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太子、公主、周后同上。",
      "text_length": 11
    },
    {
      "event_id": "01018006_e00004",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周后"
      ],
      "text": "臣妾接驾。",
      "text_length": 5
    },
    {
      "event_id": "01018006_e00005",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "崇祯"
      ],
      "text": "叫声梓橦事不好，闯贼不住把城攻。",
      "text_length": 16
    },
    {
      "event_id": "01018006_e00006",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周后"
      ],
      "text": "那王忠呢？",
      "text_length": 5
    },
    {
      "event_id": "01018006_e00007",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "崇祯"
      ],
      "text": "算来总是朕的错，决不该用了贼王忠。他通了闯贼将城献，堪堪攻破彰仪门。",
      "text_length": 34
    },
    {
      "event_id": "01018006_e00008",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "周后"
      ],
      "text": "既然贼人将城临，臣妾焉敢去逃生。我今舍了娇生两个子，顾不得金枝玉叶人。低下头来忙跪倒，二十四拜辞主公。我抽身就往御园走，",
      "text_length": 60
    },
    {
      "event_id": "01018006_e00009",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "梓橦，你要怎么样？",
      "text_length": 9
    },
    {
      "event_id": "01018006_e00010",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "周后"
      ],
      "text": "御果园内去丧生。",
      "text_length": 8
    },
    {
      "event_id": "01018006_e00011",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太子"
      ],
      "text": "皇娘，难道舍了孩儿不成？",
      "text_length": 12
    },
    {
      "event_id": "01018006_e00012",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "周后"
      ],
      "text": "孩儿呀！",
      "text_length": 4
    },
    {
      "event_id": "01018006_e00013",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "周后"
      ],
      "text": "倘然闯贼将宫进，你皇娘千载落丑名。我宁可今朝舍一死，",
      "text_length": 26
    },
    {
      "event_id": "01018006_e00014",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "周后"
      ],
      "text": "孩儿呀！",
      "text_length": 4
    },
    {
      "event_id": "01018006_e00015",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "周后"
      ],
      "text": "可怜你兄妹两个人。从此母子生拆散，要相逢除非一梦中。",
      "text_length": 26
    },
    {
      "event_id": "01018006_e00016",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "周后下。崇祯哭。",
      "text_length": 8
    },
    {
      "event_id": "01018006_e00017",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "眼看梓橦投井死，",
      "text_length": 8
    },
    {
      "event_id": "01018006_e00018",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "咳，梓橦呀！",
      "text_length": 6
    },
    {
      "event_id": "01018006_e00019",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "却把为王摘了心。俺这里忙把侍臣叫，",
      "text_length": 17
    },
    {
      "event_id": "01018006_e00020",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内监上。",
      "text_length": 4
    },
    {
      "event_id": "01018006_e00021",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内监"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01018006_e00022",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "你快把太子领出宫。你领着逃出京城外，改名换姓去逃生。回头来看娇生女，不由我满眼落泪痕。你虽是生长昭阳院，反不如民间作穷人。为父的出于无可奈，手向腰间拔青铜。",
      "text_length": 78
    },
    {
      "event_id": "01018006_e00023",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "公主"
      ],
      "text": "咳，父王呀，难道杀了孩儿么？",
      "text_length": 14
    },
    {
      "event_id": "01018006_e00024",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "儿呀！",
      "text_length": 3
    },
    {
      "event_id": "01018006_e00025",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "为父的出于无可奈，望着姣生下绝情。",
      "text_length": 17
    },
    {
      "event_id": "01018006_e00026",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "公主下。报子上。",
      "text_length": 8
    },
    {
      "event_id": "01018006_e00027",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "报子"
      ],
      "text": "万岁爷，不好了，贼把彰仪门打开。",
      "text_length": 16
    },
    {
      "event_id": "01018006_e00028",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "报子下。",
      "text_length": 4
    },
    {
      "event_id": "01018006_e00029",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王承恩"
      ],
      "text": "启我主，贼把彰仪门打开，我主快快换衣服，溜出城门，再作商量。",
      "text_length": 30
    },
    {
      "event_id": "01018006_e00030",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "今大事已去，你叫朕往哪里逃走去。",
      "text_length": 16
    },
    {
      "event_id": "01018006_e00031",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "崇祯"
      ],
      "text": "满京城尽都是贼的人马，却叫孤家哪里行？我宁可死在昭阳院，不肯丧在贼手中。王承恩前面引着路，为王前到万寿亭。",
      "text_length": 53
    },
    {
      "event_id": "01018006_e00032",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01018006_e00033",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "崇祯"
      ],
      "text": "四面八方烟尘起，火炮不住响连声。忽想起铁冠道人留图画，他说过事到紧急看分明。",
      "text_length": 38
    },
    {
      "event_id": "01018006_e00034",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "王承恩，把铁冠道人昔日进的画图取来。",
      "text_length": 18
    },
    {
      "event_id": "01018006_e00035",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王承恩"
      ],
      "text": "奴婢取来。万岁，画图在此。",
      "text_length": 13
    },
    {
      "event_id": "01018006_e00036",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "展开呀。",
      "text_length": 4
    },
    {
      "event_id": "01018006_e00037",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "为王一见痴呆了，不由我顶上走真魂。我看他蓬头跣足发盖面，脖子排了一条绳。这分明是王真形象，他数年以来算得清。罢罢罢，原来天数安排定，为王焉能逆天行。这就是无能臣子误了朕，为王误了天下民。我明家大数虽然尽，可惜我多少保国臣。",
      "text_length": 111
    },
    {
      "event_id": "01018006_e00038",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "王承恩，你把以前边上报来，阵中亡身，骂贼殉难，这些死节的忠臣图挂起。",
      "text_length": 34
    },
    {
      "event_id": "01018006_e00039",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王承恩"
      ],
      "text": "奴婢晓得。",
      "text_length": 5
    },
    {
      "event_id": "01018006_e00040",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "王承恩。",
      "text_length": 4
    },
    {
      "event_id": "01018006_e00041",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王承恩"
      ],
      "text": "奴婢在。",
      "text_length": 4
    },
    {
      "event_id": "01018006_e00042",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "若是朝中大臣，亡身为国，得似这些武将，焉有今日！",
      "text_length": 24
    },
    {
      "event_id": "01018006_e00043",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "为王一见痛伤情，两眼不住落泪痕。你今日为国将身丧，万古千秋落好名。可惜那湖广左良玉，昌平州好一个李子修；金所聪保定头撞破，夜裸贼营孙传廷；居庸关总兵好马岱，陕西城又死了赵昔云；吕青箭骂贼身遭铚，宣府里杀了朱之文；蔡茂德太原身缢死，可怜那福州洪苏云；有一个米脂县的边大寿，雪夜里前去刨贼坟；宁武关总兵周遇吉，可怜他乱箭丧了身；母子夫妻俱尽节，一家团团用火焚；襄城伯巡城受尽了苦，赤胆忠心只有这王承恩。有几个骂贼刀剁死，有几个阵上丧了生；有几个抱城遭贼死，有几个连营分了身；有几个一门儿女全忠孝，有几个满城老幼送了生。耳边厢不住人马喊，霎时间震得天地昏。回头来忙把承恩叫，你且引朕向前行。急速快把煤山上，煤山以上看分明。",
      "text_length": 308
    },
    {
      "event_id": "01018006_e00044",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01018006_e00045",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "贼子此地将人砍，大炮连天把屋焚。",
      "text_length": 16
    },
    {
      "event_id": "01018006_e00046",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "崇祯"
      ],
      "text": "咳，皇天呀！",
      "text_length": 6
    },
    {
      "event_id": "01018006_e00047",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "崇祯"
      ],
      "text": "我舍了祖宗创来的花世界，我舍了十六帝的众皇陵；我舍了三官六院嫔妃女，我舍了忠君保国众能臣；我舍了皇家太子并公主，我舍了安分守己好良民。我扯下了衮龙袍一片，咬破了玉指血淋淋。我写着闯贼休掳索，你须要按字行行看分明：失了天下朕的罪，造罪原是朕一人。你宁可问我儿子罪，千万莫害众黎民。我百姓连年遭兵火，十七年寸草不收成。撞见你等兴人马，扰得他东奔西逃不安宁。父子夫妻不相顾，田产家园去个清。你若是杀害众百姓，天地鬼神也不容。一幅血诏写完了，可怜为王自伤情。伸手解下了丝绦带，煤山上缢死我崇祯。",
      "text_length": 243
    },
    {
      "event_id": "01018006_e00048",
      "play_id": "01018006",
      "scene_id": "01018006_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "崇祯下。王承恩下。",
      "text_length": 9
    }
  ],
  "roles_inferred": true
}