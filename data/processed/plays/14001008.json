      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "刘秀"
      ],
      "text": "孤离了龙书案——",
      "text_length": 8
    },
    {
      "event_id": "14001008_e00076",
      "play_id": "14001008",
      "scene_id": "14001008_s01",
