  "events": [
    {
      "event_id": "02001056_e00001",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "庄周上。",
      "text_length": 4
    },
    {
      "event_id": "02001056_e00002",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "一江风",
      "speakers": [
        "庄周"
      ],
      "text": "晓风凉，旭日遮晴障，信步荒芜上。",
      "text_length": 16
    },
    {
      "event_id": "02001056_e00003",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "卑人庄周，乃楚国梦邑人也。不受赵国之聘，隐迹山林，一心悟道。今早出门，来此荒郊游玩。但见乌鸦群噪，白骨成堆嗐！好伤感人也！",
      "text_length": 61
    },
    {
      "event_id": "02001056_e00004",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "一江风",
      "speakers": [
        "庄周"
      ],
      "text": "见苍松满树枯藤，听鸟语悠扬，共噪枝头上。",
      "text_length": 20
    },
    {
      "event_id": "02001056_e00005",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "呜呼呀，这是一堆骷髅，为何暴露在此？嗳！",
      "text_length": 20
    },
    {
      "event_id": "02001056_e00006",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "一江风",
      "speakers": [
        "庄周"
      ],
      "text": "想人生空自忙，空自忙，",
      "text_length": 11
    },
    {
      "event_id": "02001056_e00007",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "骷髅哇，骷髅！",
      "text_length": 7
    },
    {
      "event_id": "02001056_e00008",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "一江风",
      "speakers": [
        "庄周"
      ],
      "text": "你的形容在哪厢？这一堆白骨倩谁埋葬？",
      "text_length": 18
    },
    {
      "event_id": "02001056_e00009",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "感叹一回，身子有些困倦，不免在柳荫之下，打睡片时，起来再行。正是：",
      "text_length": 33
    },
    {
      "event_id": "02001056_e00010",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "庄周"
      ],
      "text": "残骨尚留芳草地，一番清话有谁知？",
      "text_length": 16
    },
    {
      "event_id": "02001056_e00011",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "庄周睡。老人上。",
      "text_length": 8
    },
    {
      "event_id": "02001056_e00012",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老人"
      ],
      "text": "茫茫不知处，悠悠何所归？生前无人识，死后有谁知？",
      "text_length": 24
    },
    {
      "event_id": "02001056_e00013",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "某骷髅是也。方才闻得庄先生之言，甚有训誚之意。不免把生死之事，与他辩论一番。庄先生！",
      "text_length": 42
    },
    {
      "event_id": "02001056_e00014",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "庄周起。",
      "text_length": 4
    },
    {
      "event_id": "02001056_e00015",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "庄周"
      ],
      "text": "梦里不知身是客，",
      "text_length": 8
    },
    {
      "event_id": "02001056_e00016",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "先生！",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00017",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "庄周"
      ],
      "text": "谁来耳畔唤先生？",
      "text_length": 8
    },
    {
      "event_id": "02001056_e00018",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "先生请了。",
      "text_length": 5
    },
    {
      "event_id": "02001056_e00019",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "请了。足下何来？",
      "text_length": 8
    },
    {
      "event_id": "02001056_e00020",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "适闻先生所言，句句真切。如仆者，则无斯患也。",
      "text_length": 22
    },
    {
      "event_id": "02001056_e00021",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "如此说来，足下莫非是骷髅么？",
      "text_length": 14
    },
    {
      "event_id": "02001056_e00022",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "然。",
      "text_length": 2
    },
    {
      "event_id": "02001056_e00023",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "正要请教，但不知富不如贵贫不如贱则生不如死，望足下教之。",
      "text_length": 28
    },
    {
      "event_id": "02001056_e00024",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "既蒙垂问，敢呈所知。夫死者无君于上，无臣于下，无四时之患，无万感之劳，仆今在飘飘渺渺之间，其乐无穷。虽南面帝王之乐，不我过也。",
      "text_length": 63
    },
    {
      "event_id": "02001056_e00025",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "如此说来那生不如死了？",
      "text_length": 11
    },
    {
      "event_id": "02001056_e00026",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00027",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "请教。",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00028",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "先生！",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00029",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "宜春令",
      "speakers": [
        "老人"
      ],
      "text": "生能几，死较长，有谁逃无常这桩。这腌拶臭胕，把幻身躯抛却无真相。讨得来富贵皮囊，富贵皮囊，只不过王侯尊长。",
      "text_length": 53
    },
    {
      "event_id": "02001056_e00030",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老人"
      ],
      "text": "未归三尺土，难保百年坟。",
      "text_length": 12
    },
    {
      "event_id": "02001056_e00031",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "宜春令",
      "speakers": [
        "老人"
      ],
      "text": "悲伤！怕提起在生时，有千万魔障，有千万魔障。",
      "text_length": 22
    },
    {
      "event_id": "02001056_e00032",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "宜春令",
      "speakers": [
        "庄周"
      ],
      "text": "生堪惜，死最伤，万千傀猥扮演演这场。似电光石火，一灵怎肯归黄壤？纵然是再得入身，浑不似旧时的形象。",
      "text_length": 49
    },
    {
      "event_id": "02001056_e00033",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00034",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "庄周"
      ],
      "text": "败坏不如猪狗相，人生莫作等闲看。",
      "text_length": 16
    },
    {
      "event_id": "02001056_e00035",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "宜春令",
      "speakers": [
        "庄周"
      ],
      "text": "堪伤！想贤愚贵贱，逃不得这般模样。",
      "text_length": 17
    },
    {
      "event_id": "02001056_e00036",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "骷髅，我当为汝告过阴司，命汝再转阳世，你意如何？",
      "text_length": 24
    },
    {
      "event_id": "02001056_e00037",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "先生！",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00038",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老人"
      ],
      "text": "我今为鬼已数秋，也无欢乐也无愁。先生叫我还阳去，只恐为人不到头。",
      "text_length": 32
    },
    {
      "event_id": "02001056_e00039",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "唯呀是呀！请问足下，在生时作何事业？请道其详。",
      "text_length": 23
    },
    {
      "event_id": "02001056_e00040",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "言之可伤，恐君不忍闻耳。",
      "text_length": 12
    },
    {
      "event_id": "02001056_e00041",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "愿闻。",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00042",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "先生！",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00043",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "老人"
      ],
      "text": "俺也曾为功名勤劳鞅掌，为儿孙积下了万廩千箱。俺也曾珠围翠绕在销金帐，俺也曾为国家，为国家晓夜思量。俺也曾忘餐废寝，记不尽千年帐。",
      "text_length": 64
    },
    {
      "event_id": "02001056_e00044",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "如此说你倒是个忙人了！",
      "text_length": 11
    },
    {
      "event_id": "02001056_e00045",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "忙他何用啊？",
      "text_length": 6
    },
    {
      "event_id": "02001056_e00046",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "老人"
      ],
      "text": "尽作了黄粱梦一场，顷刻无常！问你忙也不忙？",
      "text_length": 21
    },
    {
      "event_id": "02001056_e00047",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "你到底是何等样人物呢？",
      "text_length": 11
    },
    {
      "event_id": "02001056_e00048",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "喏！",
      "text_length": 2
    },
    {
      "event_id": "02001056_e00049",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "老人"
      ],
      "text": "你我同一样，你便问我是何人，我便问你是谁行？",
      "text_length": 22
    },
    {
      "event_id": "02001056_e00050",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "庄周"
      ],
      "text": "听说罢令人惨伤，这言词果不荒唐。臭皮囊暂且为人样，碎纷纷把骨骸包藏。凭你经文纬武拜了公侯相，少不得死后同登白骨场。承你开迷纲，怎能够跳出轮回，方免无常？",
      "text_length": 76
    },
    {
      "event_id": "02001056_e00051",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "先生要免无常二字，我有一偈，你必须牢牢紧记。",
      "text_length": 22
    },
    {
      "event_id": "02001056_e00052",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "领教。",
      "text_length": 3
    },
    {
      "event_id": "02001056_e00053",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老人"
      ],
      "text": "满腹贪生怕死期，死中荣处有谁知？先生要免无常路，除是长桑公子知。",
      "text_length": 32
    },
    {
      "event_id": "02001056_e00054",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "承教了。",
      "text_length": 4
    },
    {
      "event_id": "02001056_e00055",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "老人"
      ],
      "text": "记真言，还提想，模糊醉眼似徉。",
      "text_length": 15
    },
    {
      "event_id": "02001056_e00056",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老人"
      ],
      "text": "庄先生！",
      "text_length": 4
    },
    {
      "event_id": "02001056_e00057",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "老人"
      ],
      "text": "这的是生死关头，和你梦一场。",
      "text_length": 14
    },
    {
      "event_id": "02001056_e00058",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老人下。庄周睡。",
      "text_length": 8
    },
    {
      "event_id": "02001056_e00059",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "骷髅，骷髅，转来，不要远去，我还有话问你。",
      "text_length": 21
    },
    {
      "event_id": "02001056_e00060",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "庄周起。",
      "text_length": 4
    },
    {
      "event_id": "02001056_e00061",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄周"
      ],
      "text": "哎呀，奇怪，方才明明与骷髅把生死之事，辩论一番，临别时赠我一偈。他道：“满腹贪生怕死期，死中荣处有谁知？先生要免无常路，除是长桑公子知。”哎呀且住！我想那长桑公子，乃是道德真君，我一时焉能得见？也罢，不免回去撇了妻子，弃却田园，游遍天下，寻访长桑公子便了。正是：",
      "text_length": 131
    },
    {
      "event_id": "02001056_e00062",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "庄周"
      ],
      "text": "百年浑似梦，大梦古今同。",
      "text_length": 12
    },
    {
      "event_id": "02001056_e00063",
      "play_id": "02001056",
      "scene_id": "02001056_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "庄周下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}