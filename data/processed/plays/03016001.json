      "mode_label": "白",
      "speakers": [
        "尤浑"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00023",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监引纣王同上。",
      "text_length": 9
    },
    {
      "event_id": "03016001_e00024",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "纣王"
      ],
      "text": "文武双全，恃祖业，朝歌承欢。",
      "text_length": 14
    },
    {
      "event_id": "03016001_e00025",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "纣王入正座。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00026",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "费仲",
        "尤浑"
      ],
      "text": "小臣参见，吾皇万岁！",
      "text_length": 10
    },
    {
      "event_id": "03016001_e00027",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "平身！",
      "text_length": 3
    },
    {
      "event_id": "03016001_e00028",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "费仲",
        "尤浑"
      ],
      "text": "万万岁！",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00029",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "纣王"
      ],
      "text": "朝歌城中摘星楼，金钟一响文武愁。宠幸妲己贪酒色，虿盆炮烙臣民忧！",
      "text_length": 32
    },
    {
      "event_id": "03016001_e00030",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "孤，大殷太子辛在位。只因北海金鳌作乱。我命太宰，带领人马前去征剿。昨日报道，太宰今日班师回朝。费、尤二卿！",
      "text_length": 53
    },
    {
      "event_id": "03016001_e00031",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "费仲",
        "尤浑"
      ],
      "text": "臣！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00032",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "太宰还朝，你等各要小心。",
      "text_length": 12
    },
    {
      "event_id": "03016001_e00033",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "费仲",
        "尤浑"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00034",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "闻仲"
      ],
      "text": "众将官！",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00035",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "八龙套"
      ],
      "text": "有！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00036",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "闻仲"
      ],
      "text": "将人马扎在皇城。",
      "text_length": 8
    },
    {
      "event_id": "03016001_e00037",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "八龙套"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00038",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "闻仲"
      ],
      "text": "将人马扎皇城休要罗唣，",
      "text_length": 11
    },
    {
      "event_id": "03016001_e00039",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "闻仲上。",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00040",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄碰板",
      "speakers": [
        "闻仲"
      ],
      "text": "奉王命征北海得胜还朝。",
      "text_length": 11
    },
    {
      "event_id": "03016001_e00041",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "闻仲"
      ],
      "text": "在午门下麒麟忙登御道，见凤阁与龙楼甚是萧条。文班中不见了比干元老，武班中不见了黄家英豪。撩蟒袍端玉带品级台到，三呼万岁参见当朝。",
      "text_length": 64
    },
    {
      "event_id": "03016001_e00042",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "臣，太宰闻仲见驾，吾皇万岁！",
      "text_length": 14
    },
    {
      "event_id": "03016001_e00043",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "太宰平身。",
      "text_length": 5
    },
    {
      "event_id": "03016001_e00044",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "万万岁。",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00045",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "赐绣墩。",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00046",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "谢坐。",
      "text_length": 3
    },
    {
      "event_id": "03016001_e00047",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "太宰将征讨金鳌之事，一一奏来。",
      "text_length": 15
    },
    {
      "event_id": "03016001_e00048",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "臣启万岁：臣奉命征讨金鳌，大兵一到，那贼不战自降，写下降书顺表，年年进贡，岁岁来朝。",
      "text_length": 42
    },
    {
      "event_id": "03016001_e00049",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "此乃太宰虎威。",
      "text_length": 7
    },
    {
      "event_id": "03016001_e00050",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "我主洪福。",
      "text_length": 5
    },
    {
      "event_id": "03016001_e00051",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "费、尤二卿！",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00052",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "臣！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00053",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "光禄寺大摆御宴，与太宰贺功。",
      "text_length": 14
    },
    {
      "event_id": "03016001_e00054",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "且慢。",
      "text_length": 3
    },
    {
      "event_id": "03016001_e00055",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "为何拦阻？",
      "text_length": 5
    },
    {
      "event_id": "03016001_e00056",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "老臣进得朝来，为何不见比干丞相？",
      "text_length": 16
    },
    {
      "event_id": "03016001_e00057",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "太宰有所不知，只因新宫娘娘身染重病。",
      "text_length": 18
    },
    {
      "event_id": "03016001_e00058",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "但不知是新病旧病？",
      "text_length": 9
    },
    {
      "event_id": "03016001_e00059",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "乃是旧病新犯。",
      "text_length": 7
    },
    {
      "event_id": "03016001_e00060",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "就该请太医调治。",
      "text_length": 8
    },
    {
      "event_id": "03016001_e00061",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "寡人已传太医调治，但是缺少一味药引。",
      "text_length": 18
    },
    {
      "event_id": "03016001_e00062",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "但不知缺何药引？",
      "text_length": 8
    },
    {
      "event_id": "03016001_e00063",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "缺少玲珑透剔心为药引。",
      "text_length": 11
    },
    {
      "event_id": "03016001_e00064",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "老臣幼年，也曾读过药书，未见有玲珑透剔心，是何药引？",
      "text_length": 26
    },
    {
      "event_id": "03016001_e00065",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "寡人亦是这样言讲，那新宫娘娘言道：满朝文武俱是血心，惟有比干丞相，乃是玲珑透剔心，寡人将他宣上金殿，赐他宝剑一口，乃是一句戏言，不想老太宰忠心耿耿，他竟剖心而亡了。",
      "text_length": 82
    },
    {
      "event_id": "03016001_e00066",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "万岁怎讲？",
      "text_length": 5
    },
    {
      "event_id": "03016001_e00067",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "剖心而亡了。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00068",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "闻仲"
      ],
      "text": "太宰呀！",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00069",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "闻仲"
      ],
      "text": "听说是老太宰剖心而丧，我朝中又去了架海金梁。下殿角哭一声比干丞相，比干丞相，老太宰呀！可怜他忠心耿耿一命身亡。",
      "text_length": 55
    },
    {
      "event_id": "03016001_e00070",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "臣启万岁：正宫国母，挖目烙手，因何而起？",
      "text_length": 20
    },
    {
      "event_id": "03016001_e00071",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "太宰哪里知道，姜娘娘使她弟文焕，身藏短刀，在五凤楼前行刺，有心谋害寡人，因此将她挖目烙手。",
      "text_length": 45
    },
    {
      "event_id": "03016001_e00072",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "闻仲"
      ],
      "text": "国母呀！",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00073",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "闻仲"
      ],
      "text": "姜国母坐昭阳万民敬仰，最可叹受惨刑命丧无常。下金殿哭一声国母娘娘，国母娘娘，国母啊！可叹她身为国母受刑而亡。",
      "text_length": 54
    },
    {
      "event_id": "03016001_e00074",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "臣启万岁：贾氏夫人坠楼而死，黄家父子反出五关，此事又从何而起？",
      "text_length": 31
    },
    {
      "event_id": "03016001_e00075",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "只因孤闻听贾氏夫人生得美貌，将她宣上摘星楼，奉陪孤王饮酒，谁之她羞愧难当，竟自坠楼而亡。那黄家父子叛反孤家，保定太子，杀出朝歌。似这等不忠不孝之人，提他作甚？",
      "text_length": 79
    },
    {
      "event_id": "03016001_e00076",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "我主江山一旦休矣！",
      "text_length": 9
    },
    {
      "event_id": "03016001_e00077",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "闻仲"
      ],
      "text": "贾氏夫人坠楼前，黄家父子反五关。在金殿问昏君无言答辩，下殿来再问那文武两班。",
      "text_length": 38
    },
    {
      "event_id": "03016001_e00078",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费仲"
      ],
      "text": "参见老太宰。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00079",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "下站何人？",
      "text_length": 5
    },
    {
      "event_id": "03016001_e00080",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费仲"
      ],
      "text": "上大夫费仲。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00081",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "摘星楼可是尔所造？",
      "text_length": 9
    },
    {
      "event_id": "03016001_e00082",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费仲"
      ],
      "text": "圣上旨意，喏、喏、喏，小臣监造。",
      "text_length": 16
    },
    {
      "event_id": "03016001_e00083",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "唔！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00084",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "闻仲"
      ],
      "text": "摘星楼乃是尔造定，害了多少栋梁臣。",
      "text_length": 17
    },
    {
      "event_id": "03016001_e00085",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "鞭来！",
      "text_length": 3
    },
    {
      "event_id": "03016001_e00086",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "闻仲"
      ],
      "text": "金鞭一举追尔命，打死费仲再问来臣。",
      "text_length": 17
    },
    {
      "event_id": "03016001_e00087",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费仲下。",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00088",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尤浑"
      ],
      "text": "参见老太宰。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00089",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "你是何人？",
      "text_length": 5
    },
    {
      "event_id": "03016001_e00090",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尤浑"
      ],
      "text": "下大夫尤浑。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00091",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "炮烙、虿盆是尔监造？",
      "text_length": 10
    },
    {
      "event_id": "03016001_e00092",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尤浑"
      ],
      "text": "圣上旨意，喏、喏、喏，小臣监造。",
      "text_length": 16
    },
    {
      "event_id": "03016001_e00093",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 93,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "唔！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00094",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 94,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "闻仲"
      ],
      "text": "炮烙、虿盆尔监造，害了无数女多娇。金鞭一举命丧了，打死谗臣问当朝！",
      "text_length": 33
    },
    {
      "event_id": "03016001_e00095",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 95,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "尤浑下。",
      "text_length": 4
    },
    {
      "event_id": "03016001_e00096",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 96,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "臣启万岁：新宫国母，为臣要见。",
      "text_length": 15
    },
    {
      "event_id": "03016001_e00097",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 97,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "天色已晚，明日再见。",
      "text_length": 10
    },
    {
      "event_id": "03016001_e00098",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 98,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "老臣一定要见！",
      "text_length": 7
    },
    {
      "event_id": "03016001_e00099",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 99,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纣王"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00100",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 100,
      "seq_in_scene": 87,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "纣王"
      ],
      "text": "好一个胆大的太宰闻仲，敢在午门打大臣。内侍带路回宫廷，要见妲己万不能。",
      "text_length": 35
    },
    {
      "event_id": "03016001_e00101",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 101,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "纣王下，四太监随下。",
      "text_length": 10
    },
    {
      "event_id": "03016001_e00102",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 102,
      "seq_in_scene": 89,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "闻仲"
      ],
      "text": "本当打进皇宫院，他是君来某是臣。人来带过墨麒麟，明日早朝再问当今。",
      "text_length": 33
    },
    {
      "event_id": "03016001_e00103",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 103,
