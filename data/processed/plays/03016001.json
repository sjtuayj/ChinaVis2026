      ],
      "text": "明月满栏杆。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00019",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费仲"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "03016001_e00020",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "尤浑"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "03016001_e00021",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费仲"
      ],
      "text": "香烟缭绕，圣驾临朝。你我分班伺候。请！",
      "text_length": 19
    },
    {
      "event_id": "03016001_e00022",
