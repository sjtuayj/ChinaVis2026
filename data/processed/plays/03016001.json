  "events": [
    {
      "event_id": "03016001_e00001",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "八龙套、中军引闻仲同上。",
      "text_length": 12
    },
    {
      "event_id": "03016001_e00002",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "闻仲"
      ],
      "text": "锦战袍玉带围腰，征北海得胜还朝。",
      "text_length": 16
    },
    {
      "event_id": "03016001_e00003",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "闻仲"
      ],
      "text": "吾本商朝一大臣，跨下神行墨麒麟。金鞭扫荡花世界，保定我主驾乾坤。",
      "text_length": 32
    },
    {
      "event_id": "03016001_e00004",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "老夫，太宰闻。在殷纣驾前为臣。只因北海金鳌作乱，圣上命老夫领兵征讨。且喜大兵一到，那贼不战自降，写下降书顺表，愿年年进贡，岁岁来朝。今当黄道吉日，正好班师回朝。中军！",
      "text_length": 83
    },
    {
      "event_id": "03016001_e00005",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00006",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "人马可曾齐备？",
      "text_length": 7
    },
    {
      "event_id": "03016001_e00007",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "俱已齐备。",
      "text_length": 5
    },
    {
      "event_id": "03016001_e00008",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "闻仲"
      ],
      "text": "吩咐大小三军，人不卸甲，马不离鞍，班师回朝。",
      "text_length": 22
    },
    {
      "event_id": "03016001_e00009",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "得令。众将官！",
      "text_length": 7
    },
    {
      "event_id": "03016001_e00010",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "八龙套"
      ],
      "text": "有！",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00011",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "中军"
      ],
      "text": "太师有令：吩咐大小三军，人不卸甲，马不离鞍，班师回朝。",
      "text_length": 27
    },
    {
      "event_id": "03016001_e00012",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "八龙套"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "03016001_e00013",
      "play_id": "03016001",
      "scene_id": "03016001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同倒脱靴掏下。",
      "text_length": 14
    },
    {
      "event_id": "03016001_e00014",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费仲、尤浑同上。",
      "text_length": 8
    },
    {
      "event_id": "03016001_e00015",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "费仲"
      ],
      "text": "待漏五更寒，",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00016",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "尤浑"
      ],
      "text": "陪王上金銮。",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00017",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "费仲"
      ],
      "text": "鸡鸣天未晓，",
      "text_length": 6
    },
    {
      "event_id": "03016001_e00018",
      "play_id": "03016001",
      "scene_id": "03016001_s02",
      "scene_no": 2,
      "seq_global": 18,
