  "events": [
    {
      "event_id": "01002005_e00001",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "邹云英、丫鬟同上。",
      "text_length": 9
    },
    {
      "event_id": "01002005_e00002",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "邹云英"
      ],
      "text": "风吹铃儿响，荷花开满塘。",
      "text_length": 12
    },
    {
      "event_id": "01002005_e00003",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "邹云英"
      ],
      "text": "闺阁幼女不知愁，二八衣装上翠楼。身在秀房学针黹，侍奉老母到白头。（邹云英坐下。）",
      "text_length": 40
    },
    {
      "event_id": "01002005_e00004",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "奴家邹云英。爹爹邹伯符，现任河南八府巡按。母亲诰封夫人。是我未曾随父到任，在家闷闷不乐。丫鬟，带路花园。",
      "text_length": 52
    },
    {
      "event_id": "01002005_e00005",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "01002005_e00006",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "邹云英"
      ],
      "text": "老爹爹在朝中官居爵禄，我母亲受诰封在家享荣华。耳边厢又听得风声响落，",
      "text_length": 34
    },
    {
      "event_id": "01002005_e00007",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈杏元上，矮坐地下。",
      "text_length": 10
    },
    {
      "event_id": "01002005_e00008",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "邹云英"
      ],
      "text": "叫丫鬟看分明细对我说。",
      "text_length": 11
    },
    {
      "event_id": "01002005_e00009",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "启禀小姐：花园中有了妖怪了。",
      "text_length": 14
    },
    {
      "event_id": "01002005_e00010",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "有这等事？待我看来。哪里是妖怪，那旁边是一顽石，你我坐在一旁，听她讲些什么。",
      "text_length": 38
    },
    {
      "event_id": "01002005_e00011",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "苦吓！",
      "text_length": 3
    },
    {
      "event_id": "01002005_e00012",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "陈杏元"
      ],
      "text": "陈杏元身投在落雁坡下，耳边厢又听得走石飞砂。猛然间睁开眼太湖石下，那一旁坐定了观音菩萨。适才间奴投澜一心无假，昏沉沉也不知落在谁家？",
      "text_length": 66
    },
    {
      "event_id": "01002005_e00013",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "你不是妖魔鬼怪？",
      "text_length": 8
    },
    {
      "event_id": "01002005_e00014",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "陈杏元"
      ],
      "text": "本非是妖魔怪休要惊怕，",
      "text_length": 11
    },
    {
      "event_id": "01002005_e00015",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "你不是妖魔鬼怪，你是甚等样人？",
      "text_length": 15
    },
    {
      "event_id": "01002005_e00016",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "陈杏元"
      ],
      "text": "奴本是落难人奔走天涯。",
      "text_length": 11
    },
    {
      "event_id": "01002005_e00017",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "听你之言，你是被难之人，意欲带你去见我家母亲。",
      "text_length": 23
    },
    {
      "event_id": "01002005_e00018",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "但凭小姐。",
      "text_length": 5
    },
    {
      "event_id": "01002005_e00019",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "丫鬟带路。",
      "text_length": 5
    },
    {
      "event_id": "01002005_e00020",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "邹云英"
      ],
      "text": "她本是落难人来到我家，不由我一阵阵心内如麻。叫丫鬟忙带路后堂以下，",
      "text_length": 33
    },
    {
      "event_id": "01002005_e00021",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "有请母亲。",
      "text_length": 5
    },
    {
      "event_id": "01002005_e00022",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "邹母上。",
      "text_length": 4
    },
    {
      "event_id": "01002005_e00023",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "邹母"
      ],
      "text": "我的儿请为娘有何根芽？",
      "text_length": 11
    },
    {
      "event_id": "01002005_e00024",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "参见母亲。",
      "text_length": 5
    },
    {
      "event_id": "01002005_e00025",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "罢了。",
      "text_length": 3
    },
    {
      "event_id": "01002005_e00026",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "启禀母亲：孩儿花园游玩，得一难女，母亲请看。",
      "text_length": 22
    },
    {
      "event_id": "01002005_e00027",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "待我看来。原来是一被难之人，叫她前来见我。",
      "text_length": 21
    },
    {
      "event_id": "01002005_e00028",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "难女前来见过母亲。",
      "text_length": 9
    },
    {
      "event_id": "01002005_e00029",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "旦",
      "speakers": [
        "陈杏元"
      ],
      "text": "叩见老夫人。",
      "text_length": 6
    },
    {
      "event_id": "01002005_e00030",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "那一难女因何到此？",
      "text_length": 9
    },
    {
      "event_id": "01002005_e00031",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01002005_e00032",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈杏元"
      ],
      "text": "老夫人问我的真情实话，泄机关又恐怕被人所杀。不由人一霎时为难心下，",
      "text_length": 33
    },
    {
      "event_id": "01002005_e00033",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "有了。",
      "text_length": 3
    },
    {
      "event_id": "01002005_e00034",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈杏元"
      ],
      "text": "陈杏元改换了汪月英，哄骗与她。",
      "text_length": 15
    },
    {
      "event_id": "01002005_e00035",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "那一女子，为何背地沉吟？",
      "text_length": 12
    },
    {
      "event_id": "01002005_e00036",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "难女怎敢背地沉吟。夫人、小姐请高坐，听难女一言告禀。",
      "text_length": 26
    },
    {
      "event_id": "01002005_e00037",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "陈杏元"
      ],
      "text": "尊夫人与小姐听奴言讲，细听我落难人叙说端详：家住在扬州郡江都小县，奴姓汪名月英父母在堂。都只为雁门关打了败仗，恨卢杞命杏元去和番邦。选美女四十名一同——",
      "text_length": 76
    },
    {
      "event_id": "01002005_e00038",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "陈杏元"
      ],
      "text": "前往，有小女在其内离了故乡。到他国不过是下贱之样，奴投在落雁坡一命身亡。蒙神圣保佑我性命未丧，又谁知落在了夫人花墙。尊夫人、贤小姐听奴言讲：奴情愿为使女又待何妨。",
      "text_length": 81
    },
    {
      "event_id": "01002005_e00039",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "邹母"
      ],
      "text": "听伊言来泪悲伤，骂声卢杞狗奸党！",
      "text_length": 16
    },
    {
      "event_id": "01002005_e00040",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭板",
      "speakers": [
        "邹母"
      ],
      "text": "只害得他一家人东逃西往，",
      "text_length": 12
    },
    {
      "event_id": "01002005_e00041",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "邹云英"
      ],
      "text": "劝母亲免悲泪慈悲心肠。",
      "text_length": 11
    },
    {
      "event_id": "01002005_e00042",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "哎，母亲，我看此女，生的倒也聪明伶俐，何不将她收留府下，做一位螟蛉义女，母亲意下如何？",
      "text_length": 43
    },
    {
      "event_id": "01002005_e00043",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "那一难女，可知我们是甚等样人家？",
      "text_length": 16
    },
    {
      "event_id": "01002005_e00044",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "难女不知。",
      "text_length": 5
    },
    {
      "event_id": "01002005_e00045",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "我家老爷现任河南八府巡按，老身受过诰命。",
      "text_length": 20
    },
    {
      "event_id": "01002005_e00046",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "原来是一名诰命夫人，小女子不知，多多有罪。",
      "text_length": 21
    },
    {
      "event_id": "01002005_e00047",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "老身有意将你收留府下，做一位螟蛉义女，不知你意下如何？",
      "text_length": 27
    },
    {
      "event_id": "01002005_e00048",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "这……",
      "text_length": 3
    },
    {
      "event_id": "01002005_e00049",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "还不前来拜见母亲。",
      "text_length": 9
    },
    {
      "event_id": "01002005_e00050",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "如此，母亲请上，受孩儿一拜！",
      "text_length": 14
    },
    {
      "event_id": "01002005_e00051",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈杏元"
      ],
      "text": "喜洋洋近前来双膝跪倒，尊一声老夫人细听根苗：在府中望母亲多多训教，到后来儿不忘教养恩高。",
      "text_length": 44
    },
    {
      "event_id": "01002005_e00052",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "但不知你叫何名字？",
      "text_length": 9
    },
    {
      "event_id": "01002005_e00053",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "我叫汪月英。",
      "text_length": 6
    },
    {
      "event_id": "01002005_e00054",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "好。改姓不改名，改为邹月英。",
      "text_length": 14
    },
    {
      "event_id": "01002005_e00055",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "多谢母亲起名，但不知小姐青春几何？",
      "text_length": 17
    },
    {
      "event_id": "01002005_e00056",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "一十六岁。",
      "text_length": 5
    },
    {
      "event_id": "01002005_e00057",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "奴家二九，占长了。",
      "text_length": 9
    },
    {
      "event_id": "01002005_e00058",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹母"
      ],
      "text": "长则长，幼则幼，二人在这绣楼前，当着老身一拜。",
      "text_length": 23
    },
    {
      "event_id": "01002005_e00059",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "邹云英"
      ],
      "text": "叫姐姐你请上受我一拜，我与你好一比一母同胎。",
      "text_length": 22
    },
    {
      "event_id": "01002005_e00060",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "小姐请上，受愚姐一拜。",
      "text_length": 11
    },
    {
      "event_id": "01002005_e00061",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈杏元"
      ],
      "text": "近前来把贤妹一生高叫，为姐的有一言细听根苗：在府中早晚间多多看照，咱二人犹如那一母同胞。",
      "text_length": 44
    },
    {
      "event_id": "01002005_e00062",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "邹母"
      ],
      "text": "叫丫鬟将酒宴后堂摆好，母女们饮一个快乐逍遥。",
      "text_length": 22
    },
    {
      "event_id": "01002005_e00063",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "邹母下。",
      "text_length": 4
    },
    {
      "event_id": "01002005_e00064",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "邹云英"
      ],
      "text": "叫姐姐休得要珠泪嚎啕，我与你好一似一母同胞。",
      "text_length": 22
    },
    {
      "event_id": "01002005_e00065",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈杏元"
      ],
      "text": "蒙夫人与小姐恩高义好，今日里在邹府独自逍遥。",
      "text_length": 22
    },
    {
      "event_id": "01002005_e00066",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "姐姐走吓！",
      "text_length": 5
    },
    {
      "event_id": "01002005_e00067",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "01002005_e00068",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈杏元"
      ],
      "text": "背转思贤公子珠泪垂掉，我的梅……",
      "text_length": 16
    },
    {
      "event_id": "01002005_e00069",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "姐姐“梅”什么？",
      "text_length": 8
    },
    {
      "event_id": "01002005_e00070",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "看梅花开的茂盛。",
      "text_length": 8
    },
    {
      "event_id": "01002005_e00071",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "邹云英"
      ],
      "text": "嗳，姐姐喜爱梅花？",
      "text_length": 9
    },
    {
      "event_id": "01002005_e00072",
      "play_id": "01002005",
      "scene_id": "01002005_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈杏元"
      ],
      "text": "正是。",
      "text_length": 3
    },
