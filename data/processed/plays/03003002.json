  "events": [
    {
      "event_id": "03003002_e00001",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、李虎引李广同上。",
      "text_length": 12
    },
    {
      "event_id": "03003002_e00002",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "李广"
      ],
      "text": "奉旨代天，扫灭狼烟。",
      "text_length": 10
    },
    {
      "event_id": "03003002_e00003",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李广"
      ],
      "text": "剑气冲霄汉，文光射斗牛。略展经纶手，斩将觅封侯。",
      "text_length": 24
    },
    {
      "event_id": "03003002_e00004",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "本爵李广。周室驾前为臣，官拜奉命侯之职。只因北海三载未曾进贡，今奉圣旨，北海催讨。今乃黄道吉日。李虎，人马可齐？",
      "text_length": 56
    },
    {
      "event_id": "03003002_e00005",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李虎"
      ],
      "text": "齐备多时。",
      "text_length": 5
    },
    {
      "event_id": "03003002_e00006",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "吩咐外厢开道！",
      "text_length": 7
    },
    {
      "event_id": "03003002_e00007",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李广"
      ],
      "text": "东方亮海水潮日出东海，文武臣整朝衣齐拜金阶。奉王命去至在北海地界，但愿得此一去奏凯回来。",
      "text_length": 44
    },
    {
      "event_id": "03003002_e00008",
      "play_id": "03003002",
      "scene_id": "03003002_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "03003002_e00009",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四北兵引辽太同上。",
      "text_length": 9
    },
    {
      "event_id": "03003002_e00010",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "辽太"
      ],
      "text": "国乱民荒，奈天心，归向他邦。",
      "text_length": 14
    },
    {
      "event_id": "03003002_e00011",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "辽太"
      ],
      "text": "孤本北海一国王，人祸天灾痛断肠。深忧周室兴风浪，孤王日夜不安康。",
      "text_length": 32
    },
    {
      "event_id": "03003002_e00012",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "孤，辽太在位。周室为上，我国为下。原许年年进贡，岁岁往朝。至今三载，无宝奉上。他国必有良将，前来催贡，教孤何言答对？正是：",
      "text_length": 61
    },
    {
      "event_id": "03003002_e00013",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "辽太"
      ],
      "text": "忧从心上起，愁锁两眉尖。",
      "text_length": 12
    },
    {
      "event_id": "03003002_e00014",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "匡罢上。",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00015",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "匡罢"
      ],
      "text": "忙将李广催贡事，奏与我国大王知。",
      "text_length": 16
    },
    {
      "event_id": "03003002_e00016",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "匡罢"
      ],
      "text": "臣匡罢见驾，大王千岁！",
      "text_length": 11
    },
    {
      "event_id": "03003002_e00017",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "平身赐坐。",
      "text_length": 5
    },
    {
      "event_id": "03003002_e00018",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "匡罢"
      ],
      "text": "臣谢坐！",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00019",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "卿家上殿，有何本奏？",
      "text_length": 10
    },
    {
      "event_id": "03003002_e00020",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "匡罢"
      ],
      "text": "臣启奏大王：闻得天朝李广前来催贡。大王作何准备？",
      "text_length": 24
    },
    {
      "event_id": "03003002_e00021",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "孤王为此事忧虑在心，卿家有何良计？",
      "text_length": 17
    },
    {
      "event_id": "03003002_e00022",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "匡罢"
      ],
      "text": "启奏大王：依臣之见，将李广打入天牢；然后兴动人马，杀上他邦，夺取他国花花世界，有何难哉？",
      "text_length": 44
    },
    {
      "event_id": "03003002_e00023",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "卿家此言差也！从前原许年年进贡，岁岁往朝。至今三载，无宝奉上；又要兴兵杀上他邦，情理难容。",
      "text_length": 45
    },
    {
      "event_id": "03003002_e00024",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "匡罢"
      ],
      "text": "大王啊！",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00025",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "匡罢"
      ],
      "text": "大王说话懦无刚，匡罢言来听端详：将李广打入天牢内，打一封战表到他邦。他国纵有千员将，难当为臣化龙枪。",
      "text_length": 50
    },
    {
      "event_id": "03003002_e00026",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "卿家错把本奏上，孤王言来听端详：纣王无道乾坤丧，人心归附周文王。武王伐纣乾坤掌，封孤北海为帝王。军中无粮箭怎放？饥饿焉能手提枪？宁做一个太平犬，不做一国丧乱王。",
      "text_length": 80
    },
    {
      "event_id": "03003002_e00027",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "匡罢"
      ],
      "text": "军中无粮去放抢，打劫民间自有粮。争下江山大王掌，挂榜安民免钱粮。",
      "text_length": 32
    },
    {
      "event_id": "03003002_e00028",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "卿家奏本性情犟，细听孤王说端详：从前邓虎兴兵将，大战他国彩云庄。久战不胜把命丧，降书降表到他邦。劝卿家休要性情犟，怕的是马到临崖难收缰。",
      "text_length": 68
    },
    {
      "event_id": "03003002_e00029",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "匡罢"
      ],
      "text": "一言提起邓虎将，背转身来自思量：邓虎老将不能抗，何况今日少栋梁！回头我把二本上，再与大王作商量。",
      "text_length": 48
    },
    {
      "event_id": "03003002_e00030",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "匡罢"
      ],
      "text": "依大王之见？",
      "text_length": 6
    },
    {
      "event_id": "03003002_e00031",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "且听探马一报。",
      "text_length": 7
    },
    {
      "event_id": "03003002_e00032",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "报子上。",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00033",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "报子"
      ],
      "text": "忙将李广催贡事，报与我国大王知。",
      "text_length": 16
    },
    {
      "event_id": "03003002_e00034",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "报子"
      ],
      "text": "启奏大王：天朝李广前来催贡，已到十里长亭。请旨定夺！",
      "text_length": 26
    },
    {
      "event_id": "03003002_e00035",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "再探！",
      "text_length": 3
    },
    {
      "event_id": "03003002_e00036",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "报子"
      ],
      "text": "得令。",
      "text_length": 3
    },
    {
      "event_id": "03003002_e00037",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "报子下。",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00038",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "众卿站立两厢，听孤令下！",
      "text_length": 12
    },
    {
      "event_id": "03003002_e00039",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "孤王忙把旨传降，两班文武听端详：大摆队伍接李广，顺者昌来逆者亡。吩咐人役往前上，情理相待比杀砍强。",
      "text_length": 49
    },
    {
      "event_id": "03003002_e00040",
      "play_id": "03003002",
      "scene_id": "03003002_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "03003002_e00041",
      "play_id": "03003002",
      "scene_id": "03003002_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、李广、李虎同上。",
      "text_length": 12
    },
    {
      "event_id": "03003002_e00042",
      "play_id": "03003002",
      "scene_id": "03003002_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "李广"
      ],
      "text": "李广打马出皇朝，",
      "text_length": 8
    },
    {
      "event_id": "03003002_e00043",
      "play_id": "03003002",
      "scene_id": "03003002_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李广"
      ],
      "text": "对对旌旗空中飘。曾记北海打战表，要夺我主九龙朝。本爵领兵把贼剿，只杀得他国无处逃。原许下年年来进宝，每岁进在我国朝。至今三载无宝到，龙颜大怒将我召。金殿奉王旨一道，命本爵催贡到他朝。一路观看事不好，黎民百姓远脱逃。怨不得他国未进宝，树无枝叶草无苗。坐在马上传令号，大小三军听根苗：此番来至北海道，恩威并用去服辽。他要好言来哀告，宽限几载转回朝；他要言语行霸道，就在他国动枪刀。三军与爷前拥道，我看辽太怎开消！",
      "text_length": 204
    },
    {
      "event_id": "03003002_e00044",
      "play_id": "03003002",
      "scene_id": "03003002_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "03003002_e00045",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 45,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "辽太、匡罢、四朝官率四北兵摆对子同上。李广、李虎率四龙套同上。相见行礼。众人同下，同上。",
      "text_length": 44
    },
    {
      "event_id": "03003002_e00046",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 46,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "国主请上，李广参拜！",
      "text_length": 10
    },
    {
      "event_id": "03003002_e00047",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 47,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "岂敢！",
      "text_length": 3
    },
    {
      "event_id": "03003002_e00048",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 48,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "焉有不拜之理？",
      "text_length": 7
    },
    {
      "event_id": "03003002_e00049",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 49,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "这就不敢！大人请坐。",
      "text_length": 10
    },
    {
      "event_id": "03003002_e00050",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 50,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "辽太、李广同坐。",
      "text_length": 8
    },
    {
      "event_id": "03003002_e00051",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 51,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "不知大人驾到，未曾远迎，望乞恕罪！",
      "text_length": 17
    },
    {
      "event_id": "03003002_e00052",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 52,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "岂敢！少来问候国主金安，望乞海涵。",
      "text_length": 17
    },
    {
      "event_id": "03003002_e00053",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 53,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "我主龙驾可安？",
      "text_length": 7
    },
    {
      "event_id": "03003002_e00054",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 54,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "我主安泰。",
      "text_length": 5
    },
    {
      "event_id": "03003002_e00055",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 55,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "满朝文武可好？",
      "text_length": 7
    },
    {
      "event_id": "03003002_e00056",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 56,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "俱有书信手本问候国主金安。",
      "text_length": 13
    },
    {
      "event_id": "03003002_e00057",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 57,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "有劳他们。",
      "text_length": 5
    },
    {
      "event_id": "03003002_e00058",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 58,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "宴齐！",
      "text_length": 3
    },
    {
      "event_id": "03003002_e00059",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 59,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "看宴来！",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00060",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 60,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "03003002_e00061",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 61,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "两厢摆宴，款待天使。大人请！",
      "text_length": 14
    },
    {
      "event_id": "03003002_e00062",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "国主请！",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00063",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同坐。",
      "text_length": 10
    },
    {
      "event_id": "03003002_e00064",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 64,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "请问国主，从前原许年年进贡，岁岁来朝，至今三载无宝奉上，是何理也？",
      "text_length": 33
    },
    {
      "event_id": "03003002_e00065",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 65,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "大人哪！",
      "text_length": 4
    },
    {
      "event_id": "03003002_e00066",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 66,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "未曾开言珠泪涌，尊一声大人听详情：大旱三载灾荒重，黎民百姓受苦穷。望大人回朝把本动，宽限几载朝见主公。",
      "text_length": 51
    },
    {
      "event_id": "03003002_e00067",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 67,
      "seq_in_scene": 23,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李广"
      ],
      "text": "国主说话理不通，李广言来听分明：从前不该刀兵动，要夺我主锦疆洪。我国兵多将又勇，只杀得你国计皆穷。原许下年年把宝奉，每岁来朝见主公。到如今三载未进贡，情理二字实难容。",
      "text_length": 83
    },
    {
      "event_id": "03003002_e00068",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 68,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "大人说话言语重，羞得孤王脸通红。下位来我把好言奉，尊声大人听心中：有劳你千里迢迢来催贡，一路之上受霜风。避毒仙帕来相送，能解百毒妙无穷。此宝并非将王送，全仗大人多宽容。自古道礼轻人意重，望大人笑纳饮几盅。",
      "text_length": 102
    },
    {
      "event_id": "03003002_e00069",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李广"
      ],
      "text": "谢过国主把宝赠，李广言来听分明：非是我李广不肯应，圣命在身难依从。",
      "text_length": 33
    },
    {
      "event_id": "03003002_e00070",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "孤王传旨山岳动，两班文武听心中：天朝大人来催贡，每人奉敬酒一盅。",
      "text_length": 32
    },
    {
      "event_id": "03003002_e00071",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 71,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "匡罢"
      ],
      "text": "匡罢进前好言奉，",
      "text_length": 8
    },
    {
      "event_id": "03003002_e00072",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 72,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "朝官甲"
      ],
      "text": "尊声大人听详情：",
      "text_length": 8
    },
    {
      "event_id": "03003002_e00073",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 73,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "朝官乙"
      ],
      "text": "我国无有别的奉，",
      "text_length": 8
    },
    {
      "event_id": "03003002_e00074",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 74,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "朝官丙"
      ],
      "text": "每人奉敬酒一盅。",
      "text_length": 8
    },
    {
      "event_id": "03003002_e00075",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 75,
      "seq_in_scene": 31,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李广"
      ],
      "text": "他君臣全是好言奉，个个脸上带笑容。只要他不把刀兵动，宽限几载也可容。下位来我把好言奉，国主宽怀免愁容。",
      "text_length": 51
    },
    {
      "event_id": "03003002_e00076",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 76,
      "seq_in_scene": 32,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "国主！宽你三年，以后年年进贡，岁岁来朝。",
      "text_length": 20
    },
    {
      "event_id": "03003002_e00077",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 77,
      "seq_in_scene": 33,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "大人开了天地之恩，俺君臣感恩不浅。",
      "text_length": 17
    },
    {
      "event_id": "03003002_e00078",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 78,
      "seq_in_scene": 34,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "俺、告辞了！",
      "text_length": 6
    },
    {
      "event_id": "03003002_e00079",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 79,
      "seq_in_scene": 35,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "且慢！就在我国宽住几日，这有何妨？",
      "text_length": 17
    },
    {
      "event_id": "03003002_e00080",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 80,
      "seq_in_scene": 36,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李广"
      ],
      "text": "圣命在身，难以久停。",
      "text_length": 10
    },
    {
      "event_id": "03003002_e00081",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 81,
      "seq_in_scene": 37,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "辽太"
      ],
      "text": "大人留步！孤有一言，转奉天朝。",
      "text_length": 15
    },
    {
      "event_id": "03003002_e00082",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 82,
      "seq_in_scene": 38,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "深感天朝恩泽广，三呼万岁口称王。但愿各国宝进上，但愿主亚赛尧舜王。倘若哪国敢犯上，愿效犬马报君王。",
      "text_length": 49
    },
    {
      "event_id": "03003002_e00083",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 83,
      "seq_in_scene": 39,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李广"
      ],
      "text": "国主但把宽心放，你本是北海有道王。本爵回朝把本上，宽限几载见君王。辞别国主把马上，我主降罪俺李广承当。",
      "text_length": 51
    },
    {
      "event_id": "03003002_e00084",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 84,
      "seq_in_scene": 40,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李广率李虎、四龙套同下。",
      "text_length": 12
    },
    {
      "event_id": "03003002_e00085",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 85,
      "seq_in_scene": 41,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "辽太"
      ],
      "text": "天朝来了李广将，仪貌堂堂杀气昂。他本是天朝忠良将，忠心耿耿世无双。回头我对众卿讲，孤王言来听端详：自今以后休犯上，各守疆界乐安康。",
      "text_length": 65
    },
    {
      "event_id": "03003002_e00086",
      "play_id": "03003002",
      "scene_id": "03003002_s04",
      "scene_no": 4,
      "seq_global": 86,
      "seq_in_scene": 42,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}