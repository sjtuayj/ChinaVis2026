  "events": [
    {
      "event_id": "01028006_e00001",
      "play_id": "01028006",
      "scene_id": "01028006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松上，起霸。",
      "text_length": 7
    },
    {
      "event_id": "01028006_e00002",
      "play_id": "01028006",
      "scene_id": "01028006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "武松"
      ],
      "text": "沉月下踏月奔荒郊，行忙奔走路途遥。恼恨西门狗富豪，卖嘱王婆把淫嫂挑。害兄丧命赴阴曹，因此上替兄杀了嫂。",
      "text_length": 51
    },
    {
      "event_id": "01028006_e00003",
      "play_id": "01028006",
      "scene_id": "01028006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "武松"
      ],
      "text": "忆昔打虎景阳岗，替兄杀嫂惹祸殃。只因大闹飞云浦，削发为僧改旧装。",
      "text_length": 32
    },
    {
      "event_id": "01028006_e00004",
      "play_id": "01028006",
      "scene_id": "01028006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "洒家，武松。只因为兄杀了西门庆并淫妇潘氏，发配孟州为军。幸遇施恩，结为兄弟，代他夺了快活林，打倒蒋门神。偏偏又遇张都监，与俺作对，因此大闹飞云浦，血溅鸳鸯楼，题壁留名，越城逃走。多亏张青、孙二娘，他夫妻二人，将俺改扮头陀模样，又赐俺镔铁戒刀，人骨素珠一串，修书一封，命俺去至二龙山，花和尚鲁智深那里入伙。白日不敢多行，夜间贪走路程。看前面山岭重重，不免趁此月淡星稀，就此走走也。",
      "text_length": 189
    },
    {
      "event_id": "01028006_e00005",
      "play_id": "01028006",
      "scene_id": "01028006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "武松"
      ],
      "text": "芳草萋萋路不平，青松绿柳烟雾蒙。风吹树木涧泉鸣，好一似龙吟虎啸声。",
      "text_length": 33
    },
    {
      "event_id": "01028006_e00006",
      "play_id": "01028006",
      "scene_id": "01028006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松下。",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00007",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张志善上。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00008",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张志善"
      ],
      "text": "家有千担粮，前仓和后仓。",
      "text_length": 12
    },
    {
      "event_id": "01028006_e00009",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子暗上。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00010",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张志善"
      ],
      "text": "老夫，张志善。本村人氏。不幸妻子去世，所生一女，尚未许配人家。今乃清明佳节，祭扫之期。苍头，请小姐出房。",
      "text_length": 52
    },
    {
      "event_id": "01028006_e00011",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "有请小姐。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00012",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张女上。",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00013",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张女"
      ],
      "text": "不幸母亲亡故了，倒叫奴家双泪抛。",
      "text_length": 16
    },
    {
      "event_id": "01028006_e00014",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张女"
      ],
      "text": "爹爹万福。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00015",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张志善"
      ],
      "text": "罢了，我儿坐下。",
      "text_length": 8
    },
    {
      "event_id": "01028006_e00016",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张女"
      ],
      "text": "告坐。唤女儿出来，有何教训？",
      "text_length": 14
    },
    {
      "event_id": "01028006_e00017",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张志善"
      ],
      "text": "今乃清明佳节，为父要同我儿，上坟插柳。",
      "text_length": 19
    },
    {
      "event_id": "01028006_e00018",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张女"
      ],
      "text": "孩儿遵命。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00019",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张志善"
      ],
      "text": "苍头，车辆伺候。",
      "text_length": 8
    },
    {
      "event_id": "01028006_e00020",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "车辆上。院子托香纸盘。",
      "text_length": 11
    },
    {
      "event_id": "01028006_e00021",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "张女"
      ],
      "text": "清明佳节雨初晴，家家户户祭扫坟茔。看花插柳女钗裙，万紫千红好是春。",
      "text_length": 33
    },
    {
      "event_id": "01028006_e00022",
      "play_id": "01028006",
      "scene_id": "01028006_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00023",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 23,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王飞天上。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00024",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 24,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "王飞天"
      ],
      "text": "身入空门，怀抱杀心，好吃荤，不念经文，最好美佳人。",
      "text_length": 25
    },
    {
      "event_id": "01028006_e00025",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 25,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王飞天"
      ],
      "text": "走遍天下是某家，哪怕律条共王法。一身霸占蜈蚣岭，观中缺少一枝花。",
      "text_length": 32
    },
    {
      "event_id": "01028006_e00026",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 26,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "吾，王飞天，道号蜈蚣道。在这蜈蚣岭上，三清观内出家，倒也逍遥自在，只是少一美女陪伴。岭下有一家富户，他有一女子，生得十分美貌，也曾命人前去提亲，无奈他父，再三不允。今当清明佳节，他父女必定上坟插柳，不免将徒弟们唤出，想一妙计。众徒弟走上。",
      "text_length": 119
    },
    {
      "event_id": "01028006_e00027",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 27,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小道同上。",
      "text_length": 6
    },
    {
      "event_id": "01028006_e00028",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 28,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "四小道"
      ],
      "text": "出家不会诵经文，随同师父胡乱行。",
      "text_length": 16
    },
    {
      "event_id": "01028006_e00029",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 29,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小道"
      ],
      "text": "参见师父。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00030",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "罢了。",
      "text_length": 3
    },
    {
      "event_id": "01028006_e00031",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小道"
      ],
      "text": "将弟子们唤出，有何话讲？",
      "text_length": 12
    },
    {
      "event_id": "01028006_e00032",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "只因张家女子，十分美貌，提亲不允，为师时时挂念，今乃清明佳节，他父女必定上坟祭扫。特将你等唤将出来，想一妙计。",
      "text_length": 55
    },
    {
      "event_id": "01028006_e00033",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小道"
      ],
      "text": "这有何难，待弟子们下得岭去，将那女子，抢上山来，与师父成亲，岂不是好？",
      "text_length": 35
    },
    {
      "event_id": "01028006_e00034",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "此计甚好，你等速速前去，需要小心，不可惊吓那女子。",
      "text_length": 25
    },
    {
      "event_id": "01028006_e00035",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小道"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "01028006_e00036",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小道同下。老道暗上。",
      "text_length": 11
    },
    {
      "event_id": "01028006_e00037",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "老道，你将纱窗打开，准备好酒鸡肉，等候某家成亲便了。",
      "text_length": 26
    },
    {
      "event_id": "01028006_e00038",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王飞天下。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00039",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "01028006_e00040",
      "play_id": "01028006",
      "scene_id": "01028006_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老道下。",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00041",
      "play_id": "01028006",
      "scene_id": "01028006_s04",
      "scene_no": 4,
      "seq_global": 41,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子、张志善、张女同上。",
      "text_length": 12
    },
    {
      "event_id": "01028006_e00042",
      "play_id": "01028006",
      "scene_id": "01028006_s04",
      "scene_no": 4,
      "seq_global": 42,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "张志善"
      ],
      "text": "桃红柳绿万家春，眺望郊原欲断魂。",
      "text_length": 16
    },
    {
      "event_id": "01028006_e00043",
      "play_id": "01028006",
      "scene_id": "01028006_s04",
      "scene_no": 4,
      "seq_global": 43,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张志善、张女同下车，同跪。",
      "text_length": 13
    },
    {
      "event_id": "01028006_e00044",
      "play_id": "01028006",
      "scene_id": "01028006_s04",
      "scene_no": 4,
      "seq_global": 44,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "张志善"
      ],
      "text": "见坟茔不由人泪盈盈，无限悲伤哭先灵。",
      "text_length": 18
    },
    {
      "event_id": "01028006_e00045",
      "play_id": "01028006",
      "scene_id": "01028006_s04",
      "scene_no": 4,
      "seq_global": 45,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小道同上，同抢张女，同背张女，同打走张志善、院子，双下，众人同下。",
      "text_length": 34
    },
    {
      "event_id": "01028006_e00046",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 46,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松上。",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00047",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 47,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "武松"
      ],
      "text": "山路崎岖甚难行，树木叉丫荆棘横。耳边厢又听得人声震，想必是林内有歹人。",
      "text_length": 35
    },
    {
      "event_id": "01028006_e00048",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 48,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子上，撞武松，院子倒地。",
      "text_length": 13
    },
    {
      "event_id": "01028006_e00049",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 49,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "呔！昏夜之间，不看路径，慌慌张张，莫非你是奸细么？",
      "text_length": 25
    },
    {
      "event_id": "01028006_e00050",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 50,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "老汉不、不、不是奸细，老汉是避、避、避难的。",
      "text_length": 22
    },
    {
      "event_id": "01028006_e00051",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 51,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "既然你是避难之人，有话起来慢慢讲。",
      "text_length": 17
    },
    {
      "event_id": "01028006_e00052",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 52,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "哎吓爷爷吓！今当清明佳节，小老儿随同我家主人、小姐，上坟祭扫。此地有一蜈蚣岭，岭上有一三清观，观中有一道士，名叫王飞天，横行霸道，无恶不为。是他看见我家小姐，生得美貌，前来提亲。那时我家主人不允。不料他今日竟命许多强徒，竟将我家小姐抢了去了。",
      "text_length": 121
    },
    {
      "event_id": "01028006_e00053",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 53,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "想这清平世界，朗朗乾坤，竟敢擅抢良家妇女。老头儿，洒家情愿替你，搭救你家小姐，不知你意下如何？",
      "text_length": 47
    },
    {
      "event_id": "01028006_e00054",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 54,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "哎吓爷爷呀！你若能搭救我家小姐的性命，不但小老儿感激，就是我那主人也是感激不尽了。",
      "text_length": 41
    },
    {
      "event_id": "01028006_e00055",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 55,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "此番待洒家前去，你在岭下等候。若见火光一起，你便前来，迎接你家的小姐。",
      "text_length": 35
    },
    {
      "event_id": "01028006_e00056",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 56,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "爷爷吓，若是火光不起呢？",
      "text_length": 12
    },
    {
      "event_id": "01028006_e00057",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 57,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "若是火光不起么，你就各自逃命去吧。",
      "text_length": 17
    },
    {
      "event_id": "01028006_e00058",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 58,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子下。",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00059",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 59,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "武松"
      ],
      "text": "听一言把人来气坏，路见不平拔刀开。恨强徒大不该，抢夺民女为何来。急忙忙且把山路上，管叫他霎时化成灰。",
      "text_length": 50
    },
    {
      "event_id": "01028006_e00060",
      "play_id": "01028006",
      "scene_id": "01028006_s05",
      "scene_no": 5,
      "seq_global": 60,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松下。",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00061",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 61,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王飞天上。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00062",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 62,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王飞天"
      ],
      "text": "徒弟下山去抢亲，为何不见转回程。",
      "text_length": 16
    },
    {
      "event_id": "01028006_e00063",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 63,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小道背张女同上。",
      "text_length": 9
    },
    {
      "event_id": "01028006_e00064",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 64,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小道"
      ],
      "text": "抢来了！",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00065",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 65,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "好，好，好！你等下面吃酒，明日俱有重赏。",
      "text_length": 20
    },
    {
      "event_id": "01028006_e00066",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 66,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小道"
      ],
      "text": "多谢师父。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00067",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 67,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小道同下。王飞天坐，张女掩面哭。",
      "text_length": 17
    },
    {
      "event_id": "01028006_e00068",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 68,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "美人不要啼哭了。",
      "text_length": 8
    },
    {
      "event_id": "01028006_e00069",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 69,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张女"
      ],
      "text": "唗！胆大狂徒，清平世界，朗朗乾坤，擅抢良家妇女，难道你不怕王法么！",
      "text_length": 33
    },
    {
      "event_id": "01028006_e00070",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 70,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "武松急跑上。",
      "text_length": 6
    },
    {
      "event_id": "01028006_e00071",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 71,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "某家生来，向不知什么王法。你若从了某家的亲事，造化不小。",
      "text_length": 28
    },
    {
      "event_id": "01028006_e00072",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 72,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "呔！开门来！",
      "text_length": 6
    },
    {
      "event_id": "01028006_e00073",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 73,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "老道！",
      "text_length": 3
    },
    {
      "event_id": "01028006_e00074",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 74,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老道上。",
      "text_length": 4
    },
    {
      "event_id": "01028006_e00075",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 75,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "什么事吓？",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00076",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 76,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "看看外面，什么人叫门。",
      "text_length": 11
    },
    {
      "event_id": "01028006_e00077",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 77,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "01028006_e00078",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 78,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张女暗下。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00079",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 79,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "头发根札插，不妙，不妙。咳！",
      "text_length": 14
    },
    {
      "event_id": "01028006_e00080",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 80,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "老道"
      ],
      "text": "昨夜一梦甚可愁，梦见小鬼偷我的油。我今开门瞅一瞅，必定杀了我的头。",
      "text_length": 33
    },
    {
      "event_id": "01028006_e00081",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 81,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老道"
      ],
      "text": "没法子，不出去也不行，待我开开门，看看是谁。",
      "text_length": 22
    },
    {
      "event_id": "01028006_e00082",
      "play_id": "01028006",
      "scene_id": "01028006_s06",
      "scene_no": 6,
      "seq_global": 82,
      "seq_in_scene": 22,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老道开门。武松杀老道，老道下。武松扑王飞天，起打。王飞天败下，武松追下。",
      "text_length": 36
    },
    {
      "event_id": "01028006_e00083",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 83,
      "seq_in_scene": 1,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王飞天上。",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00084",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 84,
      "seq_in_scene": 2,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "众徒弟走上！",
      "text_length": 6
    },
    {
      "event_id": "01028006_e00085",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 85,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小道同上。",
      "text_length": 6
    },
    {
      "event_id": "01028006_e00086",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 86,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王飞天"
      ],
      "text": "杀！",
      "text_length": 2
    },
    {
      "event_id": "01028006_e00087",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 87,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王飞天下。武松追上，杀四小道，四小道同下。王飞天上，武松刀砍王飞天冠，起打，杀死王飞天。",
      "text_length": 44
    },
    {
      "event_id": "01028006_e00088",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 88,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "待我放起火来。",
      "text_length": 7
    },
    {
      "event_id": "01028006_e00089",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 89,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "放火彩。张女上。武松拉张女同跑圆场，院子上，跪，张女跪，哭。",
      "text_length": 30
    },
    {
      "event_id": "01028006_e00090",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 90,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "多蒙爷爷救命之恩，请问尊姓大名？",
      "text_length": 16
    },
    {
      "event_id": "01028006_e00091",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 91,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "若要问俺的名姓，俺就是景阳冈上，打虎的武松是也！",
      "text_length": 24
    },
    {
      "event_id": "01028006_e00092",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 92,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "多谢爷爷！",
      "text_length": 5
    },
    {
      "event_id": "01028006_e00093",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 93,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武松"
      ],
      "text": "你等下山去吧！",
      "text_length": 7
    },
    {
      "event_id": "01028006_e00094",
      "play_id": "01028006",
      "scene_id": "01028006_s07",
      "scene_no": 7,
      "seq_global": 94,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    }
  ],
  "roles_inferred": true
}