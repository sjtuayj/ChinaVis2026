  "events": [
    {
      "event_id": "03039004_e00001",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "傅氏"
      ],
      "text": "苦哇！",
      "text_length": 3
    },
    {
      "event_id": "03039004_e00002",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "傅氏"
      ],
      "text": "凄惨惨泪淋淋远离钱塘，",
      "text_length": 11
    },
    {
      "event_id": "03039004_e00003",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "张龙"
      ],
      "text": "呔！拉着走！",
      "text_length": 6
    },
    {
      "event_id": "03039004_e00004",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张龙拉傅氏同上。",
      "text_length": 8
    },
    {
      "event_id": "03039004_e00005",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄回龙腔",
      "speakers": [
        "傅氏"
      ],
      "text": "遭不幸我莫门家破人亡。",
      "text_length": 11
    },
    {
      "event_id": "03039004_e00006",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "郭仪赶打莫文禄同上，四校尉同随上。",
      "text_length": 17
    },
    {
      "event_id": "03039004_e00007",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "傅氏"
      ],
      "text": "想我夫莫怀古，不知犯了何罪，身遭惨戮，连累老身傅氏——",
      "text_length": 27
    },
    {
      "event_id": "03039004_e00008",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "傅氏"
      ],
      "text": "受此灾殃！叹我夫贪宦途远离家乡。实指望随心愿爵禄安享，不料想被刑诛枉遭祸殃。不料想抄家产田园扫荡，不料想累妻儿发往边疆。不料想年迈人长途奔往，可怜我，老和少，身戴枷锁，跋山涉水，只怕要命丧他乡。",
      "text_length": 97
    },
    {
      "event_id": "03039004_e00009",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "莫文禄"
      ],
      "text": "娘啊！",
      "text_length": 3
    },
    {
      "event_id": "03039004_e00010",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "莫文禄哭。",
      "text_length": 5
    },
    {
      "event_id": "03039004_e00011",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "拉着走！",
      "text_length": 4
    },
    {
      "event_id": "03039004_e00012",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "傅氏"
      ],
      "text": "又只见这前途人烟辐辏，有商贾和旅客来来往往、车水马龙、一个一个、好不自由。低下头看自身羞愧难受，老犯妇、幼童囚、因何故、身遭缧绁、却不知犯罪的根由。我的儿呀！",
      "text_length": 79
    },
    {
      "event_id": "03039004_e00013",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "莫文禄"
      ],
      "text": "母亲啊！",
      "text_length": 4
    },
    {
      "event_id": "03039004_e00014",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "莫文禄哭。",
      "text_length": 5
    },
    {
      "event_id": "03039004_e00015",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "拉着走！",
      "text_length": 4
    },
    {
      "event_id": "03039004_e00016",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "傅氏"
      ],
      "text": "我这里对长官躬身叩首，尊一声长官爷细听从头：我夫君犯何罪身被斩首？告知我犯妇人以免糊涂。",
      "text_length": 44
    },
    {
      "event_id": "03039004_e00017",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张龙"
      ],
      "text": "堪笑你夫心太贪，枉在黉门读书篇。妻妾田园不安享，偏想朝中作高官。",
      "text_length": 32
    },
    {
      "event_id": "03039004_e00018",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "你那丈夫，攀结权门，指望倚为靠山，得享高官厚禄。谁知反送了性命，连累妻儿发往边疆，这就是他取祸的根源。",
      "text_length": 51
    },
    {
      "event_id": "03039004_e00019",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "傅氏"
      ],
      "text": "噢！此言果然不错。啊长官，这前面是什么所在？",
      "text_length": 22
    },
    {
      "event_id": "03039004_e00020",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "待我看来。已到蓟州地界。",
      "text_length": 12
    },
    {
      "event_id": "03039004_e00021",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "傅氏"
      ],
      "text": "噢！可是我夫君受刑之处？",
      "text_length": 12
    },
    {
      "event_id": "03039004_e00022",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "03039004_e00023",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "傅氏"
      ],
      "text": "啊长官，可容犯妇哭吊一番？",
      "text_length": 13
    },
    {
      "event_id": "03039004_e00024",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "想俺张龙与郭仪兄弟原非长解，是奉了严府之命，将你押送配所，早日回去交差。若去哭吊，岂不耽误了路程！况你丈夫自己引火烧身，你何必吊他！https://scripts.xikao.com/play/030390042020-11-30",
      "text_length": 115
    },
    {
      "event_id": "03039004_e00025",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "傅氏"
      ],
      "text": "怎见得他是“引火烧身”？",
      "text_length": 12
    },
    {
      "event_id": "03039004_e00026",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "谅你不晓。郭贤弟将她带好，待俺说与她听：",
      "text_length": 20
    },
    {
      "event_id": "03039004_e00027",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "扑灯蛾",
      "speakers": [
        "张龙"
      ],
      "text": "引火烧身火烧身，不该严府荐汤勤。谁知那贼良心丧，居官忘了引荐恩。宴乐楼，饮杯巡，雪杯高擎把酒斟。严爷见杯心爱喜，开口要人将宝赠。你夫不该献赝品，难瞒裱褙认得清。严爷搜杯未到手，你夫逃走蓟州城。终被擒获斩就地，西门以外把命顷。引荐汤勤反招祸，岂非引火自烧身、自烧身？",
      "text_length": 132
    },
    {
      "event_id": "03039004_e00028",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张龙"
      ],
      "text": "呔！拉着走！",
      "text_length": 6
    },
    {
      "event_id": "03039004_e00029",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "傅氏"
      ],
      "text": "听罢了长官爷一番言论，方知道我夫君惹祸原因。无奈何咬牙关忙往前奔，",
      "text_length": 33
    },
    {
      "event_id": "03039004_e00030",
      "play_id": "03039004",
      "scene_id": "03039004_s01",
      "scene_no": 1,
