  "events": [
    {
      "event_id": "01023009_e00001",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四上手、高俊保同上。",
      "text_length": 14
    },
    {
      "event_id": "01023009_e00002",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "高俊保"
      ],
      "text": "帐中领了父帅言，命我出营去探山。",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00003",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "俺，高俊保。帐中领了父帅的将令，命我前去探山，不免就此前往。众三军！听你少爷一令。",
      "text_length": 41
    },
    {
      "event_id": "01023009_e00004",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "高俊保"
      ],
      "text": "高俊保在马上把令传，",
      "text_length": 10
    },
    {
      "event_id": "01023009_e00005",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "高俊保"
      ],
      "text": "叫声三军听我言：今日领兵把山探，鞍前马后莫偷闲。人来与爷往前趱，",
      "text_length": 32
    },
    {
      "event_id": "01023009_e00006",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四上手同转场，同下。",
      "text_length": 14
    },
    {
      "event_id": "01023009_e00007",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "去到山前看根源。",
      "text_length": 8
    },
    {
      "event_id": "01023009_e00008",
      "play_id": "01023009",
      "scene_id": "01023009_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高俊保下。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00009",
      "play_id": "01023009",
      "scene_id": "01023009_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "刘金定"
      ],
      "text": "辞别了圣母下山岗，",
      "text_length": 9
    },
    {
      "event_id": "01023009_e00010",
      "play_id": "01023009",
      "scene_id": "01023009_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四女兵、四下手、刘金定同上。",
      "text_length": 18
    },
    {
      "event_id": "01023009_e00011",
      "play_id": "01023009",
      "scene_id": "01023009_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘金定"
      ],
      "text": "师父教我的道法强。跨马提枪精神爽，双锁山前逞豪强。下山会授三件宝，叫奴领兵保宋王。旁人岂是真天子，真龙本是赵玄郎。众喽兵催动人和马，",
      "text_length": 66
    },
    {
      "event_id": "01023009_e00012",
      "play_id": "01023009",
      "scene_id": "01023009_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四女兵、四下手同走圆场，同下。",
      "text_length": 19
    },
    {
      "event_id": "01023009_e00013",
      "play_id": "01023009",
      "scene_id": "01023009_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘金定"
      ],
      "text": "下山去看是谁来摆战场。",
      "text_length": 11
    },
    {
      "event_id": "01023009_e00014",
      "play_id": "01023009",
      "scene_id": "01023009_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定蹚马，浪头，耍枪花，下。",
      "text_length": 15
    },
    {
      "event_id": "01023009_e00015",
      "play_id": "01023009",
      "scene_id": "01023009_s03",
      "scene_no": 3,
      "seq_global": 15,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘能上。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00016",
      "play_id": "01023009",
      "scene_id": "01023009_s03",
      "scene_no": 3,
      "seq_global": 16,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘能"
      ],
      "text": "时才领了姑娘命，叫我下山去巡风。急急忙忙把山下，去到山下看分明。",
      "text_length": 32
    },
    {
      "event_id": "01023009_e00017",
      "play_id": "01023009",
      "scene_id": "01023009_s03",
      "scene_no": 3,
      "seq_global": 17,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘能下。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00018",
      "play_id": "01023009",
      "scene_id": "01023009_s04",
      "scene_no": 4,
      "seq_global": 18,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四下手、四女兵、刘金定同上。",
      "text_length": 18
    },
    {
      "event_id": "01023009_e00019",
      "play_id": "01023009",
      "scene_id": "01023009_s04",
      "scene_no": 4,
      "seq_global": 19,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "刘金定"
      ],
      "text": "勒住马头用目看，双锁山上是威严。层层叠叠松柏树，重重密密是山巅。就在山巅留诗句，手持银枪把山剜。奴家本是刘金定，辞别师父下仙山。倘若遇着高俊保，奴与他定然结姻缘。一首诗句写完了，字字行行写的全。拨转马头回山转，松林之内暂停鞭。",
      "text_length": 113
    },
    {
      "event_id": "01023009_e00020",
      "play_id": "01023009",
      "scene_id": "01023009_s04",
      "scene_no": 4,
      "seq_global": 20,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定耍枪花，下，四龙套、四女兵、四下手同随下。",
      "text_length": 24
    },
    {
      "event_id": "01023009_e00021",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 21,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘能上。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00022",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 22,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "数板",
      "speakers": [
        "刘能"
      ],
      "text": "好，好，好，我来了，姑娘叫我来巡哨，只得下山瞧一瞧。我也不骑马，我也不坐轿，转仗两条腿来跑。若有人打从山下过，定要留下财和宝。你若留下便罢了，怒脑姑娘你名难保。姑娘武艺好，她的道法高。我刘能，不会半分毫。一打仗，我就跑，跑到营中睡大觉，一觉睡到天明了。吃的跑睡得着，说着说着，就来了，呵哈哦，我还是睡他娘的一大觉。",
      "text_length": 157
    },
    {
      "event_id": "01023009_e00023",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 23,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高俊保上。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00024",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 24,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "来在山前催坐战，勒住马头仔细观：山岩之上留诗句，字字行行写的全：奴家本是刘金定，辞别师父下仙山。倘若遇着高俊保，奴与他定然结姻缘。看罢诗句怒冲冠，丫头胆敢出大言。少爷本是将门后，怎能与女寇结姻缘。手提银枪把诗句铲，又见一人睡山前。向前且把小卒叫，",
      "text_length": 123
    },
    {
      "event_id": "01023009_e00025",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 25,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘能"
      ],
      "text": "抬头只见一少年。你是何人来到此？",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00026",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 26,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "你高少爷前来要洗山。",
      "text_length": 10
    },
    {
      "event_id": "01023009_e00027",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 27,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘能"
      ],
      "text": "听一言来心害怕，去对姑娘说跟芽。",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00028",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 28,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘能下。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00029",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 29,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "急忙催动坐下马，等候丫头动杀法。",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00030",
      "play_id": "01023009",
      "scene_id": "01023009_s05",
      "scene_no": 5,
      "seq_global": 30,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高俊保下。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00031",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 31,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四下手、四女兵、刘金定同上。",
      "text_length": 18
    },
    {
      "event_id": "01023009_e00032",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 32,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "山前山后来闲玩，",
      "text_length": 8
    },
    {
      "event_id": "01023009_e00033",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 33,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘能上。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00034",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 34,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "又只见刘能到跟前。",
      "text_length": 9
    },
    {
      "event_id": "01023009_e00035",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 35,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘能"
      ],
      "text": "报，报，报，报与姑娘你知道。山下来了一员将，威风凛凛甚年少。白盔白甲白旗号，凶猛非常赛虎豹。跨下一骑白鬃马，手提银枪光耀耀。他说他姓高，他要想把山寨洗平了。",
      "text_length": 78
    },
    {
      "event_id": "01023009_e00036",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 36,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘金定"
      ],
      "text": "一同追上前去。",
      "text_length": 7
    },
    {
      "event_id": "01023009_e00037",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 37,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四下手、四女兵、刘能、刘金定同转场。四龙套、四上手引高俊保同上。",
      "text_length": 36
    },
    {
      "event_id": "01023009_e00038",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 38,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "喽兵一齐往前进，要与来将动刀兵。",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00039",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 39,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定、高俊保同打过合，比式子。四龙套、四下手、四女兵、四龙套、四上手同哦那个钻烟筒下。",
      "text_length": 44
    },
    {
      "event_id": "01023009_e00040",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 40,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "问声小将通名姓，",
      "text_length": 8
    },
    {
      "event_id": "01023009_e00041",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 41,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "高俊保就是你少爷的名。",
      "text_length": 11
    },
    {
      "event_id": "01023009_e00042",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 42,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘金定"
      ],
      "text": "高俊保长得好。",
      "text_length": 7
    },
    {
      "event_id": "01023009_e00043",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 43,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "也罢了。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00044",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 44,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "叫小将进前来听奴相告，",
      "text_length": 11
    },
    {
      "event_id": "01023009_e00045",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 45,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定、高俊保二过合架枪。",
      "text_length": 13
    },
    {
      "event_id": "01023009_e00046",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 46,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "刘金定"
      ],
      "text": "细听奴家说根苗：山岩诗句留的好，你铲平字迹为哪条？你若与奴成婚配，双锁山中结鸾交。你我一同把山下，情愿同你保皇朝。你若不把亲事允，管教你性命就难逃。",
      "text_length": 74
    },
    {
      "event_id": "01023009_e00047",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 47,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "丫头休得来逞强，细听少爷说端详：我本堂堂有名将，怎能与你配鸾凰？你若再要胡言讲，管叫你枪下一命亡。",
      "text_length": 49
    },
    {
      "event_id": "01023009_e00048",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 48,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "听一言来怒气生，不由奴家动无名。手执银枪将尔刺，",
      "text_length": 24
    },
    {
      "event_id": "01023009_e00049",
      "play_id": "01023009",
      "scene_id": "01023009_s06",
      "scene_no": 6,
      "seq_global": 49,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定、高俊保同起打，快枪。刘金定败下，高俊保拉下场花，下。",
      "text_length": 30
    },
    {
      "event_id": "01023009_e00050",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 50,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定上。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00051",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 51,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "小将武艺时可夸，杀得奴家两眼花。急忙掐诀念咒语，遣来了六丁合六甲。",
      "text_length": 33
    },
    {
      "event_id": "01023009_e00052",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 52,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小鬼持风旗同上。",
      "text_length": 9
    },
    {
      "event_id": "01023009_e00053",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 53,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "山前来了高俊保，命你前去将他拿。",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00054",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 54,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小鬼同下。",
      "text_length": 6
    },
    {
      "event_id": "01023009_e00055",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 55,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "回头再把土地叫，",
      "text_length": 8
    },
    {
      "event_id": "01023009_e00056",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 56,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "土地上。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00057",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 57,
      "seq_in_scene": 8,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "土地"
      ],
      "text": "参见道姑。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00058",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 58,
      "seq_in_scene": 9,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "将小将吊在半山崖。莫要伤了他性命，他本是栋梁保皇家。拨转马头追小将，奴再与他动杀法。",
      "text_length": 42
    },
    {
      "event_id": "01023009_e00059",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 59,
      "seq_in_scene": 10,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定下。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00060",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 60,
      "seq_in_scene": 11,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "土地"
      ],
      "text": "道姑已去，待吾变来。一变二变，樵夫出现。",
      "text_length": 20
    },
    {
      "event_id": "01023009_e00061",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 61,
      "seq_in_scene": 12,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "土地扮樵夫。",
      "text_length": 6
    },
    {
      "event_id": "01023009_e00062",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 62,
      "seq_in_scene": 13,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "土地"
      ],
      "text": "这还无有柴担，待我用拐杖变来。看柴担已有了，待我在此。等候他便了。",
      "text_length": 33
    },
    {
      "event_id": "01023009_e00063",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 63,
      "seq_in_scene": 14,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "土地下。【【第八场】",
      "text_length": 10
    },
    {
      "event_id": "01023009_e00064",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 64,
      "seq_in_scene": 15,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高俊保上。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00065",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 65,
      "seq_in_scene": 16,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "催马来到山岗上，待等丫头摆战场。",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00066",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 66,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定上，打过合。四小鬼同上，同托高俊保上桌子。刘金定下。樵夫上。",
      "text_length": 33
    },
    {
      "event_id": "01023009_e00067",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 67,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "樵夫"
      ],
      "text": "老汉今年八十八，一生尚未成过家。娶了一个老伴九十二，我两个人足足一百八。每日上山把柴打，回家把米面糊涂揸。每人咂上一二碗，预备明年抱娃娃。",
      "text_length": 69
    },
    {
      "event_id": "01023009_e00068",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 68,
      "seq_in_scene": 19,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "这丫头也不知怎样，把我引到这山岩之上，我是怎生下去？看下面有一老汉，带我唤他一声。老伯伯请了！",
      "text_length": 47
    },
    {
      "event_id": "01023009_e00069",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 69,
      "seq_in_scene": 20,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "何人唤我？",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00070",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 70,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "老伯请了。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00071",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 71,
      "seq_in_scene": 22,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "你这个娃娃，怎么跑到山岩上去玩耍？倘若跌将下来，那还了得！",
      "text_length": 29
    },
    {
      "event_id": "01023009_e00072",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 72,
      "seq_in_scene": 23,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "老伯，你在那里作甚？",
      "text_length": 10
    },
    {
      "event_id": "01023009_e00073",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 73,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "老汉在此砍。",
      "text_length": 6
    },
    {
      "event_id": "01023009_e00074",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 74,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "你若大的年纪，怎么还砍呐？",
      "text_length": 13
    },
    {
      "event_id": "01023009_e00075",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 75,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "嗳。老汉在此砍樵。",
      "text_length": 9
    },
    {
      "event_id": "01023009_e00076",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 76,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "望求老伯，救我一救。",
      "text_length": 10
    },
    {
      "event_id": "01023009_e00077",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 77,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "要我救你，也倒不难。待我将柴担捆好了。",
      "text_length": 19
    },
    {
      "event_id": "01023009_e00078",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 78,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "老伯伯你来呀。",
      "text_length": 7
    },
    {
      "event_id": "01023009_e00079",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 79,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "樵夫"
      ],
      "text": "我来了。",
      "text_length": 4
    },
    {
      "event_id": "01023009_e00080",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 80,
      "seq_in_scene": 31,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小鬼同上，用风旗遮高俊保，樵夫下。",
      "text_length": 18
    },
    {
      "event_id": "01023009_e00081",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 81,
      "seq_in_scene": 32,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "不、不好了！",
      "text_length": 6
    },
    {
      "event_id": "01023009_e00082",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 82,
      "seq_in_scene": 33,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "高俊保"
      ],
      "text": "中了丫头牢笼计，将我吊在半山漥。倘若失足跌下去，定然一命染黄沙。我哭一声父帅，叫一声老爹爹！嗳嗳，我的娘吓！",
      "text_length": 54
    },
    {
      "event_id": "01023009_e00083",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 83,
      "seq_in_scene": 34,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘金定上。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00084",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 84,
      "seq_in_scene": 35,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘金定"
      ],
      "text": "叫声小将休逞能，少时叫你一名倾。",
      "text_length": 16
    },
    {
      "event_id": "01023009_e00085",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 85,
      "seq_in_scene": 36,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "刘小姐，刘姑娘，你将我放下山来吧！",
      "text_length": 17
    },
    {
      "event_id": "01023009_e00086",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 86,
      "seq_in_scene": 37,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘金定"
      ],
      "text": "叫姑娘放你倒也不难，只是姻缘之事如何？",
      "text_length": 19
    },
    {
      "event_id": "01023009_e00087",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 87,
      "seq_in_scene": 38,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "我从下就是。",
      "text_length": 6
    },
    {
      "event_id": "01023009_e00088",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 88,
      "seq_in_scene": 39,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘金定"
      ],
      "text": "恐怕你还有三心二意，必须对天明誓。",
      "text_length": 17
    },
    {
      "event_id": "01023009_e00089",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 89,
      "seq_in_scene": 40,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "我若有三心二意，叫天厌之，天厌之！",
      "text_length": 17
    },
    {
      "event_id": "01023009_e00090",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 90,
      "seq_in_scene": 41,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘金定"
      ],
      "text": "众神速退。",
      "text_length": 5
    },
    {
      "event_id": "01023009_e00091",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 91,
      "seq_in_scene": 42,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小鬼同下。高俊保自桌下。",
      "text_length": 13
    },
    {
      "event_id": "01023009_e00092",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 92,
      "seq_in_scene": 43,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘金定"
      ],
      "text": "山寨摆宴与将军接风。歇兵三日，同下南唐。",
      "text_length": 20
    },
    {
      "event_id": "01023009_e00093",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 93,
      "seq_in_scene": 44,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高俊保"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "01023009_e00094",
      "play_id": "01023009",
      "scene_id": "01023009_s07",
      "scene_no": 7,
      "seq_global": 94,
      "seq_in_scene": 45,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吹牌子。刘金定、高俊保同下。",
      "text_length": 14
    }
  ],
  "roles_inferred": true
}