      "speakers": [],
      "text": "香柳娘",
      "text_length": 3
    },
    {
      "event_id": "70902145_e00006",
      "play_id": "70902145",
      "scene_id": "70902145_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
