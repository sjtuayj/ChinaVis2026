  "events": [
    {
      "event_id": "01021008_e00001",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四青袍、丑院子抬董洪同上。丑院子上桌，开水牢门，四青袍同送董洪下水牢。四青袍、丑院子同下。",
      "text_length": 45
    },
    {
      "event_id": "01021008_e00002",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "我当是什么所在，原来是一座水牢。今日到此，只恐性命难保了！",
      "text_length": 29
    },
    {
      "event_id": "01021008_e00003",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "董洪"
      ],
      "text": "悔不该打从这贼府门过，又谁知平地里其了风波。打在了水牢内身糟大祸，只怕我这今生命难活。",
      "text_length": 43
    },
    {
      "event_id": "01021008_e00004",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "哎呀，且住！想我今日，落在水牢之中，是怎生逃得性命？待我四下看来。",
      "text_length": 33
    },
    {
      "event_id": "01021008_e00005",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "董洪"
      ],
      "text": "来在这水牢内用目观看，四下里黑洞洞暗不见天。只觉得我脚下有物来绊，急忙向前看根源。",
      "text_length": 41
    },
    {
      "event_id": "01021008_e00006",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "正行之间，只觉得有什么东西，将我绊了一下，待我向前摸上一摸。哎呀呀，原来是一个死尸。打鬼！打鬼！哎，想我董洪，被奸贼刘玉龙，将我打在水牢，看看待死，还怕的什么鬼？待我向前在摸上一摸，看看是男是女。原来是一老者，他怀中是什么东西，待我取出来观看。原来是一颗印信。想这水牢里边，哪里来得这颗印信？待我将自己的印信取出来，与他对上一对。哈哈，双合印，双合印！呵呵！是了，此人想必是前任巡按黄朝宗，带印前来私访，被刘玉龙看破，将他打入水牢而死。黄年兄吓！你死在此地，真真可谓无才！咳，说什么有才无才，想我董洪，却倒有才，为何也来在水牢里面？可说是海老师吓，海刚峰！你今日保举与我，明日保举与我，保来保去，将门生，可就保举在这水牢之中了！",
      "text_length": 314
    },
    {
      "event_id": "01021008_e00007",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "董洪"
      ],
      "text": "心中只把刘贼恨，害得我董洪好惨情。今日落在水牢内，要想逃生万不能。",
      "text_length": 33
    },
    {
      "event_id": "01021008_e00008",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "王月梅"
      ],
      "text": "走吓！",
      "text_length": 3
    },
    {
      "event_id": "01021008_e00009",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王月梅上。",
      "text_length": 5
    },
    {
      "event_id": "01021008_e00010",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王月梅"
      ],
      "text": "忽听得谯楼上起了更，王月梅出了绣房中。将身且把花园进，见了那老夫人去问安宁。",
      "text_length": 38
    },
    {
      "event_id": "01021008_e00011",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "我，王月梅。我父王永，官拜首相。得罪严嵩，被他陷害，全家遭斩。是我打从后花园逃出，连夜赶出皇城，来在此地。不料又被刘玉龙将我掠进府来，要与我成亲。是我再三不允，刘贼大怒，就要将我乱棍打死。多蒙老夫人，与我讲情，才得了活命。就在老夫人跟前，做了一个侍女丫鬟。颇蒙老夫人抬爱，是我一天三次，前去问安。今日晚饭用过，不免到老夫人那里问安便了。",
      "text_length": 168
    },
    {
      "event_id": "01021008_e00012",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王月梅"
      ],
      "text": "轻移莲步出花园，去到后堂来问安。有一物将我足来螫，手持银灯细看一番。",
      "text_length": 34
    },
    {
      "event_id": "01021008_e00013",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "慢着！行走之间，不只是什么东西将我的脚螫了一下，待我看来。原来是一个锁上的钥匙。呵呵，是了！想是刘玉龙，又抢了人家的妇女，不肯允从，被他打入水牢里面，将钥匙失落在此。我不免去到水牢，问个明白。她若是良家妇女，我便将她救出，叫她逃命。她若是歹人家的妇女，我便不管。就此走走。",
      "text_length": 136
    },
    {
      "event_id": "01021008_e00014",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "王月梅"
      ],
      "text": "急急走来急急行，去到水牢问详情。",
      "text_length": 16
    },
    {
      "event_id": "01021008_e00015",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "待我听他说些什么。",
      "text_length": 9
    },
    {
      "event_id": "01021008_e00016",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "想我董洪身为八府巡按，来在此地私访，不料被刘玉龙奸贼，将我暴打一顿，推入水牢，断无生理。怎奈我有三件大事在心，纵死九泉，也难瞑目。我这头一件，家中老母年迈，无人侍奉；第二件，我定下妻氏，尚未成婚；这第三件，我今以死，无人知晓，不能与我报仇。可说是海老师，海刚峰！你今日蒙你保举，明日蒙你保举，保来保去，将门生，可就保举在这水牢之中来了！",
      "text_length": 168
    },
    {
      "event_id": "01021008_e00017",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "呔，水牢之内，是什么人讲话？",
      "text_length": 14
    },
    {
      "event_id": "01021008_e00018",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "水牢中，无有人吓。",
      "text_length": 9
    },
    {
      "event_id": "01021008_e00019",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "分明你在水牢里面讲话，怎说是无人？",
      "text_length": 17
    },
    {
      "event_id": "01021008_e00020",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "呵呵是了！想是刘贼叫人前来害我。也罢，事已至此，听天由命而已。",
      "text_length": 31
    },
    {
      "event_id": "01021008_e00021",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "我说你且不要害怕，你若说出真名实姓，我便将你救出。",
      "text_length": 25
    },
    {
      "event_id": "01021008_e00022",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "你是何人啊？",
      "text_length": 6
    },
    {
      "event_id": "01021008_e00023",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "我是这府中的丫鬟，你方才的言语，我已听得明白。待我将牢门的锁开了，救你就是。",
      "text_length": 38
    },
    {
      "event_id": "01021008_e00024",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "多蒙丫鬟姐打救。我感恩非浅。",
      "text_length": 14
    },
    {
      "event_id": "01021008_e00025",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "你等着罢。",
      "text_length": 5
    },
    {
      "event_id": "01021008_e00026",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王月梅持匙开锁，匙断。王月梅持砖打锁落地。推开牢门，解汗巾，持巾在牢门摆。",
      "text_length": 37
    },
    {
      "event_id": "01021008_e00027",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "我用汗巾在牢门口，摆来摆去，你可曾够得着么？",
      "text_length": 22
    },
    {
      "event_id": "01021008_e00028",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "我实实的够不着。（王月梅想，看足，去缠足布，接汗巾，连断三次，上桌，摆汗巾。董洪持巾头登，巾断。王月梅复接巾，救董洪上。）",
      "text_length": 61
    },
    {
      "event_id": "01021008_e00029",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "多蒙丫鬟姐救命之恩，日后定当酬报。我告辞了。",
      "text_length": 22
    },
    {
      "event_id": "01021008_e00030",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王月梅坐地缠足。",
      "text_length": 8
    },
    {
      "event_id": "01021008_e00031",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "你快快逃走吧！",
      "text_length": 7
    },
    {
      "event_id": "01021008_e00032",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "走不得！走不得！",
      "text_length": 8
    },
    {
      "event_id": "01021008_e00033",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "你为何不走？",
      "text_length": 6
    },
    {
      "event_id": "01021008_e00034",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "想这黑夜之间，我不认识路境，叫我往哪里逃走？",
      "text_length": 22
    },
    {
      "event_id": "01021008_e00035",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "既然如此，待我送你出去。",
      "text_length": 12
    },
    {
      "event_id": "01021008_e00036",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王月梅提缠足布扯董洪同走转场，王月梅坐地。",
      "text_length": 21
    },
    {
      "event_id": "01021008_e00037",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "你就从此处出去吧！",
      "text_length": 9
    },
    {
      "event_id": "01021008_e00038",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "告辞了。去不得！去不得！",
      "text_length": 12
    },
    {
      "event_id": "01021008_e00039",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "你为何去而复返？",
      "text_length": 8
    },
    {
      "event_id": "01021008_e00040",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "你在此做什么呀。",
      "text_length": 8
    },
    {
      "event_id": "01021008_e00041",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "我们在这儿裹脚呐。",
      "text_length": 9
    },
    {
      "event_id": "01021008_e00042",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "吓！丫鬟姐！你今将我放走。倘被那刘贼知道，他岂肯与你干休？",
      "text_length": 29
    },
    {
      "event_id": "01021008_e00043",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "你只管逃走，我自有妙计，脱离虎口。",
      "text_length": 17
    },
    {
      "event_id": "01021008_e00044",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "听她之言，倒不像小家之女。待我向前问来。请问丫鬟姐贵姓高名，对我说来，日后定要酬报。",
      "text_length": 42
    },
    {
      "event_id": "01021008_e00045",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "奴家王月梅。我父王永，管拜当朝首相，被严嵩陷害，全家抄斩。是我一人，逃出皇城，来在此处。又被刘玉龙，将我掠进府来，就要成亲。是我再三不允，刘贼就要将我乱棍打死。多亏老夫人讲情，才得活命。我就在老夫人前做了一个侍女丫鬟。",
      "text_length": 109
    },
    {
      "event_id": "01021008_e00046",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "原来是一位千金小姐，多蒙救命之恩。无以为报。意欲与你，成却了这——",
      "text_length": 33
    },
    {
      "event_id": "01021008_e00047",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "若要成亲，却也使得，只是你我日后在哪里相会？",
      "text_length": 22
    },
    {
      "event_id": "01021008_e00048",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "此地离顺德府城不远。你去投奔总兵李大人那里，安身便了。",
      "text_length": 27
    },
    {
      "event_id": "01021008_e00049",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "我乃女流之辈，与李大人夙不相识。他是怎肯收留与我？",
      "text_length": 25
    },
    {
      "event_id": "01021008_e00050",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "这有按院大人印信一颗。你就说我董洪叫你来的，他定要收留与你。",
      "text_length": 30
    },
    {
      "event_id": "01021008_e00051",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "如此甚好。天已不早，你快快逃走了吧。",
      "text_length": 18
    },
    {
      "event_id": "01021008_e00052",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "董洪"
      ],
      "text": "正是：",
      "text_length": 3
    },
    {
      "event_id": "01021008_e00053",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "董洪"
      ],
      "text": "鳌鱼脱却金钩钓，摆尾摇头再不来。",
      "text_length": 16
    },
    {
      "event_id": "01021008_e00054",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "董洪下。",
      "text_length": 4
    },
    {
      "event_id": "01021008_e00055",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王月梅"
      ],
      "text": "带我去至绣房，打点行李，带些金银，连夜逃走了吧。",
      "text_length": 24
    },
    {
      "event_id": "01021008_e00056",
      "play_id": "01021008",
      "scene_id": "01021008_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吹牌子。王月梅下。",
      "text_length": 9
    }
  ],
  "roles_inferred": true
}