  "events": [
    {
      "event_id": "94000001_e00001",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四宫女引孙尚香同上。",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00002",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "孙尚香"
      ],
      "text": "恹恹守损，怎能消，终日愁闷。",
      "text_length": 14
    },
    {
      "event_id": "94000001_e00003",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙尚香"
      ],
      "text": "别君常挂念，难忘夫妻恩。虽无千丈线，万里系人心。",
      "text_length": 24
    },
    {
      "event_id": "94000001_e00004",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "奴家孙尚香。只因兄王孙权，与周郎定下美人之计，将刘皇叔诓下东吴，谁知弄假成真，母后作主，将我许配皇叔为偶，一同回转荆州；未到三载，又差周善将我诓回。思想起来，好不愁闷人也！",
      "text_length": 86
    },
    {
      "event_id": "94000001_e00005",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "坐吴宫每日里长吁短叹，思想起已往事好不惨然！遭不幸父王爷命丧一旦，我兄长继父业执掌江南。与周郎定巧计把皇叔来骗，又谁知弄假成真反配凤鸾。回荆州未三载诓我回转，阿斗儿在中途被子龙追还。恨只恨我兄长把事办错，拆散我好夫妻人各一天。",
      "text_length": 113
    },
    {
      "event_id": "94000001_e00006",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监上。",
      "text_length": 5
    },
    {
      "event_id": "94000001_e00007",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "启郡主：大事不好啦。",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00008",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "94000001_e00009",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "刘皇叔晏驾白帝城。",
      "text_length": 9
    },
    {
      "event_id": "94000001_e00010",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "怎么讲？",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00011",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "刘皇叔晏驾白帝城啦。",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00012",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "94000001_e00013",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香昏去。",
      "text_length": 6
    },
    {
      "event_id": "94000001_e00014",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "孙尚香"
      ],
      "text": "听皇叔白帝城龙驾已晏，",
      "text_length": 11
    },
    {
      "event_id": "94000001_e00015",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "皇叔，夫主，喂呀夫哇……",
      "text_length": 12
    },
    {
      "event_id": "94000001_e00016",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙尚香"
      ],
      "text": "好一似万把刀刺在心间。可叹你为江山经百战，",
      "text_length": 21
    },
    {
      "event_id": "94000001_e00017",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "孙尚香"
      ],
      "text": "皇叔哇！梦不想一旦间命赴黄泉！",
      "text_length": 15
    },
    {
      "event_id": "94000001_e00018",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "且住！皇叔晏驾，我不免换了孝服，进宫辞别母后，去到江边一祭。宫娥们，伺候了！",
      "text_length": 38
    },
    {
      "event_id": "94000001_e00019",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香换孝服。",
      "text_length": 7
    },
    {
      "event_id": "94000001_e00020",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "孙尚香"
      ],
      "text": "喂呀……",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00021",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙尚香"
      ],
      "text": "宫娥女忙引路把母后去见，",
      "text_length": 12
    },
    {
      "event_id": "94000001_e00022",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监暗下。",
      "text_length": 6
    },
    {
      "event_id": "94000001_e00023",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙尚香"
      ],
      "text": "长寿宫见母后细说一番。",
      "text_length": 11
    },
    {
      "event_id": "94000001_e00024",
      "play_id": "94000001",
      "scene_id": "94000001_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四宫女引孙尚香同下。",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00025",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "吴国太"
      ],
      "text": "一日清闲一日安，",
      "text_length": 8
    },
    {
      "event_id": "94000001_e00026",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二大太监引吴国太同上。",
      "text_length": 11
    },
    {
      "event_id": "94000001_e00027",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "吴国太"
      ],
      "text": "光阴一去不回还！我儿孙权身荣显，承父兄基业镇江南。可恨那曹丕把位篡，图谋汉室锦江山。我婿刘备重兴汉，",
      "text_length": 50
    },
    {
      "event_id": "94000001_e00028",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "吴国太"
      ],
      "text": "称孤道寡坐西川。将身且坐皇宫院，",
      "text_length": 16
    },
    {
      "event_id": "94000001_e00029",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "等候尚香来问安。",
      "text_length": 8
    },
    {
      "event_id": "94000001_e00030",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四宫女引孙尚香同上。",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00031",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "叹夫君白帝城把驾晏，去愁容忍悲泪问娘金安。",
      "text_length": 21
    },
    {
      "event_id": "94000001_e00032",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "尚香见驾，母后千岁。",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00033",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "皇儿平身。",
      "text_length": 5
    },
    {
      "event_id": "94000001_e00034",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "千千岁。",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00035",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "赐座。",
      "text_length": 3
    },
    {
      "event_id": "94000001_e00036",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "谢母后。",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00037",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "孙尚香"
      ],
      "text": "喂呀……",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00038",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "啊？我儿今日进宫身穿素服，面带泪痕是何缘故？",
      "text_length": 22
    },
    {
      "event_id": "94000001_e00039",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后哇！",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00040",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "时才宫人报道，刘皇叔晏驾白帝城了……",
      "text_length": 18
    },
    {
      "event_id": "94000001_e00041",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "孙尚香"
      ],
      "text": "哇！",
      "text_length": 2
    },
    {
      "event_id": "94000001_e00042",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "哦！刘皇叔晏驾白帝城了？",
      "text_length": 12
    },
    {
      "event_id": "94000001_e00043",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "94000001_e00044",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "孙尚香"
      ],
      "text": "喂呀……",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00045",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "咳！可伤啊可伤呀！",
      "text_length": 9
    },
    {
      "event_id": "94000001_e00046",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "为此，女儿身穿孝服，要到江边一祭；特来辞别母后。",
      "text_length": 24
    },
    {
      "event_id": "94000001_e00047",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "去往江边祭奠，多有不便；不如就在宫中备下祭礼，祭奠一番也就是了。",
      "text_length": 32
    },
    {
      "event_id": "94000001_e00048",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "咳，母后哇！",
      "text_length": 6
    },
    {
      "event_id": "94000001_e00049",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后说话理太偏，细听女儿说根源：回荆州未及三年满，又差周善诓儿还。到如今不容儿江边祭奠，怎不叫儿珠泪涟！",
      "text_length": 52
    },
    {
      "event_id": "94000001_e00050",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "儿啊！",
      "text_length": 3
    },
    {
      "event_id": "94000001_e00051",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "吴国太"
      ],
      "text": "我的儿不必泪满面，细听为娘把话言：儿嫁那刘备娘心愿，送儿到荆州有三年；接儿回转差周善，母女们分别才得团圆。江边祭奠空祭奠，一滴何曾到九泉？",
      "text_length": 69
    },
    {
      "event_id": "94000001_e00052",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后啊！",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00053",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "孙尚香"
      ],
      "text": "儿在东吴心在汉，夫妻永别不团圆。当年为讨荆州郡，把儿定计就理不端。说什么祭奠空祭奠，一滴怎不能够到九泉！",
      "text_length": 52
    },
    {
      "event_id": "94000001_e00054",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "吴国太"
      ],
      "text": "我的儿不必来埋怨，提起往事也枉然。夫妻好比同林鸟，大限来时各一天。",
      "text_length": 33
    },
    {
      "event_id": "94000001_e00055",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "孙尚香"
      ],
      "text": "昔日里有个孟姜女，千里寻夫到城边。哭倒了长城人称赞，留得美名万古传。夫死不容儿祭奠，就不该当初配夫男！母后空把弥陀念，往日贤来，如今反不贤。",
      "text_length": 70
    },
    {
      "event_id": "94000001_e00056",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿说话失检点，讲什么古来论的什么贤！为娘我坐在皇宫院，看哪个大胆到江边！",
      "text_length": 37
    },
    {
      "event_id": "94000001_e00057",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "孙尚香"
      ],
      "text": "儿今一心要祭奠！",
      "text_length": 8
    },
    {
      "event_id": "94000001_e00058",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "吴国太"
      ],
      "text": "为娘我一定要阻拦！",
      "text_length": 9
    },
    {
      "event_id": "94000001_e00059",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "94000001_e00060",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后不容儿祭奠，",
      "text_length": 8
    },
    {
      "event_id": "94000001_e00061",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "罢！",
      "text_length": 2
    },
    {
      "event_id": "94000001_e00062",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙尚香"
      ],
      "text": "不如碰死在娘前！",
      "text_length": 8
    },
    {
      "event_id": "94000001_e00063",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "且慢！",
      "text_length": 3
    },
    {
      "event_id": "94000001_e00064",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿不必寻短见，为娘同儿到江边。",
      "text_length": 16
    },
    {
      "event_id": "94000001_e00065",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿定要江边祭奠，也不阻拦于你；待为娘同儿前去就是。",
      "text_length": 26
    },
    {
      "event_id": "94000001_e00066",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "这个……女儿怎敢劳动母后。有宫娥陪伴就是了……",
      "text_length": 23
    },
    {
      "event_id": "94000001_e00067",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "孙尚香"
      ],
      "text": "哇！",
      "text_length": 2
    },
    {
      "event_id": "94000001_e00068",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "有宫娥陪伴，我放心不下。也罢，为娘赐你半副銮驾护送前往，儿要早去早回。",
      "text_length": 35
    },
    {
      "event_id": "94000001_e00069",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "如此，母后请上，女儿我拜别。",
      "text_length": 14
    },
    {
      "event_id": "94000001_e00070",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "啊？江边祭奠，去去就回，何言“拜别”二字？",
      "text_length": 21
    },
    {
      "event_id": "94000001_e00071",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后哇！",
      "text_length": 4
    },
    {
      "event_id": "94000001_e00072",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "孙尚香"
      ],
      "text": "虽然暂别皇宫院，为人须要礼当先；儿愿母后多健康，儿原母后福寿全。辞别母后出宫院，",
      "text_length": 40
    },
    {
      "event_id": "94000001_e00073",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四宫女同下。",
      "text_length": 6
    },
    {
      "event_id": "94000001_e00074",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙尚香"
      ],
      "text": "我母后不解巧机关。",
      "text_length": 9
    },
    {
      "event_id": "94000001_e00075",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香下。",
      "text_length": 5
    },
    {
      "event_id": "94000001_e00076",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "吴国太"
      ],
      "text": "我儿定要去祭奠，满怀心事话难言。尚香儿若有长和短，",
      "text_length": 25
    },
    {
      "event_id": "94000001_e00077",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 53,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二大太监同下。",
      "text_length": 7
    },
    {
      "event_id": "94000001_e00078",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 54,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "吴国太"
      ],
      "text": "暮景残年谁问安！",
      "text_length": 8
    },
    {
      "event_id": "94000001_e00079",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 55,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "吴国太下。《祭江》",
      "text_length": 9
    },
    {
      "event_id": "94000001_e00080",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 56,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "孙尚香"
      ],
      "text": "摆驾！",
      "text_length": 3
    },
    {
      "event_id": "94000001_e00081",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 57,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四小太监、四宫女、二大太监、孙尚香、车夫同上。",
      "text_length": 27
    },
    {
      "event_id": "94000001_e00082",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 58,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "想当年截江事无限悔恨，背夫主撇娇儿两地离分；闻皇叔白帝城丧了性命，到江边去祭奠好不伤情。⑴",
      "text_length": 45
    },
    {
      "event_id": "94000001_e00083",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 59,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "启禀郡主：来到江边。",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00084",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 60,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "祭礼摆下！",
      "text_length": 5
    },
    {
      "event_id": "94000001_e00085",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 61,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "祭礼摆下！",
      "text_length": 5
    },
    {
      "event_id": "94000001_e00086",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 62,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖哭皇天〗。二大太监同设香案，孙尚香焚香祭奠。",
      "text_length": 23
    },
    {
      "event_id": "94000001_e00087",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 63,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "两厢退下！",
      "text_length": 5
    },
    {
      "event_id": "94000001_e00088",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 64,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四大铠、四小太监、四宫女、二大太监、车夫自两边分下。",
      "text_length": 26
    },
    {
      "event_id": "94000001_e00089",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 65,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙尚香"
      ],
      "text": "设祭长江岸，举目望西山。梦魂何日见，空教泪不干！",
      "text_length": 24
    },
    {
      "event_id": "94000001_e00090",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 66,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "孙尚香"
      ],
      "text": "在江边摆祭礼悲声告禀，",
      "text_length": 11
    },
    {
      "event_id": "94000001_e00091",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 67,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙尚香"
      ],
      "text": "皇叔，夫主，喂呀……",
      "text_length": 10
    },
    {
      "event_id": "94000001_e00092",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 92,
      "seq_in_scene": 68,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反回龙",
      "speakers": [
        "孙尚香"
      ],
      "text": "尊一声汉皇叔在天之灵。",
      "text_length": 11
    },
    {
      "event_id": "94000001_e00093",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 93,
      "seq_in_scene": 69,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "好夫妻恶因缘衷情难尽，半空中当鉴我一点诚心。可叹你大英雄出世受困，可叹你结桃园义功死生；可叹你下南阳把诸葛搬请，可叹你烧赤壁同破曹兵。⑵好容易得西川身立未稳，偏遇到讨荆州二弟丧生；未报仇战虢亭遇着陆逊，失机谋被他人火烧连营。⑶辜负了兴汉室基业初定，辜负了平生志万里鹏程。看将来叹人生总是梦境，倒不如殉一死以报亡魂。",
      "text_length": 157
    },
    {
      "event_id": "94000001_e00094",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 94,
      "seq_in_scene": 70,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖反哭皇天〗。孙尚香祭。",
      "text_length": 12
    },
    {
      "event_id": "94000001_e00095",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 95,
      "seq_in_scene": 71,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "且住！想皇叔一死，我有何面目回转西川；留在东吴，兄长又岂能容我。也罢！不免拜别母后养育之恩，寻个自尽了吧……",
      "text_length": 54
    },
    {
      "event_id": "94000001_e00096",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 96,
      "seq_in_scene": 72,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反二黄散板",
      "speakers": [
        "孙尚香"
      ],
      "text": "江水滔滔波浪滚，尚香拜别养育恩。",
      "text_length": 16
    },
    {
      "event_id": "94000001_e00097",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 97,
      "seq_in_scene": 73,
      "page_no": 4,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "孙尚香"
      ],
      "text": "叫声皇叔你且等……",
      "text_length": 9
    },
    {
      "event_id": "94000001_e00098",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 98,
      "seq_in_scene": 74,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "也罢！",
      "text_length": 3
    },
    {
      "event_id": "94000001_e00099",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 99,
      "seq_in_scene": 75,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香投江，下。——————————⑴此段另有四句唱词可供参考：",
      "text_length": 32
    },
    {
      "event_id": "94000001_e00100",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 100,
      "seq_in_scene": 76,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "曾记得当年来此郡，浪打鸳鸯两离分；从今不照菱花镜，清风一去未亡人。⑵此段有的增唱两句：",
      "text_length": 43
    },
    {
      "event_id": "94000001_e00101",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 101,
      "seq_in_scene": 77,
      "page_no": 5,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "可叹你占荆州周郎不急，周郎不忿，皇叔哇！可叹你入虎穴东吴招亲。⑶此段有的增唱两句：",
      "text_length": 41
    },
    {
      "event_id": "94000001_e00102",
      "play_id": "94000001",
      "scene_id": "94000001_s02",
      "scene_no": 2,
      "seq_global": 102,
      "seq_in_scene": 78,
      "page_no": 5,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "辜负了五虎将九泉遗恨，辜负了诸葛亮赤胆忠心。",
      "text_length": 22
    }
  ],
  "roles_inferred": true
}