  "events": [
    {
      "event_id": "70001203_e00001",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监引孙权上。",
      "text_length": 8
    },
    {
      "event_id": "70001203_e00002",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "孙权"
      ],
      "text": "中原大势三分鼎，霸主江东万代馨。",
      "text_length": 16
    },
    {
      "event_id": "70001203_e00003",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙权"
      ],
      "text": "赤壁鏖兵余火残，孙刘联合拒曹瞒。楼桑大耳真无信，借占荆州久不还。",
      "text_length": 32
    },
    {
      "event_id": "70001203_e00004",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "孤孙权，只因赤壁鏖兵，我东吴费了兵马钱粮，刘备坐收渔人之利，占据荆州，久借不还，今刘备取得西川曾命诸葛瑾前去索讨，刘备允许暂还三郡，可恨关羽不允，今调鲁肃回朝，共同商议，还未到来？",
      "text_length": 90
    },
    {
      "event_id": "70001203_e00005",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监上。",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00006",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "启奏千岁：鲁都督回朝。",
      "text_length": 11
    },
    {
      "event_id": "70001203_e00007",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "宣他上殿。",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00008",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "千岁有旨：鲁都督上殿。",
      "text_length": 11
    },
    {
      "event_id": "70001203_e00009",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "鲁肃"
      ],
      "text": "领旨！",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00010",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "鲁肃上。",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00011",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "鲁肃"
      ],
      "text": "刘备全无信，孔明弄巧心。荆州久不返，鲁肃作难人。",
      "text_length": 24
    },
    {
      "event_id": "70001203_e00012",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "臣鲁肃见驾，吴侯千岁。",
      "text_length": 11
    },
    {
      "event_id": "70001203_e00013",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "平身。",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00014",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "千千岁。",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00015",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "赐座。",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00016",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "谢座。宣臣回朝，莫非为了荆州之事？",
      "text_length": 17
    },
    {
      "event_id": "70001203_e00017",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "诸葛瑾入川，刘备允许暂还长沙、零陵，桂阳三郡，可恨关羽执意不还，反将诸葛瑾羞辱一场。你道恼是不恼！",
      "text_length": 49
    },
    {
      "event_id": "70001203_e00018",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "70001203_e00019",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "鲁肃"
      ],
      "text": "那刘备作事无信义，我鲁肃无才惹是非。",
      "text_length": 18
    },
    {
      "event_id": "70001203_e00020",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "当初刘备借荆州，可是你的保？",
      "text_length": 14
    },
    {
      "event_id": "70001203_e00021",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "是鲁肃作的保。",
      "text_length": 7
    },
    {
      "event_id": "70001203_e00022",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "他不还荆州，你这保人又待怎样？",
      "text_length": 15
    },
    {
      "event_id": "70001203_e00023",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "千岁！",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00024",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "鲁肃"
      ],
      "text": "鲁肃作保要保到底，",
      "text_length": 9
    },
    {
      "event_id": "70001203_e00025",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "荆州一日不还，你这保人就难脱关系。",
      "text_length": 17
    },
    {
      "event_id": "70001203_e00026",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "千岁吓！",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00027",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "鲁肃"
      ],
      "text": "为此事昼夜费心机。今日定下了三条计，他不还荆州定不依。",
      "text_length": 27
    },
    {
      "event_id": "70001203_e00028",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "但不知哪三条计？这一？",
      "text_length": 11
    },
    {
      "event_id": "70001203_e00029",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "第一条计，就以庆贺刘备进位汉中王为由，修下书信一封，命人下到荆州，请那关云长过江赴宴。",
      "text_length": 43
    },
    {
      "event_id": "70001203_e00030",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "哦，请那关云长过江赴宴！你料他来是不来？",
      "text_length": 20
    },
    {
      "event_id": "70001203_e00031",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "他若不来，便是惧怕我东吴，料那关云长性情高傲，他必然前来！酒席筵前，还了荆州，万事全休——",
      "text_length": 45
    },
    {
      "event_id": "70001203_e00032",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "若是不还？",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00033",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "在衣壁之中，暗藏甲士，击杯为号，伏兵齐起，擒着关羽囚于江东。",
      "text_length": 30
    },
    {
      "event_id": "70001203_e00034",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "第二计呢？",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00035",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "我将一应战船，尽行拘收，不放云长回去，拘囚日久，他自然悔惧，那时不怕他不还。",
      "text_length": 38
    },
    {
      "event_id": "70001203_e00036",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "想云长英勇过人，他若恃武不还，你又待怎样？",
      "text_length": 21
    },
    {
      "event_id": "70001203_e00037",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "还有这第三条吓！",
      "text_length": 8
    },
    {
      "event_id": "70001203_e00038",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "鲁肃"
      ],
      "text": "关云长是刘备股肱臣宰，他焉能作痴聋把手足情乖！那时节我君臣安坐而待，管教他奉荆州双手送来。",
      "text_length": 45
    },
    {
      "event_id": "70001203_e00039",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "70001203_e00040",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙权"
      ],
      "text": "三条计顿教我愁眉尽解，讨荆州—任你妙计安排。",
      "text_length": 22
    },
    {
      "event_id": "70001203_e00041",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小太监上。",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00042",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小太监"
      ],
      "text": "启奏千岁：乔国老有本启奏。",
      "text_length": 13
    },
    {
      "event_id": "70001203_e00043",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "乔国老，久不上朝，今日前来，定有大事，宣国老上殿。",
      "text_length": 25
    },
    {
      "event_id": "70001203_e00044",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小太监"
      ],
      "text": "千岁有旨：乔国老上殿！",
      "text_length": 11
    },
    {
      "event_id": "70001203_e00045",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "乔玄"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00046",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "乔玄上。",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00047",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "乔玄"
      ],
      "text": "赤壁鏖兵曹兵败，曹操不敢卷土来。孙刘联合遭破坏，只怕荆州是祸胎。",
      "text_length": 32
    },
    {
      "event_id": "70001203_e00048",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "老臣见驾，吴侯千岁。",
      "text_length": 10
    },
    {
      "event_id": "70001203_e00049",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "国老不要多礼，请坐。",
      "text_length": 10
    },
    {
      "event_id": "70001203_e00050",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "谢座。",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00051",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "国老请坐。",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00052",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "鲁肃让上坐。",
      "text_length": 6
    },
    {
      "event_id": "70001203_e00053",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "鲁都督请坐。",
      "text_length": 6
    },
    {
      "event_id": "70001203_e00054",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "国老今日上殿，有何大事？",
      "text_length": 12
    },
    {
      "event_id": "70001203_e00055",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "诸葛瑾空手而回，调回鲁都督，莫非为讨荆州？",
      "text_length": 21
    },
    {
      "event_id": "70001203_e00056",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "刘备倒有还三郡之意；可恨关羽执意不允，令人可恼。",
      "text_length": 24
    },
    {
      "event_id": "70001203_e00057",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "屡讨荆州，一事无成，今番又恐画虎不成，反被耻笑。",
      "text_length": 24
    },
    {
      "event_id": "70001203_e00058",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "鲁都督定下三条妙计：这一，请他赴宴，当宴索讨。这二，他若不允，拘留江东。这三，刘备闻知，必定献城赎将，荆州可得。",
      "text_length": 56
    },
    {
      "event_id": "70001203_e00059",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "这三计不成，必然引起争战，曹操虎视耽耽，必然乘机杀来，报赤壁之仇；不如相安—时，再等时机。",
      "text_length": 45
    },
    {
      "event_id": "70001203_e00060",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "我意已决，不必多言。",
      "text_length": 10
    },
    {
      "event_id": "70001203_e00061",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "千岁！",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00062",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "乔玄"
      ],
      "text": "汉高祖在咸阳登了大宝，四百年至桓灵八方萧条。董卓贼霸朝纲豺狼当道，众诸侯兴义兵大战虎牢。王司徒献连环董卓诛了，曹孟德挟天子又霸汉朝。刘皇叔居西川狼烟尽扫，我东吴承父兄列土分茅；这才是既得陇又望蜀道，怕的是，螳螂捕蝉，黄雀在后，那曹操乘隙而攻，自取火烧。",
      "text_length": 126
    },
    {
      "event_id": "70001203_e00063",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "孙权"
      ],
      "text": "汉光武灭王莽汉室暂保，传至在桓灵帝瓦解冰消。孤承受父兄业国安民好，恨曹瞒领人马威赫我朝；战赤壁费尽了兵马粮草，刘玄德在夏口有何功劳？",
      "text_length": 66
    },
    {
      "event_id": "70001203_e00064",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "乔玄"
      ],
      "text": "曾记得曹操打战表，他要把东吴一笔销。文班中准备写降表，",
      "text_length": 27
    },
    {
      "event_id": "70001203_e00065",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "乔玄"
      ],
      "text": "武将土不敢动枪刀。我国中若不是周郎好，江南九郡尽归曹。老黄盖苦肉计献粮草，庞士元连环计谋高；若不亏南阳诸葛东风祭得妙，这东吴焉有半分毫！孙刘若是失和好，鹬蚌相争自把祸招。",
      "text_length": 85
    },
    {
      "event_id": "70001203_e00066",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "国老吓！",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00067",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "鲁肃"
      ],
      "text": "国老把话讲差了，鲁肃言来听根苗：诸葛瑾曾把荆州讨，那刘备允还三郡归我朝。可恨那关羽性高傲，寸土不还恨难消。蜀中大将年纪老，何惧他将老兵又骄。",
      "text_length": 70
    },
    {
      "event_id": "70001203_e00068",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "乔玄"
      ],
      "text": "休道蜀中兵将老，现有五虎将英豪：关云长谋略好，全凭青龙偃月刀。张翼德，情性躁，大吼一声断了坝林桥；赵子龙，胆量好，曹兵一见魂魄消；马孟起，似虎豹，只杀得曹操割须弃了袍；黄汉升八十不服老，百步穿杨射得高；五虎将、我不表，还有那诸葛孔明他的志谋高。",
      "text_length": 122
    },
    {
      "event_id": "70001203_e00069",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "孙权"
      ],
      "text": "体道蜀中兵将好，东吴也有将英豪：丁奉、徐盛韬略好，蒋钦、周泰志谋高；甘宁、韩当赛虎豹，陈老、潘璋似龙蛟。一心要把荆州讨，何惜—战动枪刀！",
      "text_length": 68
    },
    {
      "event_id": "70001203_e00070",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "国老！",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00071",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "鲁肃"
      ],
      "text": "昔借荆州我为保，久惜不还我常把心操。故此定下三杰计，宴请关羽去相邀。席前便把荆州讨，管教他束手被擒无处逃。",
      "text_length": 53
    },
    {
      "event_id": "70001203_e00072",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 4,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "乔玄"
      ],
      "text": "哈哈哈！",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00073",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "乔玄"
      ],
      "text": "休道你三条计真巧妙，休道他三条计定难逃。你头次曾把荆州讨，未曾取得半分毫。二次定下美人套，以假成真在甘露寺把亲招；美人计曾把郡主陪送掉，陪了夫人又折兵这话柄被人笑嘲。三次又把荆州讨，中了孔明计笼牢；损兵折将事非小，可叹我小婿周瑜命丧巴丘赴阴曹。前车之鉴你忘怀了，看起来你智穷力竭把旧文章抄，大妙不妙，看来计不高。",
      "text_length": 156
    },
    {
      "event_id": "70001203_e00074",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "住了！",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00075",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙权"
      ],
      "text": "不提甘露寺还罢了，提起此事怒眉梢。周公瑾定下牢笼套，金钩准备钓海螯。被你泄露母后知晓，以假成真无下梢；今日又来多阻挠，请太尉再休要谰言絮叨。",
      "text_length": 70
    },
    {
      "event_id": "70001203_e00076",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "下殿去罢！",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00077",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "乔玄"
      ],
      "text": "他君臣必要行此道，好似沙中把金淘。话不投机良言少，",
      "text_length": 25
    },
    {
      "event_id": "70001203_e00078",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "咳！",
      "text_length": 2
    },
    {
      "event_id": "70001203_e00079",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "乔玄"
      ],
      "text": "我不愿袖手旁观再去絮叨。",
      "text_length": 12
    },
    {
      "event_id": "70001203_e00080",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "国老，你为何去而复返？",
      "text_length": 11
    },
    {
      "event_id": "70001203_e00081",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "我总觉得三计不妙，这一封小简，焉能会来，纵然来了，焉能一席小宴，就退回荆州，你要擒他，难道他就一无准备不成？何况那关羽他那样英雄、那样的神威。",
      "text_length": 71
    },
    {
      "event_id": "70001203_e00082",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "他只要肯来，四方都是我国兵将，他纵然是一只猛虎，也飞不过江去，他还有什么威风，还称什么英雄？",
      "text_length": 46
    },
    {
      "event_id": "70001203_e00083",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "千岁！",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00084",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "你又来了！",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00085",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮小导板",
      "speakers": [
        "乔玄"
      ],
      "text": "他上阵风摆美髯飘又飘，",
      "text_length": 11
    },
    {
      "event_id": "70001203_e00086",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "他胡子长得好，又有什么了不得？",
      "text_length": 15
    },
    {
      "event_id": "70001203_e00087",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "胡子，哈哈，我也有胡子吓！",
      "text_length": 13
    },
    {
      "event_id": "70001203_e00088",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "你呀！差得多。",
      "text_length": 7
    },
    {
      "event_id": "70001203_e00089",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "乔玄"
      ],
      "text": "雄纠纠一丈虎躯摇。恰便似六丁六甲活神道，敌人见了就魂消。他诛文丑，逞粗躁，他刺颜良，显英豪；战虎牢曾把华雄斩了，百万军中把上将首级轻轻的枭；曹孟德灞桥饯行只落得一场谈笑，青龙刀挑起了大红袍，赤兔马飞过了灞陵桥。过五关斩将如同削草，怎挡他千里追风驹，闪不过青龙偃月刀。你讨荆州好有一比，好比那水中捞月——",
      "text_length": 151
    },
    {
      "event_id": "70001203_e00090",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "吴侯，鲁都督！",
      "text_length": 7
    },
    {
      "event_id": "70001203_e00091",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "乔玄"
      ],
      "text": "月难捞。",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00092",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "孙权"
      ],
      "text": "你将云长夸大了，孤家看来等鸿毛。鲁都督安排三条计，准备孙刘动枪刀。",
      "text_length": 33
    },
    {
      "event_id": "70001203_e00093",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "退班。",
      "text_length": 3
    },
    {
      "event_id": "70001203_e00094",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 94,
      "seq_in_scene": 94,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙权下，四太监随下。",
      "text_length": 10
    },
    {
      "event_id": "70001203_e00095",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 95,
      "seq_in_scene": 95,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "乔玄"
      ],
      "text": "他君臣不听良言告，唇破舌焦枉徒劳。关云长恩怨分明又高又傲，",
      "text_length": 29
    },
    {
      "event_id": "70001203_e00096",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 96,
      "seq_in_scene": 96,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "乔玄向鲁肃。",
      "text_length": 6
    },
    {
      "event_id": "70001203_e00097",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 97,
      "seq_in_scene": 97,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "乔玄"
      ],
      "text": "怎肯一席将荆州交！莫道他武将粗鲁你文官狡，",
      "text_length": 21
    },
    {
      "event_id": "70001203_e00098",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 98,
      "seq_in_scene": 98,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "乔玄"
      ],
      "text": "我好怕呀！",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00099",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 99,
      "seq_in_scene": 99,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "你怕什么？",
      "text_length": 5
    },
    {
      "event_id": "70001203_e00100",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 100,
      "seq_in_scene": 100,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "乔玄"
      ],
      "text": "怕只怕，扯住你的带，抓住你的袍，就是一刀，死也不饶。",
      "text_length": 26
    },
    {
      "event_id": "70001203_e00101",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 101,
      "seq_in_scene": 101,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "乔玄下。",
      "text_length": 4
    },
    {
      "event_id": "70001203_e00102",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 102,
      "seq_in_scene": 102,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "鲁肃"
      ],
      "text": "只说他上殿有高教，当面奚落我心内焦。虽定下三条计成败难料，为国家讨荆州职责难逃。",
      "text_length": 40
    },
    {
      "event_id": "70001203_e00103",
      "play_id": "70001203",
      "scene_id": "70001203_s01",
      "scene_no": 1,
      "seq_global": 103,
      "seq_in_scene": 103,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "鲁肃下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}