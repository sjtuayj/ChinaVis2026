      "text": "同白",
      "text_length": 2
    },
    {
      "event_id": "70902178_e00104",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 104,
      "seq_in_scene": 104,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宫女甲",
        "费贞娥"
      ],
      "text": "",
      "text_length": 0
    },
    {
      "event_id": "70902178_e00105",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 105,
      "seq_in_scene": 105,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥自刎下。",
      "text_length": 7
    },
    {
      "event_id": "70902178_e00106",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 106,
      "seq_in_scene": 106,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "宫女甲",
        "宫女乙"
      ],
      "text": "",
      "text_length": 0
    },
    {
      "event_id": "70902178_e00107",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 107,
      "seq_in_scene": 107,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "同念",
      "text_length": 2
    },
    {
      "event_id": "70902178_e00108",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 108,
      "seq_in_scene": 108,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "同白啊呀费贞娥吓费贞娥——她叫费贞娥！可惜你大才小用了！𠮾，又、又何必多磨吻。你看此贼又活了！在哪里？啊呀，罢！呀，她竟自刎了，我们将尸首抬过一旁，报与大大王知道。正是：三寸气在千般用，一旦无常万事休。啊呀，二大王吓！",
      "text_length": 109
    },
    {
      "event_id": "70902178_e00109",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 109,
      "seq_in_scene": 109,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "宫女甲、宫女乙同哭下。",
      "text_length": 11
    }
  ],
  "roles_inferred": true
}