  "events": [
    {
      "event_id": "70902178_e00001",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥上。",
      "text_length": 5
    },
    {
      "event_id": "70902178_e00002",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "端正好",
      "speakers": [
        "费贞娥"
      ],
      "text": "蕴君仇，含国恨；切切地蕴君仇，愤愤地含国恨。誓捐躯，要把仇讎手刃！因此上苟日贪生一息存。这就里谁知悯？",
      "text_length": 51
    },
    {
      "event_id": "70902178_e00003",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "奴家费氏，小字贞娥，从幼选入宫闱，以充嫔御，蒙国母娘娘命我服侍公主。不想流贼簒夺我国，逼死君父，一家骨肉，吓，死于非命。可笑那些臣子，没有一个为国家报仇雪耻的。难道如此奇冤极恨，就罢了不成？我想忠义之事，男女皆可做得。为此我到宫中取了一把匕首，藏于身畔，又假妆公主模样，指望得近闯贼，杀此巨寇，与君父报仇。谁想反将我赐于兄弟一只虎为配。待他来时，我自有道理！",
      "text_length": 179
    },
    {
      "event_id": "70902178_e00004",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "滚绣球",
      "speakers": [
        "费贞娥"
      ],
      "text": "俺切着齿点绛唇，搵着泪施脂粉；故意儿花簇簇巧梳着云鬓，锦层层穿着这衫裙。怀儿里冷飕飕匕首寒光喷，俺佯姣假媚妆痴蠢，巧语花言谄佞人。纤纤玉手剜仇人目，细细银牙啖贼子心！要与那漆肤豫让争声誉，断臂要离逞智能。拚得个身为齑粉！拚得个骨化飞尘！誓把那九重帝主沉冤泄，四海苍生怨气伸。方显得大明朝还有个女佳人！",
      "text_length": 150
    },
    {
      "event_id": "70902178_e00005",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖节节高〗。",
      "text_length": 6
    },
    {
      "event_id": "70902178_e00006",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "呀，听鼓乐之声，想是此贼来了。我且假装欢笑便了。",
      "text_length": 24
    },
    {
      "event_id": "70902178_e00007",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥暗哭下。李过上，四小卒随同上。",
      "text_length": 18
    },
    {
      "event_id": "70902178_e00008",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李过"
      ],
      "text": "拓地开疆胆气豪，从龙附凰佐皇朝。龙潜且作赵匡义，有日天心属我曹。",
      "text_length": 32
    },
    {
      "event_id": "70902178_e00009",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李过"
      ],
      "text": "方才众将道俺，今夜与公主成亲，备了筵宴与俺称贺。俺哪有心情饮酒，被他们你一杯我一盏，吃得大醉，才得放我回营，好不知趣也！回避！",
      "text_length": 63
    },
    {
      "event_id": "70902178_e00010",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小卒同下，宫女甲、宫女乙同上。",
      "text_length": 16
    },
    {
      "event_id": "70902178_e00011",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "宫女甲",
        "宫女乙"
      ],
      "text": "二大王回来了。",
      "text_length": 7
    },
    {
      "event_id": "70902178_e00012",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李过"
      ],
      "text": "公主在哪里？",
      "text_length": 6
    },
    {
      "event_id": "70902178_e00013",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "宫女甲",
        "宫女乙"
      ],
      "text": "在内帐。",
      "text_length": 4
    },
    {
      "event_id": "70902178_e00014",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李过"
      ],
      "text": "就请相见。",
      "text_length": 5
    },
    {
      "event_id": "70902178_e00015",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "宫女甲",
        "宫女乙"
      ],
      "text": "公主娘娘有请！",
      "text_length": 7
    },
    {
      "event_id": "70902178_e00016",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "费贞娥上。",
      "text_length": 5
    },
    {
      "event_id": "70902178_e00017",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "吓，将军。",
      "text_length": 5
    },
    {
      "event_id": "70902178_e00018",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李过"
      ],
      "text": "公主。",
      "text_length": 3
    },
    {
      "event_id": "70902178_e00019",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "费贞娥"
      ],
      "text": "将军请！",
      "text_length": 4
    },
    {
      "event_id": "70902178_e00020",
      "play_id": "70902178",
      "scene_id": "70902178_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
