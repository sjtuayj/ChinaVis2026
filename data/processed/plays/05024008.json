  "events": [
    {
      "event_id": "05024008_e00001",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子、徐母同上。",
      "text_length": 8
    },
    {
      "event_id": "05024008_e00002",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐母"
      ],
      "text": "可恨曹操眼无珠，痴心妄想儿来扶。不是老身贤愚识，险把我儿韬略辜。",
      "text_length": 32
    },
    {
      "event_id": "05024008_e00003",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "老身徐母吴氏。可恨曹操诱我作书，唤回徐庶，我想我儿既投刘备，喜得其主，哪有唤回背明投暗之理，被我当面辱骂一场，彼时要将我推出斩首，多亏程昱再三保全，又承他早晚在此殷勤致意，使我心中不安。家院！",
      "text_length": 96
    },
    {
      "event_id": "05024008_e00004",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "05024008_e00005",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "今早程老爷可曾到来？",
      "text_length": 10
    },
    {
      "event_id": "05024008_e00006",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "今早到此，见夫人未起，不曾通报，回去了。",
      "text_length": 20
    },
    {
      "event_id": "05024008_e00007",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "下面伺候。",
      "text_length": 5
    },
    {
      "event_id": "05024008_e00008",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "05024008_e00009",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐庶上。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00010",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "自离新野，不觉来此许昌。",
      "text_length": 12
    },
    {
      "event_id": "05024008_e00011",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "主人回来了。",
      "text_length": 6
    },
    {
      "event_id": "05024008_e00012",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "回来了，老夫人在何处？",
      "text_length": 11
    },
    {
      "event_id": "05024008_e00013",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "在堂上。启禀老夫人：主人回来了。",
      "text_length": 16
    },
    {
      "event_id": "05024008_e00014",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "呵，我儿回来了。",
      "text_length": 8
    },
    {
      "event_id": "05024008_e00015",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "母亲，孩儿拜揖。",
      "text_length": 8
    },
    {
      "event_id": "05024008_e00016",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "罢了，闻儿在襄阳扶助刘皇叔，得了樊城一带地方，今日因甚到此？",
      "text_length": 30
    },
    {
      "event_id": "05024008_e00017",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "哎呀，母亲呵，孩儿自离膝下二十余载，东投西奔，多蒙水镜先生指引，投于刘皇叔驾下为臣，侥幸得了樊城一带地方，正在用兵之际，忽接母书，言道身在缧绁，要孩儿急急赶回，因此不分昼夜，赶回见母。",
      "text_length": 92
    },
    {
      "event_id": "05024008_e00018",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "唗，我书从何来，书从何来！我道你在外二十余载，谅必广见多闻，这等看将起来，反不如初。我闻知你扶助刘皇叔，以为得其主矣，不辨真假，凭一纸伪书，竟辞主而归，你活活气煞为娘也！",
      "text_length": 85
    },
    {
      "event_id": "05024008_e00019",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐庶"
      ],
      "text": "娘自幼配儿父贤德兼并，生尔辈弟兄们小小娃婴。你父亲去世早家门不幸，为娘的受孤孀弟兄二人。我心中学孟母朝夕教训，只说是儿长成显亲扬名。你不肖杀死人埋名隐姓，又谁知徐康儿命丧幽冥。你在外二十载杳无音信，为娘的在家中倒也放心。谁知你胸无才真假不认，今日里回家中气煞娘亲。",
      "text_length": 132
    },
    {
      "event_id": "05024008_e00020",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐庶"
      ],
      "text": "徐元直跪尘埃含悲答应，尊一声老娘亲暂息雷霆。是孩儿胸无才错认书信，望娘亲念孩儿思母之情。离膝下二十载埋名隐姓，今日里回家中得见娘亲。虽则是儿不才胸无学问，看在了父死早孤苦伶仃。",
      "text_length": 88
    },
    {
      "event_id": "05024008_e00021",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐母"
      ],
      "text": "听一言我这里珠泪难忍，骂一声不肖子大胆畜生。昔日里孟子母居邻择正，到后来成大贤领袖群伦。幼年间尔不学还可发奋，到如今年三十一事无成。食君禄报君恩为臣本份，保玄德无始终万古骂名。今日里回家来见我则甚，倒不如早与我速速登程。",
      "text_length": 110
    },
    {
      "event_id": "05024008_e00022",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐母"
      ],
      "text": "畜生呵畜生！我也不来责备与你，你与我速速地去罢，哎呀！皇天呵皇天，我徐门为何这等不幸？呵！也罢，我想这等不肖之子，我有何面目再见人，你与我速速地去，你与我速速地去呵！",
      "text_length": 83
    },
    {
      "event_id": "05024008_e00023",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐母哭下。",
      "text_length": 5
    },
    {
      "event_id": "05024008_e00024",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "主人请起，老夫人进内堂去了。",
      "text_length": 14
    },
    {
      "event_id": "05024008_e00025",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "哎！",
      "text_length": 2
    },
    {
      "event_id": "05024008_e00026",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐庶"
      ],
      "text": "母悲儿说得我抬头不起，错中了奸雄计难以回头。今日里落圈套思想无计，",
      "text_length": 33
    },
    {
      "event_id": "05024008_e00027",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "哦！有了。",
      "text_length": 5
    },
    {
      "event_id": "05024008_e00028",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐庶"
      ],
      "text": "且做个明保曹暗保汉自有神机。",
      "text_length": 14
    },
    {
      "event_id": "05024008_e00029",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟上。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00030",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "哎呀老爷不好了，老夫人在二堂自尽了！",
      "text_length": 18
    },
    {
      "event_id": "05024008_e00031",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "怎么讲？",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00032",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "老夫人二堂自尽了。",
      "text_length": 9
    },
    {
      "event_id": "05024008_e00033",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "哎呀，母亲呀，为什么寻此短见，兀的不痛煞我也！",
      "text_length": 23
    },
    {
      "event_id": "05024008_e00034",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "徐庶"
      ],
      "text": "一阵阵痛煞我徐庶元直，为什么我的母自尽丧身。叫家院和丫鬟上房引路，回家来害了母一命归阴。",
      "text_length": 44
    },
    {
      "event_id": "05024008_e00035",
      "play_id": "05024008",
      "scene_id": "05024008_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐庶哭。众人同下。",
      "text_length": 9
    },
    {
      "event_id": "05024008_e00036",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹操上。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00037",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "曹操"
      ],
      "text": "安下天罗地网，",
      "text_length": 7
    },
    {
      "event_id": "05024008_e00038",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "程昱上。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00039",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "程昱"
      ],
      "text": "难逃袖里机关。",
      "text_length": 7
    },
    {
      "event_id": "05024008_e00040",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程昱"
      ],
      "text": "主公。",
      "text_length": 3
    },
    {
      "event_id": "05024008_e00041",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "先生。",
      "text_length": 3
    },
    {
      "event_id": "05024008_e00042",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程昱"
      ],
      "text": "闻听徐庶归家。",
      "text_length": 7
    },
    {
      "event_id": "05024008_e00043",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "你我前去看看。",
      "text_length": 7
    },
    {
      "event_id": "05024008_e00044",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程昱"
      ],
      "text": "有理。",
      "text_length": 3
    },
    {
      "event_id": "05024008_e00045",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "曹操",
        "程昱"
      ],
      "text": "请。",
      "text_length": 2
    },
    {
      "event_id": "05024008_e00046",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹操"
      ],
      "text": "只为求贤到臣门，回转头来叫先生：若得元直忠心顺，管叫刘备走无门。你我前去将他问，看看元直是怎生？",
      "text_length": 48
    },
    {
      "event_id": "05024008_e00047",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程昱"
      ],
      "text": "来此已是，主公站立一时，待臣前去看来。门上哪位在？",
      "text_length": 25
    },
    {
      "event_id": "05024008_e00048",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "院子上。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00049",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "什么人？",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00050",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程昱"
      ],
      "text": "前去通报，说丞相同我要见。",
      "text_length": 13
    },
    {
      "event_id": "05024008_e00051",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "是。主人有请。",
      "text_length": 7
    },
    {
      "event_id": "05024008_e00052",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐庶上。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00053",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "何事？",
      "text_length": 3
    },
    {
      "event_id": "05024008_e00054",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "曹丞相与程老爷在外。",
      "text_length": 10
    },
    {
      "event_id": "05024008_e00055",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "有请。",
      "text_length": 3
    },
    {
      "event_id": "05024008_e00056",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "院子"
      ],
      "text": "有请。",
      "text_length": 3
    },
    {
      "event_id": "05024008_e00057",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "徐庶迎接丞相。",
      "text_length": 7
    },
    {
      "event_id": "05024008_e00058",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "岂敢，先生请。",
      "text_length": 7
    },
    {
      "event_id": "05024008_e00059",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "请。丞相驾到，徐庶又制在身，未曾远迎，望乞恕罪。",
      "text_length": 24
    },
    {
      "event_id": "05024008_e00060",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "好说，老夫来得莽撞，幸勿见怪。",
      "text_length": 15
    },
    {
      "event_id": "05024008_e00061",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "岂敢。",
      "text_length": 3
    },
    {
      "event_id": "05024008_e00062",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程昱"
      ],
      "text": "元直，丞相特来拜请，同扶汉室，平定天下，命登廊庙，未知尊意如何？",
      "text_length": 32
    },
    {
      "event_id": "05024008_e00063",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "徐庶有何德能，敢劳丞相驾临，何以克当，只是徐庶庸才，有负丞相、先生之意耳！",
      "text_length": 37
    },
    {
      "event_id": "05024008_e00064",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "好说，如果不嫌，便请同行。",
      "text_length": 13
    },
    {
      "event_id": "05024008_e00065",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "当得遵命。",
      "text_length": 5
    },
    {
      "event_id": "05024008_e00066",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "先生请。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00067",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐庶"
      ],
      "text": "丞相请。",
      "text_length": 4
    },
    {
      "event_id": "05024008_e00068",
      "play_id": "05024008",
      "scene_id": "05024008_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
