      ],
      "text": "紫气凌云玉门关，万里封侯取功名。",
      "text_length": 16
    },
    {
      "event_id": "01013015_e00003",
      "play_id": "01013015",
      "scene_id": "01013015_s01",
      "scene_no": 1,
      "seq_global": 3,
