      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "上小楼",
      "speakers": [
        "关羽"
      ],
      "text": "恁道他，兵多将广，",
      "text_length": 9
    },
    {
      "event_id": "70901101_e00078",
      "play_id": "70901101",
      "scene_id": "70901101_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关平"
      ],
      "text": "他那里人强马壮。",
      "text_length": 8
    },
    {
      "event_id": "70901101_e00079",
      "play_id": "70901101",
      "scene_id": "70901101_s01",
