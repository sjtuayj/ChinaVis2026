      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关平"
      ],
      "text": "大江遥远，恐难接应。",
      "text_length": 10
    },
    {
      "event_id": "70901101_e00081",
      "play_id": "70901101",
      "scene_id": "70901101_s01",
      "scene_no": 1,
      "seq_global": 81,
