      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "上小楼",
      "speakers": [
        "关羽"
      ],
      "text": "人强马壮。大丈夫奋勇当先，一人拼命，万夫难挡。",
      "text_length": 23
    },
    {
      "event_id": "70901101_e00080",
      "play_id": "70901101",
      "scene_id": "70901101_s01",
      "scene_no": 1,
      "seq_global": 80,
