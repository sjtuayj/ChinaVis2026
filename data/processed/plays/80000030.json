      "speakers": [
        "中军"
      ],
      "text": "班师回朝。",
      "text_length": 5
    },
    {
      "event_id": "80000030_e00012",
      "play_id": "80000030",
      "scene_id": "80000030_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
