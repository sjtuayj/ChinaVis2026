        "多福星君",
        "多禄星君",
        "多寿星君",
        "九如仙"
      ],
      "text": "领法旨。",
      "text_length": 4
    },
    {
      "event_id": "02001002_e00028",
      "play_id": "02001002",
      "scene_id": "02001002_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
