  "events": [
    {
      "event_id": "70005111_e00001",
      "play_id": "70005111",
      "scene_id": "70005111_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四大铠、陈元礼同上。",
      "text_length": 14
    },
    {
      "event_id": "70005111_e00002",
      "play_id": "70005111",
      "scene_id": "70005111_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "陈元礼"
      ],
      "text": "渔阳击鼓起仓猝，护驾巡行到西蜀。且喜逆贼已就戮，五色旌旗返帝都。",
      "text_length": 32
    },
    {
      "event_id": "70005111_e00003",
      "play_id": "70005111",
      "scene_id": "70005111_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈元礼"
      ],
      "text": "俺，右护龙卫将军陈元礼是也。只因安禄山造反，圣驾西行。今幸反贼平靖，正好保驾还朝。御林军，人马可齐？",
      "text_length": 50
    },
    {
      "event_id": "70005111_e00004",
      "play_id": "70005111",
      "scene_id": "70005111_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大铠"
      ],
      "text": "俱已齐备。",
      "text_length": 5
    },
    {
      "event_id": "70005111_e00005",
      "play_id": "70005111",
      "scene_id": "70005111_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈元礼"
      ],
      "text": "候驾起行者。",
      "text_length": 6
    },
    {
      "event_id": "70005111_e00006",
      "play_id": "70005111",
      "scene_id": "70005111_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "70005111_e00007",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、高力士、天宝帝同上。",
      "text_length": 14
    },
    {
      "event_id": "70005111_e00008",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "天宝帝"
      ],
      "text": "万里巡行路途穷，看云山，乱愁交迸。长空孤雁添悲哽，无边落木响秋声。叹凄凉，万种离情。",
      "text_length": 42
    },
    {
      "event_id": "70005111_e00009",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天宝帝"
      ],
      "text": "江山只为美人愁，万里山河半壁休。自愧三郎空好色，风流天子惯无忧。",
      "text_length": 32
    },
    {
      "event_id": "70005111_e00010",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天宝帝"
      ],
      "text": "孤，大唐天子天宝在位。只因安禄山造反，谋取神京，将孤逼至西蜀。行至中途六军不发，众小军声声言道：“不杀杨家兄妹，誓不保驾。”陈元礼那时奏道：“社稷为重。”孤万般无奈，行在马嵬坡下，只得传旨赐玉环一死。今幸反贼平复，每忆玉环，不禁伤感。陈元礼又催驾还朝。",
      "text_length": 126
    },
    {
      "event_id": "70005111_e00011",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "御林军走上。",
      "text_length": 6
    },
    {
      "event_id": "70005111_e00012",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四大铠、陈元礼同上。",
      "text_length": 14
    },
    {
      "event_id": "70005111_e00013",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "天宝帝"
      ],
      "text": "恨禄山贼造反逼我神京，李猪儿刺逆贼才得太平。真个是蜀道难道途泥泞，峨眉山下少人行。风飘飘一阵阵愁云滚滚，",
      "text_length": 52
    },
    {
      "event_id": "70005111_e00014",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "雨来啦！请万岁爷剑阁避雨！",
      "text_length": 13
    },
    {
      "event_id": "70005111_e00015",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "天宝帝下马。",
      "text_length": 6
    },
    {
      "event_id": "70005111_e00016",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "天宝帝"
      ],
      "text": "下金鞍离玉辔剑阁来登。",
      "text_length": 11
    },
    {
      "event_id": "70005111_e00017",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "天宝帝上山。",
      "text_length": 6
    },
    {
      "event_id": "70005111_e00018",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "天宝帝"
      ],
      "text": "观一派白茫茫云遮日影，雨苦风酸扑面迎。",
      "text_length": 19
    },
    {
      "event_id": "70005111_e00019",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天宝帝"
      ],
      "text": "高力士，看看是什么声音？",
      "text_length": 12
    },
    {
      "event_id": "70005111_e00020",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "70005111_e00021",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高力士看。",
      "text_length": 5
    },
    {
      "event_id": "70005111_e00022",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "启万岁：外面乃是雨打树林之声，风吹栈间铁马之声。",
      "text_length": 24
    },
    {
      "event_id": "70005111_e00023",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "天宝帝"
      ],
      "text": "断肠最是雨淋淋，与愁人泪血相交并！",
      "text_length": 17
    },
    {
      "event_id": "70005111_e00024",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "天宝帝"
      ],
      "text": "想孤魂此际太凄清，白杨萧萧夜雨淋。鬼火青磷寒霄静，听一片风声、雨声、铃声、锣声、人声、马声、愁声、金声并作了断肠声！",
      "text_length": 58
    },
    {
      "event_id": "70005111_e00025",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "雨住了，请万岁爷下剑阁。",
      "text_length": 12
    },
    {
      "event_id": "70005111_e00026",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "天宝帝下山。",
      "text_length": 6
    },
    {
      "event_id": "70005111_e00027",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "天宝帝"
      ],
      "text": "雨霁风消寒夜冷，人马浩荡转帝京。",
      "text_length": 16
    },
    {
      "event_id": "70005111_e00028",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "前面人马为何不进？",
      "text_length": 9
    },
    {
      "event_id": "70005111_e00029",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大铠"
      ],
      "text": "来此已是马嵬坡了。",
      "text_length": 9
    },
    {
      "event_id": "70005111_e00030",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天宝帝"
      ],
      "text": "高力士，来此什么所在？",
      "text_length": 11
    },
    {
      "event_id": "70005111_e00031",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "来此已是马嵬坡。",
      "text_length": 8
    },
    {
      "event_id": "70005111_e00032",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天宝帝"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "70005111_e00033",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "天宝帝"
      ],
      "text": "听说来到马嵬坡，",
      "text_length": 8
    },
    {
      "event_id": "70005111_e00034",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "天宝帝"
      ],
      "text": "点点珠泪似滂沱。陈元礼将人马且扎山脚，满腹酸辛可奈何。",
      "text_length": 27
    },
    {
      "event_id": "70005111_e00035",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天宝帝"
      ],
      "text": "内侍，吩咐外面预备清香白酒，到贵妃娘娘坟前一祭，聊表寸心。",
      "text_length": 29
    },
    {
      "event_id": "70005111_e00036",
      "play_id": "70005111",
      "scene_id": "70005111_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "70005111_e00037",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监同上，高力士上，设祭堂。",
      "text_length": 15
    },
    {
      "event_id": "70005111_e00038",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "有请万岁！",
      "text_length": 5
    },
    {
      "event_id": "70005111_e00039",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "天宝帝上。",
      "text_length": 5
    },
    {
      "event_id": "70005111_e00040",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "天宝帝"
      ],
      "text": "定情钿盒今犹在，长生密誓记心怀。冤怨缘三字孤不解，这才是伯劳飞燕两分开。看天台犹是人不在，我前度刘郎今又来。",
      "text_length": 54
    },
    {
      "event_id": "70005111_e00041",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "启万岁：杨娘娘坟茔，已经打扫洁净了。",
      "text_length": 18
    },
    {
      "event_id": "70005111_e00042",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天宝帝"
      ],
      "text": "待孤拈香。",
      "text_length": 5
    },
    {
      "event_id": "70005111_e00043",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖哭皇天〗，〖吹打〗，〖牌子〗。",
      "text_length": 16
    },
    {
      "event_id": "70005111_e00044",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "天宝帝"
      ],
      "text": "梓童！爱卿啊！",
      "text_length": 7
    },
    {
      "event_id": "70005111_e00045",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄顶板",
      "speakers": [
        "天宝帝"
      ],
      "text": "尊一声贵妃杨玉环孤的爱卿，在夜台下，九泉间，一件件，一桩桩，细听根芽：",
      "text_length": 35
    },
    {
      "event_id": "70005111_e00046",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "天宝帝"
      ],
      "text": "想当初孤坐的风流天下，重国色慕倾城运走桃花。为娇容孤也曾求遍风雅，压六宫冠粉黛绝世才华。七月七日长生殿花前月下，连理枝比翼鸟并蒂莲花。遭不幸安禄山渔阳杀驾，破潼关扫河北直抵京华。无奈何暂且迁起了銮驾，幸西蜀为的是有情冤家。离都门路不远马嵬坡下，最可恨这六军按兵不发。孤忙问尔六军因何驻马？扬言道杀兄妹六军始发。叹贵妃死在这白绫之下，卿家吓！红颜女变作了白骨黄沙，可怜你今日里玉殒桃花。谢秋波止不转百媚无价，倒叫孤空辜负恩宠独加。唐天宝空坐了一朝天下，身不能庇一女辜负名花。卿一死且莫要将孤咒骂，夜台下谁怜你少妇无家。朕负卿并非是卿负陛下，国乱时权在臣不在孤家。李三郎只哭得泪如雨下，泪如雨下，爱卿啊！",
      "text_length": 300
    },
    {
      "event_id": "70005111_e00047",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "万岁不可过伤，务宜保重圣体要紧。",
      "text_length": 16
    },
    {
      "event_id": "70005111_e00048",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "天宝帝"
      ],
      "text": "高力士捧金爵酒祭香插。",
      "text_length": 11
    },
    {
      "event_id": "70005111_e00049",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高力士"
      ],
      "text": "遵命。祭奠已毕，请万岁上马回銮。",
      "text_length": 16
    },
    {
      "event_id": "70005111_e00050",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "天宝帝"
      ],
      "text": "高力士，带马。",
      "text_length": 7
    },
    {
      "event_id": "70005111_e00051",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "天宝帝"
      ],
      "text": "陈元礼奏一本催孤起驾，浩荡荡领人马直奔京华。御林军忙转过马嵬坡下，要相逢除非是梦里天涯。",
      "text_length": 44
    },
    {
      "event_id": "70005111_e00052",
      "play_id": "70005111",
      "scene_id": "70005111_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
