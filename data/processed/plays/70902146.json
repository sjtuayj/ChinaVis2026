      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牛氏"
      ],
      "text": "吓，相公。",
      "text_length": 5
    },
    {
      "event_id": "70902146_e00025",
      "play_id": "70902146",
      "scene_id": "70902146_s01",
      "scene_no": 1,
      "seq_global": 25,
