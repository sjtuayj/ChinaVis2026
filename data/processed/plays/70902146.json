      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡邕"
      ],
      "text": "夫人请坐。",
      "text_length": 5
    },
    {
      "event_id": "70902146_e00026",
      "play_id": "70902146",
      "scene_id": "70902146_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "牛氏"
      ],
      "text": "有坐。相公原来在此操琴。",
      "text_length": 12
    },
    {
      "event_id": "70902146_e00027",
      "play_id": "70902146",
      "scene_id": "70902146_s01",
