      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "牛氏"
      ],
      "text": "嫩绿池塘，梅雨歇，熏风乍转。https://scripts.xikao.com/play/709021462023-10-05",
      "text_length": 63
    },
    {
      "event_id": "70902146_e00024",
      "play_id": "70902146",
      "scene_id": "70902146_s01",
      "scene_no": 1,
      "seq_global": 24,
