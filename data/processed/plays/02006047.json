  "events": [
    {
      "event_id": "02006047_e00001",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四宫女引武则天同上。",
      "text_length": 10
    },
    {
      "event_id": "02006047_e00002",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "武则天"
      ],
      "text": "孤单凄凉坐深宫，日落西城带晚风。从前欢乐嫌夜短，切莫更长锦帐空。",
      "text_length": 32
    },
    {
      "event_id": "02006047_e00003",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张天佐上。",
      "text_length": 5
    },
    {
      "event_id": "02006047_e00004",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "张天佐"
      ],
      "text": "新君柔弱成何用，",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00005",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张天佑上。",
      "text_length": 5
    },
    {
      "event_id": "02006047_e00006",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "张天佑"
      ],
      "text": "不斩薛氏我难容。",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00007",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张天佐",
        "张天佑"
      ],
      "text": "臣张（天佐）（天佑）见驾，愿太后千岁！",
      "text_length": 19
    },
    {
      "event_id": "02006047_e00008",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "二卿平身。",
      "text_length": 5
    },
    {
      "event_id": "02006047_e00009",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张天佐",
        "张天佑"
      ],
      "text": "千千岁。",
      "text_length": 4
    },
    {
      "event_id": "02006047_e00010",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "赐坐。",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00011",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张天佐",
        "张天佑"
      ],
      "text": "谢坐。",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00012",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "二卿进宫，有何本奏？",
      "text_length": 10
    },
    {
      "event_id": "02006047_e00013",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张天佐"
      ],
      "text": "启太后：新君昏懦，忘先帝之遗恨。惟乞降旨。",
      "text_length": 21
    },
    {
      "event_id": "02006047_e00014",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张天佑"
      ],
      "text": "容留叛臣家，日与群小荒淫酒色，不理国政，岂能执掌天下？乞太后以社稷为重，早定大计，庶天下太平。",
      "text_length": 47
    },
    {
      "event_id": "02006047_e00015",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "新君有道，本后岂可将他废却？",
      "text_length": 14
    },
    {
      "event_id": "02006047_e00016",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张天佐"
      ],
      "text": "那薛刚身遭不赦之罪，应该将丁山满门，既行诛戮。为何纵容叛逆之臣，岂不忘先君之恨？",
      "text_length": 40
    },
    {
      "event_id": "02006047_e00017",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张天佑"
      ],
      "text": "薛刚逃走，未曾拿获，丁山又在天牢，朝中功臣，与薛家尽是一党，惟恐暗扶薛刚，杀到长安。不但社稷难保，恐有惊太后龙驾。今日废新君，斩薛氏方得天下太平，国正民顺。",
      "text_length": 78
    },
    {
      "event_id": "02006047_e00018",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "今废新君，江山何人执掌？",
      "text_length": 12
    },
    {
      "event_id": "02006047_e00019",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张天佐",
        "张天佑"
      ],
      "text": "太后临朝执政，统领社稷，有何难哉？",
      "text_length": 17
    },
    {
      "event_id": "02006047_e00020",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "恐有文武保奏，本后如何降旨？",
      "text_length": 14
    },
    {
      "event_id": "02006047_e00021",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张天佐",
        "张天佑"
      ],
      "text": "只要太后龙心已定，哪怕他文武保奏。",
      "text_length": 17
    },
    {
      "event_id": "02006047_e00022",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "依卿所奏，本后即废新君，立斩薛氏满门。出宫去罢。",
      "text_length": 24
    },
    {
      "event_id": "02006047_e00023",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "张天佐",
        "张天佑"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00024",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张天佐"
      ],
      "text": "不怕虎生三只眼，",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00025",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张天佑"
      ],
      "text": "只愁人起两样心。",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00026",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张天佐、张天佑同下。小太监、二大太监引李显同上。",
      "text_length": 24
    },
    {
      "event_id": "02006047_e00027",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李显"
      ],
      "text": "龙心嗟叹思忠勇，寡人常怀薛氏功。",
      "text_length": 16
    },
    {
      "event_id": "02006047_e00028",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "儿李显见驾，愿母后千岁！",
      "text_length": 12
    },
    {
      "event_id": "02006047_e00029",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "皇儿平身。",
      "text_length": 5
    },
    {
      "event_id": "02006047_e00030",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "千千岁。",
      "text_length": 4
    },
    {
      "event_id": "02006047_e00031",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "赐坐。",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00032",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "谢坐。",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00033",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "儿吓，薛氏满门，可曾诛戮？",
      "text_length": 13
    },
    {
      "event_id": "02006047_e00034",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "启奏母后：薛刚虽有不赦之罪，可念忠武王薛仁贵，有许多功劳。就是先君，哪件不赦薛家？今日特求母后赦却忠良满门，只拿薛刚一人治罪，乞母后降旨。",
      "text_length": 69
    },
    {
      "event_id": "02006047_e00035",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "吓，那薛刚踢死殿下，惊死你父，此乃不共戴天之仇，与逆叛同罪，理当诛戮九族，为何反要赦他，这是何恩德？",
      "text_length": 50
    },
    {
      "event_id": "02006047_e00036",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "踢死御弟，乃一时酒醉，儿也曾绘影图形拿薛刚问罪。特求国母恩赦薛氏一门，那忠武王在九泉之下，感恩无尽矣。",
      "text_length": 51
    },
    {
      "event_id": "02006047_e00037",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "哎，你不诛父遗恨，容留叛逆，懦弱为君，怎掌天下大事？今废你为卢陵王，贬往湖广房州。若无旨意，不可擅入长安。将御印交出，速行去吧！",
      "text_length": 64
    },
    {
      "event_id": "02006047_e00038",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "哎呀，孩儿为君，并无失政，不过求赦忠良之心，为何将儿贬出长安？",
      "text_length": 31
    },
    {
      "event_id": "02006047_e00039",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "哎，你无父王之仇，为娘哪有母子之意？内侍，快到韦后宫内，请御印前来。",
      "text_length": 34
    },
    {
      "event_id": "02006047_e00040",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00041",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太监下。",
      "text_length": 4
    },
    {
      "event_id": "02006047_e00042",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "你即出长安。",
      "text_length": 6
    },
    {
      "event_id": "02006047_e00043",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "哎呀，母后吓！",
      "text_length": 7
    },
    {
      "event_id": "02006047_e00044",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李显"
      ],
      "text": "孩儿为君非失政，为何谪贬出都城？今日奉诏泄母恨，母后吓，大唐社稷付何人？",
      "text_length": 36
    },
    {
      "event_id": "02006047_e00045",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "武则天"
      ],
      "text": "为娘临朝比儿胜，汉室吕后女为君。懦弱怎掌天下任，可知成汤亡百春。",
      "text_length": 32
    },
    {
      "event_id": "02006047_e00046",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四宫女、二太监捧印引韦后同上。",
      "text_length": 15
    },
    {
      "event_id": "02006047_e00047",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "韦后"
      ],
      "text": "主上为君如尧舜，为救薛氏一满门。",
      "text_length": 16
    },
    {
      "event_id": "02006047_e00048",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韦后"
      ],
      "text": "国母千岁。进宫何事？",
      "text_length": 10
    },
    {
      "event_id": "02006047_e00049",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "主上柔弱，夫妻早出长安便罢，若是迟延，提头来见。内侍，快将他夫妻赶出去。",
      "text_length": 36
    },
    {
      "event_id": "02006047_e00050",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "李显",
        "韦后"
      ],
      "text": "哎呀母后吓！",
      "text_length": 6
    },
    {
      "event_id": "02006047_e00051",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮滚板",
      "speakers": [
        "李显"
      ],
      "text": "儿承父业风雨顺，",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00052",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮滚板",
      "speakers": [
        "韦后"
      ],
      "text": "人在尧天舜日中。",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00053",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮滚板",
      "speakers": [
        "李显"
      ],
      "text": "国母废业社稷送，",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00054",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韦后"
      ],
      "text": "国母吓！",
      "text_length": 4
    },
    {
      "event_id": "02006047_e00055",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮滚板",
      "speakers": [
        "韦后"
      ],
      "text": "哀告膝下求乞恩。",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00056",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "哎，无用之辈，怎为天子，再不出宫，提头来见。",
      "text_length": 22
    },
    {
      "event_id": "02006047_e00057",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00058",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李显"
      ],
      "text": "甜言蜜语全无用，",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00059",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "韦后"
      ],
      "text": "再三哀告总是空。",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00060",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "罢！",
      "text_length": 2
    },
    {
      "event_id": "02006047_e00061",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李显"
      ],
      "text": "大唐江山无我分，",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00062",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "韦后"
      ],
      "text": "眼含珠泪出皇宫。",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00063",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "李显",
        "韦后"
      ],
      "text": "哎呀，国母吓！",
      "text_length": 7
    },
    {
      "event_id": "02006047_e00064",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李显、韦后同下。",
      "text_length": 8
    },
    {
      "event_id": "02006047_e00065",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "武则天"
      ],
      "text": "哈哈哈！",
      "text_length": 4
    },
    {
      "event_id": "02006047_e00066",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "武则天"
      ],
      "text": "临朝执掌唐一统，女王天子独为君。",
      "text_length": 16
    },
    {
      "event_id": "02006047_e00067",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "武则天"
      ],
      "text": "内侍，速传旨意：新君已废，本后登基，改元为垂拱元年。朝内大事，付与天佐、天佑执掌；命武三思统领都城禁军。打扫法场，将薛家满门正法；再命武承嗣，在丁山中殿上，掘一深坑，以便埋葬叛臣尸首。恐有文武保奏，谏者提头来见。",
      "text_length": 106
    },
    {
      "event_id": "02006047_e00068",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二太监"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "02006047_e00069",
      "play_id": "02006047",
      "scene_id": "02006047_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
