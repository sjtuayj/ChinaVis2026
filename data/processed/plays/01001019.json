      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "先生。",
      "text_length": 3
    },
    {
      "event_id": "01001019_e00013",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 13,
