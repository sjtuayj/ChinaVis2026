  "events": [
    {
      "event_id": "01001019_e00001",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同上，鲁肃上。",
      "text_length": 10
    },
    {
      "event_id": "01001019_e00002",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "鲁肃"
      ],
      "text": "身挂帅印，统雄兵，扫荡烟尘。",
      "text_length": 14
    },
    {
      "event_id": "01001019_e00003",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "本帅姓鲁名肃，字子敬。前者三江夏口周都督一死，吴侯挂我为帅。今乃周都督开吊之期，尤恐众将前来吊祭。来，伺候了。",
      "text_length": 55
    },
    {
      "event_id": "01001019_e00004",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四吴将同上。",
      "text_length": 6
    },
    {
      "event_id": "01001019_e00005",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四吴将"
      ],
      "text": "启禀都督：孔明过江吊祭。",
      "text_length": 12
    },
    {
      "event_id": "01001019_e00006",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "哦，孔明过江吊祭。",
      "text_length": 9
    },
    {
      "event_id": "01001019_e00007",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四吴将"
      ],
      "text": "何不将他拿下，与都督报仇。",
      "text_length": 13
    },
    {
      "event_id": "01001019_e00008",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "且慢。想那孔明过江，必有能将跟随，你等看我眼色行事。两厢伺候。退下。",
      "text_length": 34
    },
    {
      "event_id": "01001019_e00009",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四吴将同下。",
      "text_length": 6
    },
    {
      "event_id": "01001019_e00010",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "有请诸葛先生。",
      "text_length": 7
    },
    {
      "event_id": "01001019_e00011",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "诸葛亮、赵云同上。",
      "text_length": 9
    },
    {
      "event_id": "01001019_e00012",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 12,
