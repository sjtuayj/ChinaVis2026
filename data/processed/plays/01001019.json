      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "鲁肃"
      ],
      "text": "不知先生驾到，未曾远迎，当面恕罪。",
      "text_length": 17
    },
    {
      "event_id": "01001019_e00017",
      "play_id": "01001019",
      "scene_id": "01001019_s01",
      "scene_no": 1,
      "seq_global": 17,
