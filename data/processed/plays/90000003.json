  "events": [
    {
      "event_id": "90000003_e00001",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦观、家院同上。",
      "text_length": 8
    },
    {
      "event_id": "90000003_e00002",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "秦观"
      ],
      "text": "淮海客家，正青春，锦样年华。",
      "text_length": 14
    },
    {
      "event_id": "90000003_e00003",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "秦观"
      ],
      "text": "暗空万缕漾垂杨，尚有春寒到画堂。歌扇未阑馀酒力，满身花气日初长。",
      "text_length": 32
    },
    {
      "event_id": "90000003_e00004",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "下官姓秦名观字少游，高邮人也。官拜翰林子七，夫人苏氏名唤小妹，乃苏老泉之女苏轼之妹，才华第一，与下官时常唱和。今当三月，百花盛开，命人预备酒筵与夫人赏花饮酒。左右，酒筵可曾齐备？",
      "text_length": 89
    },
    {
      "event_id": "90000003_e00005",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "齐备多时了。",
      "text_length": 6
    },
    {
      "event_id": "90000003_e00006",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "请夫人出堂。",
      "text_length": 6
    },
    {
      "event_id": "90000003_e00007",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "有请夫人。",
      "text_length": 5
    },
    {
      "event_id": "90000003_e00008",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苏小妹、丫鬟同上。",
      "text_length": 9
    },
    {
      "event_id": "90000003_e00009",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "苏小妹"
      ],
      "text": "春光无限，看闺林，柳媚花妍。",
      "text_length": 14
    },
    {
      "event_id": "90000003_e00010",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "夫人来了，请坐。",
      "text_length": 8
    },
    {
      "event_id": "90000003_e00011",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "官人请坐。",
      "text_length": 5
    },
    {
      "event_id": "90000003_e00012",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "夫人，今当春景融和，百花开放，下官命人置酒花前与夫人痛饮几杯。",
      "text_length": 31
    },
    {
      "event_id": "90000003_e00013",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "妾身陪伴官人。",
      "text_length": 7
    },
    {
      "event_id": "90000003_e00014",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "酒筵摆上，夫人请酒。",
      "text_length": 10
    },
    {
      "event_id": "90000003_e00015",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "官人请。",
      "text_length": 4
    },
    {
      "event_id": "90000003_e00016",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "秦观"
      ],
      "text": "看园林春色好百花俱放，一双双粉蝴蝶上下飞扬。举起了金锤酒心中欢畅，劝夫人且痛饮玉液琼浆。",
      "text_length": 44
    },
    {
      "event_id": "90000003_e00017",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "苏小妹"
      ],
      "text": "坐花前面对着风和日朗，喜的是酒筵前蝶粉蜂黄。满庭中又只见柔丝荡漾，休得要辜负了锦样春阳。",
      "text_length": 44
    },
    {
      "event_id": "90000003_e00018",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "家院上。",
      "text_length": 4
    },
    {
      "event_id": "90000003_e00019",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "家院"
      ],
      "text": "忽奉宫中诏，看花要赋诗。",
      "text_length": 12
    },
    {
      "event_id": "90000003_e00020",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "家院"
      ],
      "text": "启老爷：适才宫中传旨，万岁爷在上林赏花，宣召老爷速进宫去。",
      "text_length": 29
    },
    {
      "event_id": "90000003_e00021",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "晓得了。夫人，下官与夫人畅饮，谁想宫中宣召，不敢延迟，下官要进宫去了。",
      "text_length": 35
    },
    {
      "event_id": "90000003_e00022",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "想宫中宣召，不可延迟，官人快去。",
      "text_length": 16
    },
    {
      "event_id": "90000003_e00023",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "左右，与我更衣。",
      "text_length": 8
    },
    {
      "event_id": "90000003_e00024",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦观更衣。",
      "text_length": 5
    },
    {
      "event_id": "90000003_e00025",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "夫人自饮几杯，下官失陪了。",
      "text_length": 13
    },
    {
      "event_id": "90000003_e00026",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦观下。",
      "text_length": 4
    },
    {
      "event_id": "90000003_e00027",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "官人请便。",
      "text_length": 5
    },
    {
      "event_id": "90000003_e00028",
      "play_id": "90000003",
      "scene_id": "90000003_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苏小妹下。",
      "text_length": 5
    },
    {
      "event_id": "90000003_e00029",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苏小妹上。",
      "text_length": 5
    },
    {
      "event_id": "90000003_e00030",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "苏小妹"
      ],
      "text": "我官人原本是才名远震，在朝中为侍从执掌经纶。都只为行新法万民怨恨，因此上去奏本上达天闻。虽然是秉忠心凶吉不问，怕只怕天颜怒要逐孤臣。",
      "text_length": 66
    },
    {
      "event_id": "90000003_e00031",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "奴家苏氏，配夫秦少游，琴瑟和谐，唱随甚乐，只因朝廷，设行新法，万民不便，我夫要上奏章弹劾宰相。今早上朝，尚未回来，不知事体怎么样了，好叫我放不下，等官人回来问个明白。",
      "text_length": 83
    },
    {
      "event_id": "90000003_e00032",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦观上。",
      "text_length": 4
    },
    {
      "event_id": "90000003_e00033",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮散板",
      "speakers": [
        "秦观"
      ],
      "text": "为新法使平民四方怨恨，我只得上一本去奏明君。又谁知贬他方官移远郡，从今后望长安万里君门。",
      "text_length": 44
    },
    {
      "event_id": "90000003_e00034",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "官人回来了，官人请坐，上本之事怎么样了？",
      "text_length": 20
    },
    {
      "event_id": "90000003_e00035",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "上本之后，圣上震怒，道我毁谤贤相，罪在不赦，把我贬到郴洲监酒税去了。",
      "text_length": 34
    },
    {
      "event_id": "90000003_e00036",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "吓，官人贬他方去了……",
      "text_length": 11
    },
    {
      "event_id": "90000003_e00037",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苏小妹哭。",
      "text_length": 5
    },
    {
      "event_id": "90000003_e00038",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "夫人不必愁烦，下官有志锄奸，无心恋位，虽然贬谪，实出天恩，只是钦限逼迫不可久留，下官就要起程了。",
      "text_length": 48
    },
    {
      "event_id": "90000003_e00039",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "官人就要远别了！",
      "text_length": 8
    },
    {
      "event_id": "90000003_e00040",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "90000003_e00041",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "此去郴洲千里之遥，长途辛苦，妾身实在放心不下。",
      "text_length": 23
    },
    {
      "event_id": "90000003_e00042",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "夫人不必担心，下官此去自能排解，不劳夫人挂心；只是家中之事，全丈夫人照管，夫人自己保重才好。",
      "text_length": 46
    },
    {
      "event_id": "90000003_e00043",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苏小妹"
      ],
      "text": "妾身自当尽心，官人保重。",
      "text_length": 12
    },
    {
      "event_id": "90000003_e00044",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦观"
      ],
      "text": "下官就此去也！",
      "text_length": 7
    },
    {
      "event_id": "90000003_e00045",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "秦观"
      ],
      "text": "辞别了闺中人登程趱行，我此去经多少水驿山林。",
      "text_length": 22
    },
    {
      "event_id": "90000003_e00046",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "苏小妹"
      ],
      "text": "这一去落南荒山程路远，见浮云西北返回望修门。",
      "text_length": 22
    },
    {
      "event_id": "90000003_e00047",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦观下。",
      "text_length": 4
    },
    {
      "event_id": "90000003_e00048",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "苏小妹"
      ],
      "text": "只见官人投远郡，不由奴家痛伤心。水宿山行天样远，不知何日转家门。",
      "text_length": 32
    },
    {
      "event_id": "90000003_e00049",
      "play_id": "90000003",
      "scene_id": "90000003_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苏小妹下。",
      "text_length": 5
    }
  ],
