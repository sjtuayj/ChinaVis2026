  "events": [
    {
      "event_id": "03060002_e00001",
      "play_id": "03060002",
      "scene_id": "03060002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤上。",
      "text_length": 5
    },
    {
      "event_id": "03060002_e00002",
      "play_id": "03060002",
      "scene_id": "03060002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵匡胤"
      ],
      "text": "时不济来运不通，别却爹娘走关东。",
      "text_length": 16
    },
    {
      "event_id": "03060002_e00003",
      "play_id": "03060002",
      "scene_id": "03060002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "俺，姓赵名匡胤，字表玄郎。只因酒醉，杀了御乐一十七口，我父修书，命俺四路探亲，就此马上加鞭。",
      "text_length": 46
    },
    {
      "event_id": "03060002_e00004",
      "play_id": "03060002",
      "scene_id": "03060002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "悔不该杀御乐一十七命，只落得别爹娘四路探亲。普天下画图形捉拿匡胤，走关东和关西无处存身。一路上懒观这遍地美景，有豪杰催坐骑忙往前行。",
      "text_length": 66
    },
    {
      "event_id": "03060002_e00005",
      "play_id": "03060002",
      "scene_id": "03060002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤下。",
      "text_length": 5
    },
    {
      "event_id": "03060002_e00006",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苗顺上。",
      "text_length": 4
    },
    {
      "event_id": "03060002_e00007",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "苗顺"
      ],
      "text": "在仙山我领了师傅之命，洒金桥摆卦棚指点前程。招牌上写的是神算苗顺，算人间吉凶事不差毫分。观东方红光照紫气一阵，霎时间冲霄汉雾气腾腾。黄莺儿不住的枝头站定，见翠柏和苍松密密层层。金桥下鱼戏水观之不尽，见许多名利客车马来行。这几天并无有一人来问，又只见桌案上灰尘寸深。将身儿来至在卦棚坐定，等候了赤须龙指点前程。",
      "text_length": 154
    },
    {
      "event_id": "03060002_e00008",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "内唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "日夜里如酒醉昏迷不醒！",
      "text_length": 11
    },
    {
      "event_id": "03060002_e00009",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤上。",
      "text_length": 5
    },
    {
      "event_id": "03060002_e00010",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "时刻间胆战惊如掉三魂。饥饿了好茶饭未餐一顿，招商店好美酒哪饮几瓶？走过了多少个高山峻岭，奔过了多少个闹市关津。莫不是前世里欠债未尽，走关东奔关西何曾安宁！见一人坐卦棚眼观书本，他看的非地理定是天文。料此人他胸中必有学问，好比那三国中诸葛孔明。招牌上写的是神算苗顺，算人间吉凶事不差毫分。上前来施一礼先生请问，",
      "text_length": 154
    },
    {
      "event_id": "03060002_e00011",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤施礼。",
      "text_length": 6
    },
    {
      "event_id": "03060002_e00012",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "我特来请先生推算子平。",
      "text_length": 11
    },
    {
      "event_id": "03060002_e00013",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苗顺"
      ],
      "text": "请坐！",
      "text_length": 3
    },
    {
      "event_id": "03060002_e00014",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "有坐。",
      "text_length": 3
    },
    {
      "event_id": "03060002_e00015",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "苗顺"
      ],
      "text": "你既来算八字休通名姓，待山人将八卦细算分明。你本是西洛县赵门匡胤，你本是人帝主降下凡尘。都只为你祖上积有德行，因此上两条龙一母降生。这几年时不济蛟龙遭困，因此上别爹娘四路探亲。",
      "text_length": 88
    },
    {
      "event_id": "03060002_e00016",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "都只为时不至特来求问，望先生多劳神细算分明。",
      "text_length": 22
    },
    {
      "event_id": "03060002_e00017",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "苗顺"
      ],
      "text": "你不该江湖上结拜异姓，你不该嫖素梅走却元真。你不该杀御乐一十七命，你不该累双亲身受苦刑。",
      "text_length": 44
    },
    {
      "event_id": "03060002_e00018",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "提起了从前事一言难尽，实服你卜吉凶妙算如神。过去事悔不及今后改正，再算我前途上可有灾星？",
      "text_length": 44
    },
    {
      "event_id": "03060002_e00019",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "苗顺"
      ],
      "text": "此一去中途路酒要少饮，百日内还有那血光灾星。一不可董家桥自逞本领，二不可三皇庙求雨祈神。三不可华山上下棋争论，四不可清幽观结拜赵京。五不可宿古庙恐遭迷阵，六不可黄叶寺惹祸生嗔。七不可归故里盘查严紧，八不可鱼池内射妖逞能。九不可上燕京刺杀刘主，十不可高平关将妹许婚。我算你十件事件件有准，到后来才知我苗顺卦灵。",
      "text_length": 154
    },
    {
      "event_id": "03060002_e00020",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "苗先生他把我未来算定，只说得赵玄郎二目圆睁。走向前施一礼还要求问，再算我到何日大运亨通？",
      "text_length": 44
    },
    {
      "event_id": "03060002_e00021",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "苗顺"
      ],
      "text": "我算你四十岁才交大运，到陈桥戴冕旒南面称尊。",
      "text_length": 22
    },
    {
      "event_id": "03060002_e00022",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "苗先生你说话需要谨慎，这件事犯王法不可看轻。虽则是我祖父为官清正，哪有个荫子孙擅坐朝廷？赵玄郎若还有天子福分，那时节你就是开国元勋。",
      "text_length": 66
    },
    {
      "event_id": "03060002_e00023",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "苗顺"
      ],
      "text": "我在那江湖上四路访问，只等到八月中相会汴京。",
      "text_length": 22
    },
    {
      "event_id": "03060002_e00024",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "告辞了！",
      "text_length": 4
    },
    {
      "event_id": "03060002_e00025",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "赵匡胤"
      ],
      "text": "洒金桥算八卦半疑半信，也不知到后来灵也不灵。苏彭杰他是我玄郎旧恨，普天下捉拿我画影图形。只怕我遭罗网谁来怜悯，在他乡落圈套有翅难腾。",
      "text_length": 66
    },
    {
      "event_id": "03060002_e00026",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤下。",
      "text_length": 5
    },
    {
      "event_id": "03060002_e00027",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "苗顺"
      ],
      "text": "几句话说得他无言可问，他本是人帝王创业之君。保护他在江湖四路访问，应天星辅南宋扫荡乾坤。",
      "text_length": 44
    },
    {
      "event_id": "03060002_e00028",
      "play_id": "03060002",
      "scene_id": "03060002_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "苗顺下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}