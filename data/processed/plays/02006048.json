      "play_id": "02006048",
      "scene_id": "02006048_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    },
