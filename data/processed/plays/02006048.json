      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马周、程万牛、罗章、李敬犹同摆驾，四太监、四宫女、韦后同下。",
      "text_length": 30
    },
