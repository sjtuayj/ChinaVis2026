  "events": [
    {
      "event_id": "02006048_e00001",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内同白",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "请吓！",
      "text_length": 3
    },
    {
      "event_id": "02006048_e00002",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马周、程万牛、罗章、李敬犹同上。",
      "text_length": 16
    },
    {
      "event_id": "02006048_e00003",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同唱",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "不是献帝禅台命，哪有君王贬出京？",
      "text_length": 16
    },
    {
      "event_id": "02006048_e00004",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、四宫女引李显、韦后同上。",
      "text_length": 16
    },
    {
      "event_id": "02006048_e00005",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "李显"
      ],
      "text": "眼含珠泪离宫禁，",
      "text_length": 8
    },
    {
      "event_id": "02006048_e00006",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "韦后"
      ],
      "text": "主为天子作公卿。",
      "text_length": 8
    },
    {
      "event_id": "02006048_e00007",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "臣等见驾，愿陛下万岁，娘娘千岁。",
      "text_length": 16
    },
    {
      "event_id": "02006048_e00008",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "众卿平身。",
      "text_length": 5
    },
    {
      "event_id": "02006048_e00009",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "万万岁。",
      "text_length": 4
    },
    {
      "event_id": "02006048_e00010",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "卿等来至宫门，有何国事？",
      "text_length": 12
    },
    {
      "event_id": "02006048_e00011",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "闻陛下谪贬湖广房州，臣等进宫保奏。",
      "text_length": 17
    },
    {
      "event_id": "02006048_e00012",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "哎呀众卿吓，朕母后传旨，但有文武保本，即便提头来见。",
      "text_length": 26
    },
    {
      "event_id": "02006048_e00013",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "主往房州，江山何人执掌？",
      "text_length": 12
    },
    {
      "event_id": "02006048_e00014",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "李显",
        "韦后"
      ],
      "text": "母后临朝执政。",
      "text_length": 7
    },
    {
      "event_id": "02006048_e00015",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "太后焉能执掌江山？主公、娘娘停龙驾，臣等舍死谏奏便了。",
      "text_length": 27
    },
    {
      "event_id": "02006048_e00016",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "哎呀，众卿吓，太后不念母子之情，岂留君臣之义？但朕去后，全仗卿等整理皇唐天下，寡人在房州，静听好音。",
      "text_length": 50
    },
    {
      "event_id": "02006048_e00017",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马周",
        "程万牛",
        "罗章",
        "李敬犹"
      ],
      "text": "既然如此，臣等送驾起行。",
      "text_length": 12
    },
    {
      "event_id": "02006048_e00018",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李显"
      ],
      "text": "卿家吓！",
      "text_length": 4
    },
    {
      "event_id": "02006048_e00019",
      "play_id": "02006048",
      "scene_id": "02006048_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
