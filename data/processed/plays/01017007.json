      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老二"
      ],
      "text": "不要挑啦，扛着走罢。",
      "text_length": 10
    },
    {
      "event_id": "01017007_e00073",
      "play_id": "01017007",
      "scene_id": "01017007_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "老二拉花大汉。",
      "text_length": 7
    },
    {
      "event_id": "01017007_e00074",
      "play_id": "01017007",
      "scene_id": "01017007_s01",
      "scene_no": 1,
      "seq_global": 74,
