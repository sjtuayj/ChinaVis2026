      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "老二"
      ],
      "text": "让你拿了家伙。快走！",
      "text_length": 10
    },
    {
      "event_id": "01017007_e00076",
      "play_id": "01017007",
      "scene_id": "01017007_s01",
      "scene_no": 1,
      "seq_global": 76,
