      "event_id": "01017007_e00078",
      "play_id": "01017007",
      "scene_id": "01017007_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "花大汉"
      ],
      "text": "我的姣姣，我的姣姣。行囊挂在马鞍桥。我去后，休被旁人笑，我去后，休被旁人笑。",
      "text_length": 38
    },
    {
      "event_id": "01017007_e00079",
      "play_id": "01017007",
      "scene_id": "01017007_s01",
      "scene_no": 1,
