  "events": [
    {
      "event_id": "03027005_e00001",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四大铠、诸葛亮同上。",
      "text_length": 14
    },
    {
      "event_id": "03027005_e00002",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄慢板",
      "speakers": [
        "诸葛亮"
      ],
      "text": "叹先帝白帝城龙归海藏，托孤与诸葛亮扶保朝纲。遵圣命与魏兵连打数仗，夏侯懋无名辈奔走西羌。取天水多亏了子龙老将，幸喜得降伯约前来投降。我看他用兵法孙吴一样，将我这兵机战策传授他参详。闷恹恹坐至在中军宝帐，且等候众将归再作商量。",
      "text_length": 112
    },
    {
      "event_id": "03027005_e00003",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "马岱、高翔、关兴、张苞同上。",
      "text_length": 14
    },
    {
      "event_id": "03027005_e00004",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马岱",
        "高翔",
        "关兴",
        "张苞"
      ],
      "text": "参见丞相！",
      "text_length": 5
    },
    {
      "event_id": "03027005_e00005",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "罢了。命你等打探魏兵之事如何？",
      "text_length": 15
    },
    {
      "event_id": "03027005_e00006",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "马岱",
        "高翔",
        "关兴",
        "张苞"
      ],
      "text": "启丞相：今有曹叡命曹真为帅，郭淮为副帅，司徒王朗为军师，带领二十万雄兵前来征战，已在渭河之西扎了营寨，特地前来禀报。",
      "text_length": 58
    },
    {
      "event_id": "03027005_e00007",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "诸葛亮"
      ],
      "text": "想那曹真、郭淮，虽然带兵多年，也不足论。",
      "text_length": 20
    },
    {
      "event_id": "03027005_e00008",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "旗牌上。",
      "text_length": 4
    },
    {
      "event_id": "03027005_e00009",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "旗牌"
      ],
      "text": "奉了元帅命，下书到蜀营。",
      "text_length": 12
    },
    {
      "event_id": "03027005_e00010",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "旗牌"
      ],
      "text": "营中哪位在？",
      "text_length": 6
    },
    {
      "event_id": "03027005_e00011",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马岱"
      ],
      "text": "什么人？",
      "text_length": 4
    },
    {
      "event_id": "03027005_e00012",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "旗牌"
      ],
      "text": "奉曹元帅之命，前来下书。",
      "text_length": 12
    },
    {
      "event_id": "03027005_e00013",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马岱"
      ],
      "text": "候着！启丞相：魏营差人前来下书。",
      "text_length": 16
    },
    {
      "event_id": "03027005_e00014",
      "play_id": "03027005",
      "scene_id": "03027005_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
