    },
    {
      "event_id": "03027005_e00066",
      "play_id": "03027005",
      "scene_id": "03027005_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马岱"
      ],
      "text": "奉了丞相将令，在祁山左右扎下营寨，准备截杀曹兵，就此前往！",
      "text_length": 29
    },
    {
      "event_id": "03027005_e00067",
      "play_id": "03027005",
      "scene_id": "03027005_s03",
