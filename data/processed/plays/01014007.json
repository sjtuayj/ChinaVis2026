  "events": [
    {
      "event_id": "01014007_e00001",
      "play_id": "01014007",
      "scene_id": "01014007_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化上。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00002",
      "play_id": "01014007",
      "scene_id": "01014007_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "蔡天化"
      ],
      "text": "身入空门，习拳棒，不念经文。",
      "text_length": 14
    },
    {
      "event_id": "01014007_e00003",
      "play_id": "01014007",
      "scene_id": "01014007_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "蔡天化"
      ],
      "text": "自幼出家入空门，禅堂不喜念经文。闲来无事习枪棒，闷来山后听鸟鸣。",
      "text_length": 32
    },
    {
      "event_id": "01014007_e00004",
      "play_id": "01014007",
      "scene_id": "01014007_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "咱家，蔡天化，道号悟清。自幼出家，身居绿林，结交天下英雄好汉。今在这淮安府大树林北极观内，修真养性，倒也逍遥自在。知因赃官施不全，每每伤害绿林，是某于本月十九日，夤夜暗入察院，将他的印信盗来，藏在玄天大帝兜裆之内。看他有官无印，不久就要离任了。正是：",
      "text_length": 125
    },
    {
      "event_id": "01014007_e00005",
      "play_id": "01014007",
      "scene_id": "01014007_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "蔡天化"
      ],
      "text": "暗地撒下青丝网，哪怪鱼儿不上钩。",
      "text_length": 16
    },
    {
      "event_id": "01014007_e00006",
      "play_id": "01014007",
      "scene_id": "01014007_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化下。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00007",
      "play_id": "01014007",
      "scene_id": "01014007_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "吓哈！",
      "text_length": 3
    },
    {
      "event_id": "01014007_e00008",
      "play_id": "01014007",
      "scene_id": "01014007_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺仁杰上，起霸。",
      "text_length": 8
    },
    {
      "event_id": "01014007_e00009",
      "play_id": "01014007",
      "scene_id": "01014007_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "贺仁杰"
      ],
      "text": "自幼生来胆气豪，爱惜棍棒和枪刀。飞檐走壁武艺好，一心报效在皇朝。",
      "text_length": 32
    },
    {
      "event_id": "01014007_e00010",
      "play_id": "01014007",
      "scene_id": "01014007_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "俺，贺仁杰。奉了母亲之命，投奔施大人台前，出力报效。只因十九日夜晚，有大胆的贼寇，私入察院，盗去大人的印信。是俺私自出衙，访印信下落。趁此月暗星稀，不免走走也。",
      "text_length": 80
    },
    {
      "event_id": "01014007_e00011",
      "play_id": "01014007",
      "scene_id": "01014007_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "斗鹌鹑",
      "speakers": [
        "贺仁杰"
      ],
      "text": "英雄侠义气轩昂，遇不平定逞刚强。恨恶霸胆大猖狂，入公衙暗进庙堂。盗国宝远走高飏，我只得设计寻访。",
      "text_length": 48
    },
    {
      "event_id": "01014007_e00012",
      "play_id": "01014007",
      "scene_id": "01014007_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺仁杰下。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00013",
      "play_id": "01014007",
      "scene_id": "01014007_s03",
      "scene_no": 3,
      "seq_global": 13,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李兴儿上。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00014",
      "play_id": "01014007",
      "scene_id": "01014007_s03",
      "scene_no": 3,
      "seq_global": 14,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "在下李兴儿便是。今奉主母之命，去到大树林北极观蔡老师父那里送信。就此走走。",
      "text_length": 37
    },
    {
      "event_id": "01014007_e00015",
      "play_id": "01014007",
      "scene_id": "01014007_s03",
      "scene_no": 3,
      "seq_global": 15,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李兴儿下。贺仁杰上。",
      "text_length": 10
    },
    {
      "event_id": "01014007_e00016",
      "play_id": "01014007",
      "scene_id": "01014007_s03",
      "scene_no": 3,
      "seq_global": 16,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "且住。看前面有一人，急走如飞，定不是好人，待我赶上前去。",
      "text_length": 28
    },
    {
      "event_id": "01014007_e00017",
      "play_id": "01014007",
      "scene_id": "01014007_s03",
      "scene_no": 3,
      "seq_global": 17,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "斗鹌鹑",
      "speakers": [
        "贺仁杰"
      ],
      "text": "我这里急走慌忙，哪怕他飞至天上。",
      "text_length": 16
    },
    {
      "event_id": "01014007_e00018",
      "play_id": "01014007",
      "scene_id": "01014007_s03",
      "scene_no": 3,
      "seq_global": 18,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺仁杰下。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00019",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 19,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李兴儿上。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00020",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 20,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "来此已是，待我上前叫门。里面哪位师父在？",
      "text_length": 20
    },
    {
      "event_id": "01014007_e00021",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 21,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "小道士上。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00022",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 22,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小道士"
      ],
      "text": "原来是李管家，到此何事？",
      "text_length": 12
    },
    {
      "event_id": "01014007_e00023",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 23,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "我奉了我家主母之命，要见老师父，有要紧的话说。",
      "text_length": 23
    },
    {
      "event_id": "01014007_e00024",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 24,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小道士"
      ],
      "text": "候着。有请师父。",
      "text_length": 8
    },
    {
      "event_id": "01014007_e00025",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 25,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化上。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00026",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 26,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "何事？",
      "text_length": 3
    },
    {
      "event_id": "01014007_e00027",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 27,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小道士"
      ],
      "text": "李管家求见。",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00028",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 28,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "唤他进来。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00029",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 29,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "小道士"
      ],
      "text": "我师父叫你哪。",
      "text_length": 7
    },
    {
      "event_id": "01014007_e00030",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 30,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "01014007_e00031",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 31,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺仁杰暗上花墙。",
      "text_length": 8
    },
    {
      "event_id": "01014007_e00032",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 32,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "参见老师父。",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00033",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 33,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "罢了。",
      "text_length": 3
    },
    {
      "event_id": "01014007_e00034",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 34,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "老师父，大事不好了！",
      "text_length": 10
    },
    {
      "event_id": "01014007_e00035",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 35,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00036",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 36,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "只因我家公子大爷，与你家大徒弟，在小东营，摆下百日擂台。打了九十多天，并无敌手。这一天，忽然来了一个小孩子，上得擂台，三拳两脚，就将你那大徒弟，踢了一个大跟头。众家英雄看事不好，一齐动手。台底下有一群看热闹的，说道：“唉，你们擅动官兵，犹如造反，我等俱是总漕标下，参将、副将、游击、都司、守备老爷们。”他等上得擂台，捆的捆，绑的绑，一齐就拿进城去了。那赃官施不全，即刻升堂。问到你家大徒弟在哪里出家。你家大徒弟言道：在大树林北极观，蔡老师父你老这里出家。那赃官言道：“这就不错啦，本月十九日夜晚，丢了一宗宝贝。”可并没有推出是什么东西来，一口就赖在你家大徒弟身上，夹了一夹棍，夹了个活来死去，死去活来。你家大徒弟，也真于你做脸，并没有一点裂纹裂缝。是我家主母放心不下，叫我连夜来与你送信。我想这件事情，老师父你老得那个主意才好哪。",
      "text_length": 365
    },
    {
      "event_id": "01014007_e00037",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 37,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "你等哪里知道：是我本月十九日夜晚，私入公衙，盗了赃官的印信。那赃官有官无印，他不久也要离任了。",
      "text_length": 47
    },
    {
      "event_id": "01014007_e00038",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 38,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李兴儿"
      ],
      "text": "既然如此，老师父，你老把这印信，要收好了才是。",
      "text_length": 23
    },
    {
      "event_id": "01014007_e00039",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 39,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "无妨。此物吾藏在玄天大帝兜裆之内，就是孔明复生，也难知晓。李管家，随吾后面用饭，再去回复你家主母便了。",
      "text_length": 51
    },
    {
      "event_id": "01014007_e00040",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 40,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化、李兴儿、小道士同下。贺仁杰下花墙。",
      "text_length": 21
    },
    {
      "event_id": "01014007_e00041",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 41,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "哎呀好呀，听他之言，此乃是天助俺成功也！",
      "text_length": 20
    },
    {
      "event_id": "01014007_e00042",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 42,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺仁杰盗印。",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00043",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 43,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "且喜印信到手，待我到大树林内，等候众家叔父便了。",
      "text_length": 24
    },
    {
      "event_id": "01014007_e00044",
      "play_id": "01014007",
      "scene_id": "01014007_s04",
      "scene_no": 4,
      "seq_global": 44,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "贺仁杰下。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00045",
      "play_id": "01014007",
      "scene_id": "01014007_s05",
      "scene_no": 5,
      "seq_global": 45,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄天霸、关泰、李堃、朱光祖、金大力同上，出城，同转场，下。",
      "text_length": 29
    },
    {
      "event_id": "01014007_e00046",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 46,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化上。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00047",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 47,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "呀，天明了。",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00048",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 48,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "菩萨蛮",
      "speakers": [
        "蔡天化"
      ],
      "text": "玉漏初残露光寒，村鸡高唱烧烟漫。来至在大雄宝殿，手推门参拜玄天，印信不见为哪般？",
      "text_length": 40
    },
    {
      "event_id": "01014007_e00049",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 49,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "徒弟们走上！",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00050",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 50,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众徒弟同上。",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00051",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 51,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "师父何事惊慌？",
      "text_length": 7
    },
    {
      "event_id": "01014007_e00052",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 52,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "印信不见，被何人盗去？",
      "text_length": 11
    },
    {
      "event_id": "01014007_e00053",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 53,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同看。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00054",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 54,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "原来从天窗内而。印信既被他人盗去，必有人前来见我。大家一同用了斋饭，等候便了。",
      "text_length": 39
    },
    {
      "event_id": "01014007_e00055",
      "play_id": "01014007",
      "scene_id": "01014007_s06",
      "scene_no": 6,
      "seq_global": 55,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00056",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 56,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄天霸、关泰、李堃、朱光祖、金大力同上，贺仁杰上。",
      "text_length": 25
    },
    {
      "event_id": "01014007_e00057",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 57,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "参见众位叔父。",
      "text_length": 7
    },
    {
      "event_id": "01014007_e00058",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 58,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄天霸"
      ],
      "text": "印信之事如何？",
      "text_length": 7
    },
    {
      "event_id": "01014007_e00059",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 59,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "印信已被小侄盗来，叔父请看。",
      "text_length": 14
    },
    {
      "event_id": "01014007_e00060",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 60,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄天霸"
      ],
      "text": "好。一同带路前往。",
      "text_length": 9
    },
    {
      "event_id": "01014007_e00061",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 61,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同走圆场。",
      "text_length": 7
    },
    {
      "event_id": "01014007_e00062",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 62,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "哎，蔡天化可在里面？",
      "text_length": 10
    },
    {
      "event_id": "01014007_e00063",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 63,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化、众徒弟同上。",
      "text_length": 10
    },
    {
      "event_id": "01014007_e00064",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 64,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "徒弟们打座！",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00065",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 65,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化上台。",
      "text_length": 6
    },
    {
      "event_id": "01014007_e00066",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 66,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄天霸"
      ],
      "text": "哎，月台之上，坐的敢是蔡天化？",
      "text_length": 15
    },
    {
      "event_id": "01014007_e00067",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 67,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "你祖师号悟清。",
      "text_length": 7
    },
    {
      "event_id": "01014007_e00068",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 68,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄天霸"
      ],
      "text": "蔡天化，你私盗皇家国宝，该当何罪？今特带领人来，与尔要印。",
      "text_length": 29
    },
    {
      "event_id": "01014007_e00069",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 69,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "住了！印信既被你等盗回，休得在你祖师爷跟前卖弄。",
      "text_length": 24
    },
    {
      "event_id": "01014007_e00070",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 70,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "蔡天化，前番盗印，不足为奇，二次被你少爷盗回，方显手段。",
      "text_length": 28
    },
    {
      "event_id": "01014007_e00071",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 71,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "呀，小小年纪，口出朗言大话，通尔的名来！",
      "text_length": 20
    },
    {
      "event_id": "01014007_e00072",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 72,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "贺仁杰"
      ],
      "text": "你少爷住江南金华县四霸天贺天保之子贺仁杰！",
      "text_length": 21
    },
    {
      "event_id": "01014007_e00073",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 73,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "晚生下辈，何足道哉。那一个红脸的呢？",
      "text_length": 18
    },
    {
      "event_id": "01014007_e00074",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 74,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关泰"
      ],
      "text": "你老爷，家住山西蒲州府，漕标参将，姓关名泰，字小西！",
      "text_length": 26
    },
    {
      "event_id": "01014007_e00075",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 75,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "无名之辈，也不在你祖师爷的心上，闪开！那一白面，他是何人？",
      "text_length": 29
    },
    {
      "event_id": "01014007_e00076",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 76,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄天霸"
      ],
      "text": "你且听了！你老爷家住江南绍兴府金华县，飞镖黄三泰之子，四霸天赛罗成黄天霸！",
      "text_length": 37
    },
    {
      "event_id": "01014007_e00077",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 77,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "呵，呀呀呀呀！",
      "text_length": 7
    },
    {
      "event_id": "01014007_e00078",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 78,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄天霸"
      ],
      "text": "看镖！",
      "text_length": 3
    },
    {
      "event_id": "01014007_e00079",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 79,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "久闻你黄家金镖厉害，每每伤害绿林，今日一见也是平常。众徒弟一齐动手！",
      "text_length": 34
    },
    {
      "event_id": "01014007_e00080",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 80,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "蔡天化下高台，亮相，起打。贺仁杰使流星打蔡天化，蔡天化下，众徒弟同下。众人同追下。蔡天化上。",
      "text_length": 46
    },
    {
      "event_id": "01014007_e00081",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 81,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "且住。那一娃娃，手中不知使的什么兵刃，耀人二目，打了我这啦！众徒弟走上。",
      "text_length": 36
    },
    {
      "event_id": "01014007_e00082",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 82,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众徒弟同上。黄天霸、关泰、李堃、朱光祖、金大力、贺仁杰同上，开打，打连环。金大力擒蔡天化。",
      "text_length": 45
    },
    {
      "event_id": "01014007_e00083",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 83,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "蔡天化"
      ],
      "text": "无量寿佛。",
      "text_length": 5
    },
    {
      "event_id": "01014007_e00084",
      "play_id": "01014007",
      "scene_id": "01014007_s07",
      "scene_no": 7,
      "seq_global": 84,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}