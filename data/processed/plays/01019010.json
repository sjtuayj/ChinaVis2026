      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "杨业"
      ],
      "text": "二人庙内双膝跪，",
      "text_length": 8
    },
    {
      "event_id": "01019010_e00086",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 86,
