  "events": [
    {
      "event_id": "01019010_e00001",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "女马童上。吹工尺上牌。女马童洗马，备马。",
      "text_length": 20
    },
    {
      "event_id": "01019010_e00002",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "女马童"
      ],
      "text": "请姑娘上马。",
      "text_length": 6
    },
    {
      "event_id": "01019010_e00003",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花上，拉起霸，上马。四龙旗、四女兵同上。",
      "text_length": 22
    },
    {
      "event_id": "01019010_e00004",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "佘赛花"
      ],
      "text": "我翻身跨上了桃花马，",
      "text_length": 10
    },
    {
      "event_id": "01019010_e00005",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花趟马，转场。",
      "text_length": 9
    },
    {
      "event_id": "01019010_e00006",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "佘赛花"
      ],
      "text": "佘塘关来了我佘赛花。心中恼恨杨家将，不该把我兄长杀。帐中领下父王令，倒叫奴家怒气发。扣定玲珑锦战甲，梨花银枪手中拿。叫三军与我把关下，",
      "text_length": 67
    },
    {
      "event_id": "01019010_e00007",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙旗、四女兵、女马童同转场，同下。",
      "text_length": 18
    },
    {
      "event_id": "01019010_e00008",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "佘赛花"
      ],
      "text": "要与那杨家将动杀法。",
      "text_length": 10
    },
    {
      "event_id": "01019010_e00009",
      "play_id": "01019010",
      "scene_id": "01019010_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花下。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00010",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、四上手、杨业同上。",
      "text_length": 13
    },
    {
      "event_id": "01019010_e00011",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "杨业"
      ],
      "text": "两国不和把仗打，一来一往动杀法。将身且坐营盘下，且听探马报根芽。",
      "text_length": 32
    },
    {
      "event_id": "01019010_e00012",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "探子上。",
      "text_length": 4
    },
    {
      "event_id": "01019010_e00013",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "探子"
      ],
      "text": "佘赛花讨战。",
      "text_length": 6
    },
    {
      "event_id": "01019010_e00014",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "再探。",
      "text_length": 3
    },
    {
      "event_id": "01019010_e00015",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "杨业"
      ],
      "text": "人来带过少爷的马，见了丫头把兵加。",
      "text_length": 17
    },
    {
      "event_id": "01019010_e00016",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "会阵。四龙旗、四女兵、佘赛花同上，打过合。",
      "text_length": 21
    },
    {
      "event_id": "01019010_e00017",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "佘赛花"
      ],
      "text": "阵前来了杨家将，不由奴家怒心上。提枪拍马往前闯，少时叫你无下场。（四龙旗、四女兵、四龙套、四上手同钻烟筒，双下场。佘赛花、杨业同起打。杨业败下，佘赛花耍枪花，下。四上手、四女兵同对打，同追下。杨业上，佘赛花追上，打杨业下，佘赛花追下。杨业上。）",
      "text_length": 122
    },
    {
      "event_id": "01019010_e00018",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "且住。看这个丫头，杀法厉害，杀得我上天无路，入地无门，这便如何是好！",
      "text_length": 34
    },
    {
      "event_id": "01019010_e00019",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业看。",
      "text_length": 4
    },
    {
      "event_id": "01019010_e00020",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "“七星庙”，“七星庙”。来此已是七星庙，待我下马进庙。",
      "text_length": 27
    },
    {
      "event_id": "01019010_e00021",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业下马，进庙。",
      "text_length": 8
    },
    {
      "event_id": "01019010_e00022",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "待我将门闭上。我就在此处，躲避一时，再做道理。",
      "text_length": 23
    },
    {
      "event_id": "01019010_e00023",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花上。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00024",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "吓。时才与杨家小将交战，被奴将他杀的大败。他在前面跑，奴在后面赶，来在此地，为何不见？",
      "text_length": 43
    },
    {
      "event_id": "01019010_e00025",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花看。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00026",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "“七星庙”，“七星庙”。想是他在庙中藏躲。看他将庙门关闭，这便怎么样。待奴喊叫一声。呔！杨家小将听真！你家姑娘，在此等候，你快开庙门，与姑娘再战三合。",
      "text_length": 75
    },
    {
      "event_id": "01019010_e00027",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "这个丫头，她竟自赶来了。她叫我开门，与她再战。你家少爷，在庙内安身。任凭你这丫头，说得天花乱坠，你少爷就是不开门的了。",
      "text_length": 59
    },
    {
      "event_id": "01019010_e00028",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "看他执意不肯开门，这便如何是好？吓咳，有了。待我唬他一唬。杨家小将，你隐藏庙内，不肯开门，待奴吩咐三军，将庙墙团团围住，四面放起火来，将庙宇烧坏，管叫你死无葬身之地。",
      "text_length": 83
    },
    {
      "event_id": "01019010_e00029",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "嗳呀！这个丫头言道：吩咐三军，将庙宇烧坏，要叫我死无葬身之地，这便怎好？",
      "text_length": 36
    },
    {
      "event_id": "01019010_e00030",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业跪拜。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00031",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "望求神圣保佑，望求神圣保佑。呔！佘赛花丫头，你既叫你少爷开门，你少爷敢开庙门，只怕你不敢下马。",
      "text_length": 47
    },
    {
      "event_id": "01019010_e00032",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "你既敢开庙门，你姑娘就敢下马。",
      "text_length": 15
    },
    {
      "event_id": "01019010_e00033",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业跪拜神。",
      "text_length": 6
    },
    {
      "event_id": "01019010_e00034",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "望求神圣多多保佑。",
      "text_length": 9
    },
    {
      "event_id": "01019010_e00035",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "你姑娘下马来了。",
      "text_length": 8
    },
    {
      "event_id": "01019010_e00036",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "待我与你开门。",
      "text_length": 7
    },
    {
      "event_id": "01019010_e00037",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "你开来。",
      "text_length": 4
    },
    {
      "event_id": "01019010_e00038",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "01019010_e00039",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业开门，佘赛花执枪刺，杨业夺枪，绑佘赛花跪地。",
      "text_length": 24
    },
    {
      "event_id": "01019010_e00040",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "我看你这个丫头，还往哪里走。待我将她的战马，牵进庙来，我将门关闭了。",
      "text_length": 34
    },
    {
      "event_id": "01019010_e00041",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业拴马。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00042",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "好杀呀，好杀。",
      "text_length": 7
    },
    {
      "event_id": "01019010_e00043",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "好战吓，好战。",
      "text_length": 7
    },
    {
      "event_id": "01019010_e00044",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "好跑呀，好跑。",
      "text_length": 7
    },
    {
      "event_id": "01019010_e00045",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "好赶吓，好赶。",
      "text_length": 7
    },
    {
      "event_id": "01019010_e00046",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "赶的你家少爷是燕儿不下蛋。",
      "text_length": 13
    },
    {
      "event_id": "01019010_e00047",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "赶的你姑娘，是一身的透汗。",
      "text_length": 13
    },
    {
      "event_id": "01019010_e00048",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你这丫头，实实的好狠心呐。",
      "text_length": 13
    },
    {
      "event_id": "01019010_e00049",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "你的心肠，也就不软。",
      "text_length": 10
    },
    {
      "event_id": "01019010_e00050",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "怎见得你少爷心狠？",
      "text_length": 9
    },
    {
      "event_id": "01019010_e00051",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "你为何将奴家兄长杀死？",
      "text_length": 11
    },
    {
      "event_id": "01019010_e00052",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你就不该，赖了我的亲事。",
      "text_length": 12
    },
    {
      "event_id": "01019010_e00053",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "那是我家爹爹做主，与奴什么相干。",
      "text_length": 16
    },
    {
      "event_id": "01019010_e00054",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你倒推得干净。今日你既被擒，我且问你，你还是愿意一死，还是愿意一活？",
      "text_length": 34
    },
    {
      "event_id": "01019010_e00055",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "死是怎么讲，活是怎么说？",
      "text_length": 12
    },
    {
      "event_id": "01019010_e00056",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你要是愿意死吓，我就是这一枪，将你刺死。",
      "text_length": 20
    },
    {
      "event_id": "01019010_e00057",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "这一活呢？",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00058",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "这一活呀，来，来，来，你就与我成亲事，拜天地。",
      "text_length": 23
    },
    {
      "event_id": "01019010_e00059",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "我吓，我愿意一死。",
      "text_length": 9
    },
    {
      "event_id": "01019010_e00060",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "这个丫头，她愿意一死。",
      "text_length": 11
    },
    {
      "event_id": "01019010_e00061",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业提枪。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00062",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "来，你看枪！",
      "text_length": 6
    },
    {
      "event_id": "01019010_e00063",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花闪。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00064",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "慢来，我愿意一活罢。",
      "text_length": 10
    },
    {
      "event_id": "01019010_e00065",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你愿意一活，好好，来来来拜天地罢！",
      "text_length": 17
    },
    {
      "event_id": "01019010_e00066",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "你看这世界之上，男女拜天地，还有捆着绑着拜天地吗？",
      "text_length": 25
    },
    {
      "event_id": "01019010_e00067",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你是想叫我与你松绑吓。",
      "text_length": 11
    },
    {
      "event_id": "01019010_e00068",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "那是自然。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00069",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "我要与你松了绑，怕你一时反悔。你须要与我对天明誓。",
      "text_length": 25
    },
    {
      "event_id": "01019010_e00070",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "我一生一世，就是不会明誓。",
      "text_length": 13
    },
    {
      "event_id": "01019010_e00071",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你既不会明誓，你还与我一死吧。",
      "text_length": 15
    },
    {
      "event_id": "01019010_e00072",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业倒提枪。",
      "text_length": 6
    },
    {
      "event_id": "01019010_e00073",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "来，看枪。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00074",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "佘赛花闪。",
      "text_length": 5
    },
    {
      "event_id": "01019010_e00075",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "我明誓，我明誓。",
      "text_length": 8
    },
    {
      "event_id": "01019010_e00076",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你不要害怕，你看这是枪把。枪头在这一头儿呢。你与我明誓罢。",
      "text_length": 29
    },
    {
      "event_id": "01019010_e00077",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "皇天在上，我佘赛花在下，我今与小将成亲，若有三心二意，天厌之，天厌之。",
      "text_length": 35
    },
    {
      "event_id": "01019010_e00078",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "什么叫做添胭脂？你还添粉不成？",
      "text_length": 15
    },
    {
      "event_id": "01019010_e00079",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "此乃是个咒语。",
      "text_length": 7
    },
    {
      "event_id": "01019010_e00080",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "这是一句咒语，待我与你松绑。",
      "text_length": 14
    },
    {
      "event_id": "01019010_e00081",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "佘赛花"
      ],
      "text": "你看今日在庙内，你我夫妻，何处安身？",
      "text_length": 18
    },
    {
      "event_id": "01019010_e00082",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "这有何难，你我就将马褥子，拿下来，铺在殿内，就此成亲便了。你我来呀。（佘赛花拔剑砍。杨业退。胡琴拉牌子。杨业比手势，佘赛花倦，杨业暗拔佘赛花剑，比手势。佘赛花拔剑空，杨业砍佘赛花，佘赛花向杨业讨剑。杨业比势，佘赛花拜。）",
      "text_length": 110
    },
    {
      "event_id": "01019010_e00083",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "杨业"
      ],
      "text": "你我就此一拜。",
      "text_length": 7
    },
    {
      "event_id": "01019010_e00084",
      "play_id": "01019010",
      "scene_id": "01019010_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "杨业、佘赛花同拜。",
      "text_length": 9
    },
