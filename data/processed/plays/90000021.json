    },
    {
      "event_id": "90000021_e00003",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、曹彬同上。",
      "text_length": 9
    },
    {
      "event_id": "90000021_e00004",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵匡胤"
      ],
      "text": "逃出天罗地网，",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00005",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "曹彬"
      ],
      "text": "好似雀鸟腾飞。",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00006",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "兄长请坐。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00007",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "有坐。多蒙贤弟搭救，我这里当面谢过。",
      "text_length": 18
    },
    {
      "event_id": "90000021_e00008",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "岂敢。小弟当报前恩。",
      "text_length": 10
    },
    {
      "event_id": "90000021_e00009",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "岂敢。",
      "text_length": 3
    },
    {
      "event_id": "90000021_e00010",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "小弟备得有酒，为兄长压惊。",
      "text_length": 13
    },
    {
      "event_id": "90000021_e00011",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "来此就要叨扰。",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00012",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "兄长请。",
      "text_length": 4
    },
    {
      "event_id": "90000021_e00013",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "贤弟请。",
      "text_length": 4
    },
    {
      "event_id": "90000021_e00014",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "曹彬"
      ],
      "text": "受恩不报非君子，忘恩负义是小人。",
      "text_length": 16
    },
    {
      "event_id": "90000021_e00015",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹彬醉状睡。〖起初更鼓〗。",
      "text_length": 13
    },
    {
      "event_id": "90000021_e00016",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "他倒睡着了。",
      "text_length": 6
    },
    {
      "event_id": "90000021_e00017",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄三眼板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "小豪杰坐书房心中暗想，二相公心无事瞌睡一旁。无奈何推吊窗观看月亮，此乃是中秋月分外明光。",
      "text_length": 44
    },
    {
      "event_id": "90000021_e00018",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "叹爹娘和弟妹在家悬望，盼玄郎功名就急早还乡。酒金桥遇苗训对我来讲，他道我后来有九五之望。周文王坐江山全凭姜尚，小唐王坐江山元霸逞强。汉刘秀坐江山二十八将，二十八将，俺玄郎坐江山妄想一场。恨金鸡不报晓天还未亮，谯楼上睡着了打更儿郎。恨不得抛长枪刺落了天边月亮，用金钩钩出了红日轮光。",
      "text_length": 140
    },
    {
      "event_id": "90000021_e00019",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起二更鼓〗。张氏上。",
      "text_length": 11
    },
    {
      "event_id": "90000021_e00020",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "张氏"
      ],
      "text": "轻移莲步到书房，且听恩人说端详。",
      "text_length": 16
    },
    {
      "event_id": "90000021_e00021",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "奴家张氏，赵恩人正在书房饮酒，不免去到窗外，听他讲些什么。正是：",
      "text_length": 32
    },
    {
      "event_id": "90000021_e00022",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张氏"
      ],
      "text": "要知心腹事，但听口中言。",
      "text_length": 12
    },
    {
      "event_id": "90000021_e00023",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "哎呀且住，适才在关前，被崔龙拿住，多亏张氏嫂嫂叫俺一声丈夫，真乃难得啊难得。哎呀，讲什么难得，若是俺玄郎的妻子叫了别人一声丈夫，我就是这一刀……",
      "text_length": 72
    },
    {
      "event_id": "90000021_e00024",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "90000021_e00025",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "哎呀。",
      "text_length": 3
    },
    {
      "event_id": "90000021_e00026",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "一句言语错出唇，墙内说话墙外听。不饮酒来假装醉，酒醉的人儿话不清。",
      "text_length": 33
    },
    {
      "event_id": "90000021_e00027",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "张氏"
      ],
      "text": "听一言来吃一惊，羞得脸上起红云。腰间解下丝罗带，不如一死丧残生。",
      "text_length": 32
    },
    {
      "event_id": "90000021_e00028",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张氏下。〖起三更鼓〗。华佗上。",
      "text_length": 15
    },
    {
      "event_id": "90000021_e00029",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "华佗"
      ],
      "text": "闷坐松林下，修道数百年。三国行医术，自称华佗仙。",
      "text_length": 24
    },
    {
      "event_id": "90000021_e00030",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "我乃华佗是也，只因赤须龙在曹府被困，特地前来讨一封号，来此已是。",
      "text_length": 32
    },
    {
      "event_id": "90000021_e00031",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "华佗"
      ],
      "text": "不用忧来不用愁，宝刀割去肉龙瘤。阳世之间无用处，抛在长江顺水流。",
      "text_length": 32
    },
    {
      "event_id": "90000021_e00032",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "何方妖道在此摆来摆去？",
      "text_length": 11
    },
    {
      "event_id": "90000021_e00033",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "贫道华佗。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00034",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "前来则甚？",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00035",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "前来讨封。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00036",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "修炼多少年代？",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00037",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "数百余年了。",
      "text_length": 6
    },
    {
      "event_id": "90000021_e00038",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "可算得一洞老神仙。",
      "text_length": 9
    },
    {
      "event_id": "90000021_e00039",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "华佗"
      ],
      "text": "谢主龙恩。正是：",
      "text_length": 8
    },
    {
      "event_id": "90000021_e00040",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "华佗"
      ],
      "text": "不是真龙开金口，焉得蓬莱一洞仙。",
      "text_length": 16
    },
    {
      "event_id": "90000021_e00041",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "华佗下。〖起四更鼓〗。张氏上。",
      "text_length": 15
    },
    {
      "event_id": "90000021_e00042",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "张氏"
      ],
      "text": "人死如灯灭，犹如汤泼雪。若要还阳转，海底捞明月。",
      "text_length": 24
    },
    {
      "event_id": "90000021_e00043",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "奴乃张氏鬼魂是也，只因闻听赵公子之言，羞愧难当，回房自缢身死，方知他日后有九五之尊，不免去至书房，向他讨一封号。来此已是，待我进去。",
      "text_length": 66
    },
    {
      "event_id": "90000021_e00044",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "何处鬼魂在此摆来摆去？",
      "text_length": 11
    },
    {
      "event_id": "90000021_e00045",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "奴乃张氏鬼魂是也。",
      "text_length": 9
    },
    {
      "event_id": "90000021_e00046",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "到此何事？",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00047",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "前来讨封。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00048",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "前日打从华山经过，缺一圣母，就封你以为茶花圣母，归位去吧。",
      "text_length": 29
    },
    {
      "event_id": "90000021_e00049",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金童、玉女同上。",
      "text_length": 8
    },
    {
      "event_id": "90000021_e00050",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "金童、玉女送她归位。",
      "text_length": 10
    },
    {
      "event_id": "90000021_e00051",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张氏"
      ],
      "text": "谢主龙恩。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00052",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张氏、金童、玉女同下。〖起五更鼓〗。",
      "text_length": 18
    },
    {
      "event_id": "90000021_e00053",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "曹小姐"
      ],
      "text": "走哇。",
      "text_length": 3
    },
    {
      "event_id": "90000021_e00054",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹小姐上。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00055",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "曹小姐"
      ],
      "text": "忙将大嫂事，报与二哥知。",
      "text_length": 12
    },
    {
      "event_id": "90000021_e00056",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹小姐"
      ],
      "text": "二哥快快开门。",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00057",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹彬醒，开门。",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00058",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "贤妹何事？",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00059",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹小姐"
      ],
      "text": "嫂嫂悬梁自尽了。",
      "text_length": 8
    },
    {
      "event_id": "90000021_e00060",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "你且回房去吧。",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00061",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "曹小姐"
      ],
      "text": "唉，嫂嫂哇……",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00062",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹小姐下。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00063",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "兄长醒来。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00064",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "茶花圣母归了位，三国华佗受封回。猛然睁开丹凤眼，贤弟为何两泪垂？",
      "text_length": 32
    },
    {
      "event_id": "90000021_e00065",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "曹彬"
      ],
      "text": "唉，嫂嫂哇……",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00066",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "贤弟为何落泪？",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00067",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "我家嫂嫂悬梁自尽了。",
      "text_length": 10
    },
    {
      "event_id": "90000021_e00068",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "有这等事。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00069",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内呐喊声。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00070",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "哪里人马呐喊？",
      "text_length": 7
    },
    {
      "event_id": "90000021_e00071",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "待小弟府门打探再来回报。",
      "text_length": 12
    },
    {
      "event_id": "90000021_e00072",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "有劳贤弟。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00073",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹彬下，上。",
      "text_length": 6
    },
    {
      "event_id": "90000021_e00074",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "兄长大事不好了。",
      "text_length": 8
    },
    {
      "event_id": "90000021_e00075",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00076",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "今有崔龙带领人马，将府门围住。口口声声要拿兄长上殿。",
      "text_length": 26
    },
    {
      "event_id": "90000021_e00077",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "贤弟今乃什么日期？",
      "text_length": 9
    },
    {
      "event_id": "90000021_e00078",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "八月十四日。",
      "text_length": 6
    },
    {
      "event_id": "90000021_e00079",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "明日呢？",
      "text_length": 4
    },
    {
      "event_id": "90000021_e00080",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "中秋之日了。",
      "text_length": 6
    },
    {
      "event_id": "90000021_e00081",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "如此说来，俺玄郎也有出头之日了。",
      "text_length": 16
    },
    {
      "event_id": "90000021_e00082",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "想你这光棍之家，还有什么出头之日不成？",
      "text_length": 19
    },
    {
      "event_id": "90000021_e00083",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵匡胤"
      ],
      "text": "贤弟呀。",
      "text_length": 4
    },
    {
      "event_id": "90000021_e00084",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄碰板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "休道我光棍家根本无有，请台座听玄郎细说从头：",
      "text_length": 22
    },
    {
      "event_id": "90000021_e00085",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "想当年俺玄郎江湖上走，柴大哥贩雨伞郑恩卖油。我三人秦王庙焚香叩首，胜似那一母生心意相投。董家桥打五虎弟兄分手，柴大哥上淮庆官封王侯。好一个柴大哥不忘故友，修书信接玄郎全家来投。弟兄们闲无事在花厅饮酒，鱼池内起怪风妖魔出头。大哥道龙戏水常常则有，俺玄郎一见是妖魔出头。左拉弓右搭箭照怪射走，又听得谯楼上鼓打三筹。",
      "text_length": 155
    },
    {
      "event_id": "90000021_e00086",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "胡琴过门。",
      "text_length": 5
    },
    {
      "event_id": "90000021_e00087",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "次日里柴大哥朝房待漏，郭王爷一见俺火上浇油。某一言未出口就要斩首，多亏了柴大哥一本保留。悔不该在金殿夸下海口，不用兵不用将独下燕州。在关前遇崔龙蒙你搭救，多亏了贤弟你将我收留。今夜晚在书房一觉醒后，偶然间得二梦大不相投。头一梦梦见了华佗老叟，执宝刀照左臂割去肉瘤。贤弟你若不信解衣看透，",
      "text_length": 143
    },
    {
      "event_id": "90000021_e00088",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "90000021_e00089",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 89,
      "seq_in_scene": 89,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "曹彬"
      ],
      "text": "细端详果然是割去了肉瘤。",
      "text_length": 12
    },
    {
      "event_id": "90000021_e00090",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 90,
      "seq_in_scene": 90,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹彬"
      ],
      "text": "请问兄长这第二梦？",
      "text_length": 9
    },
    {
      "event_id": "90000021_e00091",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 91,
      "seq_in_scene": 91,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "第二梦梦尊嫂书房来走，披着发相带愁她苦苦哀求。我封她到华山茶花圣后，赐金童和玉女送上瀛州。劝贤弟在此间休要多守，倒不如同家眷搬出燕州。天牢内替愚兄代为问侯，说玄郎成了功即刻回头。叫贤弟看过了——",
      "text_length": 97
    },
    {
      "event_id": "90000021_e00092",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 92,
      "seq_in_scene": 92,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄散板",
      "speakers": [
        "赵匡胤"
      ],
      "text": "铁链手杻，此一番上金殿杀他个寸草不留。辞别了曹贤弟就要分手，这才是祸到临头来不自由，我去献肉瘤。",
      "text_length": 48
    },
    {
      "event_id": "90000021_e00093",
      "play_id": "90000021",
      "scene_id": "90000021_s01",
      "scene_no": 1,
      "seq_global": 93,
      "seq_in_scene": 93,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "赵匡胤、曹彬同下。",
      "text_length": 9
    }
  ],
  "roles_inferred": true
}