  "events": [
    {
      "event_id": "03092004_e00001",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷上。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00002",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "秦罗敷"
      ],
      "text": "绣阁衾香，配鸾凰，哪羡君王！",
      "text_length": 14
    },
    {
      "event_id": "03092004_e00003",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "秦罗敷"
      ],
      "text": "海棠红上碧纱窗，漫摘梨花助晓妆。春色萦人腰欲折，难禁三月好风光。",
      "text_length": 32
    },
    {
      "event_id": "03092004_e00004",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "奴家、秦氏罗敷。配夫王仁，家住邯郸，现为赵王家令。夫妻日出而作，日入而息。薄田数顷，颇堪自给。一角红楼，双宿双飞。既不讪笑旁人的百结鹑衣，也不羡慕他人的高车驷马，安居乐业，于愿斯足。看今日天气清和，蜂蝶成阵，我不免前去桑园，采取嫩叶柔枝，饲养春蚕，以作这御寒之计。正是：",
      "text_length": 135
    },
    {
      "event_id": "03092004_e00005",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "秦罗敷"
      ],
      "text": "冬去春来麦又黄，织衣莫待降寒霜。",
      "text_length": 16
    },
    {
      "event_id": "03092004_e00006",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "舒玉腕推纱窗楼头远望，百花开绿叶肥麦浪汪洋。惜花蝶闹东墙纷飞上下，又只见穿林燕戏舞垂杨。提钩篮来至在陌头以上，御沟水漂金莲花放奇芳。",
      "text_length": 66
    },
    {
      "event_id": "03092004_e00007",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "我看此处，距离吾家园亭不远，这道旁桑树，倒也青翠可爱，想系官家种植，定有官人照顾。只是如此有用之物，弃置未免可惜，我若择其善者而留之，岂不是好！哎呀且住！设有官人前来干涉，我便如何答对？",
      "text_length": 93
    },
    {
      "event_id": "03092004_e00008",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷想。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00009",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "哦，有了！设有官人前来，我只道与赵王当家令的我那王郎，命我前来摘取便了！",
      "text_length": 36
    },
    {
      "event_id": "03092004_e00010",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷采桑。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00011",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "满天红雨近端阳，旭日东升浮碧塘。绿叶成荫张翠盖，往来都为麦田忙。微风吹发凉如水，荆针又刺破了我的好衣裳。夫君朝里将君侍，奴这里殷勤采野桑。欲攀高枝凭远望，",
      "text_length": 77
    },
    {
      "event_id": "03092004_e00012",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷攀树跌下。",
      "text_length": 8
    },
    {
      "event_id": "03092004_e00013",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "跌碎怀中紫荷囊！",
      "text_length": 8
    },
    {
      "event_id": "03092004_e00014",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "罢了，奴家桑叶业已足数，本待凭高一望，怎奈又跌将下来！只这一跤，跌得我眼花缭乱，宝髻低垂，就是这耳上的明月双珠，也失落了一个！",
      "text_length": 63
    },
    {
      "event_id": "03092004_e00015",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷寻找。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00016",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "可见为人切莫攀高，攀高必然跌落！看这道旁，石青树碧，正好休息一番，再回家转。",
      "text_length": 38
    },
    {
      "event_id": "03092004_e00017",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷看。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00018",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "这阳关大道，游人如蚁，好不热闹也！怎么那个担担子的，痴立那厢，正不知他心中在想些什么！怎么，那壁厢的人儿，将冠巾脱下，立在那里，意欲何为呀？莫非他们都在注意我么？",
      "text_length": 81
    },
    {
      "event_id": "03092004_e00019",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷笑。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00020",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "自幼罗敷爱艳妆，常向花间斗晚芳。一任他人道长短，惟爱吾家王二郎。",
      "text_length": 32
    },
    {
      "event_id": "03092004_e00021",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷看。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00022",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "怎么，那一伙耕地的农夫，都把锄头丢了。就是那放牛的哥哥么，也将这牛儿牵着不走，都越发地看起奴家来了！",
      "text_length": 50
    },
    {
      "event_id": "03092004_e00023",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷笑。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00024",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "想奴家生来与旁人一般无二，为何他们把那凶呆呆的眼睛，盯着奴家呢？",
      "text_length": 32
    },
    {
      "event_id": "03092004_e00025",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷笑。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00026",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "哎呀呀，哪里来的这许多无有见过世面的男子哟！",
      "text_length": 22
    },
    {
      "event_id": "03092004_e00027",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "笑痴人如狼虎将奴来望，倒叫我罗敷女好不心慌。提篮笼和勾竿家门来转，一任他莽男儿如醉如狂！",
      "text_length": 44
    },
    {
      "event_id": "03092004_e00028",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "且慢！莫非是他们道我罗敷不该采取这陌上的官家桑叶么？哎呀且住！我忽然间想起一桩心事来了！向我罗敷，自从出嫁以来，郎君如意，恩爱非常，前日也曾去到那边陌头之上，采桑玩耍，正值那赵王他与随从人等，凭楼远望，单单看见了奴家，就寻向我的夫君，道我的风姿窈窕，竟欲宣入宫中，赐以酒宴，但不知他意欲何为？莫非赵王他起了不良之意么？若是去么，只怕是被……",
      "text_length": 170
    },
    {
      "event_id": "03092004_e00029",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷焦急。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00030",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "不去么，又待怎样？我只好急急回家，与我那王郎，商议一个脱身之计！若是等到那东离西散的时节，就悔之晚矣！",
      "text_length": 51
    },
    {
      "event_id": "03092004_e00031",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷跑圆场。",
      "text_length": 7
    },
    {
      "event_id": "03092004_e00032",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "自幼儿美姿容风流自赏，哪管他长舌妇飞短流长。挽云鬟拢翠髻描眉画鬓，一任他田舍郎枉费肝肠。坐鸾井望天鹅徒生魔障，女儿家撒娇俏这又何妨！论容颜如桃李天仙模样，事夫君全节义凛若冰霜。",
      "text_length": 88
    },
    {
      "event_id": "03092004_e00033",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "来此已是家门，但不知夫君他回来无有？",
      "text_length": 18
    },
    {
      "event_id": "03092004_e00034",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷进门，看。",
      "text_length": 8
    },
    {
      "event_id": "03092004_e00035",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "怎么今日天到这般时候，还未曾回来？莫非是我王家，要祸从天降不成么！",
      "text_length": 33
    },
    {
      "event_id": "03092004_e00036",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "看春蚕已无心竿篮乱放，",
      "text_length": 11
    },
    {
      "event_id": "03092004_e00037",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷放篮。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00038",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "盼夫君未回转好不神伤！",
      "text_length": 11
    },
    {
      "event_id": "03092004_e00039",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "记得昨日王郎一进门来，他就愁眉不展，还是我温存软语，细细地追问情由，方才知道那赵王昨日将他招进书房言道：昨日我登楼远望，看见你的妻子风流貌美；又闻人言，道她玉指搊筝，盖世无双，可否宣进宫中，前来一见？怎奈我那王郎，素昔忠厚，当面应允。想那赵王，乃是一国之主，听政安民，且无余暇，怎么单单要召见我这无德无才的妇人呢？这是何道理？莫非他真痴心妄想不成么！我想这筵宴是用不得的！看那侯门墙院，深如渊海，易入难出，到那时节，更有何缘再见我那王郎啊！",
      "text_length": 220
    },
    {
      "event_id": "03092004_e00040",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷哭。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00041",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "苍天哪，天！想我罗敷，夙行多义，为什么这祸从天起！吾想此事，业已如此，枉自伤心，也徒然无益。我不免寻思一脱身之计！",
      "text_length": 57
    },
    {
      "event_id": "03092004_e00042",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷想。",
      "text_length": 5
    },
    {
      "event_id": "03092004_e00043",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "有了，奴家听人言道：那赵王潜心礼乐，言义行仁，昨日偶作非分之想，或系一时之误，也是有的。我不免借此天光尚早，制出几支歌曲，谱入筝中，待他召见之日，奏与他听；他若明白，自然追悔，如若不然，我就将身一越，撞死阶前！这一，可以报我那王郎相爱之义！这二，可以免去秦氏家门之羞！这三，可以警戒后来无道昏君，不要贪恋别人家的妻子！人生在世，忍辱含羞，有何颜面！我就这样对付赵王便了！",
      "text_length": 185
    },
    {
      "event_id": "03092004_e00044",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷弹筝。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00045",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "日出东南隅，照我秦氏楼。秦氏有好女，自名为罗敷。罗敷喜蚕桑，采桑城南隅。青丝为笼系，桂枝为笼钩。头上倭堕髻，耳中明月珠。缃绮为下裙，紫绮为上襦。行者见罗敷，下担捋髭须。少年见罗敷，脱帽著帩头。耕者忘其犁，锄者忘其锄。来归相怒怨，但坐观罗敷。",
      "text_length": 120
    },
    {
      "event_id": "03092004_e00046",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "这第一段中，叙明我自身的身世，叫他知道，喜爱我罗敷的，并不是他一人哪！",
      "text_length": 35
    },
    {
      "event_id": "03092004_e00047",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷弹筝。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00048",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "使君从东来，五马立踌躇。使君遣吏问，问是谁家妹？秦氏有好女，自名为罗敷。罗敷年几何？二十尚不足，十五颇有余。使君谢罗敷，宁可共载不？罗敷前置辞：使君一何愚！使君自有妇，罗敷自有夫。",
      "text_length": 90
    },
    {
      "event_id": "03092004_e00049",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "这一段是不卑不亢，说明我自家的志愿，就是皇帝来此，也不见得就能更改了我的志愿，何况这赵王！他如何配得呀！",
      "text_length": 52
    },
    {
      "event_id": "03092004_e00050",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷弹筝。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00051",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "秦罗敷"
      ],
      "text": "东方千余骑，夫婿居上头。何用识夫婿，白马从骊驹。青丝系马尾，黄金络马头。腰中鹿卢剑，可值千万余。十五府小史，二十朝大夫。三十侍中郎，四十专城居。为人洁白皙，鬑鬑颇有须。盈盈公府步，冉冉府中趋。坐中数千人，皆言夫婿殊！",
      "text_length": 108
    },
    {
      "event_id": "03092004_e00052",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷作喜慰状。",
      "text_length": 8
    },
    {
      "event_id": "03092004_e00053",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "这第三段么，叫他知道我那王郎是如何人物，其实他那久居宫中之人能比得的！好不害羞噢！",
      "text_length": 41
    },
    {
      "event_id": "03092004_e00054",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷弹筝。",
      "text_length": 6
    },
    {
      "event_id": "03092004_e00055",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "秦罗敷"
      ],
      "text": "所幸歌曲筝声，业已谱好。且到后面，收拾一番，等我那王郎回来，告知于他便了！正是：",
      "text_length": 40
    },
    {
      "event_id": "03092004_e00056",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "秦罗敷"
      ],
      "text": "自家且顾安神乐，休管他人抢帝王！",
      "text_length": 16
    },
    {
      "event_id": "03092004_e00057",
      "play_id": "03092004",
      "scene_id": "03092004_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "秦罗敷下。",
      "text_length": 5
    }
  ],
  "roles_inferred": true
}