  "events": [
    {
      "event_id": "01006013_e00001",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套引孙尚香同上。",
      "text_length": 10
    },
    {
      "event_id": "01006013_e00002",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "孙尚香"
      ],
      "text": "沧海连江，乾坤浩荡，虽受职，哪有庙堂，何处受祭享！",
      "text_length": 25
    },
    {
      "event_id": "01006013_e00003",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香上高台。",
      "text_length": 7
    },
    {
      "event_id": "01006013_e00004",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "孙尚香"
      ],
      "text": "大孝能感天，节义须周全。神光照水府，慧眼望西川。",
      "text_length": 24
    },
    {
      "event_id": "01006013_e00005",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "吾乃孙氏尚香灵魂是也。配夫玄德，在西蜀为君。只因荆州失陷，在白帝城晏驾。幸喜阿斗接位。奴在东吴，投江尽节一死。蒙上帝怜悯，敕封为神。奈无庙堂，谁来祭祀？今去托兆母后，建造庙堂，重名于世。众水卒，",
      "text_length": 97
    },
    {
      "event_id": "01006013_e00006",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同允。",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00007",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "随我同往。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00008",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香下高台。",
      "text_length": 7
    },
    {
      "event_id": "01006013_e00009",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "孙尚香"
      ],
      "text": "驾神风急冲开长江波浪，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00010",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "灵光照齐护拥孝姬娘娘。我本是千金女皇宫生长，今方见世间人名利奔忙。蒙敕封并无有",
      "text_length": 39
    },
    {
      "event_id": "01006013_e00011",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "坐位神像，",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00012",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同下。",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00013",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "长寿宫托母兆建造庙堂。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00014",
      "play_id": "01006013",
      "scene_id": "01006013_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香下。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00015",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女、吴国太同上。",
      "text_length": 10
    },
    {
      "event_id": "01006013_e00016",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "吴国太"
      ],
      "text": "夫本是炎汉家辅国大将，小孙策寿命短少年夭亡。孙仲谋霸江东独把业掌，汉江山分三国俱想称皇。魏天时吴地利人和气旺，为荆州叹我婿白帝城亡。尚香儿全节义祭夫亲往，儿百步母枕忧难解愁肠。",
      "text_length": 88
    },
    {
      "event_id": "01006013_e00017",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "本后吴氏。长子孙策，少年夭亡。次子孙权，虎踞江东。幼女尚香，配夫玄德，西川为帝。只为荆州，被陆逊火烧连营，叹我儿婿，身丧白帝城中。女儿亲往江边祭奠，怎么还不回宫？",
      "text_length": 81
    },
    {
      "event_id": "01006013_e00018",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监上。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00019",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "太后大事不好了！",
      "text_length": 8
    },
    {
      "event_id": "01006013_e00020",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "何事惊慌？",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00021",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "郡主投江已死！",
      "text_length": 7
    },
    {
      "event_id": "01006013_e00022",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "你才怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00023",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "郡主投江而亡！",
      "text_length": 7
    },
    {
      "event_id": "01006013_e00024",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "哎吓！",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00025",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "吴国太"
      ],
      "text": "儿为夫尽节死鱼肠埋葬，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00026",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "吴国太"
      ],
      "text": "尚香！我儿！哎儿吓！",
      "text_length": 10
    },
    {
      "event_id": "01006013_e00027",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "比前朝汉昭君不舍刘王。夫身丧妻尽节虽有榜样，",
      "text_length": 22
    },
    {
      "event_id": "01006013_e00028",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "吴国太"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00029",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "恐难效孟姜女受职表扬。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00030",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "内臣，",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00031",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监允。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00032",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "郡主投江，可有人搭救？",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00033",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "难以救起。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00034",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "报与主公知道。",
      "text_length": 7
    },
    {
      "event_id": "01006013_e00035",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大太监"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00036",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大太监下。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00037",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "三叫头",
      "speakers": [
        "吴国太"
      ],
      "text": "尚香！我儿！儿吓！",
      "text_length": 9
    },
    {
      "event_id": "01006013_e00038",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "为娘若知你有此尽节之心，我也不要你江边祭奠去了吓！",
      "text_length": 25
    },
    {
      "event_id": "01006013_e00039",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "要尽节也应该对娘直讲，讨祭奠投江死魂灵渺茫。天保佑儿命在免娘痴想，",
      "text_length": 33
    },
    {
      "event_id": "01006013_e00040",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "吴国太"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00041",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "宫娥们扶本后即归龙床。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00042",
      "play_id": "01006013",
      "scene_id": "01006013_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女搀吴国太同下。",
      "text_length": 10
    },
    {
      "event_id": "01006013_e00043",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二门神同上。",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00044",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "门神甲"
      ],
      "text": "上苍有旨意，",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00045",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "门神乙"
      ],
      "text": "看守宫门庭。",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00046",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "门神乙"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00047",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "门神甲"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00048",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "门神乙"
      ],
      "text": "奉了玉帝敕旨，看守宫门。远远望见，孙氏尚香来也。",
      "text_length": 24
    },
    {
      "event_id": "01006013_e00049",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套引孙尚香同上。",
      "text_length": 10
    },
    {
      "event_id": "01006013_e00050",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "水晶宫与阳间一般模样，也有这银銮殿画角雕梁。众神将且肃静休要声嚷，比不得水府内任儿猖狂。",
      "text_length": 44
    },
    {
      "event_id": "01006013_e00051",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "尊神请了。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00052",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门神"
      ],
      "text": "到此何事？",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00053",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "尊神吓！",
      "text_length": 4
    },
    {
      "event_id": "01006013_e00054",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "奴虽受玉帝封魂魄飘荡，哪一处是我的神位庙堂？乘夜来见我母待求方向，托一兆不久停即出宫墙。",
      "text_length": 44
    },
    {
      "event_id": "01006013_e00055",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二门神"
      ],
      "text": "只许你一人进去，休要惊吓于她。",
      "text_length": 15
    },
    {
      "event_id": "01006013_e00056",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "知道了。",
      "text_length": 4
    },
    {
      "event_id": "01006013_e00057",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "你等在宫门外隐身休闯，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00058",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套同下。",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00059",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "二尊神请让路暂息张扬。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00060",
      "play_id": "01006013",
      "scene_id": "01006013_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香下。二门神同下。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00061",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 61,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女引吴国太同上。",
      "text_length": 10
    },
    {
      "event_id": "01006013_e00062",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 62,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "吴国太"
      ],
      "text": "恨的是陆伯言智足谋广，火攻计烧连营鸡犬难藏。大限到在数灾难逃罗网，尚香在吴国内未离兰房。将身儿且坐在龙凤锦帐，",
      "text_length": 55
    },
    {
      "event_id": "01006013_e00063",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 63,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二宫女同下。",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00064",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 64,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "吴国太"
      ],
      "text": "闷恹恹只想我幼女尚香。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00065",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 65,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香上。",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00066",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 66,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "在生前常出进宫人随往，今见母孤单单躲躲藏藏。欲开言老年人心散神恍，跪御榻音声细忍住凄惶。",
      "text_length": 44
    },
    {
      "event_id": "01006013_e00067",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 67,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后醒来！",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00068",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 68,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "吴国太"
      ],
      "text": "空负我数十年儿女娇养，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00069",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后！",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00070",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "哎吓！",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00071",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 71,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "听姣音真是我幼女尚香。见儿面方把我愁眉展放，",
      "text_length": 22
    },
    {
      "event_id": "01006013_e00072",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 72,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "回龙",
      "speakers": [
        "孙尚香"
      ],
      "text": "人命大关系重岂能谎谈。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00073",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 73,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "尽节死阴灵魂水府路上，未报答哺乳恩难舍亲娘。",
      "text_length": 22
    },
    {
      "event_id": "01006013_e00074",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 74,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00075",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 75,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "吴国太"
      ],
      "text": "听儿言似空中霹雳下降，娘好似燕衔泥枉费心肠。为荆州献儿计恨你兄长，甘露寺娘见面相儿招夫郎。今尽节不尽孝娘谁供养？",
      "text_length": 56
    },
    {
      "event_id": "01006013_e00076",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 76,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "老娘亲缺甘旨还有兄王。尽节烈以图了后人钦仰，儿不是枭鸟心天大仓娘。",
      "text_length": 33
    },
    {
      "event_id": "01006013_e00077",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 77,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "吴国太"
      ],
      "text": "古今来女生时面生外向，但不知儿尸首漂流何方？阴灵魂既见娘直言话讲，寻着你尸和首好去奔丧。",
      "text_length": 44
    },
    {
      "event_id": "01006013_e00078",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 78,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄慢板",
      "speakers": [
        "孙尚香"
      ],
      "text": "儿的尸向西方逆水漂上，蒙上帝敕封我孝姬娘娘。",
      "text_length": 22
    },
    {
      "event_id": "01006013_e00079",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 79,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "哦，儿封为孝姬娘娘？",
      "text_length": 10
    },
    {
      "event_id": "01006013_e00080",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 80,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00081",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 81,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "儿的尸首呢？",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00082",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 82,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙尚香"
      ],
      "text": "母后。",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00083",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 83,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "孙尚香"
      ],
      "text": "女阴魂想西川独自难往，尸现在芜湖关江北路旁。",
      "text_length": 22
    },
    {
      "event_id": "01006013_e00084",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 84,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "吴国太"
      ],
      "text": "孝义心感天地上帝旌奖，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00085",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 85,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "孙尚香"
      ],
      "text": "虽敕封并无有寺院庙堂。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00086",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 86,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反二黄原板",
      "speakers": [
        "吴国太"
      ],
      "text": "娘传旨建庙堂儿受祭享，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00087",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 87,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "谢母后天地恩日月寿长。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00088",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 88,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖起五更鼓〗。",
      "text_length": 7
    },
    {
      "event_id": "01006013_e00089",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 89,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "aria",
      "mode_label": "反二黄摇板",
      "speakers": [
        "孙尚香"
      ],
      "text": "睁眼看月光隐日出浮山，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00090",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 90,
      "seq_in_scene": 30,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙尚香下。二宫女同上。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00091",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 91,
      "seq_in_scene": 31,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "太后醒来！",
      "text_length": 5
    },
    {
      "event_id": "01006013_e00092",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 92,
      "seq_in_scene": 32,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄导板",
      "speakers": [
        "吴国太"
      ],
      "text": "见姣儿诉衷肠平日一样，",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00093",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 93,
      "seq_in_scene": 33,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二宫女"
      ],
      "text": "醒来！",
      "text_length": 3
    },
    {
      "event_id": "01006013_e00094",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 94,
      "seq_in_scene": 34,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "吴国太"
      ],
      "text": "哎呀，儿吓！",
      "text_length": 6
    },
    {
      "event_id": "01006013_e00095",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 95,
      "seq_in_scene": 35,
      "page_no": 4,
      "type": "aria",
      "mode_label": "二黄摇板",
      "speakers": [
        "吴国太"
      ],
      "text": "宫娥女惊醒了大梦一场。",
      "text_length": 11
    },
    {
      "event_id": "01006013_e00096",
      "play_id": "01006013",
      "scene_id": "01006013_s04",
      "scene_no": 4,
      "seq_global": 96,
