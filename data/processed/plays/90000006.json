  "events": [
    {
      "event_id": "90000006_e00001",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟引王宝钏同上。",
      "text_length": 9
    },
    {
      "event_id": "90000006_e00002",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "王宝钏"
      ],
      "text": "燕语莺啼，惊醒了，春梦迷离！",
      "text_length": 14
    },
    {
      "event_id": "90000006_e00003",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王宝钏"
      ],
      "text": "闺中独处整红妆，承欢膝下慰高堂。五色绒将彩球绣，二月二日选佳郎。",
      "text_length": 32
    },
    {
      "event_id": "90000006_e00004",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "奴家王宝钏。爹爹王允，官居朝堂首相；母亲陈氏，膝下无儿，所生我姊妹三人：大姊金钏，许配苏龙；二姊银钏，配与魏虎。只有奴家尚待字闺中，这且不言。只因那年母亲染病在床，是我伺汤药三载，母病全愈。圣上闻知见喜，赐我五色绒线绣成彩球，定于二月二日在十字街前，高搭彩楼招赘。但愿打中如意郎君，方为终身之幸。今当正月，大雪初晴，园中梅花盛开，正好前去赏雪观花。丫鬟，看衣伺候，引路花园！",
      "text_length": 187
    },
    {
      "event_id": "90000006_e00005",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是啦！",
      "text_length": 3
    },
    {
      "event_id": "90000006_e00006",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "王宝钏"
      ],
      "text": "银光耀眼雪初晴，新春天气正宜人。几处楼台如画镜，无边玉宇净无尘。丫环带路花园进，",
      "text_length": 40
    },
    {
      "event_id": "90000006_e00007",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "您可小心着点儿。",
      "text_length": 8
    },
    {
      "event_id": "90000006_e00008",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "无妨。",
      "text_length": 3
    },
    {
      "event_id": "90000006_e00009",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "王宝钏"
      ],
      "text": "踏雪寻梅迎芳芬。",
      "text_length": 8
    },
    {
      "event_id": "90000006_e00010",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "小姐，你看满园的梅花开得多好啊！",
      "text_length": 16
    },
    {
      "event_id": "90000006_e00011",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "开的果然茂盛。",
      "text_length": 7
    },
    {
      "event_id": "90000006_e00012",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "小姐，您请在亭中小坐，那株梅花花开的更好，我给您摘上一枝来。",
      "text_length": 30
    },
    {
      "event_id": "90000006_e00013",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我在亭中等你！",
      "text_length": 7
    },
    {
      "event_id": "90000006_e00014",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是啦。",
      "text_length": 3
    },
    {
      "event_id": "90000006_e00015",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵上。",
      "text_length": 5
    },
    {
      "event_id": "90000006_e00016",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "肚中饥饿身寒冷，头晕目眩难支撑。霎时只觉站立不稳，",
      "text_length": 25
    },
    {
      "event_id": "90000006_e00017",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵倒。",
      "text_length": 5
    },
    {
      "event_id": "90000006_e00018",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "小姐，这枝红梅开得多好啊！",
      "text_length": 13
    },
    {
      "event_id": "90000006_e00019",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "黄钟·醉花荫",
      "speakers": [
        "王宝钏"
      ],
      "text": "雪斗红梅花枝俏，见喜鹊飞来喧闹。又谁人领路识孤芳，何处知音，毕竟人间难找。",
      "text_length": 37
    },
    {
      "event_id": "90000006_e00020",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊，丫鬟，你我闷坐凉亭，何不想个法儿消遣？",
      "text_length": 21
    },
    {
      "event_id": "90000006_e00021",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "我去拿棋盘，陪你下棋可好？",
      "text_length": 13
    },
    {
      "event_id": "90000006_e00022",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "不好！",
      "text_length": 3
    },
    {
      "event_id": "90000006_e00023",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "那就打千秋玩吧？",
      "text_length": 8
    },
    {
      "event_id": "90000006_e00024",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "也不好！",
      "text_length": 4
    },
    {
      "event_id": "90000006_e00025",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "也不好！嗳！要不然我就将后花园门儿打开，陪你观看野景好不好啊？",
      "text_length": 31
    },
    {
      "event_id": "90000006_e00026",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "相爷可在府中？",
      "text_length": 7
    },
    {
      "event_id": "90000006_e00027",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "不在府中。",
      "text_length": 5
    },
    {
      "event_id": "90000006_e00028",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "如此将花园门开了！",
      "text_length": 9
    },
    {
      "event_id": "90000006_e00029",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是啦！啊呀！我的妈呀！启禀小姐：后花园门口有个花郎倒卧。",
      "text_length": 28
    },
    {
      "event_id": "90000006_e00030",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "有这等事，待我看来。",
      "text_length": 10
    },
    {
      "event_id": "90000006_e00031",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "您快去看看。",
      "text_length": 6
    },
    {
      "event_id": "90000006_e00032",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "啊呀且住！果然是个花郎倒卧在此。丫鬟快快将那花郎唤醒。",
      "text_length": 27
    },
    {
      "event_id": "90000006_e00033",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "遵命。嗳……这一花郎你快醒醒，哎，我说花郎你倒是醒醒啊！",
      "text_length": 28
    },
    {
      "event_id": "90000006_e00034",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "薛平贵醒。",
      "text_length": 5
    },
    {
      "event_id": "90000006_e00035",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "原来是位大姐，唤我何事？",
      "text_length": 12
    },
    {
      "event_id": "90000006_e00036",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "你这个人为什么倒卧在我们后花园门口哇？",
      "text_length": 19
    },
    {
      "event_id": "90000006_e00037",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "只因天气寒冷，腹中饥饿，两眼昏花，不料倒卧在此。多蒙大姐将我唤醒，我这里当面谢过！",
      "text_length": 41
    },
    {
      "event_id": "90000006_e00038",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "慢着，慢着，你先谢过我们小姐吧！",
      "text_length": 16
    },
    {
      "event_id": "90000006_e00039",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "哦，是是是，多谢小姐！",
      "text_length": 11
    },
    {
      "event_id": "90000006_e00040",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "罢了。且住，看这花郎，面目清秀，十分英俊，因何落魄至此啊？丫鬟，将这花郎带进花园，我要周济与他。",
      "text_length": 48
    },
    {
      "event_id": "90000006_e00041",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是啦！那一花郎随我来！",
      "text_length": 11
    },
    {
      "event_id": "90000006_e00042",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "喔，参见小姐！",
      "text_length": 7
    },
    {
      "event_id": "90000006_e00043",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "罢了，这一花郎，你家住哪里？姓甚名谁？因何落到这般光景？",
      "text_length": 28
    },
    {
      "event_id": "90000006_e00044",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "卑人薛平贵，乃长安人氏。晓读诗书，略通武艺。只因父母早亡，闻得苏元帅招兵将，为此，沿途乞讨，前去投军报国，怎奈天气寒冷，腹中饥饿，困倒在此，啊！真正困煞人也！",
      "text_length": 79
    },
    {
      "event_id": "90000006_e00045",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "落魄之身当发奋，有心立志去投军。",
      "text_length": 16
    },
    {
      "event_id": "90000006_e00046",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "听他言来自思忖，他家贫却是有志的人。抛球选婿事不稳，我有意与他订下亲。彩楼之事对他论，",
      "text_length": 43
    },
    {
      "event_id": "90000006_e00047",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "呀，",
      "text_length": 2
    },
    {
      "event_id": "90000006_e00048",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "又恐丫鬟一旁听。",
      "text_length": 8
    },
    {
      "event_id": "90000006_e00049",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "这一花郎你可曾用过饭么？",
      "text_length": 12
    },
    {
      "event_id": "90000006_e00050",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "这个……惭愧。",
      "text_length": 7
    },
    {
      "event_id": "90000006_e00051",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "丫鬟，看这花郎饿得甚是可怜，速去取些银米过来！",
      "text_length": 23
    },
    {
      "event_id": "90000006_e00052",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "90000006_e00053",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟下。",
      "text_length": 4
    },
    {
      "event_id": "90000006_e00054",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "那一花郎，你方才言道父母双亡，但不知家中可有……",
      "text_length": 24
    },
    {
      "event_id": "90000006_e00055",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "有什么？",
      "text_length": 4
    },
    {
      "event_id": "90000006_e00056",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "可有妻室否？",
      "text_length": 6
    },
    {
      "event_id": "90000006_e00057",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "小姐说哪里话来，落在乞讨之中，哪有银钱娶妻室呢？",
      "text_length": 24
    },
    {
      "event_id": "90000006_e00058",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "奴有一言，不好启齿。",
      "text_length": 10
    },
    {
      "event_id": "90000006_e00059",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "小姐有话请当面。",
      "text_length": 8
    },
    {
      "event_id": "90000006_e00060",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我实对你说了吧，我父亲为我终身大事，定于二月二日，在十字街前，高搭彩楼，抛球招婿。不知你前来接彩？",
      "text_length": 49
    },
    {
      "event_id": "90000006_e00061",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "多承小姐如此见爱，感恩非浅，怎奈落魄之人，怎配相府千金，还望小姐三思！",
      "text_length": 35
    },
    {
      "event_id": "90000006_e00062",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "我既以身相许，你……你……又何必迟疑？",
      "text_length": 19
    },
    {
      "event_id": "90000006_e00063",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "想那抛球招婿，必是王孙公子，哪有花郎之分？",
      "text_length": 21
    },
    {
      "event_id": "90000006_e00064",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "无妨，到了那日你早些站在楼前，我自有道理。",
      "text_length": 21
    },
    {
      "event_id": "90000006_e00065",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "理当遵命！",
      "text_length": 5
    },
    {
      "event_id": "90000006_e00066",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "花郎啊！",
      "text_length": 4
    },
    {
      "event_id": "90000006_e00067",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "王宝钏"
      ],
      "text": "二月二日事有准，请君听我说分明：莫道姻缘君无份，万事只怕有心的人。",
      "text_length": 33
    },
    {
      "event_id": "90000006_e00068",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "丫鬟上。",
      "text_length": 4
    },
    {
      "event_id": "90000006_e00069",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "小姐，银米在此。",
      "text_length": 8
    },
    {
      "event_id": "90000006_e00070",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王宝钏"
      ],
      "text": "付于花郎，叫他去罢。",
      "text_length": 10
    },
    {
      "event_id": "90000006_e00071",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丫鬟"
      ],
      "text": "花郎，你把银米拿去，谢过小姐，你快走吧！",
      "text_length": 20
    },
    {
      "event_id": "90000006_e00072",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛平贵"
      ],
      "text": "多谢小姐，平贵告辞了！",
      "text_length": 11
    },
    {
      "event_id": "90000006_e00073",
      "play_id": "90000006",
      "scene_id": "90000006_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "薛平贵"
      ],
      "text": "辞别小姐出园门，",
      "text_length": 8
    },
    {
      "event_id": "90000006_e00074",
      "play_id": "90000006",
