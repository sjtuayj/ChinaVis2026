      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "释迦牟尼"
      ],
      "text": "天花灿灿落红尘，",
      "text_length": 8
    },
    {
      "event_id": "02001005_e00033",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 33,
