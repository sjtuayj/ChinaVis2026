  "events": [
    {
      "event_id": "02001005_e00001",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同端正好",
      "speakers": [
        "普贤"
      ],
      "text": "隐雷者，西方妙，亘古来，隐雷者，端的是西方妙。慧光明照，着那蓬茅，看彤云遍绕。红尘道，正锐器空中落。",
      "text_length": 50
    },
    {
      "event_id": "02001005_e00002",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗。释迦牟尼、文殊、普贤同入座。",
      "text_length": 19
    },
    {
      "event_id": "02001005_e00003",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "释迦牟尼"
      ],
      "text": "海裳春，卿云开处祥光袅。施慧眼，普天皆晓。",
      "text_length": 21
    },
    {
      "event_id": "02001005_e00004",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "文殊"
      ],
      "text": "物阜与民安，海宇咸恩浩。",
      "text_length": 12
    },
    {
      "event_id": "02001005_e00005",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "普贤"
      ],
      "text": "昨有散花仙女报道蓬岛奇葩开了，",
      "text_length": 15
    },
    {
      "event_id": "02001005_e00006",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "释迦牟尼",
        "文殊",
        "普贤"
      ],
      "text": "试取众花来。齐贺升平兆。",
      "text_length": 12
    },
    {
      "event_id": "02001005_e00007",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "释迦牟尼"
      ],
      "text": "吾乃释迦摩尼佛是也。",
      "text_length": 10
    },
    {
      "event_id": "02001005_e00008",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "文殊"
      ],
      "text": "吾乃文殊是也。",
      "text_length": 7
    },
    {
      "event_id": "02001005_e00009",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "普贤"
      ],
      "text": "吾乃普贤是也。",
      "text_length": 7
    },
    {
      "event_id": "02001005_e00010",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "释迦牟尼"
      ],
      "text": "方今圣朝德政，国泰民安。恩膏遍及，仙岛均沾其惠。好太平景象也。",
      "text_length": 31
    },
    {
      "event_id": "02001005_e00011",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "十天王",
        "四侍者"
      ],
      "text": "阿弥陀佛。",
      "text_length": 5
    },
    {
      "event_id": "02001005_e00012",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "滚绣球",
      "speakers": [
        "释迦牟尼"
      ],
      "text": "敬则敬，君家的恩波天样高，爱则爱。贤甫弼匡扶贺圣朝。更喜的四海内万民皆欢乐，俺可也荷皇家似舜如尧。因此上散花女，先来报，报说海岛内众卉娇。庆丰年，普天下雨顺风调。这是那贤能文武甫政勤劳。将得个太平物阜天心顺，早则是国泰民安圣德昭。极乐处，呈瑞逍遥。",
      "text_length": 124
    },
    {
      "event_id": "02001005_e00013",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "散花天女上。",
      "text_length": 6
    },
    {
      "event_id": "02001005_e00014",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "散花天女"
      ],
      "text": "天心永洽呈祥瑞，地发奇葩庆岁华。",
      "text_length": 16
    },
    {
      "event_id": "02001005_e00015",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "散花天女"
      ],
      "text": "散花女参见佛祖。昨奉敕旨，命众仙女在十州三岛，各取奇花献瑞。今在极乐坛外，候佛法旨。",
      "text_length": 42
    },
    {
      "event_id": "02001005_e00016",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "释迦牟尼"
      ],
      "text": "好，就命尔率众仙女到极乐坛来者。",
      "text_length": 16
    },
    {
      "event_id": "02001005_e00017",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "散花天女"
      ],
      "text": "领佛旨。我佛法旨：命仙女们进坛。",
      "text_length": 16
    },
    {
      "event_id": "02001005_e00018",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众仙女同上。",
      "text_length": 6
    },
    {
      "event_id": "02001005_e00019",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众仙女"
      ],
      "text": "众仙女参见佛爷。",
      "text_length": 8
    },
    {
      "event_id": "02001005_e00020",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "释迦牟尼"
      ],
      "text": "看——",
      "text_length": 3
    },
    {
      "event_id": "02001005_e00021",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 21,
