      "text": "年年岁岁贺皇恩。",
      "text_length": 8
    },
    {
      "event_id": "02001005_e00036",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 36,
