      ],
      "text": "一曲新歌传盛世，",
      "text_length": 8
    },
    {
      "event_id": "02001005_e00035",
      "play_id": "02001005",
      "scene_id": "02001005_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 3,
