  "events": [
    {
      "event_id": "02006044_e00001",
      "play_id": "02006044",
      "scene_id": "02006044_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套引马登同上。",
      "text_length": 9
    },
    {
      "event_id": "02006044_e00002",
      "play_id": "02006044",
      "scene_id": "02006044_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "马登"
      ],
      "text": "玉鉴冰壶悬夜月，金章紫绶照青春。",
      "text_length": 16
    },
    {
      "event_id": "02006044_e00003",
      "play_id": "02006044",
      "scene_id": "02006044_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "马登"
      ],
      "text": "谈兵虎帐著英名，食君爵禄秉忠心。貔貅营内朔风引，阻隔将军马难行。",
      "text_length": 32
    },
    {
      "event_id": "02006044_e00004",
      "play_id": "02006044",
      "scene_id": "02006044_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马登"
      ],
      "text": "本藩，武国公马登是也。只因江淮侯李敬犹有帖前来，相邀去到鲁王府中议事，想是同心上本，搭救薛氏满门。诚恐众卿等久。军士们，鲁王府中去者。",
      "text_length": 67
    },
    {
      "event_id": "02006044_e00005",
      "play_id": "02006044",
      "scene_id": "02006044_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "六幺令。马登下，四龙套同下。",
      "text_length": 14
    },
    {
      "event_id": "02006044_e00006",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四喽啰、四头目、四女兵、纪鸾英同上。〖牌子〗。四头目、四女兵同下。丑兵上。",
      "text_length": 37
    },
    {
      "event_id": "02006044_e00007",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纪鸾英"
      ],
      "text": "奴，纪鸾英。在山下擒来一黑汉，豹头环眼，俨若玄坛临凡；龙行虎步，可比天神下降。此人必有王侯之位。喽兵，将那黑汉绑上。",
      "text_length": 58
    },
    {
      "event_id": "02006044_e00008",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四喽兵、丑兵、纪申绑薛刚同上。",
      "text_length": 15
    },
    {
      "event_id": "02006044_e00009",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纪申"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "02006044_e00010",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛刚"
      ],
      "text": "呔，女强盗，你用诡计擒俺，何为英雄？",
      "text_length": 18
    },
    {
      "event_id": "02006044_e00011",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "薛刚"
      ],
      "text": "不纳皇粮把山占，打劫行人为哪般？虎口扳牙心不善，",
      "text_length": 24
    },
    {
      "event_id": "02006044_e00012",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛刚"
      ],
      "text": "呔！",
      "text_length": 2
    },
    {
      "event_id": "02006044_e00013",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "薛刚"
      ],
      "text": "强盗劣性，英雄胆包天。",
      "text_length": 11
    },
    {
      "event_id": "02006044_e00014",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纪鸾英"
      ],
      "text": "唗！",
      "text_length": 2
    },
    {
      "event_id": "02006044_e00015",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "纪鸾英"
      ],
      "text": "武艺高强我称羡，不该军前出狂言。",
      "text_length": 16
    },
    {
      "event_id": "02006044_e00016",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纪鸾英"
      ],
      "text": "罢！",
      "text_length": 2
    },
    {
      "event_id": "02006044_e00017",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "纪鸾英"
      ],
      "text": "假意生嗔使宝剑，",
      "text_length": 8
    },
    {
      "event_id": "02006044_e00018",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛刚"
      ],
      "text": "呔，谁敢？谁敢？",
      "text_length": 8
    },
    {
      "event_id": "02006044_e00019",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纪申"
      ],
      "text": "呔，着爷的斧头，吓！",
      "text_length": 10
    },
    {
      "event_id": "02006044_e00020",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "薛刚"
      ],
      "text": "呔！",
      "text_length": 2
    },
    {
      "event_id": "02006044_e00021",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "纪申"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "02006044_e00022",
      "play_id": "02006044",
      "scene_id": "02006044_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "纪鸾英"
      ],
      "text": "斩你首级挂山前。",
      "text_length": 8
    },
    {
      "event_id": "02006044_e00023",
