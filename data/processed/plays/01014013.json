      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张聪"
      ],
      "text": "我不告了。",
      "text_length": 5
    },
    {
      "event_id": "01014013_e00016",
      "play_id": "01014013",
      "scene_id": "01014013_s01",
      "scene_no": 1,
      "seq_global": 16,
