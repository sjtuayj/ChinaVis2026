      "speakers": [
        "白俭"
      ],
      "text": "为何不告了。",
      "text_length": 6
    },
    {
      "event_id": "01014013_e00017",
      "play_id": "01014013",
      "scene_id": "01014013_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张聪"
      ],
      "text": "原告跪在此地，被告上坐，我这官司岂不是输了？",
      "text_length": 22
    },
    {
      "event_id": "01014013_e00018",
      "play_id": "01014013",
      "scene_id": "01014013_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "庄子"
      ],
      "text": "想我出家人，本有座位。",
      "text_length": 11
    },
    {
