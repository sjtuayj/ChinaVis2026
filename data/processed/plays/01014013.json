      ],
      "text": "来，与那一道家看座。",
      "text_length": 10
    },
    {
      "event_id": "01014013_e00014",
      "play_id": "01014013",
      "scene_id": "01014013_s01",
      "scene_no": 1,
      "seq_global": 14,
