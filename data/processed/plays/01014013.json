      "mode_label": "白",
      "speakers": [
        "庄子"
      ],
      "text": "参见大檀越。",
      "text_length": 6
    },
    {
      "event_id": "01014013_e00013",
      "play_id": "01014013",
      "scene_id": "01014013_s01",
      "scene_no": 1,
      "seq_global": 13,
