  "events": [
    {
      "event_id": "01017008_e00001",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四龙套、八卦旗、二马童、关羽同上。",
      "text_length": 17
    },
    {
      "event_id": "01017008_e00002",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "关羽"
      ],
      "text": "雄心赤胆汉英豪，撩袍勒马破奸曹。",
      "text_length": 16
    },
    {
      "event_id": "01017008_e00003",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "关羽"
      ],
      "text": "丹心耿耿社稷牢，万马营中逞英豪。力斩华雄谁不晓，桃园武艺美名标。",
      "text_length": 32
    },
    {
      "event_id": "01017008_e00004",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "俺乃汉室关公，自从桃园结义以来，宰白马以祭天，杀乌牛以祭地。一在三在，一亡三亡。只因水淹下沛，擒了吕布。三弟擒了貂蝉，送与某家，铺床叠被，这也不在话下。来，",
      "text_length": 78
    },
    {
      "event_id": "01017008_e00005",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01017008_e00006",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "看今夜有月无月？",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00007",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "马童"
      ],
      "text": "启爷，今夜有月。",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00008",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "把四面亮窗挂起。",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00009",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "一轮明月照山川，推去了云雾星斗全。坐虎椅看几本春秋左传，春秋内尽都是妖女婵娟。",
      "text_length": 39
    },
    {
      "event_id": "01017008_e00010",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "我想权臣篡位，即是董卓父子；妖女丧夫，即是貂蝉也！",
      "text_length": 25
    },
    {
      "event_id": "01017008_e00011",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "想起来此事儿令人可恼，今夜里唤她来问个分晓。",
      "text_length": 22
    },
    {
      "event_id": "01017008_e00012",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "来，唤貂蝉入帐。",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00013",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "众人"
      ],
      "text": "大王吩咐，唤貂蝉入帐。",
      "text_length": 11
    },
    {
      "event_id": "01017008_e00014",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "貂蝉"
      ],
      "text": "来了。",
      "text_length": 3
    },
    {
      "event_id": "01017008_e00015",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "貂蝉上。",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00016",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "转移莲步兰房出，想起温侯心惨伤。儿夫吕布失了阵，擒了奴家付关王。",
      "text_length": 32
    },
    {
      "event_id": "01017008_e00017",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "小女子貂蝉。被张三将军擒拿，送与二大王铺床叠被。适才呼唤，不免将茶奉上。",
      "text_length": 36
    },
    {
      "event_id": "01017008_e00018",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "十指尖尖捧茶汤，走向前来细端详。我见他杀气如山样，低头不语拜大王。",
      "text_length": 33
    },
    {
      "event_id": "01017008_e00019",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "下跪何人？",
      "text_length": 5
    },
    {
      "event_id": "01017008_e00020",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "小女子貂蝉。",
      "text_length": 6
    },
    {
      "event_id": "01017008_e00021",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "为何不抬起头来？",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00022",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "有罪不敢抬头。",
      "text_length": 7
    },
    {
      "event_id": "01017008_e00023",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "恕你无罪。",
      "text_length": 5
    },
    {
      "event_id": "01017008_e00024",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "灯光下见貂蝉十分美貌，杨柳腰裙不染尘。怪不得温侯父子来争论，好似嫦娥降下了凡尘。",
      "text_length": 40
    },
    {
      "event_id": "01017008_e00025",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "你乃司徒之女，可知春秋历代褒贬之事么？",
      "text_length": 19
    },
    {
      "event_id": "01017008_e00026",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "小女子不知。",
      "text_length": 6
    },
    {
      "event_id": "01017008_e00027",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "能知什么？",
      "text_length": 5
    },
    {
      "event_id": "01017008_e00028",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "能知三杰。",
      "text_length": 5
    },
    {
      "event_id": "01017008_e00029",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "哪三杰？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00030",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "周三杰，汉三杰。",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00031",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "周三杰？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00032",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "周公、召公、太公。",
      "text_length": 9
    },
    {
      "event_id": "01017008_e00033",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "汉三杰？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00034",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "萧何、韩信、张良。",
      "text_length": 9
    },
    {
      "event_id": "01017008_e00035",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "自周朝到我朝，出了多少古今上将？",
      "text_length": 16
    },
    {
      "event_id": "01017008_e00036",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "小女子才疏学浅，倘有一字差误，望大王恕罪。",
      "text_length": 21
    },
    {
      "event_id": "01017008_e00037",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "恕你无罪，你且讲来。",
      "text_length": 10
    },
    {
      "event_id": "01017008_e00038",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "大王容禀。",
      "text_length": 5
    },
    {
      "event_id": "01017008_e00039",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "讲。",
      "text_length": 2
    },
    {
      "event_id": "01017008_e00040",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "前三皇后五帝年深月久，有尧舜和禹汤四大明王。周文王梦飞熊曾经入帐，渭水河手指下定国安邦。十八国论子胥明甫上将，十二国钟娘娘女中豪强。前七国有孙庞二人斗志，后七国有乐毅来到齐邦。我朝中自平帝出了王莽，光武兴平汉世迁都洛阳。小女子说不尽古今兴废，一朝君一朝臣直到我邦。",
      "text_length": 132
    },
    {
      "event_id": "01017008_e00041",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "有关某听此言微微冷笑，好一个貂蝉女伶俐佳人。不问你前朝兴和废，只问你虎牢关谁是英雄？",
      "text_length": 42
    },
    {
      "event_id": "01017008_e00042",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "貂蝉女听此言心惊胆怕，口问心，心问口，自己思量：论英雄我儿夫可算吕布，",
      "text_length": 35
    },
    {
      "event_id": "01017008_e00043",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "呀，",
      "text_length": 2
    },
    {
      "event_id": "01017008_e00044",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "这眼前还有那刘备、关、张。我只得上前去曲膝来跪，急忙忙上前去口称大王：论英雄三将军天下无双，",
      "text_length": 46
    },
    {
      "event_id": "01017008_e00045",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "你丈夫吕布呢？",
      "text_length": 7
    },
    {
      "event_id": "01017008_e00046",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "我儿夫三姓奴臭名难当。",
      "text_length": 11
    },
    {
      "event_id": "01017008_e00047",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "可曾见我三弟么？",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00048",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "虎牢关鼓咚咚锣声响亮，一霎时呼啦啦排开战场。",
      "text_length": 22
    },
    {
      "event_id": "01017008_e00049",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "头戴着？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00050",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "头戴着乌金盔光彩明亮，",
      "text_length": 11
    },
    {
      "event_id": "01017008_e00051",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "身穿着？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00052",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "身穿着乌油甲盖世无双。",
      "text_length": 11
    },
    {
      "event_id": "01017008_e00053",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "跨下的？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00054",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "跨下的乌骓马能行千里，",
      "text_length": 11
    },
    {
      "event_id": "01017008_e00055",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "手提着？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00056",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "手提着一杆丈八蛇枪。在阵前吼一声如同雷响，好一似黑煞神降下天堂。",
      "text_length": 32
    },
    {
      "event_id": "01017008_e00057",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "关羽"
      ],
      "text": "有关某听此言双眉倒竖，骂一声貂蝉女无义不良！我这里将袍袖来卷上，今夜里斩了她万古名扬。",
      "text_length": 43
    },
    {
      "event_id": "01017008_e00058",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "貂蝉，你可知俺家此剑否？",
      "text_length": 12
    },
    {
      "event_id": "01017008_e00059",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "小女子不知。",
      "text_length": 6
    },
    {
      "event_id": "01017008_e00060",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "此剑乃周文王所造，菩萨所赐。倘有不平不德之事，便响。",
      "text_length": 26
    },
    {
      "event_id": "01017008_e00061",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "但不知响过几次了？",
      "text_length": 9
    },
    {
      "event_id": "01017008_e00062",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "响过三次了。",
      "text_length": 6
    },
    {
      "event_id": "01017008_e00063",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "这第一次？",
      "text_length": 5
    },
    {
      "event_id": "01017008_e00064",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "斩了颜良、文丑。",
      "text_length": 8
    },
    {
      "event_id": "01017008_e00065",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "这第二？",
      "text_length": 4
    },
    {
      "event_id": "01017008_e00066",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "斩你丈夫吕布。",
      "text_length": 7
    },
    {
      "event_id": "01017008_e00067",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "第三？",
      "text_length": 3
    },
    {
      "event_id": "01017008_e00068",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "你可知第三响么？今日帐前没有别人，就要应在你的身上！休走，看剑！",
      "text_length": 32
    },
    {
      "event_id": "01017008_e00069",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "01017008_e00070",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "吹腔",
      "speakers": [
        "貂蝉"
      ],
      "text": "貂蝉女上前曲膝跪，叫一声大王听我言：往日里斩的是英雄汉，今日斩奴为哪般？",
      "text_length": 36
    },
    {
      "event_id": "01017008_e00071",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "关羽"
      ],
      "text": "貂蝉，可知俺是真斩假斩？",
      "text_length": 12
    },
    {
      "event_id": "01017008_e00072",
      "play_id": "01017008",
      "scene_id": "01017008_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "貂蝉"
      ],
      "text": "大王定是真斩。",
      "text_length": 7
    },
    {
