  "events": [
    {
      "event_id": "02003003_e00001",
      "play_id": "02003003",
      "scene_id": "02003003_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹操上。",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00002",
      "play_id": "02003003",
      "scene_id": "02003003_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹操"
      ],
      "text": "实指望除贼定朝歌，谁知事漏惹风波。称王霸业俱抛却，星夜逃出是非窝。",
      "text_length": 33
    },
    {
      "event_id": "02003003_e00003",
      "play_id": "02003003",
      "scene_id": "02003003_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "俺，曹操。可恨董卓，误国专权，我与司徒王允定下一计，不料被他镜中看破，彼时假称献剑被我哄过一时。是俺心中害怕，连夜逃出皇城。谁知那贼差吕布带兵捉拿于我。前面已是中牟县，俺不免假扮卖绸缎的客人，混进城去，再作道理。天色尚早，马上加鞭。",
      "text_length": 116
    },
    {
      "event_id": "02003003_e00004",
      "play_id": "02003003",
      "scene_id": "02003003_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹操"
      ],
      "text": "曹孟德在马上痛恨董卓，欺天子压诸侯恶事颇多。实指望献宝剑将他结果，又谁知天不佑惹下风波。",
      "text_length": 44
    },
    {
      "event_id": "02003003_e00005",
      "play_id": "02003003",
      "scene_id": "02003003_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹操下。",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00006",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 6,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王升上。",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00007",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 7,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王升"
      ],
      "text": "领了一句话，千金不敢移。",
      "text_length": 12
    },
    {
      "event_id": "02003003_e00008",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "在下王升的便是。我等奉太爷之命，画影图形捉拿刺客曹操。伙计们，将图形挂起来。有人出入须要盘查明白。",
      "text_length": 49
    },
    {
      "event_id": "02003003_e00009",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹操上。",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00010",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹操"
      ],
      "text": "远望这中牟县城池一座，且喜得上钩鱼逃出网罗。俺这里忙加鞭城池经过，",
      "text_length": 33
    },
    {
      "event_id": "02003003_e00011",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "拿曹操！",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00012",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹操"
      ],
      "text": "耳边厢又听得有人拿我。",
      "text_length": 11
    },
    {
      "event_id": "02003003_e00013",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "且住。耳听城门之下喊叫“捉拿曹操”，俺不是逃生，反是送死，待俺转回；呀叱呸！大丈夫只有向前，哪有退后之理，待俺闯进城去。",
      "text_length": 60
    },
    {
      "event_id": "02003003_e00014",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "作什么的？",
      "text_length": 5
    },
    {
      "event_id": "02003003_e00015",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "进城去的。",
      "text_length": 5
    },
    {
      "event_id": "02003003_e00016",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "进不得城了。",
      "text_length": 6
    },
    {
      "event_id": "02003003_e00017",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "为何进不得城了？",
      "text_length": 8
    },
    {
      "event_id": "02003003_e00018",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "只因日前董太师行文，叫各府州县画影图形，捉拿刺客曹操。有腰牌放你进去。",
      "text_length": 35
    },
    {
      "event_id": "02003003_e00019",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "你拿曹操与俺什么相干？俺是卖绸缎的客人，有什么腰牌？",
      "text_length": 26
    },
    {
      "event_id": "02003003_e00020",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "没有腰牌，要拿你去见我家太爷。",
      "text_length": 15
    },
    {
      "event_id": "02003003_e00021",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "你家太爷姓甚名谁？",
      "text_length": 9
    },
    {
      "event_id": "02003003_e00022",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "我家太爷姓陈名宫，字公台。",
      "text_length": 13
    },
    {
      "event_id": "02003003_e00023",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "少待。久闻陈宫素有贤名，我不免趁此机会，前去见了陈宫，用言语打动于他，管叫他弃职而逃，会合天下诸侯，共灭董卓，方遂吾愿。呔！把城的儿郎，俺便是曹操。见了你家太爷，难道他有斩人剑，将俺斩了不成？",
      "text_length": 96
    },
    {
      "event_id": "02003003_e00024",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "既是曹操，带上刑具。",
      "text_length": 10
    },
    {
      "event_id": "02003003_e00025",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "这刑具不带也罢。",
      "text_length": 8
    },
    {
      "event_id": "02003003_e00026",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王升"
      ],
      "text": "朝廷的王法。",
      "text_length": 6
    },
    {
      "event_id": "02003003_e00027",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "要带，拿过来！",
      "text_length": 7
    },
    {
      "event_id": "02003003_e00028",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "曹操"
      ],
      "text": "我本待刺董卓与国除祸，好一似抢食鱼自入网罗。到今日我这里反戴项锁，见陈宫我和他自有话说。",
      "text_length": 44
    },
    {
      "event_id": "02003003_e00029",
      "play_id": "02003003",
      "scene_id": "02003003_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹操、王升同下。",
      "text_length": 8
    },
    {
      "event_id": "02003003_e00030",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 30,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四衙役、门子引陈宫同上。",
      "text_length": 12
    },
    {
      "event_id": "02003003_e00031",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 31,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "陈宫"
      ],
      "text": "身受皇恩，与黎民，判断冤情。",
      "text_length": 14
    },
    {
      "event_id": "02003003_e00032",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 32,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "陈宫"
      ],
      "text": "头戴乌纱忠孝先，慈祥愷悌万民欢。嘉言犹如壶中地，德霈汪洋水底天。",
      "text_length": 32
    },
    {
      "event_id": "02003003_e00033",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 33,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "本县姓陈名宫，字公台。幼年科甲出身。蒙主恩特授中牟县正印。前日接到董太师钧旨，上面写道：曹操相府行刺不成，惧罪脱逃。因此命各州县，画影图形，捉拿刺客曹操。我也曾差王升等四门巡查，未见交签。今日升堂理事。来，伺候了。",
      "text_length": 107
    },
    {
      "event_id": "02003003_e00034",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 34,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "捕头上。",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00035",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 35,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "捕头"
      ],
      "text": "捉拿曹操事，报与太爷知。",
      "text_length": 12
    },
    {
      "event_id": "02003003_e00036",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 36,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "捕头"
      ],
      "text": "太爷在上，小人叩头。",
      "text_length": 10
    },
    {
      "event_id": "02003003_e00037",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 37,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "罢了。",
      "text_length": 3
    },
    {
      "event_id": "02003003_e00038",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 38,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "捕头"
      ],
      "text": "恭喜太爷，贺喜太爷！",
      "text_length": 10
    },
    {
      "event_id": "02003003_e00039",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 39,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "喜从何来？",
      "text_length": 5
    },
    {
      "event_id": "02003003_e00040",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 40,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "捕头"
      ],
      "text": "曹操被小人们拿获了。",
      "text_length": 10
    },
    {
      "event_id": "02003003_e00041",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 41,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "有何为证？",
      "text_length": 5
    },
    {
      "event_id": "02003003_e00042",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 42,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "捕头"
      ],
      "text": "有宝剑为证。",
      "text_length": 6
    },
    {
      "event_id": "02003003_e00043",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 43,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "呈上来。",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00044",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 44,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "捕头"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "02003003_e00045",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 45,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "陈宫接宝剑，细看。",
      "text_length": 9
    },
    {
      "event_id": "02003003_e00046",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 46,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "自要尔等拿得不差，解进京去，俱有千金重赏。",
      "text_length": 21
    },
    {
      "event_id": "02003003_e00047",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 47,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "捕头"
      ],
      "text": "小人们不愿领赏，愿太爷禄位高升。",
      "text_length": 16
    },
    {
      "event_id": "02003003_e00048",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 48,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "陈宫"
      ],
      "text": "哈哈哈！",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00049",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "官升隶赏，分所当然。吩咐将刺客曹操，押上堂来。",
      "text_length": 23
    },
    {
      "event_id": "02003003_e00050",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "捕头"
      ],
      "text": "伙计们，将曹操押上堂来。",
      "text_length": 12
    },
    {
      "event_id": "02003003_e00051",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "捕头副"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "02003003_e00052",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "捕头副押曹操同上。",
      "text_length": 9
    },
    {
      "event_id": "02003003_e00053",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "曹操"
      ],
      "text": "跳龙潭出虎穴逃灾避祸，又谁知中牟县又入网罗。怒冲冲站立在滴水檐过，看陈宫他把我怎样发落。",
      "text_length": 44
    },
    {
      "event_id": "02003003_e00054",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈宫"
      ],
      "text": "曹孟德进衙来齐声威喝，书吏们站两旁虎占山坡。观刺客面貌上带定凶恶，见本县不下跪却是为何？",
      "text_length": 44
    },
    {
      "event_id": "02003003_e00055",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "下站可是曹操？",
      "text_length": 7
    },
    {
      "event_id": "02003003_e00056",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "既知我名，何必动问？",
      "text_length": 10
    },
    {
      "event_id": "02003003_e00057",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "见了本县，为何不跪？",
      "text_length": 10
    },
    {
      "event_id": "02003003_e00058",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "我这双金膝，上跪天子，下跪父母，岂肯跪你这小小县令？",
      "text_length": 26
    },
    {
      "event_id": "02003003_e00059",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "岂不知王子犯法，与民同罪。",
      "text_length": 13
    },
    {
      "event_id": "02003003_e00060",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "我身犯何法？",
      "text_length": 6
    },
    {
      "event_id": "02003003_e00061",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "你行刺董太师，还说无罪？",
      "text_length": 12
    },
    {
      "event_id": "02003003_e00062",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "我行刺董太师，可是你亲眼得见？",
      "text_length": 15
    },
    {
      "event_id": "02003003_e00063",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 34,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "虽非亲眼得见，现有董太师钧旨，捉拿于你，还敢强辩不成？",
      "text_length": 27
    },
    {
      "event_id": "02003003_e00064",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 35,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "吓！",
      "text_length": 2
    },
    {
      "event_id": "02003003_e00065",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 36,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "曹操"
      ],
      "text": "听他言吓得我心似刀割，心问口口问心自己揣摩。说几句巧言语将他哄过，管叫他弃县令随我逃脱。",
      "text_length": 44
    },
    {
      "event_id": "02003003_e00066",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 37,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "公台，你可知朝中谁忠谁奸？",
      "text_length": 13
    },
    {
      "event_id": "02003003_e00067",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 38,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "我在廉外为官，怎知朝中之事？",
      "text_length": 14
    },
    {
      "event_id": "02003003_e00068",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 68,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "却又来！",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00069",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 69,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "曹操"
      ],
      "text": "你本是外省官怎知朝歌，哪知道董卓贼奸雄作恶？刺死了丁建阳文武胆破，满朝中文共武木雕泥塑。到如今收吕布作事太错，一心要谋取那汉室山河。我看你做的事广有才学，细思量董卓贼奸恶如何？",
      "text_length": 88
    },
    {
      "event_id": "02003003_e00070",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 70,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "02003003_e00071",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 71,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "陈宫"
      ],
      "text": "曹孟德休得要谤毁董卓，董太师他倒有治国的韬略。破黄巾虽无功却也无过，十常侍乱宫门扫荡群魔。收下了吕奉先威镇海角，传将令好一似山倒海落。你好比扑灯蛾自来投火，又好比抢食鱼你自投网罗。你本是出山虎把路来投错，既擒虎焉能够放虎归窝？擒住了你反放你必来伤我，擒虎易放虎难你自去揣摩。",
      "text_length": 137
    },
    {
      "event_id": "02003003_e00072",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 72,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "曹操"
      ],
      "text": "你将我解进京献与董卓，那时节见太师自有话说：刺董卓是陈宫修书与我，管叫你遍体排牙难以分说！",
      "text_length": 45
    },
    {
      "event_id": "02003003_e00073",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 73,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "02003003_e00074",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 74,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "陈宫"
      ],
      "text": "听他言吓得我双眉皱锁，这件事倒叫我无可奈何。若放他只恐怕罪归于我，若不放又恐怕惹出风波。思一思想一想无计安妥，",
      "text_length": 55
    },
    {
      "event_id": "02003003_e00075",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 75,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "哦，有了！",
      "text_length": 5
    },
    {
      "event_id": "02003003_e00076",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 76,
      "seq_in_scene": 47,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "陈宫"
      ],
      "text": "学苏秦放张仪计上心窝。既被拿放不放全凭于我，就放你也说个言投意合。",
      "text_length": 33
    },
    {
      "event_id": "02003003_e00077",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 77,
      "seq_in_scene": 48,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "曹操"
      ],
      "text": "陈公台说此话真个软弱，小县令怎能够名标烟阁？依我劝弃县令随定与我，约诸侯带人马杀进朝歌。到那时灭谗臣除奸剿恶，管叫你换朝衣封官受爵。陈公台人道你才似王佐，细思量想一想心下如何？",
      "text_length": 88
    },
    {
      "event_id": "02003003_e00078",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 78,
      "seq_in_scene": 49,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈宫"
      ],
      "text": "曹孟德出此言如梦初觉，七品县岂不负经纶才学。倒不如弃县令从你入伙，奔天下约诸侯重整朝歌。下位来与明公亲解扭锁，",
      "text_length": 55
    },
    {
      "event_id": "02003003_e00079",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 79,
      "seq_in_scene": 50,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四衙役"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "02003003_e00080",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 80,
      "seq_in_scene": 51,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈宫"
      ],
      "text": "衙役们且退避也有发落。",
      "text_length": 11
    },
    {
      "event_id": "02003003_e00081",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 81,
      "seq_in_scene": 52,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四衙役、捕头、捕头副同下。",
      "text_length": 13
    },
    {
      "event_id": "02003003_e00082",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 82,
      "seq_in_scene": 53,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "陈宫"
      ],
      "text": "手挽手与明公二堂内坐，驾光临少奉迎望乞恕却。",
      "text_length": 22
    },
    {
      "event_id": "02003003_e00083",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 83,
      "seq_in_scene": 54,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "明公到此，衙役们得罪，望乞宽恕。",
      "text_length": 16
    },
    {
      "event_id": "02003003_e00084",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 84,
      "seq_in_scene": 55,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "岂敢。多蒙释放，日后必当重报！",
      "text_length": 15
    },
    {
      "event_id": "02003003_e00085",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 85,
      "seq_in_scene": 56,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "久闻明公献剑为名，刺杀董卓。天意不随，今欲何往？",
      "text_length": 24
    },
    {
      "event_id": "02003003_e00086",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 86,
      "seq_in_scene": 57,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "我有意奔走天涯，颁来五路诸侯，灭却董卓。",
      "text_length": 20
    },
    {
      "event_id": "02003003_e00087",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 87,
      "seq_in_scene": 58,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "下官有意随同明公，奔走天涯，不知意下如何？",
      "text_length": 21
    },
    {
      "event_id": "02003003_e00088",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 88,
      "seq_in_scene": 59,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "若得公台同去便好。只是连累宝眷不便。",
      "text_length": 18
    },
    {
      "event_id": "02003003_e00089",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 89,
      "seq_in_scene": 60,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "不妨。老母、妻子，俱在东郡。仆人、使女，不在衙署。料无妨碍。",
      "text_length": 30
    },
    {
      "event_id": "02003003_e00090",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 90,
      "seq_in_scene": 61,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "既然如此，事不宜迟，你我连夜出城，以遮百姓耳目。",
      "text_length": 24
    },
    {
      "event_id": "02003003_e00091",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 91,
      "seq_in_scene": 62,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "请至书房待茶。下官料理公案，即便同行。",
      "text_length": 19
    },
    {
      "event_id": "02003003_e00092",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 92,
      "seq_in_scene": 63,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "曹操"
      ],
      "text": "暂且告别。",
      "text_length": 5
    },
    {
      "event_id": "02003003_e00093",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 93,
      "seq_in_scene": 64,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "曹操下。",
      "text_length": 4
    },
    {
      "event_id": "02003003_e00094",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 94,
      "seq_in_scene": 65,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "少刻奉陪。来！",
      "text_length": 7
    },
    {
      "event_id": "02003003_e00095",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 95,
      "seq_in_scene": 66,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "门子"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02003003_e00096",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 96,
      "seq_in_scene": 67,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "将印信付与右堂代管。说老爷领了上司公文，下乡查旱，多则十日，少则一日就回。你附耳上来。",
      "text_length": 43
    },
    {
      "event_id": "02003003_e00097",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 97,
      "seq_in_scene": 68,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "门子附耳听，点头。",
      "text_length": 9
    },
    {
      "event_id": "02003003_e00098",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 98,
      "seq_in_scene": 69,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "陈宫"
      ],
      "text": "备马伺候。",
      "text_length": 5
    },
    {
      "event_id": "02003003_e00099",
      "play_id": "02003003",
      "scene_id": "02003003_s03",
      "scene_no": 3,
      "seq_global": 99,
      "seq_in_scene": 70,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "门子、陈宫同下。",
      "text_length": 8
    }
  ],
  "roles_inferred": true
}