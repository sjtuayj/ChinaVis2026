  "events": [
    {
      "event_id": "01007014_e00001",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑上。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00002",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快三眼",
      "speakers": [
        "孙膑"
      ],
      "text": "自幼儿悟参禅云梦修炼，为主爷三诏宣才下高山。都只为演阵图得罪庞涓，狗奸贼害得我六根不全。那奸贼想谋去天书三卷，因此上学乞丐假装疯癫。在齐国领人马与贼交战，马陵道分贼尸才报仇冤。到如今又出了恶人王翦，杀死我父兄仇不共戴天。但愿得老爹尊阴灵早显，杀退了贼王翦好整家园。",
      "text_length": 132
    },
    {
      "event_id": "01007014_e00003",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四绿龙套引孙燕同上。",
      "text_length": 10
    },
    {
      "event_id": "01007014_e00004",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙燕"
      ],
      "text": "适才一阵金光现，杀得豪杰透骨寒。翻身离蹬下雕鞍，见了三叔把话言。",
      "text_length": 32
    },
    {
      "event_id": "01007014_e00005",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四绿龙套同下。",
      "text_length": 7
    },
    {
      "event_id": "01007014_e00006",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "参见三叔。",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00007",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "儿吓，回来了？",
      "text_length": 7
    },
    {
      "event_id": "01007014_e00008",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "回来了。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00009",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "命你巡营了哨，为何这等模样？",
      "text_length": 14
    },
    {
      "event_id": "01007014_e00010",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "孩儿巡营了哨，遇见黄冠道人，将孩儿杀得大败。",
      "text_length": 22
    },
    {
      "event_id": "01007014_e00011",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "可曾问那道人的名姓？",
      "text_length": 10
    },
    {
      "event_id": "01007014_e00012",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "那道人不肯通名，口口声声，要俺三叔出马。",
      "text_length": 20
    },
    {
      "event_id": "01007014_e00013",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "01007014_e00014",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "闻听贼言撤免战，黄冠道人胆包天！岂容贼人来要战，待某亲自到阵前。",
      "text_length": 32
    },
    {
      "event_id": "01007014_e00015",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00016",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "此去休把旌旗展，翻身出营把贼观。",
      "text_length": 16
    },
    {
      "event_id": "01007014_e00017",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙燕下。毛蕡上。",
      "text_length": 8
    },
    {
      "event_id": "01007014_e00018",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "呔！阵前来的敢是毛道友？",
      "text_length": 12
    },
    {
      "event_id": "01007014_e00019",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "然！",
      "text_length": 2
    },
    {
      "event_id": "01007014_e00020",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "毛道友来至阵前，敢是与恶人王翦，前来助战？",
      "text_length": 21
    },
    {
      "event_id": "01007014_e00021",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "孙伯龄，你不在天台山侍奉了一真人，私自下山，敢是扭天行事？",
      "text_length": 29
    },
    {
      "event_id": "01007014_e00022",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "毛道友此言差矣。",
      "text_length": 8
    },
    {
      "event_id": "01007014_e00023",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "何差？",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00024",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "可恨恶人王翦，扶助秦始皇，将我父孙操，兄长孙龙、孙虎，尽行杀死。有道是“父兄之仇，不共戴天”！俺今日要拿恶人王翦，替父兄报仇，何为扭天行事？",
      "text_length": 70
    },
    {
      "event_id": "01007014_e00025",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "孙伯龄，想我师弟王翦，奉了玉帝敕旨，并吞六国，被你这痂夫青牛挡住，岂不是扭天行事？",
      "text_length": 41
    },
    {
      "event_id": "01007014_e00026",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "毛道友，你道那秦始皇，乃是黄龙下界；想我侄儿孙燕，乃是青龙转世，后来必要兴王霸业，俺理当扶助才是。",
      "text_length": 49
    },
    {
      "event_id": "01007014_e00027",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "你才怎讲？",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00028",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "扶助青龙！",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00029",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "expression",
      "mode_label": "三笑",
      "speakers": [
        "毛蕡"
      ],
      "text": "哈哈，哈哈，哈哈哈……",
      "text_length": 11
    },
    {
      "event_id": "01007014_e00030",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "尔为何发笑？",
      "text_length": 6
    },
    {
      "event_id": "01007014_e00031",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "你孙门有短！",
      "text_length": 6
    },
    {
      "event_id": "01007014_e00032",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "有何短处？",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00033",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "你且听道：你父孙武子，惯用雷炮兴兵，玉帝大怒，用五雷将他击死。他的原魂不散，在那九霄云外，飘来飘去。见你母燕丹公主，生得几分姿色，他就降下凡来。你乃父投子胎！",
      "text_length": 79
    },
    {
      "event_id": "01007014_e00034",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "呀呸！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00035",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "败坏纲常！",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00036",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "呀呸！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00037",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "近前来！",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00038",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "呸呸呸！住口！",
      "text_length": 7
    },
    {
      "event_id": "01007014_e00039",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "大骂毛道礼不端，不该阵前出恶言！",
      "text_length": 16
    },
    {
      "event_id": "01007014_e00040",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "毛蕡"
      ],
      "text": "父投子胎纲常乱，败坏人伦欺了天！哗啦啦打开青锋剑，",
      "text_length": 25
    },
    {
      "event_id": "01007014_e00041",
      "play_id": "01007014",
      "scene_id": "01007014_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑、毛蕡同开打，同下。",
      "text_length": 12
    },
    {
      "event_id": "01007014_e00042",
      "play_id": "01007014",
      "scene_id": "01007014_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛蕡上。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00043",
      "play_id": "01007014",
      "scene_id": "01007014_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "且住，痂夫杀法厉害，他若追来，混元铜锤伤他！",
      "text_length": 22
    },
    {
      "event_id": "01007014_e00044",
      "play_id": "01007014",
      "scene_id": "01007014_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑上。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00045",
      "play_id": "01007014",
      "scene_id": "01007014_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "哪里走！",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00046",
      "play_id": "01007014",
      "scene_id": "01007014_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑打毛蕡，毛蕡下。",
      "text_length": 10
    },
    {
      "event_id": "01007014_e00047",
      "play_id": "01007014",
      "scene_id": "01007014_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "道友休走，你孙老师不来赶你！",
      "text_length": 14
    },
    {
      "event_id": "01007014_e00048",
      "play_id": "01007014",
      "scene_id": "01007014_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑下。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00049",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 49,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四蓝龙套、王翦同上。",
      "text_length": 10
    },
    {
      "event_id": "01007014_e00050",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 50,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王翦"
      ],
      "text": "辕门战鼓响，儿郎报端详。",
      "text_length": 12
    },
    {
      "event_id": "01007014_e00051",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 51,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛蕡上，吐血。",
      "text_length": 7
    },
    {
      "event_id": "01007014_e00052",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 52,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "吐",
      "speakers": [
        "毛蕡"
      ],
      "text": "唔……",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00053",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 53,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "师兄醒来！",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00054",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 54,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "杀败了！",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00055",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 55,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "为何这等模样？",
      "text_length": 7
    },
    {
      "event_id": "01007014_e00056",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 56,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "被痂夫打了一拐，去了五百年道行。",
      "text_length": 16
    },
    {
      "event_id": "01007014_e00057",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 57,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "来，免战高悬。",
      "text_length": 7
    },
    {
      "event_id": "01007014_e00058",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 58,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "且慢，待愚兄摆下五雷大阵擒他！",
      "text_length": 15
    },
    {
      "event_id": "01007014_e00059",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 59,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "那贼惯用五雷伤人，画虎不成，反类其犬。",
      "text_length": 19
    },
    {
      "event_id": "01007014_e00060",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 60,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "愚下摆的阴五雷，那贼摆的阳五雷，有道是“阴能克阳”。当是一件。",
      "text_length": 31
    },
    {
      "event_id": "01007014_e00061",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 61,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "哪一件？",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00062",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 62,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "秦始皇冠袍带履，可在营中？",
      "text_length": 13
    },
    {
      "event_id": "01007014_e00063",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 63,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王翦"
      ],
      "text": "现在营中。",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00064",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 64,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "请至后面。",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00065",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 65,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王翦、四蓝龙套同下。毛蕡烧香，画符，引五雷上。王翦上。",
      "text_length": 27
    },
    {
      "event_id": "01007014_e00066",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 66,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛蕡"
      ],
      "text": "呔！孙伯龄阴魂前来打阵！",
      "text_length": 12
    },
    {
      "event_id": "01007014_e00067",
      "play_id": "01007014",
      "scene_id": "01007014_s03",
      "scene_no": 3,
      "seq_global": 67,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑上，打阵。众人同下。",
      "text_length": 12
    },
    {
      "event_id": "01007014_e00068",
      "play_id": "01007014",
      "scene_id": "01007014_s04",
      "scene_no": 4,
      "seq_global": 68,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂上。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00069",
      "play_id": "01007014",
      "scene_id": "01007014_s04",
      "scene_no": 4,
      "seq_global": 69,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "毛遂"
      ],
      "text": "俺毛遂今有三哥有难，不免前去搭救，就此阵中走走。",
      "text_length": 24
    },
    {
      "event_id": "01007014_e00070",
      "play_id": "01007014",
      "scene_id": "01007014_s04",
      "scene_no": 4,
      "seq_global": 70,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "毛遂下。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00071",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 71,
      "seq_in_scene": 1,
      "page_no": 3,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "孙膑"
      ],
      "text": "正在营中心惊战，",
      "text_length": 8
    },
    {
      "event_id": "01007014_e00072",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 72,
      "seq_in_scene": 2,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙燕搀孙膑同上。",
      "text_length": 8
    },
    {
      "event_id": "01007014_e00073",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 73,
      "seq_in_scene": 3,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "三魂飘渺不安然。胆战心寒心神乱，身似筛糠为哪般？",
      "text_length": 24
    },
    {
      "event_id": "01007014_e00074",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 74,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "儿吓，为叔这几日心惊肉跳，坐卧不安，不知为了何事？",
      "text_length": 25
    },
    {
      "event_id": "01007014_e00075",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 75,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "待侄儿看来。吓，叔父头上鲜花，哪里去了？",
      "text_length": 20
    },
    {
      "event_id": "01007014_e00076",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 76,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "不好了！",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00077",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 77,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "妖道设下巧机关，将为叔鲜花押阵前。纵有神通难施展，要报冤仇难上难。",
      "text_length": 33
    },
    {
      "event_id": "01007014_e00078",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 78,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "儿吓，那妖道摆下五雷大阵，将为叔鲜花，压在阵中了。",
      "text_length": 25
    },
    {
      "event_id": "01007014_e00079",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 79,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "叔父就该身背杏黄旗，前去破阵。",
      "text_length": 15
    },
    {
      "event_id": "01007014_e00080",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 80,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "那贼摆的阴五雷，为叔摆的阳五雷，有道是“阴能克阳”，那杏黄旗不能得破！",
      "text_length": 35
    },
    {
      "event_id": "01007014_e00081",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 81,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "叔父不去打阵，祖母娘亲，倚靠何人？",
      "text_length": 17
    },
    {
      "event_id": "01007014_e00082",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 82,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "哎吓！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00083",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 83,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "孙膑"
      ],
      "text": "猛然提起老慈颜，",
      "text_length": 8
    },
    {
      "event_id": "01007014_e00084",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 84,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙膑"
      ],
      "text": "娘亲，母亲，娘……",
      "text_length": 9
    },
    {
      "event_id": "01007014_e00085",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 85,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "寸断肝肠泪珠涟。恼恨毛蕡骂王翦，两家结下山海冤。孙老爷不是儿的患，反将鲜花押阵前。思来想去肝肠断，亲到阵前走一番。",
      "text_length": 57
    },
    {
      "event_id": "01007014_e00086",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 86,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "儿吓，",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00087",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 87,
      "seq_in_scene": 17,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "准备下杏黄旗、鹅眉剑，再备为叔的引魂幡。斑角青牛备鞍韂，",
      "text_length": 28
    },
    {
      "event_id": "01007014_e00088",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 88,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑下。孙燕备牛。",
      "text_length": 9
    },
    {
      "event_id": "01007014_e00089",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 89,
      "seq_in_scene": 19,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙燕"
      ],
      "text": "有请叔父！",
      "text_length": 5
    },
    {
      "event_id": "01007014_e00090",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 90,
      "seq_in_scene": 20,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑上。",
      "text_length": 4
    },
    {
      "event_id": "01007014_e00091",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 91,
      "seq_in_scene": 21,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "小孙燕在一旁珠泪不干。",
      "text_length": 11
    },
    {
      "event_id": "01007014_e00092",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 92,
      "seq_in_scene": 22,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙膑"
      ],
      "text": "儿吓！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00093",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 93,
      "seq_in_scene": 23,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "孙膑"
      ],
      "text": "实指望扶儿登宝殿，恢复燕邦锦江山。为叔的苦仗恶征有三年，到如今事事不周全。看酒来把为叔活来祭奠，这杯酒送我到鬼门三关。看过来沉香棍请把礼见，此一番全仗你会战军前。悲切切上青牛肝肠痛断，可叹我入仙山，悟参禅，到如今，为报父仇冤，无有结果收缘。",
      "text_length": 120
    },
    {
      "event_id": "01007014_e00094",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 94,
      "seq_in_scene": 24,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙膑"
      ],
      "text": "孙燕！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00095",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 95,
      "seq_in_scene": 25,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙燕"
      ],
      "text": "三叔！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00096",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 96,
      "seq_in_scene": 26,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙膑"
      ],
      "text": "我儿！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00097",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 97,
      "seq_in_scene": 27,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "孙燕"
      ],
      "text": "叔父！",
      "text_length": 3
    },
    {
      "event_id": "01007014_e00098",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 98,
      "seq_in_scene": 28,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "同叫头",
      "speakers": [
        "孙膑",
        "孙燕"
      ],
      "text": "（儿）（叔父）吓！",
      "text_length": 9
    },
    {
      "event_id": "01007014_e00099",
      "play_id": "01007014",
      "scene_id": "01007014_s05",
      "scene_no": 5,
      "seq_global": 99,
      "seq_in_scene": 29,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "孙膑、孙燕同下。",
      "text_length": 8
    }
  ],
  "roles_inferred": true
}