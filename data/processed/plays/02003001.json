  "events": [
    {
      "event_id": "02003001_e00001",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "冯显上。",
      "text_length": 4
    },
    {
      "event_id": "02003001_e00002",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "冯显"
      ],
      "text": "豪杰英雄为丈夫，能文会武效孙、吴。有朝大展擎天手，定把乾坤一掌扶。",
      "text_length": 33
    },
    {
      "event_id": "02003001_e00003",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "某姓冯名显，字寿昌。乃蒲州解梁人也。自幼父母双亡，多蒙母舅扶养。今日母舅下乡讨取账目去了，不免在灯下观看《春秋》一番。",
      "text_length": 59
    },
    {
      "event_id": "02003001_e00004",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "冯显归座，看书。",
      "text_length": 8
    },
    {
      "event_id": "02003001_e00005",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "点绛唇",
      "speakers": [
        "冯显"
      ],
      "text": "鲁史春秋，鲁史春秋，胡文左传，为褒贬。奸佞忠良，正直无偏向。",
      "text_length": 30
    },
    {
      "event_id": "02003001_e00006",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "冯显"
      ],
      "text": "自古来忠臣良将，一个儿丹心耿耿气昂昂。一个儿赤胆忠心扶社稷，一个儿正诚直烈佐朝堂。一个儿芳名在，一个儿臭名扬。一个儿叨荣显，一个儿受灾殃。因此上圣人制律造《春秋》，乱臣贼子心胆丧。",
      "text_length": 90
    },
    {
      "event_id": "02003001_e00007",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "冯显"
      ],
      "text": "本待要秉正除奸定国安邦，本待要秉正除奸定国安邦。",
      "text_length": 24
    },
    {
      "event_id": "02003001_e00008",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "看此《春秋》愈加烦闷，不免佩了宝剑到街市之上闲步一回，有何不可。",
      "text_length": 32
    },
    {
      "event_id": "02003001_e00009",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "冯显出门。",
      "text_length": 5
    },
    {
      "event_id": "02003001_e00010",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "出得门来，但见星朗朗、月明明、风飒飒、雾沉沉，好一派晚景也。",
      "text_length": 30
    },
    {
      "event_id": "02003001_e00011",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "冯显"
      ],
      "text": "俺则见万里无云——",
      "text_length": 9
    },
    {
      "event_id": "02003001_e00012",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "吐魄光，万里无云吐魄光，早不觉冷清清神精气爽。",
      "text_length": 23
    },
    {
      "event_id": "02003001_e00013",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖剑响〗。",
      "text_length": 5
    },
    {
      "event_id": "02003001_e00014",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "02003001_e00015",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "因甚的昆吾应响吐红光？",
      "text_length": 11
    },
    {
      "event_id": "02003001_e00016",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "此剑乃周穆王所造，削铁如泥。但有不平之事，它在匣中恋鞘白吼！",
      "text_length": 30
    },
    {
      "event_id": "02003001_e00017",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "俺也知道了晓得了，莫不是今夜晚有什么不平的事儿，将伊家来冲撞。",
      "text_length": 31
    },
    {
      "event_id": "02003001_e00018",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "韩守义上。https://scripts.xikao.com/play/020030012021-11-09",
      "text_length": 54
    },
    {
      "event_id": "02003001_e00019",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "韩守义"
      ],
      "text": "苦哇！",
      "text_length": 3
    },
    {
      "event_id": "02003001_e00020",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "冯显"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "02003001_e00021",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "忽听得那壁厢叫苦甚凄凉。他道是有天无日将人丧，又道是好夫妻无故的受着灾殃。他那里诉得断肠，俺这里听得悽惶。诉得断肠，听得悽惶，使人心儿添悒怏。向前去究问端详，禁内的因甚的披枷锁坐监房。莫不是你逞雄斗强，敢则是你把人杀伤？莫不是少人家私债，敢则是你拖欠官粮？",
      "text_length": 128
    },
    {
      "event_id": "02003001_e00022",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "韩守义"
      ],
      "text": "不是。",
      "text_length": 3
    },
    {
      "event_id": "02003001_e00023",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "既不是，其中必有什么含冤枉。",
      "text_length": 14
    },
    {
      "event_id": "02003001_e00024",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "冯显"
      ],
      "text": "对吾行从头细讲，俺与你挺身竭力诉黄堂。",
      "text_length": 19
    },
    {
      "event_id": "02003001_e00025",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩守义"
      ],
      "text": "外面爷爷听者：小人叫作韩守义，只因清明佳节同妻子上坟插柳，偶遇熊虎员外，见我妻子生得美貌，竟自抢去。将小人送到州里打了四十，监禁在狱呀！爷爷！",
      "text_length": 71
    },
    {
      "event_id": "02003001_e00026",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "02003001_e00027",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "听说罢心中气昂，不由人恼寸肠。恨只恨为富不良官吏贪赃，快说那豪强家住在何方？俺与你救转你的妻房。",
      "text_length": 48
    },
    {
      "event_id": "02003001_e00028",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "冯显"
      ],
      "text": "管教你夫妻会合依旧成双，管教你夫妻会合依旧成双。",
      "text_length": 24
    },
    {
      "event_id": "02003001_e00029",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "韩守义，里面可有躲身之处？",
      "text_length": 13
    },
    {
      "event_id": "02003001_e00030",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩守义"
      ],
      "text": "有哇爷爷。",
      "text_length": 5
    },
    {
      "event_id": "02003001_e00031",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "闪开！",
      "text_length": 3
    },
    {
      "event_id": "02003001_e00032",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "揪断门销打开监房，将枷钮劈碎将伊来放。你且不必惊慌，天来大事俺自承当。他若是肯放，俺与他善自开交不逞强梁。",
      "text_length": 53
    },
    {
      "event_id": "02003001_e00033",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "韩守义"
      ],
      "text": "他若是不放？",
      "text_length": 6
    },
    {
      "event_id": "02003001_e00034",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "冯显"
      ],
      "text": "他若是不放——",
      "text_length": 7
    },
    {
      "event_id": "02003001_e00035",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "冯显"
      ],
      "text": "恼得俺雄心似虎狼。",
      "text_length": 9
    },
    {
      "event_id": "02003001_e00036",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "冯显"
      ],
      "text": "哪怕他铜铸金刚，俺与他搅乱乾坤闹一场。",
      "text_length": 19
    },
    {
      "event_id": "02003001_e00037",
      "play_id": "02003001",
      "scene_id": "02003001_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "冯显、韩守义同下。",
      "text_length": 9
    },
    {
      "event_id": "02003001_e00038",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四丑院子引熊虎通上。",
      "text_length": 10
    },
    {
      "event_id": "02003001_e00039",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "燕儿舞",
      "speakers": [
        "熊虎"
      ],
      "text": "风流腰摆，风流腰摆，跨马游街夺美乖。昨日抢了个俏乖乖，今日筵席筵席大摆开。",
      "text_length": 37
    },
    {
      "event_id": "02003001_e00040",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "熊虎"
      ],
      "text": "咱家熊虎员外的便是。昨日清明佳节，带领小厮们上坟插柳，遇见韩守义的妻子，生得十分美貌，被我抢夺在家，将韩守义送到州里监禁在狱。吓小子们！https://scripts.xikao.com/play/020030012021-11-09",
      "text_length": 117
    },
    {
      "event_id": "02003001_e00041",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 4,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四丑院子"
      ],
      "text": "伺候大爷。",
      "text_length": 5
    },
    {
      "event_id": "02003001_e00042",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 5,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "熊虎"
      ],
      "text": "花烛齐备了没有？",
      "text_length": 8
    },
    {
      "event_id": "02003001_e00043",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 6,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四丑院子"
      ],
      "text": "齐备了。",
      "text_length": 4
    },
    {
      "event_id": "02003001_e00044",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 7,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "熊虎"
      ],
      "text": "预备的好好儿的，伺候你大爷成亲哪！",
      "text_length": 17
    },
    {
      "event_id": "02003001_e00045",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 8,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "韩守义"
      ],
      "text": "行过安平县了，爷爷！",
      "text_length": 10
    },
    {
      "event_id": "02003001_e00046",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 9,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "韩守义、冯显同上。",
      "text_length": 9
    },
    {
      "event_id": "02003001_e00047",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 10,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "寄生草",
      "speakers": [
        "冯显"
      ],
      "text": "行过了安平县，又来到节义仓，来此是无情地。不忍堂。",
      "text_length": 25
    },
    {
      "event_id": "02003001_e00048",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 11,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "熊虎"
      ],
      "text": "外头什么响？拿灯照照。",
      "text_length": 11
    },
    {
      "event_id": "02003001_e00049",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 12,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四丑院子"
      ],
      "text": "照照。",
      "text_length": 3
    },
    {
      "event_id": "02003001_e00050",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 13,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "寄生草",
      "speakers": [
        "冯显"
      ],
      "text": "俺则见铁桶般将重门闭上，粉墙头露上灯光。",
      "text_length": 20
    },
    {
      "event_id": "02003001_e00051",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 14,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "韩守义"
      ],
      "text": "待我前去叫门。",
      "text_length": 7
    },
    {
      "event_id": "02003001_e00052",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 15,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "寄生草",
      "speakers": [
        "冯显"
      ],
      "text": "你且禁住声莫乱嚷，待某家蹑足潜踪悄地行藏。待某家蹑足潜踪悄地行藏，待某家蹑足潜踪悄地行藏，细听他里边厢说些什么彀当。",
      "text_length": 58
    },
    {
      "event_id": "02003001_e00053",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 16,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "熊虎"
      ],
      "text": "小子们。",
      "text_length": 4
    },
    {
      "event_id": "02003001_e00054",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 17,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四丑院子"
      ],
      "text": "伺候大爷。",
      "text_length": 5
    },
    {
      "event_id": "02003001_e00055",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 18,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "熊虎"
      ],
      "text": "你们请新人拜高堂，拜了高堂入洞房。同入销金帐，颠鸾倒凤闹风狂。就是睡了七八年我也不下炕。",
      "text_length": 44
    },
    {
      "event_id": "02003001_e00056",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 19,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四丑院子拉韩妻同上。熊虎抱韩妻。",
      "text_length": 16
    },
    {
      "event_id": "02003001_e00057",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 20,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "韩守义可曾听见？",
      "text_length": 8
    },
    {
      "event_id": "02003001_e00058",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 21,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩守义"
      ],
      "text": "不曾听见哪，爷爷！",
      "text_length": 9
    },
    {
      "event_id": "02003001_e00059",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 22,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "寄生草",
      "speakers": [
        "冯显"
      ],
      "text": "他道是请新人拜高堂，拜了高堂入洞房。同入销金帐，颠鸾倒凤闹风狂。贼管叫你空作阳台梦一场！",
      "text_length": 44
    },
    {
      "event_id": "02003001_e00060",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 23,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "韩守义向前叩门。",
      "text_length": 8
    },
    {
      "event_id": "02003001_e00061",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 24,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩守义"
      ],
      "text": "他若问？",
      "text_length": 4
    },
    {
      "event_id": "02003001_e00062",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 25,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "冯显"
      ],
      "text": "只说州里太爷差人送贺礼来了。",
      "text_length": 14
    },
    {
      "event_id": "02003001_e00063",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩守义"
      ],
      "text": "开门来！",
      "text_length": 4
    },
    {
      "event_id": "02003001_e00064",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丑院子甲"
      ],
      "text": "什么人哪？",
      "text_length": 5
    },
    {
      "event_id": "02003001_e00065",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩守义"
      ],
      "text": "州里太爷差人送贺礼来的。",
      "text_length": 12
    },
    {
      "event_id": "02003001_e00066",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "丑院子甲"
      ],
      "text": "大爷，州里太爷差人送贺礼来咧。",
      "text_length": 15
    },
    {
      "event_id": "02003001_e00067",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "熊虎"
      ],
      "text": "什么是贺礼，又是打咱们爷儿们的秋风来咧。开开门连扁担收。",
      "text_length": 28
    },
    {
      "event_id": "02003001_e00068",
      "play_id": "02003001",
      "scene_id": "02003001_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "spoken",
