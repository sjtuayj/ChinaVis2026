      ],
      "text": "嗯哼！",
      "text_length": 3
    },
    {
      "event_id": "13001007_e00015",
      "play_id": "13001007",
      "scene_id": "13001007_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
