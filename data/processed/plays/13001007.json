      "mode_label": "念",
      "speakers": [
        "强盗乙"
      ],
      "text": "全凭钢刀做生涯。",
      "text_length": 8
    },
    {
      "event_id": "13001007_e00004",
      "play_id": "13001007",
      "scene_id": "13001007_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "强盗甲"
      ],
      "text": "伙计请了！今日天气晴和，你我去至大路旁边，等候孤行旅客，也好打抢。走！",
      "text_length": 35
    },
    {
      "event_id": "13001007_e00005",
      "play_id": "13001007",
      "scene_id": "13001007_s01",
      "scene_no": 1,
      "seq_global": 5,
