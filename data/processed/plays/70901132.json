  "events": [
    {
      "event_id": "70901132_e00001",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域上。",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00002",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "侯方域"
      ],
      "text": "无定输赢似奕棋，书空殷浩欲何为？长江不限天南北，击楫中流看誓师。",
      "text_length": 32
    },
    {
      "event_id": "70901132_e00003",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "小生侯方域。前日替史公修书，一时激烈，有“三大罪，五不可立”之议。不料福王今已登极，马士英竟入阁办事，把那些迎驾之臣，皆录功补用。史公虽亦入阁，又令督师江北，这分明有外之之意了。史公却全不介意，反以操兵剿贼为喜，如此忠肝义胆，人所难能也。现在开府扬州，命俺参其军事，约定今日齐集四镇，共商防河之计，不免上前一问。",
      "text_length": 156
    },
    {
      "event_id": "70901132_e00004",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域至书房坐。",
      "text_length": 8
    },
    {
      "event_id": "70901132_e00005",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "管家那里？",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00006",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "书童上。",
      "text_length": 4
    },
    {
      "event_id": "70901132_e00007",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "书童"
      ],
      "text": "侯爷来了，待我通报。",
      "text_length": 10
    },
    {
      "event_id": "70901132_e00008",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "史可法上。",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00009",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "北点绛唇",
      "speakers": [
        "史可法"
      ],
      "text": "持节江皋，龙骧虎啸。忧国事，不顾残躯，双鬓苍白了。",
      "text_length": 25
    },
    {
      "event_id": "70901132_e00010",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "史可法见侯方域。",
      "text_length": 8
    },
    {
      "event_id": "70901132_e00011",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "世兄，可知今日四镇齐集，共商大事，今日整师誓旅，雪君父之仇了。",
      "text_length": 31
    },
    {
      "event_id": "70901132_e00012",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "如此甚妙，只有一件，高杰镇守扬通，兵骄将傲，那黄刘三镇，每发不平之恨。今日相见，大费调停，万一兄弟不和，岂不为敌人之利乎。",
      "text_length": 61
    },
    {
      "event_id": "70901132_e00013",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "所说极是。今日相见，俺自有一番劝慰之言。",
      "text_length": 20
    },
    {
      "event_id": "70901132_e00014",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "书童"
      ],
      "text": "辕门传鼓，说四镇到齐，伺候参谒。（侯方域下，史可法升帐。吹打〖大开门〗。仪卫排左右，高杰、黄德功、刘泽清、刘良佐穿甲胄同上。吹打住。）",
      "text_length": 67
    },
    {
      "event_id": "70901132_e00015",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念",
      "speakers": [
        "高杰",
        "黄德功",
        "刘泽清",
        "刘良佐"
      ],
      "text": "只恨燕京无乐毅，谁知江左有夷吾。",
      "text_length": 16
    },
    {
      "event_id": "70901132_e00016",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高杰、黄德功、刘泽清、刘良佐同见。",
      "text_length": 17
    },
    {
      "event_id": "70901132_e00017",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高杰",
        "黄德功",
        "刘泽清",
        "刘良佐"
      ],
      "text": "四镇小将叩谒阁部大元帅。",
      "text_length": 12
    },
    {
      "event_id": "70901132_e00018",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高杰、黄德功、刘泽清、刘良佐同拜，史可法拱手立。",
      "text_length": 24
    },
    {
      "event_id": "70901132_e00019",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "列位请起。",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00020",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高杰、黄德功、刘泽清、刘良佐同排立。",
      "text_length": 18
    },
    {
      "event_id": "70901132_e00021",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高杰",
        "黄德功",
        "刘泽清",
        "刘良佐"
      ],
      "text": "听候元帅将令。",
      "text_length": 7
    },
    {
      "event_id": "70901132_e00022",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "本帅，以阁部皆师，君命隆重，大小将士俱在指挥之下。",
      "text_length": 25
    },
    {
      "event_id": "70901132_e00023",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高杰",
        "黄德功",
        "刘泽清",
        "刘良佐"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "70901132_e00024",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "四镇乃堂堂列侯，不比寻常武弁。屈尊伺坐，共议军情。",
      "text_length": 25
    },
    {
      "event_id": "70901132_e00025",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高杰",
        "黄德功",
        "刘泽清",
        "刘良佐"
      ],
      "text": "岂敢。",
      "text_length": 3
    },
    {
      "event_id": "70901132_e00026",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "本帅命坐，便如军令一般，不可推辞。",
      "text_length": 17
    },
    {
      "event_id": "70901132_e00027",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "高杰",
        "黄德功",
        "刘泽清",
        "刘良佐"
      ],
      "text": "是。告坐了。",
      "text_length": 6
    },
    {
      "event_id": "70901132_e00028",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高杰首座，黄德功、刘泽清、刘良佐依次坐，黄德功怒视高杰。",
      "text_length": 28
    },
    {
      "event_id": "70901132_e00029",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "混江龙",
      "speakers": [
        "史可法"
      ],
      "text": "淮南险要，江河保障势滔滔。一带奇云结阵，满目细柳垂条。铁马嘶风先突塞，犀军放弩早惊潮。说甚么徐、常、沐、邓，比得上绛、灌、萧、曹。同心共把乾坤造。看古来功臣阁丹青图画，似今日列侯公剑佩弓刀。",
      "text_length": 95
    },
    {
      "event_id": "70901132_e00030",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄德功怒。",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00031",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "元帅在上，小将本不该争论。这高杰乃投诚草寇，有何战功？今日公然坐俺三镇之上，俨然以副帅自居，是何道理？",
      "text_length": 51
    },
    {
      "event_id": "70901132_e00032",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "我投诚最早，年齿又尊，岂肯居尔等之下。",
      "text_length": 19
    },
    {
      "event_id": "70901132_e00033",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "我想此处是你的汛地，我们到此都是客宾，你连宾主之礼都不晓得，还要统兵？",
      "text_length": 35
    },
    {
      "event_id": "70901132_e00034",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘良佐"
      ],
      "text": "他在扬州享受繁华，尊大惯了，今日也该让咱们享享。",
      "text_length": 24
    },
    {
      "event_id": "70901132_e00035",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "你们哪个敢来，我就奉让。",
      "text_length": 12
    },
    {
      "event_id": "70901132_e00036",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "两位刘兄同我出来，即刻与那厮见个高低。",
      "text_length": 19
    },
    {
      "event_id": "70901132_e00037",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄德功、刘泽清、刘良佐同怒下，史可法向高杰。",
      "text_length": 22
    },
    {
      "event_id": "70901132_e00038",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "他们讲的有道理，你还该谦让他们才是。",
      "text_length": 18
    },
    {
      "event_id": "70901132_e00039",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "小将宁死不肯相让！",
      "text_length": 9
    },
    {
      "event_id": "70901132_e00040",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "你这就大错了。",
      "text_length": 7
    },
    {
      "event_id": "70901132_e00041",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "油葫芦",
      "speakers": [
        "史可法"
      ],
      "text": "四镇堂堂气象豪，倚仗着恢复北朝。看您挨肩雁序，恰似好同胞。为甚的争座位，失了同心好，斗齿牙，变了协恭貌。一个儿，眼睁睁同室操戈盾；一个儿，怒冲冲平地起波涛。没见阵上逞威风，早已窝里相争闹。笑中兴，封了一伙小儿曹。",
      "text_length": 106
    },
    {
      "event_id": "70901132_e00042",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "不料四镇英雄，可笑如此。老夫一天高兴，却早灰冷一半也。没奈何，且出张告示，晓谕三镇，叫他各回汛地听候调遣。你既驻扎本境，就在本帅标下做个先锋，各有执掌，他们也不敢来争闹了。",
      "text_length": 86
    },
    {
      "event_id": "70901132_e00043",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "多谢元帅。",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00044",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "待老夫写起告示来。",
      "text_length": 9
    },
    {
      "event_id": "70901132_e00045",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "史可法写，内呐喊。黄德功、刘泽清、刘良佐持刀同上。",
      "text_length": 25
    },
    {
      "event_id": "70901132_e00046",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "黄德功",
        "刘泽清",
        "刘良佐"
      ],
      "text": "高杰快快出来！",
      "text_length": 7
    },
    {
      "event_id": "70901132_e00047",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "青天白日持刀呐喊，竟是反了。",
      "text_length": 14
    },
    {
      "event_id": "70901132_e00048",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "我们为什么反？只要杀你这个无礼贼子！",
      "text_length": 18
    },
    {
      "event_id": "70901132_e00049",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "你们敢在帅府门前如此放肆，难道不是无礼贼子吗？",
      "text_length": 23
    },
    {
      "event_id": "70901132_e00050",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄德功、刘泽清、刘良佐同追杀高杰，高杰入辕门叫。",
      "text_length": 24
    },
    {
      "event_id": "70901132_e00051",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "阁部大老爷，救命呀！黄、刘三贼杀入帅府来了！",
      "text_length": 22
    },
    {
      "event_id": "70901132_e00052",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄德功、刘泽清、刘良佐同外骂，史可法惊立。",
      "text_length": 21
    },
    {
      "event_id": "70901132_e00053",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "呀！",
      "text_length": 2
    },
    {
      "event_id": "70901132_e00054",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "天下乐",
      "speakers": [
        "史可法"
      ],
      "text": "俺只道，塞马南来把战挑。杀声渐高，却是咱兵自鏖。这时协力同仇还愁少，怎当的阋墙鼓噪，起了离间根苗。这才是将难调，北贼易讨。",
      "text_length": 61
    },
    {
      "event_id": "70901132_e00055",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "快请侯相公出来。",
      "text_length": 8
    },
    {
      "event_id": "70901132_e00056",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "龙套"
      ],
      "text": "侯爷有请。",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00057",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域急上。",
      "text_length": 6
    },
    {
      "event_id": "70901132_e00058",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "晚生已听得明白了。",
      "text_length": 9
    },
    {
      "event_id": "70901132_e00059",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "借重高才，传俺帅令，安抚乱军。",
      "text_length": 15
    },
    {
      "event_id": "70901132_e00060",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "如何安抚？",
      "text_length": 5
    },
    {
      "event_id": "70901132_e00061",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "老夫有告示一纸，快去晓谕他们便了。",
      "text_length": 17
    },
    {
      "event_id": "70901132_e00062",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "70901132_e00063",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "侯方域接告示，见。",
      "text_length": 9
    },
    {
      "event_id": "70901132_e00064",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "列侯请了！小弟乃本府参谋，奉阁部大元帅之命，晓谕三镇知悉：恭逢新主中兴，闯贼未讨，正我辈枕戈待旦，立功报效之时，不宜怀挟小忿，致乱大谋。俟收复中原，太平赐宴，论功叙坐，自有朝仪。目下军容匆遽，凡事权宜，皆当相谅，无失旧好。兴平侯高，原镇扬、通，今即留在本帅标下，委作先锋。靖安侯黄，仍回庐和。东平侯刘，仍回淮徐。广昌侯刘，仍回凤、泗。静听调遣，勿得违抗。军法凛然，本帅不能容情也。特谕。",
      "text_length": 193
    },
    {
      "event_id": "70901132_e00065",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "黄德功"
      ],
      "text": "我们只要杀死无礼贼子，怎敢犯元帅军法。",
      "text_length": 19
    },
    {
      "event_id": "70901132_e00066",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "目今辕门截杀，这就是军法难容的了。",
      "text_length": 17
    },
    {
      "event_id": "70901132_e00067",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘泽清"
      ],
      "text": "既是这等，不要惊着元帅，大家且散。",
      "text_length": 17
    },
    {
      "event_id": "70901132_e00068",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘良佐"
      ],
      "text": "明日杀到高杰家里去罢。正是：",
      "text_length": 14
    },
    {
      "event_id": "70901132_e00069",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘良佐"
      ],
      "text": "国仇犹可恕，私恨最难消。",
      "text_length": 12
    },
    {
      "event_id": "70901132_e00070",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "黄德功、刘泽清、刘良佐同下，侯方域入见史可法。",
      "text_length": 23
    },
    {
      "event_id": "70901132_e00071",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "三镇闻令，暂且退散去，明日还要厮杀哩。",
      "text_length": 19
    },
    {
      "event_id": "70901132_e00072",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "这便怎么处？",
      "text_length": 6
    },
    {
      "event_id": "70901132_e00073",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 73,
      "seq_in_scene": 73,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "后庭花",
      "speakers": [
        "史可法"
      ],
      "text": "高将军，你横将仇衅招，为甚的不谦恭，妄自骄；坐了个首席乡三老，惹动他诸侯五路刀。凭仪秦一番舌战巧，也不过息兵半晌饶。费调停，干焦躁。难消释，空懊恼。这情形何待瞧，那事业全去了。",
      "text_length": 88
    },
    {
      "event_id": "70901132_e00074",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 74,
      "seq_in_scene": 74,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "元帅不必着急，明日和他见个输赢，把三镇人马并俺一处，随着元帅恢复中原，却亦不难也。",
      "text_length": 41
    },
    {
      "event_id": "70901132_e00075",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 75,
      "seq_in_scene": 75,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "你说的是哪里话，现今流寇北来，将渡黄河。总兵许定国，不能阻挡，连夜告急；正要与四镇商议，发兵防河。今日一动争端，误俺大事，岂不可忧！",
      "text_length": 66
    },
    {
      "event_id": "70901132_e00076",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 76,
      "seq_in_scene": 76,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "他三镇也不为别的，只因扬州繁华，要来夺取，俺怎肯让他。",
      "text_length": 27
    },
    {
      "event_id": "70901132_e00077",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 77,
      "seq_in_scene": 77,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "这话益发可笑了。",
      "text_length": 8
    },
    {
      "event_id": "70901132_e00078",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 78,
      "seq_in_scene": 78,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "煞尾",
      "speakers": [
        "史可法"
      ],
      "text": "引领着一支兵，和他三家傲，似垒卵泰山压倒。你占住繁华二十四桥，竹西明月夜吹箫，他也想隋堤柳下安营巢，不教你蕃鳌观独琼花少。谁不羡扬州鹤背飘，",
      "text_length": 70
    },
    {
      "event_id": "70901132_e00079",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 79,
      "seq_in_scene": 79,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "妒杀你腰缠十万好。",
      "text_length": 9
    },
    {
      "event_id": "70901132_e00080",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 80,
      "seq_in_scene": 80,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "煞尾",
      "speakers": [
        "史可法"
      ],
      "text": "怕明日，杀声咽断广陵涛。",
      "text_length": 12
    },
    {
      "event_id": "70901132_e00081",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 81,
      "seq_in_scene": 81,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "史可法"
      ],
      "text": "罢，罢，罢！老夫已拚一死，更无他法。侯兄大才，只索凭你筹划了。",
      "text_length": 31
    },
    {
      "event_id": "70901132_e00082",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 82,
      "seq_in_scene": 82,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "且看局势，再做商量。",
      "text_length": 10
    },
    {
      "event_id": "70901132_e00083",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 83,
      "seq_in_scene": 83,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖吹打〗，〖大开门〗。",
      "text_length": 11
    },
    {
      "event_id": "70901132_e00084",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 84,
      "seq_in_scene": 84,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "侯方域"
      ],
      "text": "掩门。",
      "text_length": 3
    },
    {
      "event_id": "70901132_e00085",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 85,
      "seq_in_scene": 85,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "众人同下，史可法，侯方域同下，高杰吊场。",
      "text_length": 20
    },
    {
      "event_id": "70901132_e00086",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 86,
      "seq_in_scene": 86,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "高杰"
      ],
      "text": "俺高杰也是一条好汉，难道坐以待毙不成。明早黄金坝上，点齐人马，排下阵势，等他来时，迎敌便了。正是：",
      "text_length": 49
    },
    {
      "event_id": "70901132_e00087",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 87,
      "seq_in_scene": 87,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "高杰"
      ],
      "text": "龙争虎斗逞雄豪，杯酒筵边动剑刀。刘项何须成败论，将军头断不降曹。",
      "text_length": 32
    },
    {
      "event_id": "70901132_e00088",
      "play_id": "70901132",
      "scene_id": "70901132_s01",
      "scene_no": 1,
      "seq_global": 88,
      "seq_in_scene": 88,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "高杰下。",
      "text_length": 4
    }
  ],
  "roles_inferred": true
}