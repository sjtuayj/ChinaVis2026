      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "项羽"
      ],
      "text": "咳，嘿！",
      "text_length": 4
    },
    {
      "event_id": "70901107_e00009",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "项羽"
      ],
      "text": "盖世英雄，",
      "text_length": 5
    },
    {
      "event_id": "70901107_e00010",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "项羽"
      ],
      "text": "项羽呀项羽！",
      "text_length": 6
    },
    {
      "event_id": "70901107_e00011",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "项羽"
      ],
      "text": "始信短如春梦。",
      "text_length": 7
    },
    {
      "event_id": "70901107_e00012",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "项羽"
      ],
      "text": "力拔山兮气盖世，时不利兮骓不逝。骓不逝兮可奈何……",
      "text_length": 25
    },
    {
      "event_id": "70901107_e00013",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "虞姬"
      ],
      "text": "虞姬接驾。",
      "text_length": 5
    },
    {
      "event_id": "70901107_e00014",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
