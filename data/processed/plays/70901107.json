      ],
      "text": "哇呀……",
      "text_length": 4
    },
    {
      "event_id": "70901107_e00015",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "项羽"
      ],
      "text": "虞兮、虞兮奈若何！",
      "text_length": 9
    },
    {
      "event_id": "70901107_e00016",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "虞姬"
      ],
      "text": "吓，大王为何发此长叹？",
      "text_length": 11
    },
    {
      "event_id": "70901107_e00017",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "项羽"
      ],
      "text": "虞姬，美人。孤家行兵五载，身经七十余战，未曾有败。如今，天亡我楚，岂不可叹。",
      "text_length": 38
    },
    {
      "event_id": "70901107_e00018",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "虞姬"
      ],
      "text": "大王！",
      "text_length": 3
    },
    {
      "event_id": "70901107_e00019",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "虞姬"
      ],
      "text": "汉兵已掠地，四下楚歌声。大王意气尽，贱妾何聊生。",
      "text_length": 24
    },
    {
      "event_id": "70901107_e00020",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "项羽"
      ],
      "text": "啊呀美人哪！我霸业——",
      "text_length": 11
    },
    {
      "event_id": "70901107_e00021",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "项羽"
      ],
      "text": "已成灰。",
      "text_length": 4
    },
    {
      "event_id": "70901107_e00022",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "韩信领兵同上，同走圆场，同下。",
      "text_length": 15
    },
    {
      "event_id": "70901107_e00023",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "泣颜回",
      "speakers": [
        "项羽"
      ],
      "text": "论英雄，盖世无敌，时遇折挫，到如今枉自迟疑。思之就里，悔当初不听鸿门计，把孤身冒镝。当锋时不利，岂知今日。",
      "text_length": 53
    },
    {
      "event_id": "70901107_e00024",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "项羽、虞姬同下。韩信领兵同上。",
      "text_length": 15
    },
    {
      "event_id": "70901107_e00025",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "韩信"
      ],
      "text": "众将官！",
      "text_length": 4
    },
    {
      "event_id": "70901107_e00026",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "青天歌",
      "speakers": [
        "韩信"
      ],
      "text": "前队两边分，前队两边分，前摧马，后摧军。把都门，势摆一个常山阵。",
      "text_length": 32
    },
    {
      "event_id": "70901107_e00027",
      "play_id": "70901107",
      "scene_id": "70901107_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
