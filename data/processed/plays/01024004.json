  "events": [
    {
      "event_id": "01024004_e00001",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、内侍、朱元璋同上。",
      "text_length": 13
    },
    {
      "event_id": "01024004_e00002",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "朱元璋"
      ],
      "text": "江山一统，民安乐，海晏河清。",
      "text_length": 14
    },
    {
      "event_id": "01024004_e00003",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "朱元璋"
      ],
      "text": "平顶冠上一鲜花，太阳一出照硃砂。殿前文武千百对，朕是当今第一家。",
      "text_length": 32
    },
    {
      "event_id": "01024004_e00004",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "孤，大明天子，洪武在位。自从创业以来，东讨西杀，南征北战，马上得来，一统天下。自登基以来，倒也风调雨顺，国泰民安。今当早朝，太平无事，不免将先生宣上殿来，同到武庙前游玩一番。内侍，宣军师刘基上殿。",
      "text_length": 98
    },
    {
      "event_id": "01024004_e00005",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "内侍"
      ],
      "text": "万岁有旨：宣军师刘基上殿。",
      "text_length": 13
    },
    {
      "event_id": "01024004_e00006",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "刘伯温"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01024004_e00007",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘伯温上。",
      "text_length": 5
    },
    {
      "event_id": "01024004_e00008",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "刘伯温"
      ],
      "text": "袖里乾坤大，怀中日月长。",
      "text_length": 12
    },
    {
      "event_id": "01024004_e00009",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "臣，护国军师刘基见驾，吾皇万岁！",
      "text_length": 16
    },
    {
      "event_id": "01024004_e00010",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "先生平身。",
      "text_length": 5
    },
    {
      "event_id": "01024004_e00011",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "万万岁！",
      "text_length": 4
    },
    {
      "event_id": "01024004_e00012",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "赐坐。",
      "text_length": 3
    },
    {
      "event_id": "01024004_e00013",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "谢坐。宣臣上殿，有何国事议论？",
      "text_length": 15
    },
    {
      "event_id": "01024004_e00014",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "孤自创业以来，乃是马上得来的天下，东讨西杀，南征北剿，归成大明一统。如今天下已定，孤从未到武庙前看过，今日欲请先生，陪定孤王，同到武庙前游玩一番。不知先生意下如何？",
      "text_length": 82
    },
    {
      "event_id": "01024004_e00015",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "臣愿保驾前往。",
      "text_length": 7
    },
    {
      "event_id": "01024004_e00016",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "内侍，带马武庙去者。",
      "text_length": 10
    },
    {
      "event_id": "01024004_e00017",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "朱元璋"
      ],
      "text": "有孤王坐江山太平天下，",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00018",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "刘伯温"
      ],
      "text": "大明朝归一统锦绣中华。",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00019",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "朱元璋"
      ],
      "text": "文站东武列西扶保王驾，",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00020",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "刘伯温"
      ],
      "text": "这两旁排的是钺斧金瓜。",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00021",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "朱元璋"
      ],
      "text": "为王的在马上得来天下，",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00022",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "刘伯温"
      ],
      "text": "文有谋武有勇保定皇家。",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00023",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "朱元璋"
      ],
      "text": "内侍臣摆御驾急忙催马，",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00024",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘伯温"
      ],
      "text": "去到那武庙前同把香插。",
      "text_length": 11
    },
    {
      "event_id": "01024004_e00025",
      "play_id": "01024004",
      "scene_id": "01024004_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "朱元璋、刘伯温同下。",
      "text_length": 10
    },
    {
      "event_id": "01024004_e00026",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 1,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "道士上。",
      "text_length": 4
    },
    {
      "event_id": "01024004_e00027",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 2,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "道士"
      ],
      "text": "道心似藏玉，双手不染尘。",
      "text_length": 12
    },
    {
      "event_id": "01024004_e00028",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 3,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "道士"
      ],
      "text": "贫道，悟静。自幼在这武庙出家，主持香火。今有当今万岁，前来庙中游玩，不免将禅堂神殿，打扫干净，等候圣驾。",
      "text_length": 52
    },
    {
      "event_id": "01024004_e00029",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 29,
      "seq_in_scene": 4,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。",
      "text_length": 5
    },
    {
      "event_id": "01024004_e00030",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 30,
      "seq_in_scene": 5,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "道士"
      ],
      "text": "远远望见，圣驾来也。",
      "text_length": 10
    },
    {
      "event_id": "01024004_e00031",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 31,
      "seq_in_scene": 6,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "桌前供奉太公、伍员、张良、韩信、赵云、王勇神像。四太监、四大铠、二内侍、刘伯温、朱元璋同上。",
      "text_length": 46
    },
    {
      "event_id": "01024004_e00032",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 7,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "朱元璋"
      ],
      "text": "来在庙前用目覻，见一道人来屈膝。弃镫离鞍下龙驹，孤王言来听端的：内侍臣摆驾进庙里，举目抬头看仔细。回头便把军师叫，他是何人，你要奏与孤知。",
      "text_length": 69
    },
    {
      "event_id": "01024004_e00033",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 33,
      "seq_in_scene": 8,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "啊先生，你看这殿外，供的一员将官，头戴白银盔，身穿白银甲，胯下一骑白马，手持银枪，威风凛凛，杀气腾腾，但不知他是何人？",
      "text_length": 59
    },
    {
      "event_id": "01024004_e00034",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 34,
      "seq_in_scene": 9,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "万岁容奏。",
      "text_length": 5
    },
    {
      "event_id": "01024004_e00035",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 35,
      "seq_in_scene": 10,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "刘伯温"
      ],
      "text": "刘基奏本把身躬，尊一声万岁龙耳听：这就是三国有名将，英雄姓赵名云字子龙。长板坡前多英勇，七进七出显奇能。只杀得曹兵无踪影，曹营中有名上将，一个一个望风而逃、卸甲丢盔，败走急如风。只因为糜夫人身投井，落一个保驾臣不忠。虽然是将军人可敬，因此上不能供在了殿中。",
      "text_length": 128
    },
    {
      "event_id": "01024004_e00036",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 36,
      "seq_in_scene": 11,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "哦，这就是三国的赵子龙么？",
      "text_length": 13
    },
    {
      "event_id": "01024004_e00037",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 37,
      "seq_in_scene": 12,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "正是。",
      "text_length": 3
    },
    {
      "event_id": "01024004_e00038",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 38,
      "seq_in_scene": 13,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "想当年，他在长板坡前，怀抱幼主阿斗，只杀得曹兵闻风丧胆，到后来累建奇功，战无不胜，可以算得是大大的忠臣，为何今日，反供在殿外。金瓜武士，将此像请进殿去。",
      "text_length": 76
    },
    {
      "event_id": "01024004_e00039",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 39,
      "seq_in_scene": 14,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大铠"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01024004_e00040",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 40,
      "seq_in_scene": 15,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "啊先生，你看这一旁，站定一将，白面长髯，耀武扬威，精神抖擞，他是何人？",
      "text_length": 35
    },
    {
      "event_id": "01024004_e00041",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 41,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "此人姓王名勇字伯当，乃是隋唐有名勇将。只因他事非其主，保定李密，患难相从，始终如一，颇有忠心。到后来逃至断密涧，被唐太宗用乱箭将他君臣射死。但是他临死，臣压在君身之上，故而供在殿外。",
      "text_length": 91
    },
    {
      "event_id": "01024004_e00042",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 42,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "哦，这就是昔年的王伯当。他曾保定李密，言道忠臣不事二主，到后来在断密涧下，箭射身亡。据孤王看来，到是一位忠良。来，将他神像，请到殿中。",
      "text_length": 67
    },
    {
      "event_id": "01024004_e00043",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 43,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四大铠"
      ],
      "text": "领旨。",
      "text_length": 3
    },
    {
      "event_id": "01024004_e00044",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 44,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "先生，你看孤王，办的是与不是？",
      "text_length": 15
    },
    {
      "event_id": "01024004_e00045",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 45,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "为臣佩服。",
      "text_length": 5
    },
    {
      "event_id": "01024004_e00046",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 46,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "朱元璋"
      ],
      "text": "呵哈呵哈呵哈！",
      "text_length": 7
    },
    {
      "event_id": "01024004_e00047",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 47,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "expression",
      "mode_label": "笑",
      "speakers": [
        "刘伯温"
      ],
      "text": "哈哈哈哈哈！",
      "text_length": 6
    },
    {
      "event_id": "01024004_e00048",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 48,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "先生，你看这一员将官，白髯白发，手持打将钢鞭，十分骁勇，他是何人？",
      "text_length": 33
    },
    {
      "event_id": "01024004_e00049",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 49,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "万岁呀。",
      "text_length": 4
    },
    {
      "event_id": "01024004_e00050",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 50,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "刘伯温"
      ],
      "text": "刘基二本奏君知，这员将姓伍名员字子胥。临潼会，把鼎举，各国不敢动兵机。楚平王无道行不义，为父反纳了子的妻。金顶轿改换银顶轿，无祥女改变了马昭仪。伍奢上殿把本启，怒恼了奸贼费无极。私自调回他的子，可怜他一家满门三百余口，一刀一个、一个一刀，人头血染衣。子胥弃了樊城地，保定太子出重围。巧装混出昭关地，去投吴国报冤屈。带领兵将灭楚地，只杀得尸骨堆山血成渠。那时节无道昏王身已死，他开棺鞭打平王尸。报仇雪恨有志气，因此上千秋受血食。",
      "text_length": 213
    },
    {
      "event_id": "01024004_e00051",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 51,
      "seq_in_scene": 26,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "呀呀呸！",
      "text_length": 4
    },
    {
      "event_id": "01024004_e00052",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 52,
      "seq_in_scene": 27,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "朱元璋"
      ],
      "text": "听一言来怒不息，开言大骂伍子胥！平王虽然太无礼，你不该鞭打他的尸。忙将此像扯出去，怎由你在此乱胡为。",
      "text_length": 50
    },
    {
      "event_id": "01024004_e00053",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 53,
      "seq_in_scene": 28,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "01024004_e00054",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 54,
      "seq_in_scene": 29,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘伯温"
      ],
      "text": "果然君王势力大，眉头一皱把人杀，伍员父兄的冤仇如天大，鞭打平王就犯了王法。全不许百姓来讲话，怪不得君臣就变了冤家。",
      "text_length": 57
    },
    {
      "event_id": "01024004_e00055",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 55,
      "seq_in_scene": 30,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "呵，先生，你看这一员小将，头戴帅盔，身穿蟒袍，怀中抱定令旗令箭，他是何人？",
      "text_length": 37
    },
    {
      "event_id": "01024004_e00056",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 56,
      "seq_in_scene": 31,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "刘伯温"
      ],
      "text": "刘基三本来奏上，这就是韩信官封三齐王。九里山前曾拜将，设下了十面埋伏在乌江。立逼项羽身遭丧，江山一统保汉王。到后来君臣定下天罗网，未央宫中一命亡。汗马功劳全不讲，盖世忠良无下场。因此庙中塑神像，千秋万古受蒸尝。",
      "text_length": 105
    },
    {
      "event_id": "01024004_e00057",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 57,
      "seq_in_scene": 32,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "呀呀呸！",
      "text_length": 4
    },
    {
      "event_id": "01024004_e00058",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 58,
      "seq_in_scene": 33,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "朱元璋"
      ],
      "text": "听一言来怒满腔，开言大骂无知的儿郎！你少年为人太狂妄，不该问路于樵夫反斩陈仓。不该受高祖廿四拜，不该在九里山前活埋娘。人来与孤扯神像，",
      "text_length": 67
    },
    {
      "event_id": "01024004_e00059",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 59,
      "seq_in_scene": 34,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "刘伯温"
      ],
      "text": "刘基心中自思量：说什么问路樵夫丧，说什么九里山前活埋了娘。楚汉相争打过了七十二仗，末一阵竟逼死了楚霸王。汉高祖江山本无望，韩信一战定了家邦。这样的功劳全不想，这才是狡兔死走狗烹、高鸟尽来良弓藏。江山社稷他安享，倒叫忠良无有下场。低下头来暗思想，才知臣子终受灾殃。",
      "text_length": 131
    },
    {
      "event_id": "01024004_e00060",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 60,
      "seq_in_scene": 35,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "呵先生，这一旁站定一人，头戴道巾，身穿鹤氅，他是何人？",
      "text_length": 27
    },
    {
      "event_id": "01024004_e00061",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 61,
      "seq_in_scene": 36,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "万岁容奏！",
      "text_length": 5
    },
    {
      "event_id": "01024004_e00062",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 62,
      "seq_in_scene": 37,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘伯温"
      ],
      "text": "此人姓张名良字子房，在博浪沙也曾锥击秦王。偏偏不中贼皇上，误中副车心太慌。汉高祖一样太狂妄，因此上告职归山，云游四方。",
      "text_length": 59
    },
    {
      "event_id": "01024004_e00063",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 63,
      "seq_in_scene": 38,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "呸！",
      "text_length": 2
    },
    {
      "event_id": "01024004_e00064",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 64,
      "seq_in_scene": 39,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "朱元璋"
      ],
      "text": "听一言来气上撞，开言大骂张子房：保主须要保到底，为何告职游四方。",
      "text_length": 32
    },
    {
      "event_id": "01024004_e00065",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 65,
      "seq_in_scene": 40,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "武士手！",
      "text_length": 4
    },
    {
      "event_id": "01024004_e00066",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 66,
      "seq_in_scene": 41,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "朱元璋"
      ],
      "text": "急忙与我扯碎了像，",
      "text_length": 9
    },
    {
      "event_id": "01024004_e00067",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 67,
      "seq_in_scene": 42,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "且慢！",
      "text_length": 3
    },
    {
      "event_id": "01024004_e00068",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 68,
      "seq_in_scene": 43,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "刘伯温"
      ],
      "text": "气得我刘伯温面皮黄。有道是为臣子忠于皇上，臣不忠子不孝难整朝纲。适才间我主爷把旨来降，暗指我刘伯温，明骂的张良。低下头来心暗思想，猛然间一计上胸膛。我这里回头来对主公讲，有为臣我也要告职还乡。",
      "text_length": 96
    },
    {
      "event_id": "01024004_e00069",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 69,
      "seq_in_scene": 44,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "01024004_e00070",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 70,
      "seq_in_scene": 45,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮正板",
      "speakers": [
        "朱元璋"
      ],
      "text": "听一言来心中暗想，不该对刘基骂张良。回头来对军师把话讲，孤王言来听端详：孤王江山全仗你掌，你神机妙算腹中藏。君明臣良多欢畅，你就该在朝中扶保孤王。",
      "text_length": 73
    },
    {
      "event_id": "01024004_e00071",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 71,
      "seq_in_scene": 46,
      "page_no": 4,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "刘伯温"
      ],
      "text": "臣耳聋听不见金钟响，臣眼花看不清朝王的本章。万岁爷开鸿恩将臣发放，就如同开笼放鸟，臣散淡悠扬。",
      "text_length": 47
    },
    {
      "event_id": "01024004_e00072",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 72,
      "seq_in_scene": 47,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "朱元璋"
      ],
      "text": "听一言倒叫孤好悲伤，怎舍得军师离却朝纲。孤只得含悲泪把旨来降，且准你告官职转回故乡。",
      "text_length": 42
    },
    {
      "event_id": "01024004_e00073",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 48,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "呵先生，既然要告职还乡，孤王也只得准奏。但不知军师，几时启程？",
      "text_length": 31
    },
    {
      "event_id": "01024004_e00074",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 49,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "明日就要登程。",
      "text_length": 7
    },
    {
      "event_id": "01024004_e00075",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 50,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朱元璋"
      ],
      "text": "孤王明日，带领文武百官，在十里长亭，与军师饯行。",
      "text_length": 24
    },
    {
      "event_id": "01024004_e00076",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 51,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘伯温"
      ],
      "text": "谢万岁。",
      "text_length": 4
    },
    {
      "event_id": "01024004_e00077",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 52,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "刘伯温"
      ],
      "text": "自古道伴君伴虎眠，怕的是猛虎把脸翻。从今后朝中事我全不管，隐居在山林内快乐安然。",
      "text_length": 40
    },
    {
      "event_id": "01024004_e00078",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 53,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘伯温下。",
      "text_length": 5
    },
    {
      "event_id": "01024004_e00079",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 54,
      "page_no": 5,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "朱元璋"
      ],
      "text": "刘基告职要归田，孤王岂能把他拦。内侍臣摆驾回宫院，孤全仗文武臣扶保江山。",
      "text_length": 36
    },
    {
      "event_id": "01024004_e00080",
      "play_id": "01024004",
      "scene_id": "01024004_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 55,
      "page_no": 5,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四太监、四大铠、二内侍、朱元璋同下。",
      "text_length": 18
    }
  ],
  "roles_inferred": true
}