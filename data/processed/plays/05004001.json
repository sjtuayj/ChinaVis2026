  "events": [
    {
      "event_id": "05004001_e00001",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专母上。",
      "text_length": 4
    },
    {
      "event_id": "05004001_e00002",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "引子",
      "speakers": [
        "专母"
      ],
      "text": "节烈冰霜，慕先贤，百世流芳。",
      "text_length": 14
    },
    {
      "event_id": "05004001_e00003",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "专母"
      ],
      "text": "苦守居孀耐时光，紧闭蓬门训儿郎。要学当年先贤母，万载名标永流芳。",
      "text_length": 32
    },
    {
      "event_id": "05004001_e00004",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "老身专诸之母，在这姑苏城外居住。我儿屠猪为生，事母至孝，一生就好交友。昨日有一位伍子胥，弃楚投吴，与我儿结为生死之交，又将我儿荐在姬千岁府内，至今未见回转，是老身倚门而望。正是：",
      "text_length": 89
    },
    {
      "event_id": "05004001_e00005",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "专母"
      ],
      "text": "愿儿全忠孝，万古称英豪。",
      "text_length": 12
    },
    {
      "event_id": "05004001_e00006",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮慢板",
      "speakers": [
        "专母"
      ],
      "text": "我母子家虽贫遵古训教，苦居孀守专诸谨教子曹。儿成丁喜结交平生所好，愿我儿与真主辅保龙朝。清晨起见乌鸦对我乱叫，或主吉或凶险早现根苗。",
      "text_length": 66
    },
    {
      "event_id": "05004001_e00007",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专诸上。",
      "text_length": 4
    },
    {
      "event_id": "05004001_e00008",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "伍子胥他与我情投谊好，结金兰拜兄弟恰如同胞。昨日里姬千岁传旨一道，差我在酒席宴前刺杀王僚。因此上回家去禀母知道，",
      "text_length": 56
    },
    {
      "event_id": "05004001_e00009",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "05004001_e00010",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "见母亲在草堂闷坐无聊。",
      "text_length": 11
    },
    {
      "event_id": "05004001_e00011",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "孩儿参见母亲。",
      "text_length": 7
    },
    {
      "event_id": "05004001_e00012",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "一旁坐下。",
      "text_length": 5
    },
    {
      "event_id": "05004001_e00013",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "谢坐。母亲，今有姬千岁赏赐金银，儿在膝下献上。",
      "text_length": 23
    },
    {
      "event_id": "05004001_e00014",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "儿啦，有道是无功不受禄，放在一旁。",
      "text_length": 17
    },
    {
      "event_id": "05004001_e00015",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "孩儿遵命。",
      "text_length": 5
    },
    {
      "event_id": "05004001_e00016",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "儿啦，那姬千岁将你召进府去，但不知为了何事？",
      "text_length": 22
    },
    {
      "event_id": "05004001_e00017",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "无非是教习拳棒。",
      "text_length": 8
    },
    {
      "event_id": "05004001_e00018",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "既是教习拳棒，儿为何眼中落泪呀？",
      "text_length": 16
    },
    {
      "event_id": "05004001_e00019",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "孩儿不曾落泪。",
      "text_length": 7
    },
    {
      "event_id": "05004001_e00020",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "你脸上泪痕未干，还敢强辩！",
      "text_length": 13
    },
    {
      "event_id": "05004001_e00021",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "母亲不必动怒。只因孩儿不愿为官，愿在家中侍奉母亲。是儿进退两难，故而落泪。",
      "text_length": 37
    },
    {
      "event_id": "05004001_e00022",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "儿啦，为娘倒明白了。想必是那姬千岁将儿召进府去，有什么大事相托。你看为娘年迈，不肯前去，你道是也不是？",
      "text_length": 51
    },
    {
      "event_id": "05004001_e00023",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "既被母亲道破，孩儿不敢隐瞒。儿对母亲实说了罢！那姬千岁，将儿召进府去，对儿言道：吴王姬僚为君不正，命孩儿献鱼为名，在酒席筵前，行刺那王僚！",
      "text_length": 69
    },
    {
      "event_id": "05004001_e00024",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "05004001_e00025",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮导板",
      "speakers": [
        "专母"
      ],
      "text": "听一言来魂下掉！",
      "text_length": 8
    },
    {
      "event_id": "05004001_e00026",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "05004001_e00027",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专母"
      ],
      "text": "酒席筵前儿刺王僚。那贼人马有多少，",
      "text_length": 17
    },
    {
      "event_id": "05004001_e00028",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "专母"
      ],
      "text": "我的儿啦！",
      "text_length": 5
    },
    {
      "event_id": "05004001_e00029",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专母"
      ],
      "text": "怕儿性命难脱逃。",
      "text_length": 8
    },
    {
      "event_id": "05004001_e00030",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "母亲不必珠泪掉，孩儿言来听根苗：但等母亲百年老，孩儿再去立功劳。",
      "text_length": 32
    },
    {
      "event_id": "05004001_e00031",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "母亲不必如此，但等母亲百年之后，儿在立功，也还不迟。",
      "text_length": 26
    },
    {
      "event_id": "05004001_e00032",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "我儿此言差矣。自古道：受人点水之恩，当答涌泉之报。不必挂念为娘，只管前去才是。",
      "text_length": 39
    },
    {
      "event_id": "05004001_e00033",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "想那王僚驾下，能将不少，孩儿此去，定然吉凶难定，存亡未卜。倘有不测，母亲膝下，无人尽孝，孩儿我怎能割舍？",
      "text_length": 52
    },
    {
      "event_id": "05004001_e00034",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "你看为娘，桑榆暮景。想你那妻子，颇知礼仪，侍奉为娘，最是尽心。我儿只管前去。为娘有言，儿且听了。",
      "text_length": 48
    },
    {
      "event_id": "05004001_e00035",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "专母"
      ],
      "text": "姬千岁有贤明为人有道，我的儿保真主莫要辞劳。自古道尽其忠难行孝道，方显你尽孝心万古名标。",
      "text_length": 44
    },
    {
      "event_id": "05004001_e00036",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "专诸"
      ],
      "text": "谢罢了老娘亲将儿调教，坐草堂听孩儿细说根苗：此一番刺王僚凶多吉少，难免那酒席筵前赴阴曹。非是儿贪生命不把主保，还未曾报娘恩养育劬劳。",
      "text_length": 66
    },
    {
      "event_id": "05004001_e00037",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专母"
      ],
      "text": "遵奉母命就为孝，奉养高堂食饱勤劳。快些前去休迟了，为娘方得喜眉梢。",
      "text_length": 33
    },
    {
      "event_id": "05004001_e00038",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "儿啦，如今天下刀兵四起。儿为文官则须尽忠，儿为武将则须报效，你休要迟迟，快些去罢。",
      "text_length": 41
    },
    {
      "event_id": "05004001_e00039",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "遵命。",
      "text_length": 3
    },
    {
      "event_id": "05004001_e00040",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "多谢母亲将儿教，不由专诸泪双抛！今生难以行孝道，",
      "text_length": 24
    },
    {
      "event_id": "05004001_e00041",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "专诸"
      ],
      "text": "儿的娘啊！",
      "text_length": 5
    },
    {
      "event_id": "05004001_e00042",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "但愿老娘年寿高。拜别母亲出门道，",
      "text_length": 16
    },
    {
      "event_id": "05004001_e00043",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "专母"
      ],
      "text": "儿啦，儿啦！",
      "text_length": 6
    },
    {
      "event_id": "05004001_e00044",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "05004001_e00045",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "难舍难离痛难消。尽忠哪有行孝好？",
      "text_length": 16
    },
    {
      "event_id": "05004001_e00046",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "老娘亲！",
      "text_length": 4
    },
    {
      "event_id": "05004001_e00047",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "孩儿不愿凌烟标。",
      "text_length": 8
    },
    {
      "event_id": "05004001_e00048",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "啊儿啦，你为何去而复转？",
      "text_length": 12
    },
    {
      "event_id": "05004001_e00049",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "非是孩儿去而复转。只因母亲年迈，无人侍奉，孩儿放心不下。",
      "text_length": 28
    },
    {
      "event_id": "05004001_e00050",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "唗！你既受姬千岁重礼相托，你不肯前去，你就为不忠不孝之人，为娘就要打！",
      "text_length": 35
    },
    {
      "event_id": "05004001_e00051",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "打死孩儿，儿也是不去的了哇……",
      "text_length": 15
    },
    {
      "event_id": "05004001_e00052",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专诸哭。",
      "text_length": 4
    },
    {
      "event_id": "05004001_e00053",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "05004001_e00054",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮二六板",
      "speakers": [
        "专母"
      ],
      "text": "听儿言来心焦躁，思量辗转无有计一条。我的儿生来性情傲，把老身的良言付与了波涛。我儿若是全孝道，岂不是耽误了儿立功劳？老身今日花甲老，",
      "text_length": 66
    },
    {
      "event_id": "05004001_e00055",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "专母"
      ],
      "text": "就死黄泉也逍遥。有夫从夫妇之道，无夫就当从儿曹。我儿尽忠把国保，老身就当赴阴朝。回头便把专诸叫，娘有一言听根苗。",
      "text_length": 56
    },
    {
      "event_id": "05004001_e00056",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "儿啦。你不愿尽忠，情愿尽孝，此话当真？",
      "text_length": 19
    },
    {
      "event_id": "05004001_e00057",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "孩儿焉敢道谎。",
      "text_length": 7
    },
    {
      "event_id": "05004001_e00058",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "为娘与你讲了半日，舌干口燥，取碗水来，为娘一用。",
      "text_length": 24
    },
    {
      "event_id": "05004001_e00059",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "遵命。待孩儿厨下取来。",
      "text_length": 11
    },
    {
      "event_id": "05004001_e00060",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "唉，为娘要吃涧下清泉之水。",
      "text_length": 13
    },
    {
      "event_id": "05004001_e00061",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "儿村外去取。",
      "text_length": 6
    },
    {
      "event_id": "05004001_e00062",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专诸挑桶下。",
      "text_length": 6
    },
    {
      "event_id": "05004001_e00063",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专母"
      ],
      "text": "哎呀且住！趁此时我儿不在家中，待我行个自尽了罢啊……",
      "text_length": 26
    },
    {
      "event_id": "05004001_e00064",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专母哭，拴套。",
      "text_length": 7
    },
    {
      "event_id": "05004001_e00065",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专母"
      ],
      "text": "对白绫不由我哈哈大笑！你成就我节烈万古名标。白绫一抖无常到，",
      "text_length": 30
    },
    {
      "event_id": "05004001_e00066",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 3,
      "type": "expression",
      "mode_label": "哭头",
      "speakers": [
        "专母"
      ],
      "text": "我的儿啦！",
      "text_length": 5
    },
    {
      "event_id": "05004001_e00067",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专母"
      ],
      "text": "为儿立功赴阴曹。",
      "text_length": 8
    },
    {
      "event_id": "05004001_e00068",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专母上吊。专诸上。",
      "text_length": 9
    },
    {
      "event_id": "05004001_e00069",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "适才取水心惊跳，回到家中奉年高。",
      "text_length": 16
    },
    {
      "event_id": "05004001_e00070",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "专诸看，甩桶。",
      "text_length": 7
    },
    {
      "event_id": "05004001_e00071",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "05004001_e00072",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 3,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "专诸"
      ],
      "text": "见母亲行自尽心如刀绞，可叹娘为姣儿受尽煎熬。哭一声老娘亲，哦呀儿的娘啊！见了贤妻说根苗。",
      "text_length": 44
    },
    {
