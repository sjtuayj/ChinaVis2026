      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "专诸"
      ],
      "text": "贤妻将母亲尸首，停放灵床之上，我还要守孝百日。",
      "text_length": 23
    },
    {
      "event_id": "05004001_e00083",
      "play_id": "05004001",
      "scene_id": "05004001_s01",
