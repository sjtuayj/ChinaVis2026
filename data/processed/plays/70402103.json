      "event_id": "70402103_e00032",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "程咬金"
      ],
      "text": "列位宾朋且站开，咬金自有巧安排。",
      "text_length": 16
    },
