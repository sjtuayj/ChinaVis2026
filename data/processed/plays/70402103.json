  "events": [
    {
      "event_id": "70402103_e00001",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "催命鼓。",
      "text_length": 4
    },
    {
      "event_id": "70402103_e00002",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内西皮导板",
      "speakers": [
        "单雄信"
      ],
      "text": "号令一声绑帐外，",
      "text_length": 8
    },
    {
      "event_id": "70402103_e00003",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四刽子手举刀同走上，单雄信上。",
      "text_length": 15
    },
    {
      "event_id": "70402103_e00004",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四刽子手"
      ],
      "text": "走！",
      "text_length": 2
    },
    {
      "event_id": "70402103_e00005",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "单雄信对两旁轻蔑扫一眼，抖动手上铁链。",
      "text_length": 19
    },
    {
      "event_id": "70402103_e00006",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "单雄信"
      ],
      "text": "不由得豪杰笑开怀。某单人独一骑我把唐营踹，",
      "text_length": 21
    },
    {
      "event_id": "70402103_e00007",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四刽子手、单雄信同扯四门。",
      "text_length": 13
    },
    {
      "event_id": "70402103_e00008",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮原板",
      "speakers": [
        "单雄信"
      ],
      "text": "只杀得儿郎叫苦悲哀。遍野荒郊血成海，尸骨堆山无处里葬埋。小唐童被某胆吓坏，",
      "text_length": 37
    },
    {
      "event_id": "70402103_e00009",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "某二次被擒也应该。今生不能够把仇解，二十年投胎某再来。⑴（二刽子手同归左，二刽子手同站一排。刽子手搬椅至台口，单雄信坐。四龙套捧酒具同上。尉迟恭、罗成、程咬金、徐勣、引李世民同上。）",
      "text_length": 91
    },
    {
      "event_id": "70402103_e00010",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "李世民"
      ],
      "text": "将身来在营门外，只见雄信绑法台。",
      "text_length": 16
    },
    {
      "event_id": "70402103_e00011",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李世民"
      ],
      "text": "酒来！",
      "text_length": 3
    },
    {
      "event_id": "70402103_e00012",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "龙套斟满酒，交李世民。李世民持杯。",
      "text_length": 17
    },
    {
      "event_id": "70402103_e00013",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "李世民"
      ],
      "text": "一斗酒来满满筛，尊声将军听开怀：你今饮了杯中酒，愿你灵魂上天台。",
      "text_length": 32
    },
    {
      "event_id": "70402103_e00014",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "单雄信蔑视李世民，李世民无奈，将酒交龙套。",
      "text_length": 21
    },
    {
      "event_id": "70402103_e00015",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "一口怒气冲天外，大骂唐童小奴才：胞兄被你父箭射坏，兵发洛阳为何来？今生不能食尔的肉，你坐江山爷再来。",
      "text_length": 50
    },
    {
      "event_id": "70402103_e00016",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "单雄信不理睬李世民。徐勣向前对李世民示意。",
      "text_length": 21
    },
    {
      "event_id": "70402103_e00017",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐勣"
      ],
      "text": "主公且待营门外，为臣自有巧安排。",
      "text_length": 16
    },
    {
      "event_id": "70402103_e00018",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "徐勣"
      ],
      "text": "酒来！",
      "text_length": 3
    },
    {
      "event_id": "70402103_e00019",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "龙套拿酒杯交徐勣，徐勣接酒走向单雄信。龙套搬椅，李世民坐。",
      "text_length": 29
    },
    {
      "event_id": "70402103_e00020",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "徐勣"
      ],
      "text": "一斗酒儿满满筛，尊声五弟听开怀：贾家楼前曾结拜，惟有你我同心怀。你今饮了杯中酒，但愿你灵魂上天台。",
      "text_length": 49
    },
    {
      "event_id": "70402103_e00021",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "单雄信气愤，怒视，徐勣无奈，将酒杯交龙套。",
      "text_length": 21
    },
    {
      "event_id": "70402103_e00022",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "休要提起来结拜，提起结拜恼心怀。你在那唐营为元帅，俺在洛阳为将才。叔宝、咬金被你拐，点手又唤罗成来。锦绣江山被你卖，你是个人面兽投胎。",
      "text_length": 67
    },
    {
      "event_id": "70402103_e00023",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "徐勣羞愧。",
      "text_length": 5
    },
    {
      "event_id": "70402103_e00024",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗成"
      ],
      "text": "酒来！",
      "text_length": 3
    },
    {
      "event_id": "70402103_e00025",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "龙套拿酒杯交罗成，罗成持杯向前。",
      "text_length": 16
    },
    {
      "event_id": "70402103_e00026",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮流水板",
      "speakers": [
        "罗成"
      ],
      "text": "一斗酒儿满满筛，尊声五哥听开怀：五哥饮了杯中酒，还望你灵魂上天台。",
      "text_length": 33
    },
    {
      "event_id": "70402103_e00027",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "啊！（罗成持杯向前敬酒，单雄信甩后扎，抬左腿踢飞罗成手中酒杯，把手铐上铁链向罗成猛砸，急走快步。罗成激怒。程咬金按住罗成，单雄信用手指点。）",
      "text_length": 70
    },
    {
      "event_id": "70402103_e00028",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮快板",
      "speakers": [
        "单雄信"
      ],
      "text": "见罗成把我牙咬坏，大骂无耻小奴才。曾记得踏坏瓦岗寨，曾记得一家大小洛阳来。我为你造下了三贤府，我为你花费许多财。忘恩负义投唐寨，花言巧语哄谁来！雄信一死名还在，",
      "text_length": 80
    },
    {
      "event_id": "70402103_e00029",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "单雄信"
      ],
      "text": "奴才呀！奴才！",
      "text_length": 7
    },
    {
      "event_id": "70402103_e00030",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "aria",
      "mode_label": "西皮摇板",
      "speakers": [
        "单雄信"
      ],
      "text": "怕的是乱箭镩身尸无处葬埋。（单雄信跺脚。行弦。单雄信举左拳欲打罗成，罗成举右拳。程咬金分开，单雄信、罗成同往里对翻。单雄信举左拳，罗成举右拳。程咬金分开，单雄信、罗成同往外对翻。程咬金劝。）",
      "text_length": 95
    },
    {
      "event_id": "70402103_e00031",
      "play_id": "70402103",
      "scene_id": "70402103_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "程咬金"
      ],
      "text": "慢动手，瞧我啦。五哥！",
      "text_length": 11
    },
