        "杨素"
      ],
      "text": "请了。",
      "text_length": 3
    },
    {
      "event_id": "01016001_e00009",
      "play_id": "01016001",
      "scene_id": "01016001_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "宇文化及"
      ],
      "text": "先帝宴驾，新君登基，我等到午门朝驾。",
      "text_length": 18
    },
    {
      "event_id": "01016001_e00010",
      "play_id": "01016001",
      "scene_id": "01016001_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
