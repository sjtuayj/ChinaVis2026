      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "果然？",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00103",
      "play_id": "01013017",
      "scene_id": "01013017_s03",
      "scene_no": 3,
      "seq_global": 103,
      "seq_in_scene": 18,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张浪子"
      ],
      "text": "果然。",
