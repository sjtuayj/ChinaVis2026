  "events": [
    {
      "event_id": "01013017_e00001",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。衙役、二刽子手引王清天同上。",
      "text_length": 19
    },
    {
      "event_id": "01013017_e00002",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "王清天"
      ],
      "text": "天上冷飕飕，地下滚绣球。大炮一声响，圣旨要斩头。",
      "text_length": 24
    },
    {
      "event_id": "01013017_e00003",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "下官，王清天。今有药茶一案，律应问斩。刀斧手！",
      "text_length": 23
    },
    {
      "event_id": "01013017_e00004",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二刽子手"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "01013017_e00005",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "将浪子、郎二虎绑了上来！",
      "text_length": 12
    },
    {
      "event_id": "01013017_e00006",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二刽子手绑张浪子同上。",
      "text_length": 11
    },
    {
      "event_id": "01013017_e00007",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "时辰到了，将浪子、郎二虎一齐开刀。",
      "text_length": 17
    },
    {
      "event_id": "01013017_e00008",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王清天暗下。",
      "text_length": 6
    },
    {
      "event_id": "01013017_e00009",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二刽子手"
      ],
      "text": "是。",
      "text_length": 2
    },
    {
      "event_id": "01013017_e00010",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "王氏"
      ],
      "text": "苦哇！",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00011",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "aria",
      "mode_label": "内二黄导板",
      "speakers": [
        "王氏"
      ],
      "text": "数九寒天冷似冰，",
      "text_length": 8
    },
    {
      "event_id": "01013017_e00012",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王氏上。",
      "text_length": 4
    },
    {
      "event_id": "01013017_e00013",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "王氏"
      ],
      "text": "浪子！我儿！儿呀！",
      "text_length": 9
    },
    {
      "event_id": "01013017_e00014",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "王氏"
      ],
      "text": "万岁爷传圣旨要斩犯人。",
      "text_length": 11
    },
    {
      "event_id": "01013017_e00015",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "王氏"
      ],
      "text": "催命鼓响咚咚追人性命，救命锣响呛呛令人吊魂。悲切切且把那法场来进，阴风儿吹得我冷似冰。我不进法场回家去罢，",
      "text_length": 53
    },
    {
      "event_id": "01013017_e00016",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "哎！",
      "text_length": 2
    },
    {
      "event_id": "01013017_e00017",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "王氏"
      ],
      "text": "岂做忘恩负义人。祭礼放在席棚外，舍我这老命找姣生。大胆且把法场进，",
      "text_length": 33
    },
    {
      "event_id": "01013017_e00018",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二刽子手"
      ],
      "text": "呔！",
      "text_length": 2
    },
    {
      "event_id": "01013017_e00019",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00020",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 1,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "王氏"
      ],
      "text": "刽子手提刀吓煞人。望将爷在上容我禀，我是那张浪子的大娘亲。在法场哭坏了王氏女，",
      "text_length": 39
    },
    {
      "event_id": "01013017_e00021",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "王清天"
      ],
      "text": "传话出去：有亲探亲，有故探故，少时大炮一响，人头落地。亲故就不能相见了。",
      "text_length": 36
    },
    {
      "event_id": "01013017_e00022",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二刽子手"
      ],
      "text": "传话出去：有亲探亲，有故探故，少时大炮一响，人头落地。亲故就不能相见了。",
      "text_length": 36
    },
    {
      "event_id": "01013017_e00023",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "有哇！",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00024",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄正板",
      "speakers": [
        "王氏"
      ],
      "text": "大老爷开了那天地之恩。",
      "text_length": 11
    },
    {
      "event_id": "01013017_e00025",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王氏"
      ],
      "text": "法场上好一比森罗宝殿，监斩官好一比五殿闫君。刽子手好一比催命判鬼，众犯人好一比死去猪羊，一个个等候时辰。",
      "text_length": 52
    },
    {
      "event_id": "01013017_e00026",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "王氏"
      ],
      "text": "我的儿呀！",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00027",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王氏"
      ],
      "text": "众犯人在法场无有其数，寻不着浪子小姣生。无奈何只得挨头数，",
      "text_length": 29
    },
    {
      "event_id": "01013017_e00028",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00029",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王氏"
      ],
      "text": "这江洋大盗吓煞人。这边不是那厢认，",
      "text_length": 17
    },
    {
      "event_id": "01013017_e00030",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "哎呀！",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00031",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "aria",
      "mode_label": "二黄原板",
      "speakers": [
        "王氏"
      ],
      "text": "我的儿受绑缚叫娘心痛。",
      "text_length": 11
    },
    {
      "event_id": "01013017_e00032",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "儿在法场之上，听为大娘道来。想儿的娘亲，与为大娘的不和，不该用杯药茶，要将为大娘的害死。不想儿的娘舅，来在家中，将这杯药茶吞吃腹内，一霎时七孔流血，一命身亡。儿的娘亲一见儿的母舅身死，一计不成，又生二计。去至公堂，击鼓鸣冤，反说为大娘的害死，将为大娘屈打成招，问成死罪，下入监牢。我儿闻知，去至监牢，搭救为大娘的性命，替为大娘的一死。多亏新任老爷，尚未上任，如此我儿，你情愿替为大娘的认罪，将为大娘放出监牢，将我的儿收入监内。为大娘回得家去，闻听人言，我儿今日出斩，为大娘打来几杯浊酒，买来几文纸钱，以表我儿搭救大娘的情肠，儿要喝上几杯。",
      "text_length": 269
    },
    {
      "event_id": "01013017_e00033",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "张浪子喝酒，吐。",
      "text_length": 8
    },
    {
      "event_id": "01013017_e00034",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "张浪子"
      ],
      "text": "吃不下了。",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00035",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "吃不下了？",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00036",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "郎二虎"
      ],
      "text": "老太太，我也吃上几杯。",
      "text_length": 11
    },
    {
      "event_id": "01013017_e00037",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "大哥，你也要吃上几杯？",
      "text_length": 11
    },
    {
      "event_id": "01013017_e00038",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "郎二虎"
      ],
      "text": "啊。",
      "text_length": 2
    },
    {
      "event_id": "01013017_e00039",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "我儿死在阴曹，你要多多照应。",
      "text_length": 14
    },
    {
      "event_id": "01013017_e00040",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "郎二虎吃酒，吐。",
      "text_length": 8
    },
    {
      "event_id": "01013017_e00041",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "朗二虎"
      ],
      "text": "吃不下了。",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00042",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "你也吃不下了。儿呀，为娘打来几文纸钱，与你焚化。",
      "text_length": 24
    },
    {
      "event_id": "01013017_e00043",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "叫头",
      "speakers": [
        "王氏"
      ],
      "text": "我儿！儿呀！",
      "text_length": 6
    },
    {
      "event_id": "01013017_e00044",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王氏"
      ],
      "text": "本当为大娘的拜儿几拜，怎奈是大不拜小，只恐我儿消受不起，为大娘的望空一拜也。",
      "text_length": 38
    },
    {
      "event_id": "01013017_e00045",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "王氏"
      ],
      "text": "眼望法场深深拜，拜上我儿听开怀：在法场哭得如泥块，",
      "text_length": 25
    },
    {
      "event_id": "01013017_e00046",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 2,
      "type": "expression",
      "mode_label": "哭",
      "speakers": [
        "王氏"
      ],
      "text": "儿呀！",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00047",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "王氏下。王清天上。",
      "text_length": 9
    },
    {
      "event_id": "01013017_e00048",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "时辰可到？",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00049",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二刽子手"
      ],
      "text": "时辰已到。",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00050",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "将郎二虎开刀！",
      "text_length": 7
    },
    {
      "event_id": "01013017_e00051",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "朗二虎下。",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00052",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "二刽子手"
      ],
      "text": "啊！",
      "text_length": 2
    },
    {
      "event_id": "01013017_e00053",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "二刽子手同斩朗二虎。",
      "text_length": 10
    },
    {
      "event_id": "01013017_e00054",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "将浪子开刀！",
      "text_length": 6
    },
    {
      "event_id": "01013017_e00055",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "内白",
      "speakers": [
        "太监"
      ],
      "text": "圣旨下！",
      "text_length": 4
    },
    {
      "event_id": "01013017_e00056",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "太监上。王清天迎接。",
      "text_length": 10
    },
    {
      "event_id": "01013017_e00057",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监"
      ],
      "text": "圣旨下，跪。",
      "text_length": 6
    },
    {
      "event_id": "01013017_e00058",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "万岁。",
      "text_length": 3
    },
    {
      "event_id": "01013017_e00059",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监"
      ],
      "text": "听宣读。诏曰：今有药茶一案，律应斩首。后宫娘娘讲情，只可以赦，不可以斩。圣意读罢，望诏谢恩哪！",
      "text_length": 47
    },
    {
      "event_id": "01013017_e00060",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "万万岁！",
      "text_length": 4
    },
    {
      "event_id": "01013017_e00061",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监"
      ],
      "text": "犯人在哪儿哪？",
      "text_length": 7
    },
    {
      "event_id": "01013017_e00062",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "王清天"
      ],
      "text": "现在席棚。",
      "text_length": 5
    },
    {
      "event_id": "01013017_e00063",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "太监"
      ],
      "text": "让我瞧瞧。不是女人么，怎么是个男人？",
      "text_length": 18
    },
    {
      "event_id": "01013017_e00064",
      "play_id": "01013017",
      "scene_id": "01013017_s01",
      "scene_no": 1,
      "seq_global": 64,
