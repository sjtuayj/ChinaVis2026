  "events": [
    {
      "event_id": "70902144_e00001",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "姚氏上。",
      "text_length": 4
    },
    {
      "event_id": "70902144_e00002",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "姚氏"
      ],
      "text": "东城渐觉风光好，绉浪恬波行客棹，绿杨烟外少人行，红杏枝头春意闹。浮生常恨欢娱少，堪爱婵娟倾一笑。为君歧路看斜阳，且向花间留晚照。",
      "text_length": 64
    },
    {
      "event_id": "70902144_e00003",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚氏"
      ],
      "text": "老身姚氏，幸喜我女婿升任吉安知府，打发李成回来，接我老夫妇到任，同享荣华。咳，此时我女儿若在，同赴任所，岂不风光？正是：",
      "text_length": 60
    },
    {
      "event_id": "70902144_e00004",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "姚氏"
      ],
      "text": "娇女投何处？痛杀白头亲！",
      "text_length": 12
    },
    {
      "event_id": "70902144_e00005",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "钱流行内嗽。",
      "text_length": 6
    },
    {
      "event_id": "70902144_e00006",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚氏"
      ],
      "text": "言之未已，员外出舱来也！",
      "text_length": 12
    },
    {
      "event_id": "70902144_e00007",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "钱流行上。",
      "text_length": 5
    },
    {
      "event_id": "70902144_e00008",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "小蓬莱",
      "speakers": [
        "钱流行"
      ],
      "text": "策杖登程去也，西风里劳碌艰辛，澹烟荒草，夕阳古渡，流水孤村。",
      "text_length": 30
    },
    {
      "event_id": "70902144_e00009",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李成上。",
      "text_length": 4
    },
    {
      "event_id": "70902144_e00010",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "小蓬莱",
      "speakers": [
        "姚氏"
      ],
      "text": "满目堪图堪画，野景萧萧，冷浸黄昏。",
      "text_length": 17
    },
    {
      "event_id": "70902144_e00011",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "小蓬莱",
      "speakers": [
        "李成"
      ],
      "text": "樵歌牧唱，牛眠草径，犬吠柴门。",
      "text_length": 15
    },
    {
      "event_id": "70902144_e00012",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "钱流行"
      ],
      "text": "绿遍汀州三月景，锦江风静帆收。垂杨低映木兰舟，半蒿春水滑，一段夕阳愁。",
      "text_length": 35
    },
    {
      "event_id": "70902144_e00013",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "姚氏"
      ],
      "text": "灞水桥东回首处，美人亲卷帘钩。",
      "text_length": 15
    },
    {
      "event_id": "70902144_e00014",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "李成"
      ],
      "text": "落花几阵入红楼，行云归楚峡，飞梦绕温州。",
      "text_length": 20
    },
    {
      "event_id": "70902144_e00015",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "钱流行"
      ],
      "text": "连日在舟中闷坐，今朝日丽风和，花明景曙，我们一同登岸走走！",
      "text_length": 29
    },
    {
      "event_id": "70902144_e00016",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "姚氏",
        "李成"
      ],
      "text": "员外先请，我们随后。",
      "text_length": 10
    },
    {
      "event_id": "70902144_e00017",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "钱流行"
      ],
      "text": "好天气吓！",
      "text_length": 5
    },
    {
      "event_id": "70902144_e00018",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "八声甘州",
      "speakers": [
        "钱流行"
      ],
      "text": "春深离故家，叹衰年",
      "text_length": 9
    },
    {
      "event_id": "70902144_e00019",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同八声甘州",
      "speakers": [
        "钱流行",
        "姚氏",
        "李成"
      ],
      "text": "倦体奔走天涯。一鞭行色，遥指剩水残霞。墙头嫩柳篱畔花，只见古树枯藤棲暮鸦，槎枒，遍长途触目桑麻。",
      "text_length": 48
    },
    {
      "event_id": "70902144_e00020",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "八声甘州",
      "speakers": [
        "姚氏"
      ],
      "text": "呀呀，幽禽聚远沙，",
      "text_length": 9
    },
    {
      "event_id": "70902144_e00021",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "姚氏"
      ],
      "text": "老老！",
      "text_length": 3
    },
    {
      "event_id": "70902144_e00022",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "八声甘州",
      "speakers": [
        "姚氏"
      ],
      "text": "对仿佛禾黍宛似蒹葭。",
      "text_length": 10
    },
    {
      "event_id": "70902144_e00023",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同八声甘州",
      "speakers": [
        "钱流行",
        "姚氏",
        "李成"
      ],
      "text": "看江山如画，无限野草闲花，旗亭小桥景最佳。见竹锁溪边有三两家，渔艖，弄新腔一笛堪夸。",
      "text_length": 42
    },
    {
      "event_id": "70902144_e00024",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚氏"
      ],
      "text": "喔唷，走勿动哉！",
      "text_length": 8
    },
    {
      "event_id": "70902144_e00025",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "李成"
      ],
      "text": "员外安人在此坐坐，待男女去看船来！",
      "text_length": 17
    },
    {
      "event_id": "70902144_e00026",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "李成下。",
      "text_length": 4
    },
    {
      "event_id": "70902144_e00027",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "钱流行"
      ],
      "text": "想我早岁游庠，何曾遭此跋涉。老迈龙钟，反受许多苦楚！",
      "text_length": 26
    },
    {
      "event_id": "70902144_e00028",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "姚氏"
      ],
      "text": "今日个苦，才是孙汝权个拖牢洞害我俚个！",
      "text_length": 19
    },
    {
      "event_id": "70902144_e00029",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "钱流行"
      ],
      "text": "妈妈不要说了。",
      "text_length": 7
    },
    {
      "event_id": "70902144_e00030",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "解三酲",
      "speakers": [
        "钱流行"
      ],
      "text": "为当初被人谎诈，把家书暗地套写，致我儿一命丧在黄泉下，受多少苦波查。今日幸蒙佳婿来迎也，又还愁逆旅淹留人事赊。",
      "text_length": 55
    },
    {
      "event_id": "70902144_e00031",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同解三酲",
      "speakers": [
        "钱流行",
        "姚氏"
      ],
      "text": "空嗟呀，",
      "text_length": 4
    },
    {
      "event_id": "70902144_e00032",
      "play_id": "70902144",
      "scene_id": "70902144_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
