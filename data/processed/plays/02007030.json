  "events": [
    {
      "event_id": "02007030_e00001",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大瘟神上，拉挑。",
      "text_length": 8
    },
    {
      "event_id": "02007030_e00002",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "大瘟神"
      ],
      "text": "身在荒凉，身在荒凉，阴司作伤亡。或在平川地，或在险峻岗，或在孤村里，或在官道旁。恶妇阳寿满，降祸又降殃，降祸又降殃。",
      "text_length": 58
    },
    {
      "event_id": "02007030_e00003",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "大瘟神"
      ],
      "text": "咱是西方一魔头，乍寒乍热把筋抽。怎奈恶妇真无礼，这番叫她一命休！",
      "text_length": 32
    },
    {
      "event_id": "02007030_e00004",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大瘟神"
      ],
      "text": "吾乃赫赫相公是也。当日傅斋公在日，将俺兄弟五人的牌位，供在当中，进献斋仪素供，焚化银锭钱纸。自从斋公升天去后，刘青提将俺五人的牌位，摔在一旁。她也不瞅，她也不睬。今当她阳寿将终，我不免招聚众家兄弟，一同前去！",
      "text_length": 104
    },
    {
      "event_id": "02007030_e00005",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念长声",
      "speakers": [
        "大瘟神"
      ],
      "text": "魔障他——",
      "text_length": 5
    },
    {
      "event_id": "02007030_e00006",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "大瘟神招。",
      "text_length": 5
    },
    {
      "event_id": "02007030_e00007",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念长声",
      "speakers": [
        "大瘟神"
      ],
      "text": "伤亡吓！",
      "text_length": 4
    },
    {
      "event_id": "02007030_e00008",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四小瘟神双上。",
      "text_length": 7
    },
    {
      "event_id": "02007030_e00009",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念长声",
      "speakers": [
        "四小瘟神"
      ],
      "text": "伤亡吓，伤亡吓！",
      "text_length": 8
    },
    {
      "event_id": "02007030_e00010",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "同鬼令",
      "speakers": [
        "四小瘟神"
      ],
      "text": "伤亡身，伤亡身，乍寒乍热苦难禁。时高遇我供供手，运低逢我降灾星。听得到，听得到，兄弟们都来到。或在山林中，或在古神庙。伸一伸，头脑疼，缩一缩，魂都掉。缩一缩，魂都掉。",
      "text_length": 83
    },
    {
      "event_id": "02007030_e00011",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "同念长声",
      "speakers": [
        "四小瘟神"
      ],
      "text": "伤亡吓！",
      "text_length": 4
    },
    {
      "event_id": "02007030_e00012",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小瘟神"
      ],
      "text": "大哥招我们出来，有何吩咐？",
      "text_length": 13
    },
    {
      "event_id": "02007030_e00013",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大瘟神"
      ],
      "text": "众兄弟。",
      "text_length": 4
    },
    {
      "event_id": "02007030_e00014",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小瘟神"
      ],
      "text": "大哥。",
      "text_length": 3
    },
    {
      "event_id": "02007030_e00015",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "大瘟神"
      ],
      "text": "当日傅斋公在日，将你我五人的牌位，供在当中。自从傅斋公亡故，将你我五人的牌位，摔在一旁，她也不瞅，她也不睬。今当她阳寿将终，特邀你们到此，一同前去！",
      "text_length": 74
    },
    {
      "event_id": "02007030_e00016",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念长声",
      "speakers": [
        "大瘟神"
      ],
      "text": "要魔障她。",
      "text_length": 5
    },
    {
      "event_id": "02007030_e00017",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四小瘟神"
      ],
      "text": "我们前去——",
      "text_length": 6
    },
    {
      "event_id": "02007030_e00018",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "recitation",
      "mode_label": "同念长声",
      "speakers": [
        "四小瘟神"
      ],
      "text": "魔障她。",
      "text_length": 4
    },
    {
      "event_id": "02007030_e00019",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 19,
