      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "大瘟神"
      ],
      "text": "你们各自用心机，",
      "text_length": 8
    },
    {
      "event_id": "02007030_e00024",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同鬼令",
      "speakers": [
        "四小瘟神"
      ],
      "text": "是我们各自用心机。",
      "text_length": 9
    },
    {
      "event_id": "02007030_e00025",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "大瘟神"
      ],
      "text": "把一个躲在她的门外，把一个躲在她的门里。把一个躲在她的床上，把一个躲在她的床底。",
      "text_length": 40
    },
    {
      "event_id": "02007030_e00026",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "大瘟神"
      ],
      "text": "众兄弟——",
      "text_length": 5
    },
    {
      "event_id": "02007030_e00027",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同鬼令",
      "speakers": [
        "大瘟神",
        "四小瘟神"
      ],
      "text": "急忙前去，不可迟滞。管教她魄散与魂飞。",
      "text_length": 19
    },
    {
      "event_id": "02007030_e00028",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "大瘟神"
      ],
      "text": "忒叵奈，刘氏青提，违誓愿，杀害猪鸡。今朝祸到难逃避，",
      "text_length": 26
    },
    {
      "event_id": "02007030_e00029",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "小瘟神甲"
      ],
      "text": "我去剜她的一脑髓，",
      "text_length": 9
    },
    {
      "event_id": "02007030_e00030",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "小瘟神乙"
      ],
      "text": "我去抽她的一肚肠。",
      "text_length": 9
    },
    {
      "event_id": "02007030_e00031",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "大瘟神"
      ],
      "text": "弄得她，活不活，死不死，苦楚难支。",
      "text_length": 17
    },
    {
      "event_id": "02007030_e00032",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同鬼令",
      "speakers": [
        "四小瘟神"
      ],
      "text": "吓，活不活，死不死，苦楚难支。",
      "text_length": 15
    },
    {
      "event_id": "02007030_e00033",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "夹白",
      "speakers": [
        "大瘟神"
      ],
      "text": "众兄弟——",
      "text_length": 5
    },
    {
