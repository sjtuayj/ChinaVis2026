      "scene_id": "02007030_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "同鬼令",
      "speakers": [
        "大瘟神",
        "四小瘟神"
      ],
      "text": "急忙前去，不可迟滞，管教她魄散与魂飞。",
      "text_length": 19
    },
    {
