      "type": "other_vocal",
      "mode_label": "鬼令",
      "speakers": [
        "大瘟神"
      ],
      "text": "堪叹世人不得善良，",
      "text_length": 9
    },
    {
      "event_id": "02007030_e00036",
      "play_id": "02007030",
      "scene_id": "02007030_s01",
      "scene_no": 1,
