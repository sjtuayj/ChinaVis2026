      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "非孤发笑。我笑你东吴男子，不会乘骑，妇人倒会驾舟。",
      "text_length": 25
