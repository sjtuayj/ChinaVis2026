  "events": [
    {
      "event_id": "05014002_e00001",
      "play_id": "05014002",
      "scene_id": "05014002_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "四下手引赵云同上。",
      "text_length": 9
    },
    {
      "event_id": "05014002_e00002",
      "play_id": "05014002",
      "scene_id": "05014002_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "赵云"
      ],
      "text": "忠勇常山将，威名镇荆襄。护驾东吴地，赤胆保刘王。",
      "text_length": 24
    },
    {
      "event_id": "05014002_e00003",
      "play_id": "05014002",
      "scene_id": "05014002_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵云"
      ],
      "text": "小将赵云。保主南郡招亲。今朝独坐无聊，不免带领军士，出馆驿往城外打围则个。众将官！",
      "text_length": 41
    },
    {
      "event_id": "05014002_e00004",
      "play_id": "05014002",
      "scene_id": "05014002_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四下手"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "05014002_e00005",
      "play_id": "05014002",
      "scene_id": "05014002_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "赵云"
      ],
      "text": "将人马扯出城去！",
      "text_length": 8
    },
    {
      "event_id": "05014002_e00006",
      "play_id": "05014002",
      "scene_id": "05014002_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "同白",
      "speakers": [
        "四下手"
      ],
      "text": "哦！",
      "text_length": 2
    },
    {
      "event_id": "05014002_e00007",
      "play_id": "05014002",
      "scene_id": "05014002_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。众人同下。",
      "text_length": 10
    },
    {
      "event_id": "05014002_e00008",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 8,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘备上。",
      "text_length": 4
    },
    {
      "event_id": "05014002_e00009",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 9,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘备"
      ],
      "text": "先生八卦果不妄，今朝东阁配鸾凰。将身来在山头上，顽石挡路恼人肠。",
      "text_length": 32
    },
    {
      "event_id": "05014002_e00010",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 10,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "且住！慢说东吴不容我刘备，就是一块顽石也不容我刘备！有剑在此，不免祷告天地，破石为兆，以问吉凶。哎，苍天吓，苍天！我刘备若得重回荆襄，复兴汉室，剑下石破！",
      "text_length": 77
    },
    {
      "event_id": "05014002_e00011",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 11,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。刘备将石劈为两半。孙权上。",
      "text_length": 18
    },
    {
      "event_id": "05014002_e00012",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 12,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "吓，皇叔！此石有何碍处，为何一剑，挥为两段？",
      "text_length": 22
    },
    {
      "event_id": "05014002_e00013",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 13,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "刘备在此，破石为兆。",
      "text_length": 10
    },
    {
      "event_id": "05014002_e00014",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 14,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "如此，我也破石为兆。借剑一用！",
      "text_length": 15
    },
    {
      "event_id": "05014002_e00015",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 15,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "拿去！且慢，可知大丈夫行事。",
      "text_length": 14
    },
    {
      "event_id": "05014002_e00016",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 16,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "岂肯暗地伤人！",
      "text_length": 7
    },
    {
      "event_id": "05014002_e00017",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 17,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "拿去！",
      "text_length": 3
    },
    {
      "event_id": "05014002_e00018",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 18,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "哎，苍天吓，苍天！我孙权若得北灭曹操，西灭刘——",
      "text_length": 24
    },
    {
      "event_id": "05014002_e00019",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 19,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "“刘”什么？",
      "text_length": 6
    },
    {
      "event_id": "05014002_e00020",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 20,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "西灭刘璋，剑下石破！",
      "text_length": 10
    },
    {
      "event_id": "05014002_e00021",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 21,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "〖牌子〗。孙权将石劈开。",
      "text_length": 12
    },
    {
      "event_id": "05014002_e00022",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 22,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "果然剑下石破！",
      "text_length": 7
    },
    {
      "event_id": "05014002_e00023",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 23,
      "seq_in_scene": 16,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "内喊声。",
      "text_length": 4
    },
    {
      "event_id": "05014002_e00024",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 24,
      "seq_in_scene": 17,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "哪里这等喧嚷？",
      "text_length": 7
    },
    {
      "event_id": "05014002_e00025",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 25,
      "seq_in_scene": 18,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "江面渔船游戏。",
      "text_length": 7
    },
    {
      "event_id": "05014002_e00026",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 26,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘备"
      ],
      "text": "同登高阁一望！",
      "text_length": 7
    },
    {
      "event_id": "05014002_e00027",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 27,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "请！",
      "text_length": 2
    },
    {
      "event_id": "05014002_e00028",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 28,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘备、孙权同上桌。众渔妇同上，过场。〖步步娇〗。众渔妇同下。",
      "text_length": 30
    },
    {
