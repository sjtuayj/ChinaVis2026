    {
      "event_id": "05014002_e00032",
      "play_id": "05014002",
      "scene_id": "05014002_s02",
      "scene_no": 2,
      "seq_global": 32,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "孙权"
      ],
      "text": "皇叔！你道我国男人，不会乘骑，待我出一辔头你看！马来！",
