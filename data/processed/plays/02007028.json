  "events": [
    {
      "event_id": "02007028_e00001",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 1,
      "seq_in_scene": 1,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜上。",
      "text_length": 4
    },
    {
      "event_id": "02007028_e00002",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 2,
      "seq_in_scene": 2,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "一剪梅",
      "speakers": [
        "罗卜"
      ],
      "text": "灵椿一梦赴南柯。朝泪滂沱，暮泪滂沱。临终嘱咐事如何。委念弥陀，遵年弥陀。",
      "text_length": 36
    },
    {
      "event_id": "02007028_e00003",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 3,
      "seq_in_scene": 3,
      "page_no": 1,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "罗卜"
      ],
      "text": "步行灵椿丧九泉，萧萧风木恨无边。孤儿欲绍先人志，念佛看经与坐禅。",
      "text_length": 32
    },
    {
      "event_id": "02007028_e00004",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 4,
      "seq_in_scene": 4,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "罗卜。自从父亲丧后，只守丧柩，未曾念经。今在佛前，添上炉香，念佛则个。",
      "text_length": 35
    },
    {
      "event_id": "02007028_e00005",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 5,
      "seq_in_scene": 5,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "罗卜"
      ],
      "text": "香满金炉。坐拥团团一草蒲。念几句阿弥陀佛，修喇娑婆三昧哆哪。木鱼敲动万灵扶。真经念处仙护。灭障消除，灭障消除。生门便是菩提路，生门便是菩提路。",
      "text_length": 71
    },
    {
      "event_id": "02007028_e00006",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 6,
      "seq_in_scene": 6,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "金奴、刘青提同上。",
      "text_length": 9
    },
    {
      "event_id": "02007028_e00007",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 7,
      "seq_in_scene": 7,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "刘青提"
      ],
      "text": "痛念儿夫。血泪流残两眼枯。可怜我形容憔瘦，筋力衰微，鬓发消疏。",
      "text_length": 31
    },
    {
      "event_id": "02007028_e00008",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 8,
      "seq_in_scene": 8,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "昨听兄弟之言，劝儿开荤，依从便罢，若不依从，遣他在外经商。金奴，",
      "text_length": 32
    },
    {
      "event_id": "02007028_e00009",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 9,
      "seq_in_scene": 9,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金奴"
      ],
      "text": "有。",
      "text_length": 2
    },
    {
      "event_id": "02007028_e00010",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 10,
      "seq_in_scene": 10,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "小官人佛堂看经，随我前去。",
      "text_length": 13
    },
    {
      "event_id": "02007028_e00011",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 11,
      "seq_in_scene": 11,
      "page_no": 1,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘青提看。",
      "text_length": 5
    },
    {
      "event_id": "02007028_e00012",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 12,
      "seq_in_scene": 12,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "我儿，你在此做什么？",
      "text_length": 10
    },
    {
      "event_id": "02007028_e00013",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 13,
      "seq_in_scene": 13,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "在此看经。",
      "text_length": 5
    },
    {
      "event_id": "02007028_e00014",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 14,
      "seq_in_scene": 14,
      "page_no": 1,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "儿呀，再不要念经了。",
      "text_length": 10
    },
    {
      "event_id": "02007028_e00015",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 15,
      "seq_in_scene": 15,
      "page_no": 1,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘青提"
      ],
      "text": "想你爹爹在日，洗目焚香，调念多少经典，赈济多少贫寒。因甚的未满六旬身丧，可见得看经无用，赈济无功了。儿，那阴阳神鬼，无些踪影，倒不如肥甘滋味易菜蔬。莫使我桑榆暮景成虚度。",
      "text_length": 85
    },
    {
      "event_id": "02007028_e00016",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 16,
      "seq_in_scene": 16,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "老娘休出此言。",
      "text_length": 7
    },
    {
      "event_id": "02007028_e00017",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 17,
      "seq_in_scene": 17,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘青提"
      ],
      "text": "儿呀，你未能事人，焉能事鬼。不用踌躇，不用踌躇。那秦皇汉武成差误。不要听他。",
      "text_length": 38
    },
    {
      "event_id": "02007028_e00018",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 18,
      "seq_in_scene": 18,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "罗卜"
      ],
      "text": "我父将终，亲写遗言来嘱咐。叫儿看经念佛。戒酒除荤，吃斋把素。",
      "text_length": 30
    },
    {
      "event_id": "02007028_e00019",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 19,
      "seq_in_scene": 19,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "那都是迂谈。不要听他。",
      "text_length": 11
    },
    {
      "event_id": "02007028_e00020",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 20,
      "seq_in_scene": 20,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "罗卜"
      ],
      "text": "休言我父多迂。娘儿一体承遗嘱。父有嘉谟，父有嘉谟，三年无改于其父。",
      "text_length": 33
    },
    {
      "event_id": "02007028_e00021",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 21,
      "seq_in_scene": 21,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "儿但知三年无改，岂不闻如其道，终身无改可也。如其非道，何待三年？",
      "text_length": 32
    },
    {
      "event_id": "02007028_e00022",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 22,
      "seq_in_scene": 22,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘青提"
      ],
      "text": "你父敬浮屠。那佛如何不救助。我欲待暂开荤酒，趁此余年，且自欢娱。",
      "text_length": 32
    },
    {
      "event_id": "02007028_e00023",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 23,
      "seq_in_scene": 23,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "老娘。佛像在堂，休出此言。",
      "text_length": 13
    },
    {
      "event_id": "02007028_e00024",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 24,
      "seq_in_scene": 24,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "儿呀，娘立心已定，说下断头话来。诸佛神像在上。",
      "text_length": 23
    },
    {
      "event_id": "02007028_e00025",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 25,
      "seq_in_scene": 25,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "刘青提"
      ],
      "text": "若要我吃斋把素似当初。除非是铁树开花，扬子江心生莲藕。儿呀你何必多忧，你何必多忧。娘亲作者娘亲受。",
      "text_length": 49
    },
    {
      "event_id": "02007028_e00026",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 26,
      "seq_in_scene": 26,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "黄莺儿",
      "speakers": [
        "罗卜"
      ],
      "text": "听说泪交流。不由人生怨尤。",
      "text_length": 13
    },
    {
      "event_id": "02007028_e00027",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 27,
      "seq_in_scene": 27,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "不知母亲听信哪个谗言，改变心肠。是了。舅爷到此，一定是舅爷的言词。舅爷既念我母手足之情，合将好言劝解才是。",
      "text_length": 53
    },
    {
      "event_id": "02007028_e00028",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 28,
      "seq_in_scene": 28,
      "page_no": 2,
      "type": "other_vocal",
      "mode_label": "黄莺儿",
      "speakers": [
        "罗卜"
      ],
      "text": "为何劝娘开荤酒。爹会嘱咐，娘会发咒。今日开了荤酒呵，怕神天察，如何救。苦衷容儿剖。休学那郗后。",
      "text_length": 47
    },
    {
      "event_id": "02007028_e00029",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 29,
      "seq_in_scene": 29,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "你起来，劝娘休学郗后之言，如何解说？",
      "text_length": 18
    },
    {
      "event_id": "02007028_e00030",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 30,
      "seq_in_scene": 30,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "昔日梁武帝皇后郗氏，不信神明，死后变为蟒蛇。武帝代为忏悔，方才得还人身。老娘请自详省。",
      "text_length": 43
    },
    {
      "event_id": "02007028_e00031",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 31,
      "seq_in_scene": 31,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "武帝既能度其妻，吾儿必能度其母。",
      "text_length": 16
    },
    {
      "event_id": "02007028_e00032",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 32,
      "seq_in_scene": 32,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "老娘还当见贤思齐，因何学不贤之辈？",
      "text_length": 17
    },
    {
      "event_id": "02007028_e00033",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 33,
      "seq_in_scene": 33,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "原来我儿志不可。方才所言，亦非劝你开荤。你父亡过，恐你道心不定，特来试你如何。",
      "text_length": 39
    },
    {
      "event_id": "02007028_e00034",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 34,
      "seq_in_scene": 34,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "如此，多谢老娘。",
      "text_length": 8
    },
    {
      "event_id": "02007028_e00035",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 35,
      "seq_in_scene": 35,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "还有一事，母子商量。",
      "text_length": 10
    },
    {
      "event_id": "02007028_e00036",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 36,
      "seq_in_scene": 36,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "有何事情？",
      "text_length": 5
    },
    {
      "event_id": "02007028_e00037",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 37,
      "seq_in_scene": 37,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "只今济僧布施，费用浩大。你可出外做些买卖，生些利息。则前功可继，后用无穷。",
      "text_length": 37
    },
    {
      "event_id": "02007028_e00038",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 38,
      "seq_in_scene": 38,
      "page_no": 2,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "禀告老娘。孩儿幼依膝下，不惯经商，怎生去得？",
      "text_length": 22
    },
    {
      "event_id": "02007028_e00039",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 39,
      "seq_in_scene": 39,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "你若去，我着益利作伴，料也无妨。",
      "text_length": 16
    },
    {
      "event_id": "02007028_e00040",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 40,
      "seq_in_scene": 40,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "孩儿舍不得老娘。",
      "text_length": 8
    },
    {
      "event_id": "02007028_e00041",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 41,
      "seq_in_scene": 41,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "我今生幸未衰，你正当勇往向前不可达拗。益利何在？",
      "text_length": 24
    },
    {
      "event_id": "02007028_e00042",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 42,
      "seq_in_scene": 42,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "益利上。",
      "text_length": 4
    },
    {
      "event_id": "02007028_e00043",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 43,
      "seq_in_scene": 43,
      "page_no": 3,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "益利"
      ],
      "text": "佛殿烧香犹未毕，高堂有唤又忙来。",
      "text_length": 16
    },
    {
      "event_id": "02007028_e00044",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 44,
      "seq_in_scene": 44,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "益利"
      ],
      "text": "禀安人有何使命？",
      "text_length": 8
    },
    {
      "event_id": "02007028_e00045",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 45,
      "seq_in_scene": 45,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "黄莺儿",
      "speakers": [
        "刘青提"
      ],
      "text": "佛事虑难周，我竟遣官人出外州。",
      "text_length": 15
    },
    {
      "event_id": "02007028_e00046",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 46,
      "seq_in_scene": 46,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "因为时年不丰，求济甚多，唯恐后不应前，令与东人远行贸易，觅些利来，已为长途之计。",
      "text_length": 40
    },
    {
      "event_id": "02007028_e00047",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 47,
      "seq_in_scene": 47,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "黄莺儿",
      "speakers": [
        "刘青提"
      ],
      "text": "这生财有道方能久。你把行囊早收，同伊远游。经营不落他人后。愿来秋腰缠万贯，得意早回头。",
      "text_length": 43
    },
    {
      "event_id": "02007028_e00048",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 48,
      "seq_in_scene": 48,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "益利"
      ],
      "text": "老安人年老在堂，小官人经营不惯。伏望思忖，莫遣远行。",
      "text_length": 26
    },
    {
      "event_id": "02007028_e00049",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 49,
      "seq_in_scene": 49,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "我立心已定谁敢违。",
      "text_length": 9
    },
    {
      "event_id": "02007028_e00050",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 50,
      "seq_in_scene": 50,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "益利，安人发怒，少不得顺从前去。",
      "text_length": 16
    },
    {
      "event_id": "02007028_e00051",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 51,
      "seq_in_scene": 51,
      "page_no": 3,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "益利允。",
      "text_length": 4
    },
    {
      "event_id": "02007028_e00052",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 52,
      "seq_in_scene": 52,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "焚起香来。待我辞别神圣。",
      "text_length": 12
    },
    {
      "event_id": "02007028_e00053",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 53,
      "seq_in_scene": 53,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "泣颜回",
      "speakers": [
        "罗卜"
      ],
      "text": "辞圣离故里，亲命怎敢辞推。经商贸易，家庭事仗神佑持。程途迢遥，叹此行难定归来日。在异乡平安觅利，但愿得无事无非。一旦别慈帏，不由人心不动悲。况我无兄无弟亲衰老，谁与扶持，心中思忆。",
      "text_length": 90
    },
    {
      "event_id": "02007028_e00054",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 54,
      "seq_in_scene": 54,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "思忆何事？",
      "text_length": 5
    },
    {
      "event_id": "02007028_e00055",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 55,
      "seq_in_scene": 55,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "孩儿、益利在家，僧济贫，照例实行。孩儿、益利远去他乡，犹恐违却父志，荒废前功。",
      "text_length": 39
    },
    {
      "event_id": "02007028_e00056",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 56,
      "seq_in_scene": 56,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "泣颜回",
      "speakers": [
        "罗卜"
      ],
      "text": "愿老娘遵守着一念慈悲。散金资普济僧尼，诵宝礼念阿弥。",
      "text_length": 26
    },
    {
      "event_id": "02007028_e00057",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 57,
      "seq_in_scene": 57,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "泣颜回",
      "speakers": [
        "刘青提"
      ],
      "text": "叮咛我娇儿，宽心前去，不用忧疑。济僧布施，娘在家依旧一一施为。心中忧虑。",
      "text_length": 36
    },
    {
      "event_id": "02007028_e00058",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 58,
      "seq_in_scene": 58,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "老娘忧虑何来？",
      "text_length": 7
    },
    {
      "event_id": "02007028_e00059",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 59,
      "seq_in_scene": 59,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "我儿孝心如是，去到他乡，必然牵挂老娘。金奴看针线过来。儿揭起裹襟，待娘缝上几针。早晚见此针线，我儿近远离家，见线如见母，不用苦忧思。儿今此去，娘心忧虑。",
      "text_length": 76
    },
    {
      "event_id": "02007028_e00060",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 60,
      "seq_in_scene": 60,
      "page_no": 3,
      "type": "other_vocal",
      "mode_label": "泣颜回",
      "speakers": [
        "刘青提"
      ],
      "text": "怕你在途中早晚有谁调理，益利你须当仔细。",
      "text_length": 20
    },
    {
      "event_id": "02007028_e00061",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 61,
      "seq_in_scene": 61,
      "page_no": 3,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "小官人年幼，自幼未曾远行。你是年长之人，能知异乡风景，此去逢船过渡，需要小心着意。",
      "text_length": 41
    },
    {
      "event_id": "02007028_e00062",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 62,
      "seq_in_scene": 62,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "泣颜回",
      "speakers": [
        "刘青提"
      ],
      "text": "在旅店安歇，迟行早宿，一路与他相伴同行，不离了左右。益利，你谨记我的言词，你须仔细。罢了，我的儿，老娘只生你一人。若不为着利息，焉肯舍得你远行，与益利去到他乡，年节之时，倘有微资，须念我膝下无儿，打叠行囊早回程，是必不可迟滞。儿免娘亲倚定门儿，数着归期。",
      "text_length": 127
    },
    {
      "event_id": "02007028_e00063",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 63,
      "seq_in_scene": 63,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "益利"
      ],
      "text": "半担行李受驱驰。餐风宿水，岂敢推辞。",
      "text_length": 18
    },
    {
      "event_id": "02007028_e00064",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 64,
      "seq_in_scene": 64,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "好生服侍东人。",
      "text_length": 7
    },
    {
      "event_id": "02007028_e00065",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 65,
      "seq_in_scene": 65,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "唱",
      "speakers": [
        "益利"
      ],
      "text": "奉东人自当协力。明年捆带儿归。心中暗疑，员外在日，要安人吃斋把素，念佛看经。今日遣子往外经商，其间必有什么缘故，必有什么缘故，好教我心中暗疑虑。安人心口相违背。若得他广布阴功。不枉了远涉天。",
      "text_length": 95
    },
    {
      "event_id": "02007028_e00066",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 66,
      "seq_in_scene": 66,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "益利"
      ],
      "text": "匆匆拜别登程去，唯愿康健无危。",
      "text_length": 15
    },
    {
      "event_id": "02007028_e00067",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 67,
      "seq_in_scene": 67,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "刘青提"
      ],
      "text": "更愿你钱神子母，得意早回归。",
      "text_length": 14
    },
    {
      "event_id": "02007028_e00068",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 68,
      "seq_in_scene": 68,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜、刘青提同下。",
      "text_length": 9
    },
    {
      "event_id": "02007028_e00069",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 69,
      "seq_in_scene": 69,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "刘青提"
      ],
      "text": "金奴，我见小官人去得可怜，是我心中疼痛起来。",
      "text_length": 22
    },
    {
      "event_id": "02007028_e00070",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 70,
      "seq_in_scene": 70,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "金奴"
      ],
      "text": "有益利相伴，安人放心。",
      "text_length": 11
    },
    {
      "event_id": "02007028_e00071",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 71,
      "seq_in_scene": 71,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "尾声",
      "speakers": [
        "刘青提"
      ],
      "text": "自古人生多别离。娇儿一去好伤悲。儿你明朝回首家山远。一片白云空自飞。",
      "text_length": 34
    },
    {
      "event_id": "02007028_e00072",
      "play_id": "02007028",
      "scene_id": "02007028_s01",
      "scene_no": 1,
      "seq_global": 72,
      "seq_in_scene": 72,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "刘青提、金奴同下。",
      "text_length": 9
    },
    {
      "event_id": "02007028_e00073",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 73,
      "seq_in_scene": 1,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "内步步娇",
      "speakers": [
        "罗卜"
      ],
      "text": "野店鸡鸣天方晓。",
      "text_length": 8
    },
    {
      "event_id": "02007028_e00074",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 74,
      "seq_in_scene": 2,
      "page_no": 4,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜上，益利随上。",
      "text_length": 9
    },
    {
      "event_id": "02007028_e00075",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 75,
      "seq_in_scene": 3,
      "page_no": 4,
      "type": "other_vocal",
      "mode_label": "步步娇",
      "speakers": [
        "罗卜"
      ],
      "text": "人就长安道。重露湿衣袍。烟瘴全收，火轮飞照。回首白云高。珠泪临风落，珠泪临风落。",
      "text_length": 40
    },
    {
      "event_id": "02007028_e00076",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 76,
      "seq_in_scene": 4,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "罗卜"
      ],
      "text": "夏日苦炎热，早行须趁凉。",
      "text_length": 12
    },
    {
      "event_id": "02007028_e00077",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 77,
      "seq_in_scene": 5,
      "page_no": 4,
      "type": "recitation",
      "mode_label": "念",
      "speakers": [
        "益利"
      ],
      "text": "竹清风渐爽，荷放露生香。",
      "text_length": 12
    },
    {
      "event_id": "02007028_e00078",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 78,
      "seq_in_scene": 6,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "益利。",
      "text_length": 3
    },
    {
      "event_id": "02007028_e00079",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 79,
      "seq_in_scene": 7,
      "page_no": 4,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "益利"
      ],
      "text": "小官人。",
      "text_length": 4
    },
    {
      "event_id": "02007028_e00080",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 80,
      "seq_in_scene": 8,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "我奉母亲严命，往外经营。身虽离了家门，心则常在膝下。思念不已，如何是好？",
      "text_length": 36
    },
    {
      "event_id": "02007028_e00081",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 81,
      "seq_in_scene": 9,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "益利"
      ],
      "text": "呵小官人。你我奉老安人之命，此去贸易，觅利便归。身在途中，休要嗟叹。天色尚早，趱行则个。",
      "text_length": 44
    },
    {
      "event_id": "02007028_e00082",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 82,
      "seq_in_scene": 10,
      "page_no": 5,
      "type": "spoken",
      "mode_label": "白",
      "speakers": [
        "罗卜"
      ],
      "text": "言之有理。",
      "text_length": 5
    },
    {
      "event_id": "02007028_e00083",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 83,
      "seq_in_scene": 11,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "新水令",
      "speakers": [
        "罗卜"
      ],
      "text": "绿荫冉冉路漫漫。听枝头黄鹂声唤。榴花熏眼媚，梅子溅牙酸。回首家山，惹起我愁无限。",
      "text_length": 40
    },
    {
      "event_id": "02007028_e00084",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 84,
      "seq_in_scene": 12,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "驻马听",
      "speakers": [
        "罗卜"
      ],
      "text": "椿树摧残，椿树摧残。干无能心自闲。花景晚。经商远别意何安。好叫我恨犹露草肠寸断。似随风絮飞缭乱。心自顽，心自顽，举目把孤云盼。举目把孤云盼。",
      "text_length": 70
    },
    {
      "event_id": "02007028_e00085",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 85,
      "seq_in_scene": 13,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "川拨掉",
      "speakers": [
        "益利"
      ],
      "text": "盼着那云停处，心与俱远。云散后，魂犹未返。亲舍远，枉自追思，客途遥，客途遥，空成嗟叹。论世亲孝道多端。今日里顺亲心抛弃家园。又何须在膝下承欢。况分离有日团圆，有日团圆。",
      "text_length": 84
    },
    {
      "event_id": "02007028_e00086",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 86,
      "seq_in_scene": 14,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "雁儿落",
      "speakers": [
        "罗卜"
      ],
      "text": "须则是有日团圆。苦无奈般伤感。水带离愁向我悲，山牵别恨连肠断。",
      "text_length": 31
    },
    {
      "event_id": "02007028_e00087",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 87,
      "seq_in_scene": 15,
      "page_no": 5,
      "type": "other_vocal",
      "mode_label": "得胜令",
      "speakers": [
        "罗卜"
      ],
      "text": "伤情对景有千般。如何能，如何能把程途趱。见山僧竹林下，避暑盘。正是朝臣待漏五更寒。铁甲将军夜渡关。山寺日高僧未起，算来名利不如闲。我怎学得那山僧，那山僧般清闲。见渔翁柳荫下，执着丝杆。那渔翁一条丝线，一根杆，名不贪来利不贪。醉卧沙堤唤不醒，江山常在梦中看。我怎学得那渔翁，那渔翁般疏散，般疏散。见牧童牛背上短笛腔翻。问余何事碧山，笑而不答心自闲。桃花流水杳然去，别有天地非人间。我怎学得那牧童恁般逍然，恁般逍然。",
      "text_length": 206
    },
    {
      "event_id": "02007028_e00088",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 88,
      "seq_in_scene": 16,
      "page_no": 6,
      "type": "other_vocal",
      "mode_label": "挂玉钩",
      "speakers": [
        "益利"
      ],
      "text": "论人生寄在寰。都只为利索名牵。受馁寒，谁能解破这机关恰便似超凡脱俗神仙伴。",
      "text_length": 37
    },
    {
      "event_id": "02007028_e00089",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 89,
      "seq_in_scene": 17,
      "page_no": 6,
      "type": "other_vocal",
      "mode_label": "挂玉钩",
      "speakers": [
        "罗卜"
      ],
      "text": "你看乱石巍巍，你须是掇将开，成被平宽。荆棘挽挽，你须是剪将开，免被遮拦。",
      "text_length": 36
    },
    {
      "event_id": "02007028_e00090",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 90,
      "seq_in_scene": 18,
      "page_no": 6,
      "type": "other_vocal",
      "mode_label": "同挂玉钩",
      "speakers": [
        "罗卜",
        "益利"
      ],
      "text": "似你我这菩提心，自有龙天照鉴。方便事瞒不过天上人间。自有知音，另眼相看。自有知音，另眼相看。",
      "text_length": 46
    },
    {
      "event_id": "02007028_e00091",
      "play_id": "02007028",
      "scene_id": "02007028_s02",
      "scene_no": 2,
      "seq_global": 91,
      "seq_in_scene": 19,
      "page_no": 6,
      "type": "stage_direction",
      "mode_label": "stage_direction",
      "speakers": [],
      "text": "罗卜、益利同下。",
      "text_length": 8
    }
  ],
  "roles_inferred": true
}